# LibreOffice 26.2.3.2 custom build options for the DOCX/PPTX to PDF engine.
# Add compiler and --with-external-tar paths in the generated build input.
# The build must fail instead of fetching unverified dependency archives.
--disable-fetch-external
--enable-mergelibs=no
--disable-curl
--without-webdav
--disable-libcmis
--disable-online-update
--disable-online-update-mar
--disable-extension-update
--disable-breakpad
--disable-pdfimport
--disable-pdfium
--disable-poppler
--disable-sdremote
--disable-sdremote-bluetooth
--with-galleries=no
--disable-avmedia
--disable-skia
--disable-opencl
test_libabw=no
test_libcdr=no
test_libebook=no
test_libepubgen=no
test_libetonyek=no
test_libfreehand=no
test_libmspub=no
test_libmwaw=no
test_libpagemaker=no
test_libqxp=no
test_libstaroffice=no
test_libvisio=no
test_libwpd=no
test_libwpg=no
test_libwps=no
test_libzmf=no
--without-java
--disable-scripting
--enable-python=no
--disable-gpgmepp
--disable-openssl
--disable-nss
--with-tls=no
--disable-database-connectivity
--disable-firebird-sdbc
--disable-report-builder
--disable-lpsolve
--disable-coinmp
--disable-lotuswordpro
--without-help
