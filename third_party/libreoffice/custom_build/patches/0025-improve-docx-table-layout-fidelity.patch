+bool lcl_ShouldPreferCellWidthsForAutoFit(const std::vector<sal_Int32>& rTableGrid,
+                                          const std::vector<sal_Int32>& rCellWidths,
+                                          const std::vector<sal_uInt32>& rGridSpans,
+                                          sal_uInt32 nCellCount, sal_uInt32 nGridBefore,
+                                          sal_uInt32 nLayoutType)
+{
+    if (nLayoutType == NS_ooxml::LN_Value_doc_ST_TblLayout_fixed || nGridBefore != 0
+        || rCellWidths.size() != nCellCount || rGridSpans.size() != nCellCount
+        || rTableGrid.size() != nCellCount || rCellWidths.empty()
+        || std::any_of(rCellWidths.begin(), rCellWidths.end(), [](sal_Int32 nWidth) {
+               return nWidth <= 0;
+           })
+        || std::any_of(rGridSpans.begin(), rGridSpans.end(), [](sal_uInt32 nSpan) {
+               return nSpan != 1;
+           }))
+    {
+        return false;
+    }
+
+    const sal_Int64 nGridTotal = std::accumulate(rTableGrid.begin(), rTableGrid.end(), sal_Int64(0));
+    const sal_Int64 nCellTotal = std::accumulate(rCellWidths.begin(), rCellWidths.end(), sal_Int64(0));
+    if (nGridTotal <= 0 || nCellTotal <= 0)
+        return false;
+
+    sal_Int64 nGridPosition = 0;
+    sal_Int64 nCellPosition = 0;
+    for (size_t i = 0; i + 1 < rCellWidths.size(); ++i)
+    {
+        nGridPosition += rTableGrid[i];
+        nCellPosition += rCellWidths[i];
+        // Ignore rounding noise. A stale autofit grid differs from the preferred cell widths by
+        // more than one percent of the table width.
+        const double fGridPosition = static_cast<double>(nGridPosition) / nGridTotal;
+        const double fCellPosition = static_cast<double>(nCellPosition) / nCellTotal;
+        if (std::abs(fGridPosition - fCellPosition) > 0.01)
+        {
+            return true;
+        }
+    }
+    return false;
+}
+}
