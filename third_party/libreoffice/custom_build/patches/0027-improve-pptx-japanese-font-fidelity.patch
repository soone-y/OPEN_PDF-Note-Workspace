+bool lclHasJapaneseChartTitle(const ChartSpaceModel& rChartSpace)
+{
+    if (!rChartSpace.mxTitle.is() || !rChartSpace.mxTitle->mxText.is()
+        || !rChartSpace.mxTitle->mxText->mxTextBody.is())
+        return false;
+
+    const OUString aTitle = rChartSpace.mxTitle->mxText->mxTextBody->toString();
+    for (sal_Int32 i = 0; i < aTitle.getLength(); ++i)
+        if (aTitle[i] >= 0x3040 && aTitle[i] <= 0x30ff)
+            return true;
+    return false;
+}
