+
+bool lclContainsJapaneseText(const OUString& rText)
+{
+    for (sal_Int32 i = 0; i < rText.getLength(); ++i)
+    {
+        const sal_Unicode c = rText[i];
+        if ((c >= 0x3040 && c <= 0x30ff) || (c >= 0x3400 && c <= 0x9fff))
+            return true;
+    }
+    return false;
+}
+
+void lclApplyOfficeJapaneseFontLink(const ::oox::core::XmlFilterBase& rFilterBase,
+                                    const OUString& rText,
+                                    TextCharacterProperties& rTextCharacterProps)
+{
+    if (!lclContainsJapaneseText(rText))
+        return;
+
+    OUString aAsianFontName;
+    sal_Int16 nFontPitch = 0;
+    sal_Int16 nFontFamily = 0;
+    if (rTextCharacterProps.maAsianFont.getFontData(aAsianFontName, nFontPitch, nFontFamily,
+                                                    nullptr, rFilterBase)
+        && aAsianFontName.equalsIgnoreAsciiCase(u"Courier New"))
+    {
+        // Windows PowerPoint links Japanese glyphs in Courier New runs to MS Mincho.
+        // LibreOffice otherwise falls through to Noto Sans JP and changes the baseline.
+        rTextCharacterProps.maAsianFont.setAttributes(u"MS Mincho"_ustr);
+    }
+}
+
