diff --git a/oox/source/drawingml/table/tablecell.cxx b/oox/source/drawingml/table/tablecell.cxx
--- a/oox/source/drawingml/table/tablecell.cxx
+++ b/oox/source/drawingml/table/tablecell.cxx
@@ -47,6 +47,53 @@ using ::com::sun::star::table::BorderLine2;
 
 namespace oox::drawingml::table {
 
+namespace
+{
+
+bool lclContainsJapaneseText(const OUString& rText)
+{
+    for (sal_Int32 i = 0; i < rText.getLength(); ++i)
+    {
+        const sal_Unicode c = rText[i];
+        if ((c >= 0x3040 && c <= 0x30ff) || (c >= 0x3400 && c <= 0x9fff))
+            return true;
+    }
+    return false;
+}
+
+void lclApplyJapaneseTableFallback(const ::oox::core::XmlFilterBase& rFilterBase,
+                                   const TextBody& rTextBody,
+                                   TextCharacterProperties& rTextStyleProps)
+{
+    OUString aFontName;
+    sal_Int16 nFontPitch = 0;
+    sal_Int16 nFontFamily = 0;
+    if (!lclContainsJapaneseText(rTextBody.toString())
+        || rTextStyleProps.maAsianFont.getFontData(aFontName, nFontPitch, nFontFamily,
+                                                   nullptr, rFilterBase))
+    {
+        return;
+    }
+
+    const Theme* pTheme = rFilterBase.getCurrentTheme();
+    if (!pTheme || !pTheme->getTheme())
+        return;
+
+    OUString aJapaneseTypeface
+        = pTheme->getTheme()->getFontScheme().findMinorSupplementalTypeface(u"Jpan");
+    if (aJapaneseTypeface.isEmpty())
+        return;
+
+    // PowerPoint's classic Office table styles use the non-proportional MS Gothic
+    // fallback even though the theme advertises MS PGothic as its Japanese minor font.
+    // Modern themes keep their own Japanese supplemental typeface.
+    if (aJapaneseTypeface == u"ＭＳ Ｐゴシック")
+        aJapaneseTypeface = u"MS Gothic"_ustr;
+    rTextStyleProps.maAsianFont.setAttributes(aJapaneseTypeface);
+}
+
+} // namespace
