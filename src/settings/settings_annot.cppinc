    case ToolMode::Pan:
        return IsEnglishUi() ? L"Pan: tool" : L"パン: ツール";
    case ToolMode::Magnifier:
        return IsEnglishUi() ? L"Magnifier: shape" : L"拡大鏡: 形";
    case ToolMode::TextBox:
        return IsEnglishUi() ? L"Text: size slot" : L"テキスト: サイズスロット";
    case ToolMode::MarkerText:
        return IsEnglishUi() ? L"Text marker" : L"マーカー";
    case ToolMode::MarkerTextUnderline:
        return IsEnglishUi() ? L"Underline marker" : L"下線マーカー";
    case ToolMode::MarkerTextColor:
        return IsEnglishUi() ? L"Text color marker" : L"文字色マーカー";
    case ToolMode::MarkerFree:
        return IsEnglishUi() ? L"Freehand marker" : L"フリーハンドマーカー";
    case ToolMode::MarkerLine:
        return IsEnglishUi() ? L"Shape: marker line" : L"図形: マーカー直線";
    case ToolMode::MarkerArrow:
        return IsEnglishUi() ? L"Shape: marker arrow" : L"図形: マーカー矢印";
    case ToolMode::MarkerWave:
        return IsEnglishUi() ? L"Shape: marker wave" : L"図形: マーカー波線";
    case ToolMode::Freehand:
        return IsEnglishUi() ? L"Pen: freehand" : L"ペン: フリーハンド";
    case ToolMode::Line:
        return IsEnglishUi() ? L"Shape: line" : L"図形: 直線";
    case ToolMode::Arrow:
        return IsEnglishUi() ? L"Shape: arrow" : L"図形: 矢印";
    case ToolMode::Wave:
        return IsEnglishUi() ? L"Shape: wave" : L"図形: 波線";
