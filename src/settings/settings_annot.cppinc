constexpr int kAnnotSectionCount = 6;
enum AnnotSectionIndex : int {
    kAnnotSectionText = 0,
    kAnnotSectionMarker = 1,
    kAnnotSectionShape = 2,
    kAnnotSectionStroke = 3,
    kAnnotSectionLensPalette = 4,
    kAnnotSectionToolbar = 5,
};

struct AnnotSettingsCtx {
    HWND owner = nullptr;
    bool done = false;
    bool ok = false;
    bool embedded = false;
    HWND headerTitle = nullptr;
    HWND headerSubtitle = nullptr;
    std::array<HWND, kSettingsCategoryButtonCount> categoryButtons{};
    HWND navList = nullptr;
    HWND scrollPanel = nullptr;
    HWND btnOk = nullptr;
    HWND btnCancel = nullptr;
    bool reopenOnCancel = false;
    bool notifyCancelDiscard = false;
    int nextDialog = kSettingsNavNone;
    HWND cbTextFont = nullptr;
    HWND cbTextSize = nullptr;
    HWND cbTextColor = nullptr;
    HWND chkTextReadableBackground = nullptr;
    HWND cbLineWidth = nullptr;
    HWND cbLineColor = nullptr;
    HWND chkLineToolsShare = nullptr;
    HWND cbArrowWidth = nullptr;
    HWND cbArrowColor = nullptr;
    HWND cbArrowHead = nullptr;
    HWND cbWaveWidth = nullptr;
    HWND cbWaveColor = nullptr;
    HWND cbFreehandWidth = nullptr;
    HWND cbFreehandColor = nullptr;
    HWND cbFreehandCorrection = nullptr;
    HWND cbFreehandCorrectionStyle = nullptr;
    HWND cbFreehandCorrectionFill = nullptr;
    HWND cbMarkerWidth = nullptr;
    HWND cbMarkerColor = nullptr;
    HWND cbMarkerTextWidth = nullptr;
    HWND cbMarkerTextColor = nullptr;
    HWND cbMarkerTextStyle = nullptr;
    HWND cbShapeColor = nullptr;
    HWND cbShapeKind = nullptr;
    HWND cbShapeDrawMode = nullptr;
    HWND cbMagnifierShape = nullptr;
    HWND btnPaletteCustom = nullptr;
    HWND previewPaletteCustom = nullptr;
    HWND lbTools = nullptr;
    HWND btnToolUp = nullptr;
    HWND btnToolDown = nullptr;
    HWND cbToolState = nullptr;
    HWND btnToolReset = nullptr;
    COLORREF palettePreviewColor = RGB(128, 128, 128);
    std::vector<ToolMode> expandedToolOrder;
    std::vector<AnnotToolUiState> expandedToolStates;
    int sectionTops[kAnnotSectionCount]{};
    int sectionCount = 0;
    int scrollPos = 0;
    int scrollMax = 0;
    int wheelRemainder = 0;
    int contentHeight = 0;
    int clientHeight = 0;
};

static void UpdateAnnotSectionNavUi(AnnotSettingsCtx* ctx, int sectionIndex) {
    if (!ctx) return;
    int clamped = std::clamp(sectionIndex, 0, std::max(0, ctx->sectionCount - 1));
    if (ctx->navList) {
        SendMessageW(ctx->navList, LB_SETCURSEL, clamped, 0);
    }
}

