static int SettingsControlWidth(HWND hWnd, int contentW, bool embedded, int normalPx, int embeddedPx) {
    return std::min(contentW, ScaleY(hWnd, embedded ? embeddedPx : normalPx));
}

static std::wstring SettingLabelWithDefault(const std::wstring& label, const std::wstring& value) {
    if (value.empty()) return label;
    return IsEnglishUi()
        ? (label + L" (default: " + value + L")")
        : (label + L" (初期: " + value + L")");
}

