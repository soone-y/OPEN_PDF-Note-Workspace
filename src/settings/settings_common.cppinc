static const wchar_t* UiCloseLabel() {
    return IsEnglishUi() ? L"Close" : L"閉じる";
}

template <size_t N>
static int LayoutHeaderSectionButtons(HWND hWnd, const std::array<HWND, N>& buttons,
                                      int left, int top, int width, int rowH) {
    if (width <= 0) return top;
    int visibleCount = 0;
    for (HWND button : buttons) {
        if (button) ++visibleCount;
    }
    if (visibleCount <= 0) return top;

    const int gap = ScaleY(hWnd, 8);
    const int totalGap = gap * std::max(0, visibleCount - 1);
    const int buttonW = std::max(ScaleY(hWnd, 72), (width - totalGap) / visibleCount);
    int x = left;
    for (HWND button : buttons) {
        if (!button) continue;
        SetWindowPos(button, nullptr, x, top, buttonW, rowH, SWP_NOZORDER | SWP_NOACTIVATE);
        x += buttonW + gap;
    }
    return top + rowH;
}

constexpr int kSettingsCategoryButtonCount = 5;
enum SettingsCategoryNavTarget : int {
    kSettingsNavNone = -1,
    kSettingsNavGeneral = 0,
    kSettingsNavNote = 1,
    kSettingsNavMarkup = 2,
    kSettingsNavAnnot = 3,
    kSettingsNavPalette = 4,
};

static std::wstring SettingsCategoryDialogTitle(int target) {
    const UiText& ui = GetUiText();
    switch (target) {
    case kSettingsNavNote:
        return ui.menuNoteSettings;
    case kSettingsNavMarkup:
        return ui.menuMarkupSettings;
    case kSettingsNavAnnot:
        return ui.menuAnnotSettings;
    case kSettingsNavPalette:
        return ui.menuPaletteSettings;
    case kSettingsNavGeneral:
    default:
        return ui.menuGeneralSettings;
    }
}

static std::wstring SettingsCategoryHeaderLabel(int target) {
    switch (target) {
    case kSettingsNavNote:
        return IsEnglishUi() ? L"Note" : L"ノート";
    case kSettingsNavMarkup:
        return IsEnglishUi() ? L"Markup" : L"マークアップ";
    case kSettingsNavAnnot:
        return IsEnglishUi() ? L"Annotation" : L"注釈";
    case kSettingsNavPalette:
        return IsEnglishUi() ? L"Color Palette" : L"カラーパレット";
    case kSettingsNavGeneral:
    default:
        return IsEnglishUi() ? L"Basic" : L"基本";
    }
}

static std::array<std::wstring, kSettingsCategoryButtonCount> SettingsCategoryButtonLabels() {
    return {
        SettingsCategoryHeaderLabel(kSettingsNavGeneral),
        SettingsCategoryHeaderLabel(kSettingsNavNote),
        SettingsCategoryHeaderLabel(kSettingsNavMarkup),
        SettingsCategoryHeaderLabel(kSettingsNavAnnot),
        SettingsCategoryHeaderLabel(kSettingsNavPalette),
    };
}

static void UpdateSettingsCategoryButtons(const std::array<HWND, kSettingsCategoryButtonCount>& buttons,
                                          int activeIndex) {
    for (int i = 0; i < kSettingsCategoryButtonCount; ++i) {
        if (!buttons[static_cast<size_t>(i)]) continue;
        EnableWindow(buttons[static_cast<size_t>(i)], i != activeIndex);
    }
}

static void UpdateDialogScroll(HWND hWnd, int contentH, int clientH, int* scrollPos, int* scrollMax) {
    if (!scrollPos || !scrollMax) return;
    int maxPos = std::max(0, contentH - clientH);
    *scrollMax = maxPos;
    if (*scrollPos > maxPos) *scrollPos = maxPos;
    if (*scrollPos < 0) *scrollPos = 0;
    SCROLLINFO si{};
    si.cbSize = sizeof(si);
    si.fMask = SIF_RANGE | SIF_PAGE | SIF_POS;
    si.nMin = 0;
    si.nMax = std::max(0, contentH - 1);
    si.nPage = static_cast<UINT>(std::max(0, clientH));
    si.nPos = *scrollPos;
    SetScrollInfo(hWnd, SB_VERT, &si, TRUE);
}

static void ScrollDialogTo(HWND hWnd, int newPos, int* scrollPos, int scrollMax) {
    if (!scrollPos) return;
    int clamped = std::clamp(newPos, 0, scrollMax);
    if (clamped == *scrollPos) return;
    int delta = *scrollPos - clamped;
    *scrollPos = clamped;
    ScrollWindowEx(hWnd, 0, delta, nullptr, nullptr, nullptr, nullptr,
                   SW_INVALIDATE | SW_ERASE | SW_SCROLLCHILDREN);
    SCROLLINFO si{};
    si.cbSize = sizeof(si);
    si.fMask = SIF_POS;
    si.nPos = clamped;
    SetScrollInfo(hWnd, SB_VERT, &si, TRUE);
}

static int SettingsWheelDeltaToPixels(int wheelDelta, int stepPx, int* remainder) {
    int raw = wheelDelta * std::max(1, stepPx);
    if (remainder) raw += *remainder;
    int pixels = raw / WHEEL_DELTA;
    if (remainder) *remainder = raw % WHEEL_DELTA;
    return pixels;
}

static bool ForwardWheelToDroppedComboInTree(HWND root, UINT msg, WPARAM wParam, LPARAM lParam) {
    if (!root || !IsWindow(root)) return false;

    POINT wheelPt{ GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam) }; // screen coords
    HWND underCursor = WindowFromPoint(wheelPt);

    std::vector<HWND> stack;
    stack.push_back(root);

    while (!stack.empty()) {
        HWND cur = stack.back();
        stack.pop_back();

        for (HWND child = GetWindow(cur, GW_CHILD); child; child = GetWindow(child, GW_HWNDNEXT)) {
            wchar_t cls[64]{};
            if (GetClassNameW(child, cls, static_cast<int>(std::size(cls))) > 0) {
                if (wcscmp(cls, L"ComboBox") == 0 &&
                    SendMessageW(child, CB_GETDROPPEDSTATE, 0, 0) != 0) {
                    COMBOBOXINFO cbi{};
                    cbi.cbSize = sizeof(cbi);
                    if (GetComboBoxInfo(child, &cbi) && cbi.hwndList) {
                        HWND list = cbi.hwndList;
                        HWND dropWnd = GetParent(list) ? GetParent(list) : list;

                        RECT rcDrop{}, rcCombo{};
                        bool hasDrop = GetWindowRect(dropWnd, &rcDrop) != 0;
                        bool hasCombo = GetWindowRect(child, &rcCombo) != 0;

                        bool overDrop = hasDrop && PtInRect(&rcDrop, wheelPt);
                        bool overCombo = hasCombo && PtInRect(&rcCombo, wheelPt);
                        bool overKnownWindow = (underCursor && (underCursor == list || underCursor == dropWnd ||
                                                               IsChild(dropWnd, underCursor) || IsChild(list, underCursor)));

                        if (!overDrop && !overCombo && !overKnownWindow) {
                            // Another combo might be dropped; keep searching.
                        } else {
                            SendMessageW(dropWnd, msg, wParam, lParam);
                            return true;
                        }
                    } else {
                        RECT rcCombo{};
                        if (GetWindowRect(child, &rcCombo) && PtInRect(&rcCombo, wheelPt)) {
                            SendMessageW(child, msg, wParam, lParam);
                            return true;
                        }
                    }
                }
            }

            if (GetWindow(child, GW_CHILD)) {
                stack.push_back(child);
            }
        }
    }

    return false;
}

static bool IsEditableTextInputControlForIme(HWND hWnd) {
    if (!hWnd || !IsWindow(hWnd)) return false;
    wchar_t cls[64]{};
    if (GetClassNameW(hWnd, cls, static_cast<int>(std::size(cls))) <= 0) return false;
    if (_wcsicmp(cls, L"Edit") == 0 ||
        _wcsicmp(cls, MSFTEDIT_CLASS) == 0 ||
        _wcsnicmp(cls, L"RICHEDIT", 8) == 0) {
        LONG_PTR style = GetWindowLongPtrW(hWnd, GWL_STYLE);
        return (style & ES_READONLY) == 0;
    }
    if (_wcsicmp(cls, L"ComboBox") == 0) {
        LONG_PTR style = GetWindowLongPtrW(hWnd, GWL_STYLE);
        return (style & CBS_DROPDOWNLIST) == 0;
    }
    return false;
}

static bool IsExplicitImeTargetWindowForModal(HWND hWnd) {
    if (!hWnd || !IsWindow(hWnd)) return false;
    if (hWnd == g_hPdfView) {
        return g_pdf.editingText;
    }
    if (hWnd == g_hNoteEdit || (g_hNoteEdit && IsChild(g_hNoteEdit, hWnd))) {
        return true;
    }
    return IsEditableTextInputControlForIme(hWnd);
}

static void DisableImeForWindow(HWND hWnd) {
    if (!hWnd) return;
    HIMC himc = ImmGetContext(hWnd);
    if (himc) {
        ImmNotifyIME(himc, NI_COMPOSITIONSTR, CPS_CANCEL, 0);
        ImmSetOpenStatus(himc, FALSE);
        ImmReleaseContext(hWnd, himc);
    }
    ImmAssociateContextEx(hWnd, nullptr, 0);
}

static void EnableImeForWindow(HWND hWnd) {
    if (!hWnd) return;
    ImmAssociateContextEx(hWnd, nullptr, IACE_DEFAULT);
}

static void EnforceImePolicyForWindowInModal(HWND hWnd) {
    if (!hWnd || !IsWindow(hWnd)) return;
    if (GetWindowThreadProcessId(hWnd, nullptr) != GetCurrentThreadId()) return;
    if (IsExplicitImeTargetWindowForModal(hWnd)) {
        EnableImeForWindow(hWnd);
        return;
    }
    DisableImeForWindow(hWnd);
}

static bool ShouldSkipImeMessageInModalLoop(const MSG& msg) {
    if (HWND focused = GetFocus(); focused) {
        EnforceImePolicyForWindowInModal(focused);
    }
    if (msg.hwnd) {
        EnforceImePolicyForWindowInModal(msg.hwnd);
    }
    bool isImeMsg = (msg.message == WM_IME_STARTCOMPOSITION ||
                     msg.message == WM_IME_COMPOSITION ||
                     msg.message == WM_IME_ENDCOMPOSITION);
    HWND imeTarget = msg.hwnd ? msg.hwnd : GetFocus();
    if (isImeMsg && !IsExplicitImeTargetWindowForModal(imeTarget)) {
        DisableImeForWindow(imeTarget);
        return true;
    }
    if (msg.message == WM_KEYDOWN && msg.wParam == VK_PROCESSKEY &&
        !IsExplicitImeTargetWindowForModal(imeTarget)) {
        return true;
    }
    return false;
}

static void RestoreOwnerAfterModal(HWND owner) {
    if (!owner) return;
    if (!IsWindow(owner)) return;
    EnableWindow(owner, TRUE);
    SetForegroundWindow(owner);
    SetActiveWindow(owner);
    BringWindowToTop(owner);
}

} // namespace
