// file: settings/settings_common.cppinc
// Included by settings.cpp (single TU).

namespace {

static void RequestLayout(HWND owner) {
    if (!owner) return;
    RECT rc{};
    GetClientRect(owner, &rc);
    int w = std::max(0, static_cast<int>(rc.right - rc.left));
    int h = std::max(0, static_cast<int>(rc.bottom - rc.top));
    SendMessageW(owner, WM_SIZE, SIZE_RESTORED, MAKELPARAM(w, h));
}

struct SettingsApplyEffects {
    bool updateAutoSaveTimer = false;
    bool updateAutoIntegrateTimer = false;
    bool layout = false;
    bool updateMathListVisibility = false;
    bool refreshBottomPane = false;
    bool reloadLectureList = false;
    bool reloadSessionList = false;
    bool applyThemeUi = false;
    bool invalidatePdfView = false;
    bool invalidateNoteEdit = false;
};

static void CommitSettingsApplyEffects(HWND owner, const SettingsApplyEffects& effects) {
    if (owner) {
        if (effects.updateAutoSaveTimer) {
            UpdateAutoSaveTimer(owner);
        }
        if (effects.updateAutoIntegrateTimer) {
            UpdateAutoIntegrateTimer(owner);
        }
        if (effects.layout) {
            RequestLayout(owner);
        }
        if (effects.updateMathListVisibility) {
            UpdateMathListVisibility();
        }
        if (effects.refreshBottomPane) {
            RefreshBottomPaneView();
        }
        if (effects.reloadLectureList) {
            PostMessageW(owner, kMsgReloadLectureList, 0, 0);
        }
        if (effects.reloadSessionList) {
            PostMessageW(owner, kMsgReloadSessionList, 0, 0);
        }
        if (effects.applyThemeUi) {
            ApplyThemeToUI(owner);
        }
    } else if (effects.applyThemeUi) {
        ApplyThemeToUI(nullptr);
    }
    if (effects.invalidatePdfView && g_hPdfView) {
        InvalidateRect(g_hPdfView, nullptr, FALSE);
    }
    if (effects.invalidateNoteEdit && g_hNoteEdit) {
        InvalidateRect(g_hNoteEdit, nullptr, TRUE);
    }
}

static int GetDpiY(HWND hWnd) {
    HDC dc = GetDC(hWnd);
    if (!dc) return 96;
    int dpi = GetDeviceCaps(dc, LOGPIXELSY);
    ReleaseDC(hWnd, dc);
    return (dpi > 0) ? dpi : 96;
}

static int ScaleY(HWND hWnd, int pxAt96Dpi) {
    return MulDiv(pxAt96Dpi, GetDpiY(hWnd), 96);
}

static int FontLineHeightPx(HWND hWnd, HFONT font) {
    HDC dc = GetDC(hWnd);
    if (!dc) return 16;
    HFONT useFont = font ? font : reinterpret_cast<HFONT>(GetStockObject(DEFAULT_GUI_FONT));
    HGDIOBJ old = SelectObject(dc, useFont);
    TEXTMETRICW tm{};
    GetTextMetricsW(dc, &tm);
    SelectObject(dc, old);
    ReleaseDC(hWnd, dc);
    return std::max(1, static_cast<int>(tm.tmHeight));
}

static int MeasureTextHeight(HWND hWnd, const std::wstring& text, int width, HFONT font) {
    if (width <= 0) return FontLineHeightPx(hWnd, font);
    HDC dc = GetDC(hWnd);
    if (!dc) return FontLineHeightPx(hWnd, font);
    HFONT useFont = font ? font : reinterpret_cast<HFONT>(GetStockObject(DEFAULT_GUI_FONT));
    HGDIOBJ old = SelectObject(dc, useFont);
    RECT rc{0, 0, width, 0};
    DrawTextW(dc, text.c_str(), -1, &rc, DT_LEFT | DT_WORDBREAK | DT_CALCRECT | DT_NOPREFIX);
    SelectObject(dc, old);
    ReleaseDC(hWnd, dc);
    return std::max(1, static_cast<int>(rc.bottom - rc.top));
}

static HFONT CreateSettingsUIFont(double pt, LONG weight) {
    LOGFONTW lf{};
    if (g_hUIFont && GetObjectW(g_hUIFont, sizeof(lf), &lf)) {
        // Reuse the app UI face so settings typography stays consistent.
    } else {
        lf.lfWeight = FW_NORMAL;
        const auto face = GetDefaultFontFaceName();
        wcscpy_s(lf.lfFaceName, face.c_str());
    }
    HDC screen = GetDC(nullptr);
    int dpiY = screen ? GetDeviceCaps(screen, LOGPIXELSY) : 96;
    if (screen) ReleaseDC(nullptr, screen);
    lf.lfHeight = -MulDiv(static_cast<int>(std::lround(pt)), dpiY, 72);
    lf.lfWeight = weight;
    return CreateFontIndirectW(&lf);
}

static HFONT SettingsCategoryFont() {
    static HFONT font = CreateSettingsUIFont(11.0, FW_SEMIBOLD);
    return font ? font : g_hUIFont;
}

static HFONT SettingsNavFont() {
    static HFONT font = CreateSettingsUIFont(11.0, FW_NORMAL);
    return font ? font : g_hUIFont;
}

static HFONT SettingsSectionFont() {
    static HFONT font = CreateSettingsUIFont(12.0, FW_SEMIBOLD);
    return font ? font : g_hUIFont;
}

static void SetSettingsCategoryFont(HWND hWnd) {
    if (hWnd) SendMessageW(hWnd, WM_SETFONT, reinterpret_cast<WPARAM>(SettingsCategoryFont()), TRUE);
}

static void SetSettingsNavFont(HWND hWnd) {
    if (hWnd) SendMessageW(hWnd, WM_SETFONT, reinterpret_cast<WPARAM>(SettingsNavFont()), TRUE);
}

static void SetSettingsSectionFont(HWND hWnd) {
    if (hWnd) SendMessageW(hWnd, WM_SETFONT, reinterpret_cast<WPARAM>(SettingsSectionFont()), TRUE);
}

