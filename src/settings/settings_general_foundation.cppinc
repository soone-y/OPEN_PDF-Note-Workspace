static void EnsureScheduleStartTimesCapacity(std::vector<std::wstring>& times) {
    size_t total = static_cast<size_t>(kScheduleDayCount * kScheduleMaxPeriods);
    if (times.size() < total) {
        times.resize(total);
    } else if (times.size() > total) {
        times.resize(total);
    }
}

