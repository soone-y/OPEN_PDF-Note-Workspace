static const PdfFlowModeOption kPdfFlowModeOptions[] = {
    { L"縦: 上から下", L"Vertical: top to bottom", L"v_ttb" },
    { L"縦: 下から上", L"Vertical: bottom to top", L"v_btu" },
    { L"横: 左から右", L"Horizontal: left to right", L"h_ltr" },
    { L"横: 右から左", L"Horizontal: right to left", L"h_rtl" },
};

static std::wstring NormalizePdfFlowModeValue(const std::wstring& mode) {
    std::wstring normalized = mode;
    std::transform(normalized.begin(), normalized.end(), normalized.begin(), ::towlower);
    if (normalized == L"v_btu" || normalized == L"h_ltr" || normalized == L"h_rtl") {
        return normalized;
    }
    return L"v_ttb";
}

static std::wstring PdfFlowModeLabel(const std::wstring& mode) {
    std::wstring normalized = NormalizePdfFlowModeValue(mode);
    for (const auto& option : kPdfFlowModeOptions) {
        if (normalized == option.value) {
            return IsEnglishUi() ? option.labelEn : option.labelJa;
        }
    }
    return IsEnglishUi() ? kPdfFlowModeOptions[0].labelEn : kPdfFlowModeOptions[0].labelJa;
}

