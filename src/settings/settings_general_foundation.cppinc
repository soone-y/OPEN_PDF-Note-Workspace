    { L"オフ（自動統合なし）", kAutoIntegrateModeOffSwitchExit },
    { L"5分", 300 },
    { L"20分", 1200 },
    { L"カスタマイズ", kAutoIntegrateModeCustom }
};

static bool IsFixedAutoIntegrateTimerSeconds(int seconds) {
    return seconds == 300 || seconds == 1200;
}

static int EffectiveAutoIntegrateCustomMinutes(int minutes) {
    return std::clamp(minutes,
                      kAutoIntegrateCustomMinutesMin,
                      kAutoIntegrateCustomMinutesMax);
}

static int NormalizeAutoIntegrateModeForUi(int rawSeconds, int* inoutCustomMinutes) {
    if (rawSeconds == kAutoIntegrateModeOffSwitchExit ||
        rawSeconds == kAutoIntegrateModeCustom ||
        IsFixedAutoIntegrateTimerSeconds(rawSeconds)) {
        return rawSeconds;
    }
    if (rawSeconds > 0) {
        if (inoutCustomMinutes) {
            int mins = (rawSeconds + 59) / 60;
            *inoutCustomMinutes = EffectiveAutoIntegrateCustomMinutes(mins);
        }
        return kAutoIntegrateModeCustom;
    }
    return kAutoIntegrateModeOffSwitchExit;
}

static bool PromptAutoIntegrateCustomMinutes(HWND owner, int currentMinutes, int* outMinutes) {
    if (!outMinutes) return false;
    currentMinutes = EffectiveAutoIntegrateCustomMinutes(currentMinutes);
    std::wstring input;
    std::wstring defaultValue = std::to_wstring(currentMinutes);
    while (true) {
        std::wstring title = IsEnglishUi()
            ? L"Auto integrate staged diffs: minutes (1-1440)"
            : L"未統合差分を自動統合する間隔：分を入力（1〜1440）";
        if (!PromptSimpleText(owner, title, defaultValue, input)) {
            return false;
        }
        input = TrimWhitespace(input);
        if (input.empty()) continue;
        try {
            int minutes = std::stoi(input);
            if (minutes < kAutoIntegrateCustomMinutesMin || minutes > kAutoIntegrateCustomMinutesMax) {
                const wchar_t* err = IsEnglishUi()
                    ? L"Please enter an integer between 1 and 1440."
                    : L"1〜1440 の整数を入力してください。";
                ShowSoftNotice(owner, err, SoftNoticeKind::Warning);
                defaultValue = input;
                continue;
            }
            *outMinutes = minutes;
            return true;
        } catch (...) {
            const wchar_t* err = IsEnglishUi()
                ? L"Please enter an integer between 1 and 1440."
                : L"1〜1440 の整数を入力してください。";
            ShowSoftNotice(owner, err, SoftNoticeKind::Warning);
            defaultValue = input;
        }
    }
}

