static BYTE g_noteLineSpacingRuleCache = 0xFF;
static LONG g_noteLineSpacingTwipsCache = LONG_MIN;
static bool g_noteHasFocus = false;
static bool g_noteRenderSelecting = false;
static size_t g_noteRenderSelectAnchor = 0;
static bool g_noteRenderMouseDragActive = false;
static bool g_noteNormalMouseDragActive = false;
static std::wstring g_noteLastClickLinkId;
static DWORD g_noteLastClickTime = 0;
static POINT g_noteLastClickPt = { -1, -1 };
static size_t g_notePendingCaretIdx = static_cast<size_t>(-1);
static bool g_notePendingLinkClickInsert = false;
static POINT g_notePendingLinkClickDown = { -1, -1 };
static bool g_noteNormalVisualMode = false;
static size_t g_noteNormalVisualAnchor = 0;
static int g_noteNormalPreferredX = -1;
static bool g_noteNormalPendingY = false;
static bool g_noteNormalPendingD = false;
static bool g_noteNormalPendingC = false;
static int g_noteNormalPendingCount = 0;
static bool g_noteNormalPendingG = false;
static DWORD g_noteRenderInsertGraceUntil = 0;
static int g_noteRenderInsertGraceLine = -1;

static DWORD NoteLinkRenderGraceRemainingMs() {
    if (g_noteLastClickLinkId.empty()) return 0;
    const DWORD graceMs = std::max<DWORD>(1, GetDoubleClickTime());
    const DWORD elapsedMs = GetTickCount() - g_noteLastClickTime;
    return (elapsedMs < graceMs) ? (graceMs - elapsedMs) : 0;
}

static void StartNoteLinkRenderGrace(HWND hWnd) {
    if (!hWnd || g_noteLastClickLinkId.empty()) return;
    g_noteLastClickTime = GetTickCount();
    const DWORD remainingMs = NoteLinkRenderGraceRemainingMs();
    SetTimer(hWnd, kNoteLinkRenderGraceTimerId, std::max<DWORD>(1, remainingMs), nullptr);
}

static void ClearNoteLinkRenderGrace(HWND hWnd) {
    if (hWnd) KillTimer(hWnd, kNoteLinkRenderGraceTimerId);
    g_noteLastClickLinkId.clear();
    g_noteLastClickTime = 0;
    g_noteLastClickPt = { -1, -1 };
}

struct NoteViewState {
    note::ViewIdentity identity{};
    note::SnapshotIdentity sourceSnapshot{};
    int renderScrollX = 0;
    DWORD normalCaret = 0;
    bool normalVisualMode = false;
    size_t normalVisualAnchor = 0;
    int normalPreferredX = -1;
    int rawFirstVisibleLine = 0;
};

static note::NoteIdentityRegistry& g_noteIdentityRegistry =
    note::RuntimeNoteIdentityRegistry();
static note::ViewId g_activeNoteViewId{};
static std::unordered_map<HWND, NoteViewState> g_noteViewStateByWindow;

static void ResetNoteViewPresentationState(NoteViewState& state) {
    const note::ViewIdentity identity = state.identity;
    state = NoteViewState{};
    state.identity = identity;
}
static note::NoteIdentity NoteIdentityForCapture(HWND hWnd,
                                                 const std::wstring& noteIdentityKey) {
    const auto stateIt = g_noteViewStateByWindow.find(hWnd);
    if (stateIt != g_noteViewStateByWindow.end()) {
        const auto current = g_noteIdentityRegistry.FindNote(stateIt->second.identity.note_id);
        if (current.has_value()) {
            if (noteIdentityKey.empty() || current->path_key == noteIdentityKey) return *current;
            if (note::RebindRuntimeNoteIdentityPath(
                    current->note_id, current->path_key, noteIdentityKey)) {
                return *g_noteIdentityRegistry.FindNote(current->note_id);
            }
            return *current;
        }
    }
    return noteIdentityKey.empty()
        ? g_noteIdentityRegistry.CreateTransient()
        : note::ResolveRuntimeNoteIdentityPath(noteIdentityKey);
}

static note::NoteIdentity NoteIdentityForActivation(HWND hWnd,
                                                    const std::wstring& noteIdentityKey) {
    if (!noteIdentityKey.empty()) {
        return note::ResolveRuntimeNoteIdentityPath(noteIdentityKey);
    }
    const auto stateIt = g_noteViewStateByWindow.find(hWnd);
    if (stateIt != g_noteViewStateByWindow.end()) {
        const auto current = g_noteIdentityRegistry.FindNote(stateIt->second.identity.note_id);
        if (current.has_value() && current->transient) return *current;
    }
    return g_noteIdentityRegistry.CreateTransient();
}

static NoteViewState& EnsureNoteViewState(HWND hWnd,
                                         const note::NoteIdentity& noteIdentity) {
    auto [it, inserted] = g_noteViewStateByWindow.try_emplace(hWnd);
    NoteViewState& state = it->second;
    if (inserted || !state.identity.valid()) {
        state.identity = g_noteIdentityRegistry.CreateView(noteIdentity.note_id);
        return state;
    }
    if (state.identity.note_id != noteIdentity.note_id) {
        const auto rebound =
            g_noteIdentityRegistry.RebindView(state.identity.view_id, noteIdentity.note_id);
        ResetNoteViewPresentationState(state);
        GetViewContext(hWnd).Clear();
        if (rebound.has_value()) state.identity = *rebound;
    }
    return state;
}

static void CaptureNoteViewState(HWND hWnd, const std::wstring& noteIdentityKey) {
    if (!hWnd || !IsWindow(hWnd)) return;
    const note::NoteIdentity noteIdentity = NoteIdentityForCapture(hWnd, noteIdentityKey);
    NoteViewState& state = EnsureNoteViewState(hWnd, noteIdentity);
    if (state.sourceSnapshot.content_revision != CurrentNoteTextCoreModel().revision) {
        state.sourceSnapshot.content_fingerprint = 0;
    }
    state.sourceSnapshot.note_id = state.identity.note_id;
    state.sourceSnapshot.content_revision = CurrentNoteTextCoreModel().revision;
    if (!IsNoteRenderActive()) {
        DWORD start = 0, end = 0;
        SendMessageW(hWnd, EM_GETSEL, reinterpret_cast<WPARAM>(&start), reinterpret_cast<LPARAM>(&end));
        state.normalCaret = end;
        state.normalVisualMode = (start != end);
        state.normalVisualAnchor = start;
        state.rawFirstVisibleLine = static_cast<int>(SendMessageW(hWnd, EM_GETFIRSTVISIBLELINE, 0, 0));
        POINT pt{};
        SendMessageW(hWnd, EM_GETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&pt));
        state.renderScrollX = pt.x;
    } else {
        state.renderScrollX = g_noteRenderScrollX;
        state.normalCaret = g_noteNormalCaret;
        state.normalVisualMode = g_noteNormalVisualMode;
        state.normalVisualAnchor = g_noteNormalVisualAnchor;
        state.rawFirstVisibleLine = static_cast<int>(SendMessageW(hWnd, EM_GETFIRSTVISIBLELINE, 0, 0));
    }
    state.normalPreferredX = g_noteNormalPreferredX;
}

static void BeginNoteViewActivation(HWND hWnd, const std::wstring& noteIdentityKey) {
    if (!hWnd || !IsWindow(hWnd)) return;
    const note::NoteIdentity noteIdentity = NoteIdentityForActivation(hWnd, noteIdentityKey);
    NoteViewState& state = EnsureNoteViewState(hWnd, noteIdentity);
    g_activeNoteViewId = state.identity.view_id;
    g_noteRenderScrollX = 0;
    g_noteNormalCaret = 0;
    g_noteNormalVisualMode = false;
    g_noteNormalVisualAnchor = 0;
    g_noteNormalPreferredX = -1;
    g_noteNormalPendingY = false;
    g_noteNormalPendingD = false;
    g_noteNormalPendingC = false;
    g_noteNormalPendingCount = 0;
    g_noteNormalPendingG = false;
}

static void RestoreNoteViewState(HWND hWnd,
                                 const std::wstring& noteIdentityKey,
                                 bool contentMatchesCachedView,
                                 const note::SnapshotIdentity& loadedSnapshot) {
    if (!hWnd || !IsWindow(hWnd)) return;
    const note::NoteIdentity noteIdentity = NoteIdentityForActivation(hWnd, noteIdentityKey);
    NoteViewState& state = EnsureNoteViewState(hWnd, noteIdentity);
    const bool canRestore =
        contentMatchesCachedView &&
        state.sourceSnapshot.note_id == state.identity.note_id;
    if (!canRestore) {
        ResetNoteViewPresentationState(state);
    }

    g_activeNoteViewId = state.identity.view_id;
    g_noteNormalCaret = static_cast<DWORD>(
        std::min<size_t>(state.normalCaret, CurrentNoteTextCoreModel().raw.size()));
    g_noteNormalVisualMode = canRestore && g_noteNormalMode && state.normalVisualMode;
    g_noteNormalVisualAnchor =
        std::min(state.normalVisualAnchor, CurrentNoteTextCoreModel().raw.size());
    g_noteNormalPreferredX = canRestore ? state.normalPreferredX : -1;
    g_noteNormalPendingY = false;
    g_noteNormalPendingD = false;
    g_noteNormalPendingC = false;
    g_noteNormalPendingCount = 0;
    g_noteNormalPendingG = false;
    SetNoteRenderScrollPosX(hWnd, canRestore ? state.renderScrollX : 0);

    if (canRestore && !IsNoteRenderActive()) {
        DWORD start = g_noteNormalVisualMode ? static_cast<DWORD>(g_noteNormalVisualAnchor) : g_noteNormalCaret;
        DWORD end = g_noteNormalCaret;
        SendMessageW(hWnd, EM_SETSEL, start, end);
        int currentLine = static_cast<int>(SendMessageW(hWnd, EM_GETFIRSTVISIBLELINE, 0, 0));
        if (state.rawFirstVisibleLine != currentLine) {
            SendMessageW(hWnd, EM_LINESCROLL, 0, state.rawFirstVisibleLine - currentLine);
        }
        SendMessageW(hWnd, EM_SCROLLCARET, 0, 0);
    }

    note::SnapshotIdentity committedSnapshot = loadedSnapshot;
    if (!committedSnapshot.valid() && canRestore) {
        committedSnapshot = state.sourceSnapshot;
    }
    committedSnapshot.note_id = state.identity.note_id;
    committedSnapshot.content_revision = CurrentNoteTextCoreModel().revision;
    state.sourceSnapshot = committedSnapshot;
    state.renderScrollX = g_noteRenderScrollX;
    state.normalCaret = g_noteNormalCaret;
    state.normalVisualMode = g_noteNormalVisualMode;
    state.normalVisualAnchor = g_noteNormalVisualAnchor;
    state.rawFirstVisibleLine = canRestore ? state.rawFirstVisibleLine : 0;
    state.normalPreferredX = g_noteNormalPreferredX;
}

static void ForgetNoteViewState(HWND hWnd) {
    if (!hWnd) return;
    auto it = g_noteViewStateByWindow.find(hWnd);
    if (it == g_noteViewStateByWindow.end()) return;
    if (it->second.identity.view_id == g_activeNoteViewId) g_activeNoteViewId = {};
    g_noteIdentityRegistry.ForgetView(it->second.identity.view_id);
    g_noteViewStateByWindow.erase(it);
}

static note::ViewIdentity CurrentNoteViewIdentity() {
    const HWND hWnd = CurrentNoteViewContextWindow();
    if (!hWnd) return {};
    const note::ViewIdentity view = NoteViewIdentityForWindow(hWnd);
    if (!view.valid()) return {};
    if (g_boundNoteViewContextHwnd) return view;
    return view.view_id == g_activeNoteViewId ? view : note::ViewIdentity{};
}

static note::ViewIdentity CurrentActiveNoteViewIdentity() {
    if (!g_activeNoteViewId.valid() || !g_hNoteEdit) return {};
    const note::ViewIdentity view = NoteViewIdentityForWindow(g_hNoteEdit);
    return view.view_id == g_activeNoteViewId ? view : note::ViewIdentity{};
}

static note::ViewIdentity NoteViewIdentityForWindow(HWND hWnd) {
    if (!hWnd) return {};
    const auto stateIt = g_noteViewStateByWindow.find(hWnd);
    if (stateIt == g_noteViewStateByWindow.end()) return {};
    const auto registered =
        g_noteIdentityRegistry.FindView(stateIt->second.identity.view_id);
    return registered.has_value() ? *registered : note::ViewIdentity{};
}

static note::SnapshotIdentity CurrentActiveNoteSnapshotIdentity() {
    const note::ViewIdentity view = CurrentActiveNoteViewIdentity();
    if (!view.valid()) return {};
    const auto stateIt = g_noteViewStateByWindow.find(g_hNoteEdit);
    note::SnapshotIdentity identity = stateIt != g_noteViewStateByWindow.end()
        ? stateIt->second.sourceSnapshot
        : note::SnapshotIdentity{};
    if (identity.content_revision != CurrentNoteTextCoreModel().revision) {
        identity.content_fingerprint = 0;
    }
    identity.note_id = view.note_id;
    identity.content_revision = CurrentNoteTextCoreModel().revision;
    const note::NoteTextCore* core = CurrentNoteTextCore();
    if (core && core->note_id() == view.note_id) {
        identity.persistence_revision = core->persistence_revision();
    }
    return identity;
}

note::SnapshotIdentity CaptureCurrentNoteSnapshotIdentity() {
    return CurrentActiveNoteSnapshotIdentity();
}

bool CaptureCurrentNoteTextCoreUtf8(const std::wstring& expectedPath,
                                    std::string* outBytes,
                                    note::SnapshotIdentity* outIdentity) {
    if (outBytes) outBytes->clear();
    if (outIdentity) *outIdentity = {};
    note::NoteTextCore* core = CurrentNoteTextCore();
    if (!g_hNoteEdit || !core || expectedPath.empty() ||
        NormalizePathKey(expectedPath) != NormalizePathKey(g_currentNotePath)) {
        return false;
    }
    const std::wstring editorText = GetEditTextForIndexing(g_hNoteEdit);
    SynchronizeCurrentNoteTextCore(editorText);
    core = CurrentNoteTextCore();
    const note::ViewIdentity view = CurrentActiveNoteViewIdentity();
    if (!core || !view.valid() || view.note_id != core->note_id() ||
        !core->MatchesRaw(editorText)) {
        return false;
    }

    std::string bytes = WideToUTF8(core->BuildStorageTextCrlf());
    if (outIdentity) {
        *outIdentity = note::BuildSnapshotIdentity(
            core->note_id(),
            core->content_revision(),
            core->persistence_revision(),
            bytes);
    }
    if (outBytes) *outBytes = std::move(bytes);
    return true;
}

void RefreshCurrentNotePersistenceIdentity(const std::wstring& path) {
    if (!g_hNoteEdit || path.empty() ||
        NormalizePathKey(path) != NormalizePathKey(g_currentNotePath)) {
        return;
    }
    const note::NoteIdentity identity = note::ResolveRuntimeNoteIdentityPath(path);
    const auto record = note::FindRuntimeNotePersistenceRecord(identity.note_id);
    auto stateIt = g_noteViewStateByWindow.find(g_hNoteEdit);
    if (!record.has_value() || stateIt == g_noteViewStateByWindow.end() ||
        stateIt->second.identity.note_id != identity.note_id) {
        return;
    }
    const std::string editorBytes = WideToUTF8(GetEditText(g_hNoteEdit));
    const uint64_t editorFingerprint = note::FingerprintSnapshotBytes(editorBytes);
    if (editorFingerprint != record->disk_fingerprint) return;
    note::NoteTextCore* core = CurrentNoteTextCore();
    if (core && core->note_id() == identity.note_id) {
        core->SetPersistenceRevision(record->persistence_revision);
        note::RuntimeNoteWorkspaceService().InvalidateIndexes(identity.note_id);
    }

    stateIt->second.sourceSnapshot = note::BuildSnapshotIdentity(
        identity.note_id,
        CurrentNoteTextCoreModel().revision,
        record->persistence_revision,
        editorBytes);
}

static bool IsActiveNoteViewIdentity(note::NoteId noteId, note::ViewId viewId) {
    const note::ViewIdentity active = CurrentActiveNoteViewIdentity();
    return active.valid() && active.note_id == noteId && active.view_id == viewId;
}

static void ClearNoteRenderDirtyLines() {
    g_noteRenderDirtyLines = NoteRenderDirtyLineRange{};
}

static void ClearNoteRenderStaleLines() {
    g_noteRenderStaleLines = NoteRenderStaleLineRange{};
    g_noteDerivedFrameCommitRequiredBeforePaint = false;
}

static void MarkNoteRenderStaleLines(size_t first, size_t last) {
    if (last < first) std::swap(first, last);
    if (!g_noteRenderStaleLines.valid) {
        g_noteRenderStaleLines.valid = true;
        g_noteRenderStaleLines.first = first;
        g_noteRenderStaleLines.last = last;
    } else {
        g_noteRenderStaleLines.first = std::min(g_noteRenderStaleLines.first, first);
        g_noteRenderStaleLines.last = std::max(g_noteRenderStaleLines.last, last);
    }
}



static void ApplyNoteKernelHistoryResult(
    note::LocalNoteKernel* kernel,
    const note::NoteKernelApplyResult& apply) {
    const note::NoteDirtyGraph& graph = apply.dirty_graph;
    if (!graph.has_edit) return;
    if (graph.render_stale) {
        MarkNoteRenderStaleLines(graph.stale_lines.first, graph.stale_lines.last);
    }
    if (graph.line_count_may_change) {
        g_noteDerivedFrameCommitRequiredBeforePaint = true;
    }
    if (apply.text_result == note::NoteTextApplyResult::Applied) {
        note::RuntimeNoteWorkspaceService().InvalidateIndexes(
            kernel->text_core().note_id());
        g_noteDocumentRevisionSeed = std::max(
            g_noteDocumentRevisionSeed, kernel->text_core().content_revision());
    } else if (apply.text_result != note::NoteTextApplyResult::NoChange) {
        SynchronizeCurrentNoteTextCore(GetEditTextForIndexing(g_hNoteEdit));
    }
}

static void ApplyNoteDirtyGraphForUserTextEdit(
    const note::TextEdit& edit,
    note::NoteTextSelection selectionBefore,
    note::NoteTextSelection selectionAfter,
    note::NoteHistoryOperationKind kind) {
    note::LocalNoteKernel* kernel = CurrentNoteKernel();
    const note::NoteKernelApplyResult apply = kernel
        ? kernel->ApplyUserEdit(edit, selectionBefore, selectionAfter, kind,
                                GetTickCount64(), IsNoteRenderActive())
        : note::NoteKernelApplyResult{};
    ApplyNoteKernelHistoryResult(kernel, apply);
}



static bool IsNoteRenderStaleLine(int line) {
    if (line < 0 || !g_noteRenderStaleLines.valid) return false;
    const size_t value = static_cast<size_t>(line);
    return value >= g_noteRenderStaleLines.first && value <= g_noteRenderStaleLines.last;
}

static void MarkNoteRenderDirtyLines(size_t first, size_t last, bool lineCountChanged = false) {
    if (last < first) {
        std::swap(first, last);
    }
    if (!g_noteRenderDirtyLines.valid) {
        g_noteRenderDirtyLines.valid = true;
        g_noteRenderDirtyLines.first = first;
        g_noteRenderDirtyLines.last = last;
    } else {
        g_noteRenderDirtyLines.first = std::min(g_noteRenderDirtyLines.first, first);
        g_noteRenderDirtyLines.last = std::max(g_noteRenderDirtyLines.last, last);
    }
    g_noteRenderDirtyLines.lineCountChanged =
        g_noteRenderDirtyLines.lineCountChanged || lineCountChanged;
}

static void MarkNoteRenderDirtyAll(bool lineCountChanged = true) {
    g_noteRenderDirtyLines.valid = true;
    g_noteRenderDirtyLines.full = true;
    g_noteRenderDirtyLines.lineCountChanged =
        g_noteRenderDirtyLines.lineCountChanged || lineCountChanged;
    g_noteRenderDirtyLines.first = 0;
    g_noteRenderDirtyLines.last = g_lineCache.empty() ? 0 : (g_lineCache.size() - 1);
}

static std::optional<NoteRenderDirtyLineRange> TakeNoteRenderDirtyLines() {
    if (!g_noteRenderDirtyLines.valid) {
        return std::nullopt;
    }
    NoteRenderDirtyLineRange range = g_noteRenderDirtyLines;
    ClearNoteRenderDirtyLines();
    return range;
}

static bool ConsumeNoteLineSpacingInvalidatedNote() {
    const bool value = g_noteLineSpacingInvalidatedNote;
    g_noteLineSpacingInvalidatedNote = false;
    return value;
}

static bool IsRenderInsertGraceActiveForLine(int line) {
    if (line < 0) return false;
    if (g_noteRenderInsertGraceLine < 0) return false;
    if (line != g_noteRenderInsertGraceLine) return false;
    DWORD now = GetTickCount();
    return (g_noteRenderInsertGraceUntil - now) < 0x80000000u;
}

static int FindLineForRaw(size_t raw);

static bool IsNoteLineRawHelper(HWND hWnd, int line) {
    if (g_noteRawOnly) return true;
    if (g_linkPending.active && !g_linkPending.id.empty() && IsRenderInsertGraceActiveForLine(line)) return false;
    if (!g_noteHasFocus) return false;

    DWORD selStart = 0, selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL, reinterpret_cast<WPARAM>(&selStart), reinterpret_cast<LPARAM>(&selEnd));
    bool hasSelection = (selStart != selEnd);

    int selStartLine = 0;
    int selEndLine = 0;
    int caretLine = 0;

    const bool noteNormalModeActive = (g_noteVimModeEnabled && g_noteNormalMode);
    const bool showVimCaretLineRawInNote = (g_noteVimModeEnabled && noteNormalModeActive && !g_noteNormalVisualMode && g_noteVimCaretLineRawTextVisible);

    if (IsNoteRenderActive()) {
        const size_t rawStart = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, static_cast<size_t>(std::min(selStart, selEnd)));
        const size_t rawEnd = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, static_cast<size_t>(std::max(selStart, selEnd)));
        selStartLine = FindLineForRaw(rawStart);
        selEndLine = FindLineForRaw(rawEnd);
        caretLine = showVimCaretLineRawInNote ? FindLineForRaw(static_cast<size_t>(g_noteNormalCaret))
                                              : FindLineForRaw(rawEnd);
    } else {
        selStartLine = static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, std::min(selStart, selEnd), 0));
        selEndLine = static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, std::max(selStart, selEnd), 0));
        caretLine = showVimCaretLineRawInNote ? FindLineForRaw(static_cast<size_t>(g_noteNormalCaret))
                                              : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, std::max(selStart, selEnd), 0));
    }

    // Preserve the rendered geometry of a clicked link until Windows has
    // delivered the matching double-click message. Otherwise the caret-line
    // raw overlay shifts the second click onto the markup token instead of
    // the rendered link text.
    if (NoteLinkRenderGraceRemainingMs() > 0 && line == caretLine) return false;

    if (showVimCaretLineRawInNote) return line == caretLine;
    if (noteNormalModeActive) return false;
    if (hasSelection) return (line >= selStartLine && line <= selEndLine);
    return line == caretLine;
}


static void StartRenderInsertGrace(HWND hWnd, int line) {
    if (!hWnd || line < 0) return;
    DWORD graceMs = GetDoubleClickTime();
    if (graceMs < 1) graceMs = 1;
    g_noteRenderInsertGraceLine = line;
    g_noteRenderInsertGraceUntil = GetTickCount() + graceMs;
}

static void ClearRenderInsertGrace(HWND hWnd) {
    (void)hWnd;
    g_noteRenderInsertGraceLine = -1;
    g_noteRenderInsertGraceUntil = 0;
}

static void QueuePendingLinkInsertFromNoteClick(HWND hWnd, bool rawLikeMode) {
    if (!hWnd) return;
    if (!g_linkPending.active || g_linkPending.id.empty()) return;
    HWND owner = GetParent(hWnd);
    if (!owner) return;
    const UINT code = rawLikeMode ? kNoteShortcutInputCodeClickRaw
                                  : kNoteShortcutInputCodeClickRendered;
    PostMessageW(owner, WM_COMMAND, MAKEWPARAM(ID_NOTE_SHORTCUT_INPUT, code), 0);
}

static void ResetNoteInteractionState(HWND hWnd) {
    HWND edit = hWnd ? hWnd : g_hNoteEdit;
    g_notePendingLinkClickInsert = false;
    g_notePendingLinkClickDown = { -1, -1 };
    g_noteRenderSelecting = false;
    g_noteRenderSelectAnchor = 0;
    g_noteRenderMouseDragActive = false;
    g_noteNormalMouseDragActive = false;
    g_notePendingCaretIdx = static_cast<size_t>(-1);
    ClearNoteLinkRenderGrace(edit);
    ClearRenderInsertGrace(edit);
    if (edit && GetCapture() == edit) {
        ReleaseCapture();
    }
    if (g_hBottomMath && GetCapture() == g_hBottomMath) {
        ReleaseCapture();
    }
}

static void ClearLegacyRenderCache() {
    MarkNoteRenderDirtyAll(true);
    g_noteRenderSnapshot.Reset();
    g_renderTextCache.clear();
    g_renderLines.clear();
    g_renderLineInfos.clear();
    g_lastParsedMarkupLength = 0;
    g_lastParsedMarkupBaseFontHeightPx = 0;
    g_noteMathNodeCache.clear();
    g_noteMathLayoutCache.clear();
    g_noteMeasuredLayoutSnapshot.Reset();
    g_noteAppliedLayoutSnapshot.Reset();
    g_noteRenderedContentRightPx = 0;
    g_noteRenderedHorizontalExtentDirty = false;
    g_noteRenderedContentBottomPx = 0;
    g_noteRenderScrollX = 0;
}

static void ClearLineCache() {
    ClearLegacyRenderCache();
    ResetParsedNoteDocumentState();
}

static const mathrender::Node* GetCachedMathNode(const std::wstring& body) {
    if (body.empty()) return nullptr;
    auto it = g_noteMathNodeCache.find(body);
    if (it != g_noteMathNodeCache.end()) return it->second.get();
    if (g_noteMathNodeCache.size() > 512) {
        g_noteMathNodeCache.clear();
        g_noteMathLayoutCache.clear();
    }
    auto node = mathrender::Parse(body);
    if (!node) return nullptr;
    std::shared_ptr<mathrender::Node> shared(node.release());
    auto [insIt, ok] = g_noteMathNodeCache.emplace(body, std::move(shared));
    return insIt->second.get();
}

static std::wstring BuildMathLayoutCacheKey(HDC hdc,
                                            const std::wstring& body,
                                            int fontPx,
                                            mathrender::RenderStyle style) {
    LOGFONTW lf{};
    HGDIOBJ currentFont = hdc ? GetCurrentObject(hdc, OBJ_FONT) : nullptr;
    if (currentFont) {
        GetObjectW(currentFont, sizeof(lf), &lf);
    }

    std::wstring key;
    key.reserve(body.size() + 96);
    key.append(body);
    key.push_back(L'\x1f');
    key.append(std::to_wstring(std::max(1, fontPx)));
    key.push_back(L'\x1f');
    key.append(style == mathrender::RenderStyle::Display ? L"D" : L"I");
    key.push_back(L'\x1f');
    key.append(std::to_wstring(mathrender::GetSupSubGapSupPercent()));
    key.push_back(L'\x1f');
    key.append(lf.lfFaceName);
    key.push_back(L'\x1f');
    key.append(std::to_wstring(lf.lfWeight));
    key.push_back(L'\x1f');
    key.append(std::to_wstring(static_cast<int>(lf.lfItalic)));
    key.push_back(L'\x1f');
    key.append(std::to_wstring(static_cast<int>(lf.lfCharSet)));
    return key;
}

static mathrender::Layout MeasureCachedMathLayout(const mathrender::Node& node,
                                                  HDC hdc,
                                                  const std::wstring& body,
                                                  int fontPx,
                                                  mathrender::RenderStyle style) {
    fontPx = std::max(1, fontPx);
    std::wstring key = BuildMathLayoutCacheKey(hdc, body, fontPx, style);
    auto it = g_noteMathLayoutCache.find(key);
    if (it != g_noteMathLayoutCache.end()) return it->second;
    if (g_noteMathLayoutCache.size() > 2048) {
        g_noteMathLayoutCache.clear();
    }
    mathrender::Layout layout = mathrender::Measure(node, hdc, fontPx, style);
    g_noteMathLayoutCache.emplace(std::move(key), layout);
    return layout;
}

void SetNoteTyping(bool typing) {
    if (g_noteTyping == typing) return;
    g_noteTyping = typing;
    if (!typing) {
        ClearNoteRenderStaleLines();
    }
    if (g_hNoteEdit) InvalidateRect(g_hNoteEdit, nullptr, FALSE);
}

bool IsNoteTyping() {
    return g_noteTyping;
}

bool HasDeferredNoteFullReparse() {
    const note::LocalNoteKernel* kernel = CurrentNoteKernel();
    return kernel && kernel->has_deferred_full_refresh();
}

bool RequiresImmediateNoteDerivedFrameCommit() {
    return g_noteDerivedFrameCommitRequiredBeforePaint;
}

void RunDeferredNoteFullReparseNow() {
    note::LocalNoteKernel* kernel = CurrentNoteKernel();
    if (!kernel || !kernel->has_deferred_full_refresh() || !g_hNoteEdit) return;
    if (IsNoteImeComposing() || IsNoteTyping()) return;
    kernel->RequestFullRefresh();
    RecomputeMathFromNote();
}

static void FlushPendingMathRecompute(HWND noteWnd) {
    if (!noteWnd) return;
    if (IsNoteImeComposing()) return;
    const bool hasDeferredFullReparse = HasDeferredNoteFullReparse();
    const bool requiresDerivedFrameCommit = RequiresImmediateNoteDerivedFrameCommit();
    if (!g_noteTyping && !hasDeferredFullReparse && !requiresDerivedFrameCommit) return;
    SetNoteTyping(false);
    if (hasDeferredFullReparse) {
        // A structural edit (for example, inserting a newline) can require a full
        // refresh even when the normal typing flag has already been cleared.
        // Leaving the note is a hard consistency boundary, so commit it now.
        RunDeferredNoteFullReparseNow();
        return;
    }
    RecomputeMathFromNote();
}

bool IsNoteChangeSuppressed() {
    return g_noteTransactions.ShouldSuppressChange() || g_noteApplyingLineSpacing;
}

bool IsNoteImeComposing() {
    return g_noteImeComposing;
}

void ReleaseNoteChangeSuppressionForUserEdit() {
    const HWND hWnd = CurrentNoteViewContextWindow();
    if (!hWnd) return;
    MaybeReleaseNoteChangeSuppression(hWnd);
}

struct RenderBoundary {
    size_t raw = 0;
    int x = 0;
};

struct NoteVisibleUnit {
    wchar_t ch = 0;
    size_t beforeRaw = 0;
    size_t afterRaw = 0;
    bool separator = false;
};

static size_t ClampNoteRawIndex(size_t raw) {
    const HWND hWnd = CurrentNoteViewContextWindow();
    if (!hWnd) return 0;
    int len = GetWindowTextLengthW(hWnd);
    if (len < 0) len = 0;
    return std::min<size_t>(raw, static_cast<size_t>(len));
}

static std::vector<size_t> BuildLogicalLineStartsFromIndexingText(const std::wstring& text) {
    std::vector<size_t> starts;
    starts.reserve(256);
    starts.push_back(0);
    for (size_t i = 0; i < text.size();) {
        wchar_t ch = text[i];
        if (ch == L'\r' || ch == L'\n') {
            size_t next = i + 1;
            if (next <= text.size() && starts.back() != next) {
                starts.push_back(next);
            }
            i = next;
            continue;
        }
        ++i;
    }
    return starts;
}

static std::vector<size_t> GetNoteLogicalLineStarts(HWND hWnd, std::wstring* outIndexingText = nullptr) {
    std::wstring indexingText = GetEditTextForIndexing(hWnd);
    if (outIndexingText) {
        *outIndexingText = indexingText;
    }
    return BuildLogicalLineStartsFromIndexingText(indexingText);
}

static int FindLogicalLineForRaw(const std::vector<size_t>& starts, size_t raw) {
    if (starts.empty()) return 0;
    auto it = std::upper_bound(starts.begin(), starts.end(), raw);
    if (it == starts.begin()) return 0;
    return static_cast<int>((it - starts.begin()) - 1);
}

static bool GetLogicalLineRangeFromStarts(const std::wstring& indexingText,
                                          const std::vector<size_t>& starts,
                                          int logicalLine,
                                          size_t* outStart,
                                          size_t* outEnd,
                                          size_t* outNextStart) {
    if (starts.empty()) return false;
    logicalLine = std::clamp(logicalLine, 0, static_cast<int>(starts.size()) - 1);
    size_t start = starts[static_cast<size_t>(logicalLine)];
    size_t nextStart = (logicalLine + 1 < static_cast<int>(starts.size()))
                           ? starts[static_cast<size_t>(logicalLine + 1)]
                           : indexingText.size();
    nextStart = std::min(nextStart, indexingText.size());
    size_t end = nextStart;
    while (end > start && (indexingText[end - 1] == L'\r' || indexingText[end - 1] == L'\n')) {
        --end;
    }
    if (outStart) *outStart = start;
    if (outEnd) *outEnd = end;
    if (outNextStart) *outNextStart = nextStart;
    return true;
}

static bool QueryLogicalLineBandFromStarts(HWND hWnd,
                                           const std::wstring& indexingText,
                                           const std::vector<size_t>& starts,
                                           int logicalLine,
                                           int fallbackHeight,
                                           int* outTop,
                                           int* outBottom,
                                           size_t* outStart,
                                           size_t* outEnd,
                                           size_t* outNextStart,
                                           POINT* outPos) {
    if (!hWnd || starts.empty()) return false;
    size_t lineStart = 0;
    size_t lineEnd = 0;
    size_t nextStart = 0;
    if (!GetLogicalLineRangeFromStarts(indexingText, starts, logicalLine, &lineStart, &lineEnd, &nextStart)) {
        return false;
    }

    POINT linePos{};
    if (!GetCharPos(hWnd, lineStart, &linePos)) return false;
    int top = linePos.y;
    int bottom = top + std::max(1, fallbackHeight);

    if (logicalLine + 1 < static_cast<int>(starts.size())) {
        POINT nextPos{};
        if (GetCharPos(hWnd, nextStart, &nextPos) && nextPos.y > top) {
            bottom = nextPos.y;
        }
    }

    if (outTop) *outTop = top;
    if (outBottom) *outBottom = bottom;
    if (outStart) *outStart = lineStart;
    if (outEnd) *outEnd = lineEnd;
    if (outNextStart) *outNextStart = nextStart;
    linePos.x = NoteLineBaseXForRenderState(hWnd, linePos.x);
    if (outPos) *outPos = linePos;
    return true;
}

static bool InvalidateNoteRenderDirtyLines(HWND hWnd,
                                           const std::optional<NoteRenderDirtyLineRange>& dirtyRange,
                                           int fallbackHeight,
                                           bool allowFullFallback = true) {
    if (!hWnd) return false;
    if (!dirtyRange.has_value()) {
        return false;
    }
    if (IsNoteRenderActive()) {
        InvalidateRect(hWnd, nullptr, FALSE);
        return true;
    }
    const NoteRenderDirtyLineRange& range = *dirtyRange;
    if (!range.valid || range.full || range.lineCountChanged ||
        !IsNoteRenderActive() || g_lineCache.empty()) {
        if (!allowFullFallback) return false;
        InvalidateRect(hWnd, nullptr, FALSE);
        return true;
    }

    std::wstring indexingText;
    std::vector<size_t> starts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    const size_t usable = std::min(starts.size(), g_lineCache.size());
    if (usable == 0) {
        if (!allowFullFallback) return false;
        InvalidateRect(hWnd, nullptr, FALSE);
        return true;
    }

    size_t first = std::min(range.first, usable - 1);
    size_t last = std::min(range.last, usable - 1);
    if (last < first) std::swap(first, last);

    int top = 0;
    int bottom = 0;
    if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, starts, static_cast<int>(first),
                                        fallbackHeight, &top, nullptr,
                                        nullptr, nullptr, nullptr, nullptr) ||
        !QueryLogicalLineBandFromStarts(hWnd, indexingText, starts, static_cast<int>(last),
                                        fallbackHeight, nullptr, &bottom,
                                        nullptr, nullptr, nullptr, nullptr)) {
        if (!allowFullFallback) return false;
        InvalidateRect(hWnd, nullptr, FALSE);
        return true;
    }

    RECT client{};
    GetClientRect(hWnd, &client);
    const int pad = std::max(4, fallbackHeight);
    RECT rc{};
    rc.left = client.left;
    rc.right = std::max<LONG>(
        client.right,
        static_cast<LONG>(g_noteRenderedContentRightPx + GetNoteRenderRightPadPx(hWnd, client.right - client.left)));
    rc.top = std::max<LONG>(client.top, static_cast<LONG>(top - pad));
    rc.bottom = std::min<LONG>(client.bottom, static_cast<LONG>(bottom + pad));
    if (rc.bottom <= rc.top) {
        if (!allowFullFallback) return false;
        InvalidateRect(hWnd, nullptr, FALSE);
        return true;
    }
    InvalidateRect(hWnd, &rc, FALSE);
    return true;
}

struct NoteRenderViewportAnchor {
    bool valid = false;
    size_t rawLineStart = 0;
    int clientTop = 0;
};

static NoteRenderViewportAnchor CaptureNoteRenderViewportAnchor(HWND hWnd, int fallbackHeight) {
    NoteRenderViewportAnchor anchor;
    if (!hWnd || !IsNoteRenderActive()) return anchor;

    std::wstring indexingText;
    std::vector<size_t> starts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    if (starts.empty()) return anchor;

    POINTL topPoint{ 0, 0 };
    LRESULT topChar = SendMessageW(hWnd, EM_CHARFROMPOS, 0, reinterpret_cast<LPARAM>(&topPoint));
    int candidate = (topChar >= 0)
        ? FindLogicalLineForRaw(starts, static_cast<size_t>(topChar))
        : 0;
    candidate = std::clamp(candidate, 0, static_cast<int>(starts.size()) - 1);
    for (int guard = 0; guard < static_cast<int>(starts.size()); ++guard) {
        int top = 0;
        int bottom = 0;
        if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, starts, candidate,
                                            fallbackHeight, &top, &bottom,
                                            nullptr, nullptr, nullptr, nullptr)) {
            return anchor;
        }
        if (top > 0 && candidate > 0) {
            --candidate;
            continue;
        }
        if (bottom <= 0 && candidate + 1 < static_cast<int>(starts.size())) {
            ++candidate;
            continue;
        }
        anchor.valid = true;
        anchor.rawLineStart = starts[static_cast<size_t>(candidate)];
        anchor.clientTop = top;
        return anchor;
    }
    return anchor;
}

static bool RestoreNoteRenderViewportAnchor(HWND hWnd, const NoteRenderViewportAnchor& anchor) {
    if (!hWnd || !anchor.valid || !IsNoteRenderActive()) return false;

    POINT linePos{};
    POINT nativeScroll{};
    if (!GetCharPos(hWnd, anchor.rawLineStart, &linePos) ||
        !QueryNativeEditScrollPos(hWnd, &nativeScroll)) {
        return false;
    }

    const int deltaY = linePos.y - anchor.clientTop;
    if (deltaY == 0) return true;

    nativeScroll.x = 0;
    nativeScroll.y = std::max<LONG>(0, nativeScroll.y + static_cast<LONG>(deltaY));
    if (SendMessageW(hWnd, EM_SETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&nativeScroll))) {
        return true;
    }
    SetScrollPos(hWnd, SB_VERT, nativeScroll.y, TRUE);
    SendMessageW(hWnd, WM_VSCROLL, MAKEWPARAM(SB_THUMBPOSITION, nativeScroll.y), 0);
    return true;
}

static int NoteLineCount() {
    const HWND hWnd = CurrentNoteViewContextWindow();
    if (!hWnd) return 0;
    if (IsNoteRenderActive()) {
        return std::max<int>(1, static_cast<int>(GetNoteLogicalLineStarts(hWnd).size()));
    }
    int count = static_cast<int>(SendMessageW(hWnd, EM_GETLINECOUNT, 0, 0));
    return (count > 0) ? count : 1;
}

static bool IsNoteWordSeparatorChar(wchar_t ch) {
    if (iswspace(ch)) return true;
    switch (ch) {
    case L',':
    case L'.':
    case L':':
    case L';':
    case L'!':
    case L'?':
    case L'/':
    case L'\\':
    case L'|':
    case L'-':
    case L'+':
    case L'=':
    case L'*':
    case L'&':
    case L'^':
    case L'%':
    case L'$':
    case L'#':
    case L'@':
    case L'~':
    case L'`':
    case L'"':
    case L'\'':
    case L'(':
    case L')':
    case L'[':
    case L']':
    case L'{':
    case L'}':
    case L'<':
    case L'>':
    case L'、':
    case L'。':
    case L'，':
    case L'．':
    case L'：':
    case L'；':
    case L'！':
    case L'？':
    case L'（':
    case L'）':
    case L'［':
    case L'］':
    case L'｛':
    case L'｝':
    case L'「':
    case L'」':
    case L'『':
    case L'』':
    case L'【':
    case L'】':
    case L'〈':
    case L'〉':
    case L'《':
    case L'》':
    case L'・':
    case L'…':
    case L'ー':
    case L'は':
    case L'が':
    case L'を':
    case L'に':
    case L'へ':
    case L'と':
    case L'で':
    case L'の':
    case L'や':
    case L'も':
    case L'か':
    case L'ね':
    case L'よ':
    case L'わ':
    case L'ぞ':
    case L'さ':
    case L'な':
        return true;
    default:
        return false;
    }
}

static bool BuildNoteVisibleUnits(std::vector<NoteVisibleUnit>* out, size_t* outFinalRaw = nullptr) {
    if (!out) return false;
    out->clear();

    const HWND hWnd = CurrentNoteViewContextWindow();
    if (!hWnd) {
        if (outFinalRaw) *outFinalRaw = 0;
        return false;
    }

    std::wstring indexingText = GetEditTextForIndexing(hWnd);
    const size_t finalRaw = indexingText.size();
    if (outFinalRaw) *outFinalRaw = finalRaw;

    int lineCount = NoteLineCount();
    if (lineCount <= 0) return true;

    std::vector<size_t> logicalStarts;
    if (IsNoteRenderActive()) {
        logicalStarts = BuildLogicalLineStartsFromIndexingText(indexingText);
    }

    for (int line = 0; line < lineCount; ++line) {
        size_t lineStart = 0;
        size_t lineEnd = 0;
        size_t nextLineStart = lineEnd;
        if (IsNoteRenderActive()) {
            if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, line,
                                               &lineStart, &lineEnd, &nextLineStart)) {
                continue;
            }
        } else {
            LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineStartRes < 0) continue;
            LRESULT lineLenRes = SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineStartRes), 0);
            if (lineLenRes < 0) lineLenRes = 0;
            lineStart = static_cast<size_t>(lineStartRes);
            lineEnd = lineStart + static_cast<size_t>(lineLenRes);
            nextLineStart = lineEnd;
            if (line + 1 < lineCount) {
                LRESULT nextStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
                if (nextStartRes >= 0) nextLineStart = static_cast<size_t>(nextStartRes);
            }
        }

        size_t prevBoundary = lineStart;
        if (line < static_cast<int>(g_lineCache.size())) {
            const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
            for (const auto& seg : cache.segments) {
                if (seg.text.empty()) continue;
                std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
                for (size_t i = 0; i < seg.text.size(); ++i) {
                    size_t afterRaw = lineStart + seg.rawStart + RawOffsetForVisibleCharCount(
                        rawSeg, i + 1, SegmentDecodesMarkdownBackslashEscapes(cache, seg));
                    afterRaw = std::clamp(afterRaw, prevBoundary, lineEnd);
                    out->push_back({seg.text[i], prevBoundary, afterRaw, IsNoteWordSeparatorChar(seg.text[i])});
                    prevBoundary = afterRaw;
                }
            }
        }

        if (line + 1 < lineCount && nextLineStart > lineEnd) {
            out->push_back({L'\n', lineEnd, nextLineStart, true});
        }
    }

    return true;
}

static size_t FindVisibleUnitIndexAfterCaret(const std::vector<NoteVisibleUnit>& units, size_t caretRaw) {
    size_t idx = 0;
    while (idx < units.size() && units[idx].afterRaw <= caretRaw) {
        ++idx;
    }
    return idx;
}

static bool MoveRenderedNormalCaretWordForward() {
    if (!g_hNoteEdit) return false;
    std::vector<NoteVisibleUnit> units;
    size_t finalRaw = 0;
    if (!BuildNoteVisibleUnits(&units, &finalRaw)) return false;

    size_t caretRaw = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    size_t idx = FindVisibleUnitIndexAfterCaret(units, caretRaw);
    if (idx >= units.size()) {
        if (caretRaw < finalRaw) {
            g_noteNormalCaret = static_cast<DWORD>(finalRaw);
            g_noteNormalPreferredX = -1;
            return true;
        }
        return false;
    }

    if (units[idx].separator) {
        while (idx < units.size() && units[idx].separator) ++idx;
    } else {
        while (idx < units.size() && !units[idx].separator) ++idx;
        while (idx < units.size() && units[idx].separator) ++idx;
    }

    size_t nextRaw = (idx < units.size()) ? units[idx].beforeRaw : finalRaw;
    if (nextRaw == caretRaw) return false;
    g_noteNormalCaret = static_cast<DWORD>(nextRaw);
    g_noteNormalPreferredX = -1;
    return true;
}

static bool MoveRenderedNormalCaretWordBackward() {
    if (!g_hNoteEdit) return false;
    std::vector<NoteVisibleUnit> units;
    if (!BuildNoteVisibleUnits(&units, nullptr)) return false;

    size_t caretRaw = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    int idx = static_cast<int>(units.size()) - 1;
    while (idx >= 0 && units[static_cast<size_t>(idx)].afterRaw > caretRaw) {
        --idx;
    }
    while (idx >= 0 && units[static_cast<size_t>(idx)].separator) {
        --idx;
    }
    if (idx < 0) return false;
    while (idx > 0 && !units[static_cast<size_t>(idx - 1)].separator) {
        --idx;
    }

    size_t nextRaw = units[static_cast<size_t>(idx)].beforeRaw;
    if (nextRaw == caretRaw) return false;
    g_noteNormalCaret = static_cast<DWORD>(nextRaw);
    g_noteNormalPreferredX = -1;
    return true;
}

static bool MoveRenderedNormalCaretWordEnd() {
    if (!g_hNoteEdit) return false;
    std::vector<NoteVisibleUnit> units;
    size_t finalRaw = 0;
    if (!BuildNoteVisibleUnits(&units, &finalRaw)) return false;

    size_t caretRaw = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    size_t idx = FindVisibleUnitIndexAfterCaret(units, caretRaw);
    while (idx < units.size() && units[idx].separator) {
        ++idx;
    }
    if (idx >= units.size()) {
        if (caretRaw < finalRaw) {
            g_noteNormalCaret = static_cast<DWORD>(finalRaw);
            g_noteNormalPreferredX = -1;
            return true;
        }
        return false;
    }

    while (idx + 1 < units.size() && !units[idx + 1].separator) {
        ++idx;
    }

    size_t nextRaw = units[idx].afterRaw;
    if (nextRaw == caretRaw) return false;
    g_noteNormalCaret = static_cast<DWORD>(nextRaw);
    g_noteNormalPreferredX = -1;
    return true;
}

static bool BuildRenderedBoundariesForLine(HWND hWnd, HDC hdc, int lineIndex,
                                           std::vector<RenderBoundary>* out) {
    if (!hWnd || !hdc || !out) return false;
    out->clear();
    if (!CanReadStableRenderDerivedState()) return false;
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    int lineCount = NoteLineCount();
    if (lineCount <= 0) return false;
    lineIndex = std::clamp(lineIndex, 0, lineCount - 1);
    if (lineIndex >= static_cast<int>(g_lineCache.size())) return false;

    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    size_t lineStart = 0;
    size_t lineEnd = 0;
    if (IsNoteRenderActive()) {
        logicalStarts = GetNoteLogicalLineStarts(hWnd, &indexingText);
        if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, lineIndex, &lineStart, &lineEnd, nullptr)) {
            return false;
        }
    } else {
        LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(lineIndex), 0);
        if (lineStartRes < 0) return false;
        LRESULT lineLenRes = SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineStartRes), 0);
        if (lineLenRes < 0) lineLenRes = 0;
        lineStart = static_cast<size_t>(lineStartRes);
        lineEnd = lineStart + static_cast<size_t>(lineLenRes);
    }

    POINT linePos{};
    if (!GetCharPos(hWnd, lineStart, &linePos)) return false;

    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return false;
    int spaceW = fonts.spaceWidth;
    if (spaceW <= 0) spaceW = fonts.baseMetrics.tmAveCharWidth;
    if (spaceW <= 0) spaceW = 1;
    int indentPx = spaceW * ResolveLineIndent(g_lineCache[static_cast<size_t>(lineIndex)]);
    int baseX = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x) + indentPx;
    int runX = 0;
    const int baseFontHeight = std::max<int>(1, static_cast<int>(fonts.baseMetrics.tmHeight));
    const int clientW = layoutFrame.clientWidthPx;
    const int anchorScrollX = NoteLayoutFrameAnchorScrollX(layoutFrame, hWnd);

    out->push_back({lineStart, baseX});

    const LineCache& cache = g_lineCache[static_cast<size_t>(lineIndex)];
    for (size_t segIndex = 0; segIndex < cache.segments.size(); ++segIndex) {
        const auto& seg = cache.segments[segIndex];
        if (seg.text.empty()) continue;
        std::vector<int> textPrefix;
        bool measureAsMath = false;
        int segWidth = MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseFontHeight, &textPrefix, &measureAsMath);
        std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
        int segBaseX = baseX + runX;
        if (SegmentUsesAnchoredLayout(seg)) {
            int offsetPx = seg.style.anchorOffsetChars * spaceW;
            int anchoredRunWidth = MeasureAnchoredRunWidth(hdc, fonts, cache, segIndex, baseFontHeight);
            segBaseX = ComputeAnchoredRunStartX(hWnd, clientW, anchorScrollX,
                                                seg.style.anchor, offsetPx, anchoredRunWidth);
            for (size_t prev = segIndex; prev > 0; --prev) {
                const auto& prevSeg = cache.segments[prev - 1];
                if (!SameAnchoredLayout(prevSeg, seg)) break;
                if (prevSeg.text.empty()) continue;
                segBaseX += MeasureRenderedSegmentWidth(hdc, fonts, cache, prevSeg, baseFontHeight, nullptr, nullptr);
            }
        }
        for (size_t i = 1; i <= seg.text.size(); ++i) {
            int prefixW = segWidth;
            if (measureAsMath) {
                if (!seg.text.empty()) {
                    prefixW = static_cast<int>(std::lround(static_cast<double>(segWidth) * i /
                                                           static_cast<double>(seg.text.size())));
                }
            } else {
                if (i > textPrefix.size()) {
                    prefixW = segWidth;
                } else {
                    prefixW = (i == 0) ? 0 : textPrefix[i - 1];
                }
            }
            size_t raw = lineStart + seg.rawStart + RawOffsetForVisibleCharCount(
                rawSeg, i, SegmentDecodesMarkdownBackslashEscapes(cache, seg));
            raw = std::min(raw, lineEnd);
            int x = segBaseX + prefixW;
            if (!out->empty() && out->back().raw == raw) {
                out->back().x = x;
            } else {
                out->push_back({raw, x});
            }
        }
        if (!SegmentUsesAnchoredLayout(seg)) runX += segWidth;
    }

    if (out->empty() || out->back().raw != lineEnd) {
        out->push_back({lineEnd, baseX + runX});
    }
    return !out->empty();
}

static int FindLineForRaw(size_t raw) {
    const HWND hWnd = CurrentNoteViewContextWindow();
    if (!hWnd) return 0;
    size_t clamped = ClampNoteRawIndex(raw);
    if (IsNoteRenderActive()) {
        return std::clamp(FindLogicalLineForRaw(GetNoteLogicalLineStarts(hWnd), clamped),
                          0, std::max(0, NoteLineCount() - 1));
    }
    LRESULT lineRes = SendMessageW(hWnd, EM_LINEFROMCHAR, static_cast<WPARAM>(clamped), 0);
    int lineCount = NoteLineCount();
    int line = (lineRes >= 0) ? static_cast<int>(lineRes) : 0;
    return std::clamp(line, 0, std::max(0, lineCount - 1));
}

static int FindBoundaryIndexAtOrBefore(const std::vector<RenderBoundary>& b, size_t raw) {
    if (b.empty()) return -1;
    size_t idx = 0;
    while (idx + 1 < b.size() && b[idx + 1].raw <= raw) ++idx;
    return static_cast<int>(idx);
}

static int FindBoundaryIndexNearestRaw(const std::vector<RenderBoundary>& b, size_t raw) {
    if (b.empty()) return -1;
    int prev = FindBoundaryIndexAtOrBefore(b, raw);
    if (prev < 0) return 0;
    if (prev + 1 >= static_cast<int>(b.size())) return prev;
    size_t dPrev = (raw >= b[static_cast<size_t>(prev)].raw)
        ? (raw - b[static_cast<size_t>(prev)].raw)
        : (b[static_cast<size_t>(prev)].raw - raw);
    size_t dNext = (b[static_cast<size_t>(prev + 1)].raw >= raw)
        ? (b[static_cast<size_t>(prev + 1)].raw - raw)
        : (raw - b[static_cast<size_t>(prev + 1)].raw);
    return (dNext < dPrev) ? (prev + 1) : prev;
}

static void InvalidateNoteNormalStateViews() {
    if (g_hNoteEdit) InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
}

static std::pair<size_t, size_t> NoteNormalSelectionRange() {
    size_t a = ClampNoteRawIndex(g_noteNormalVisualAnchor);
    size_t b = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    if (b < a) std::swap(a, b);
    return {a, b};
}

static bool IsNoteNormalVisualActive() {
    return g_noteNormalVisualMode;
}

bool ClearNoteNormalVisualMode() {
    if (!g_noteNormalVisualMode) return false;
    g_noteNormalVisualMode = false;
    SyncNoteNormalSelectionToEdit();
    UpdateNotePreviewFromEdit(g_hNoteEdit);
    InvalidateNoteNormalStateViews();
    return true;
}

bool ClearNoteNormalPendingState() {
    bool hadPending = g_noteNormalPendingCount != 0
        || g_noteNormalPendingG || g_noteNormalPendingY
        || g_noteNormalPendingD || g_noteNormalPendingC;
    g_noteNormalPendingCount = 0;
    g_noteNormalPendingG = false;
    g_noteNormalPendingY = false;
    g_noteNormalPendingD = false;
    g_noteNormalPendingC = false;
    InvalidateNoteNormalStateViews();
    return hadPending;
}

static void SyncNoteNormalSelectionToEdit() {
    if (!g_hNoteEdit) return;
    size_t caret = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    if (g_noteNormalVisualMode) {
        auto range = NoteNormalSelectionRange();
        SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(range.first), static_cast<LPARAM>(range.second));
    } else {
        SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(caret), static_cast<LPARAM>(caret));
    }
}

static bool IsNoteNormalModeRawDisplayLine(int line) {
    if (line < 0) return false;
    if (!IsNoteRenderActive()) return true;
    if (g_noteNormalVisualMode) return false;
    if (!g_noteVimCaretLineRawTextVisible) return false;
    if (g_linkPending.active && !g_linkPending.id.empty() &&
        IsRenderInsertGraceActiveForLine(line)) {
        return false;
    }
    int caretLine = FindLineForRaw(static_cast<size_t>(g_noteNormalCaret));
    return line == caretLine;
}

static size_t ResolveNoteNormalModeMouseHitIndex(HWND hWnd, LPARAM lParam, DWORD fallbackSelEnd) {
    std::optional<size_t> markupHit;
    if (IsNoteRenderActive()) {
        markupHit = HitTestMarkupPosition(hWnd, GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam));
    }

    int charIdx = GetCharIndexFromPos(hWnd, lParam);
    int hitLine = -1;
    if (markupHit) {
        hitLine = FindLineForRaw(*markupHit);
    } else if (charIdx >= 0) {
        hitLine = FindLineForRaw(static_cast<size_t>(charIdx));
    }

    const bool rawLike = !IsNoteRenderActive() || IsNoteNormalModeRawDisplayLine(hitLine);
    size_t hitIdx = static_cast<size_t>(-1);
    if (!rawLike && markupHit) {
        hitIdx = *markupHit;
    } else if (charIdx >= 0) {
        hitIdx = static_cast<size_t>(charIdx);
    } else if (markupHit) {
        hitIdx = *markupHit;
    } else {
        hitIdx = static_cast<size_t>(fallbackSelEnd);
    }
    return ClampNoteRawIndex(hitIdx);
}

static bool HandleNoteNormalModeMouseDown(HWND hWnd, LPARAM lParam) {
    if (!hWnd || !(g_noteVimModeEnabled && g_noteNormalMode)) {
        return false;
    }

    g_notePendingLinkClickDown = { GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam) };
    g_notePendingLinkClickInsert = false;
    g_noteRenderSelecting = false;
    if (GetCapture() == hWnd) {
        ReleaseCapture();
    }
    g_notePendingCaretIdx = static_cast<size_t>(-1);
    ClearNoteLinkRenderGrace(hWnd);

    DWORD selStart = 0, selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));

    size_t hitIdx = ResolveNoteNormalModeMouseHitIndex(hWnd, lParam, selEnd);

    if (g_noteVimClickEntersInsertMode) {
        g_noteNormalCaret = static_cast<DWORD>(hitIdx);
        g_noteNormalMode = false;
        OnExitNoteNormalMode();
        SendMessageW(hWnd, EM_SETSEL, static_cast<WPARAM>(hitIdx), static_cast<LPARAM>(hitIdx));
        SendMessageW(hWnd, EM_SCROLLCARET, 0, 0);
        UpdateNotePreviewFromEdit(hWnd);
        InvalidateNoteNormalStateViews();
        SetFocus(hWnd);
        return true;
    }

    g_noteNormalCaret = static_cast<DWORD>(hitIdx);
    g_noteNormalVisualMode = false;
    g_noteNormalPreferredX = -1;
    g_noteRenderSelecting = true;
    g_noteRenderSelectAnchor = hitIdx;
    g_noteNormalMouseDragActive = false;
    ClearNoteNormalPendingState();
    SyncNoteNormalSelectionToEdit();
    UpdateNotePreviewFromEdit(hWnd);
    InvalidateNoteNormalStateViews();
    SetFocus(hWnd);
    SetCapture(hWnd);
    return true;
}

static bool HandleNoteNormalModeMouseMove(HWND hWnd, WPARAM wParam, LPARAM lParam) {
    if (!hWnd || !(g_noteVimModeEnabled && g_noteNormalMode) || !g_noteRenderSelecting || !(wParam & MK_LBUTTON)) {
        return false;
    }

    POINT pt{ GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam) };
    int dx = std::abs(pt.x - g_notePendingLinkClickDown.x);
    int dy = std::abs(pt.y - g_notePendingLinkClickDown.y);
    int dragX = std::max<int>(1, GetSystemMetrics(SM_CXDRAG));
    int dragY = std::max<int>(1, GetSystemMetrics(SM_CYDRAG));
    if (!g_noteNormalMouseDragActive && dx <= dragX && dy <= dragY) {
        return true;
    }

    DWORD selStart = 0, selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    size_t hitIdx = ResolveNoteNormalModeMouseHitIndex(hWnd, lParam, selEnd);

    g_noteNormalMouseDragActive = true;
    g_noteNormalVisualMode = true;
    g_noteNormalVisualAnchor = g_noteRenderSelectAnchor;
    g_noteNormalCaret = static_cast<DWORD>(hitIdx);
    g_noteNormalPreferredX = -1;
    SyncNoteNormalSelectionToEdit();
    UpdateNotePreviewFromEdit(hWnd);
    InvalidateNoteNormalStateViews();
    return true;
}

static bool HandleNoteNormalModeMouseUp(HWND hWnd) {
    if (!hWnd || !(g_noteVimModeEnabled && g_noteNormalMode) || !g_noteRenderSelecting) {
        return false;
    }

    g_noteRenderSelecting = false;
    g_notePendingLinkClickInsert = false;
    g_notePendingCaretIdx = static_cast<size_t>(-1);
    if (GetCapture() == hWnd) {
        ReleaseCapture();
    }
    if (!g_noteNormalMouseDragActive) {
        g_noteNormalVisualMode = false;
        SyncNoteNormalSelectionToEdit();
    }
    g_noteNormalMouseDragActive = false;
    UpdateNotePreviewFromEdit(hWnd);
    InvalidateNoteNormalStateViews();
    return true;
}

static bool SetClipboardUnicodeText(HWND owner, const std::wstring& text) {
    HWND clipOwner = owner ? owner : g_hMainWnd;
    if (!OpenClipboard(clipOwner)) return false;
    EmptyClipboard();
    size_t bytes = (text.size() + 1) * sizeof(wchar_t);
    HGLOBAL hmem = GlobalAlloc(GMEM_MOVEABLE, bytes);
    if (!hmem) {
        CloseClipboard();
        return false;
    }
    void* p = GlobalLock(hmem);
    if (!p) {
        GlobalFree(hmem);
        CloseClipboard();
        return false;
    }
    memcpy(p, text.c_str(), bytes);
    GlobalUnlock(hmem);
    if (!SetClipboardData(CF_UNICODETEXT, hmem)) {
        GlobalFree(hmem);
        CloseClipboard();
        return false;
    }
    CloseClipboard();
    return true;
}

static std::optional<std::wstring> GetClipboardUnicodeText(HWND owner) {
    HWND clipOwner = owner ? owner : g_hMainWnd;
    if (!IsClipboardFormatAvailable(CF_UNICODETEXT)) return std::nullopt;
    if (!OpenClipboard(clipOwner)) return std::nullopt;
    HANDLE h = GetClipboardData(CF_UNICODETEXT);
    if (!h) {
        CloseClipboard();
        return std::nullopt;
    }
    const wchar_t* p = static_cast<const wchar_t*>(GlobalLock(h));
    if (!p) {
        CloseClipboard();
        return std::nullopt;
    }
    std::wstring text(p);
    GlobalUnlock(h);
    CloseClipboard();
    return text;
}

static bool MoveRenderedNormalCaretHorizontal(int delta) {
    if (!g_hNoteEdit || delta == 0) return false;
    int line = FindLineForRaw(static_cast<size_t>(g_noteNormalCaret));
    HDC hdc = GetDC(g_hNoteEdit);
    if (!hdc) return false;
    std::vector<RenderBoundary> boundaries;
    bool ok = BuildRenderedBoundariesForLine(g_hNoteEdit, hdc, line, &boundaries);
    ReleaseDC(g_hNoteEdit, hdc);
    if (!ok || boundaries.empty()) return false;

    size_t raw = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    int idx = FindBoundaryIndexAtOrBefore(boundaries, raw);
    if (idx < 0) return false;

    size_t nextRaw = raw;
    if (delta < 0) {
        if (boundaries[static_cast<size_t>(idx)].raw < raw) {
            nextRaw = boundaries[static_cast<size_t>(idx)].raw;
        } else if (idx > 0) {
            nextRaw = boundaries[static_cast<size_t>(idx - 1)].raw;
        } else {
            return false;
        }
    } else {
        int nextIdx = idx;
        if (boundaries[static_cast<size_t>(idx)].raw <= raw) ++nextIdx;
        if (nextIdx >= static_cast<int>(boundaries.size())) return false;
        nextRaw = boundaries[static_cast<size_t>(nextIdx)].raw;
    }
    if (nextRaw == raw) return false;
    g_noteNormalCaret = static_cast<DWORD>(nextRaw);
    g_noteNormalPreferredX = -1;
    return true;
}

static bool MoveRenderedNormalCaretVertical(int delta) {
    if (!g_hNoteEdit || delta == 0) return false;
    int lineCount = NoteLineCount();
    if (lineCount <= 0) return false;
    int currentLine = FindLineForRaw(static_cast<size_t>(g_noteNormalCaret));
    int targetLine = std::clamp(currentLine + delta, 0, lineCount - 1);
    if (targetLine == currentLine) return false;

    HDC hdc = GetDC(g_hNoteEdit);
    if (!hdc) return false;
    std::vector<RenderBoundary> currentBoundaries;
    std::vector<RenderBoundary> targetBoundaries;
    bool okCurrent = BuildRenderedBoundariesForLine(g_hNoteEdit, hdc, currentLine, &currentBoundaries);
    bool okTarget = BuildRenderedBoundariesForLine(g_hNoteEdit, hdc, targetLine, &targetBoundaries);
    ReleaseDC(g_hNoteEdit, hdc);
    if (!okCurrent || !okTarget || currentBoundaries.empty() || targetBoundaries.empty()) return false;

    size_t raw = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    int curIdx = FindBoundaryIndexNearestRaw(currentBoundaries, raw);
    if (curIdx < 0) return false;
    int desiredX = g_noteNormalPreferredX;
    if (desiredX < 0) {
        desiredX = currentBoundaries[static_cast<size_t>(curIdx)].x;
        g_noteNormalPreferredX = desiredX;
    }

    int bestIdx = 0;
    int bestDist = std::abs(targetBoundaries[0].x - desiredX);
    for (int i = 1; i < static_cast<int>(targetBoundaries.size()); ++i) {
        int dist = std::abs(targetBoundaries[static_cast<size_t>(i)].x - desiredX);
        if (dist < bestDist) {
            bestDist = dist;
            bestIdx = i;
        }
    }
    size_t nextRaw = targetBoundaries[static_cast<size_t>(bestIdx)].raw;
    if (nextRaw == raw) return false;
    g_noteNormalCaret = static_cast<DWORD>(nextRaw);
    return true;
}

static bool MoveRenderedNormalCaretToLine(int lineOneBased) {
    if (!g_hNoteEdit) return false;
    int lineCount = NoteLineCount();
    if (lineCount <= 0) return false;
    int targetLine = std::clamp(lineOneBased - 1, 0, lineCount - 1);

    HDC hdc = GetDC(g_hNoteEdit);
    if (!hdc) return false;
    std::vector<RenderBoundary> boundaries;
    bool ok = BuildRenderedBoundariesForLine(g_hNoteEdit, hdc, targetLine, &boundaries);
    ReleaseDC(g_hNoteEdit, hdc);
    if (!ok || boundaries.empty()) return false;

    size_t nextRaw = boundaries.front().raw;
    size_t curRaw = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    g_noteNormalCaret = static_cast<DWORD>(nextRaw);
    g_noteNormalPreferredX = -1;
    return nextRaw != curRaw;
}

static std::wstring ExtractRenderedLineText(int lineIndex) {
    if (!CanReadStableRenderDerivedState()) return L"";
    if (lineIndex < 0 || lineIndex >= static_cast<int>(g_lineCache.size())) return L"";
    std::wstring out;
    for (const auto& seg : g_lineCache[static_cast<size_t>(lineIndex)].segments) {
        if (!seg.text.empty()) out.append(seg.text);
    }
    return out;
}

static std::wstring ExtractRenderedTextRange(size_t rawStart, size_t rawEnd) {
    if (!g_hNoteEdit) return L"";
    if (!CanReadStableRenderDerivedState()) return L"";
    rawStart = ClampNoteRawIndex(rawStart);
    rawEnd = ClampNoteRawIndex(rawEnd);
    if (rawEnd < rawStart) std::swap(rawStart, rawEnd);
    if (rawStart == rawEnd) return L"";

    std::wstring out;
    int lineCount = NoteLineCount();
    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    if (IsNoteRenderActive()) {
        logicalStarts = GetNoteLogicalLineStarts(g_hNoteEdit, &indexingText);
    }
    for (int line = 0; line < lineCount; ++line) {
        if (line >= static_cast<int>(g_lineCache.size())) break;
        size_t lineStart = 0;
        size_t lineEnd = 0;
        size_t nextLineStart = 0;
        if (IsNoteRenderActive()) {
            if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, line,
                                               &lineStart, &lineEnd, &nextLineStart)) {
                continue;
            }
        } else {
            LRESULT lineStartRes = SendMessageW(g_hNoteEdit, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineStartRes < 0) continue;
            LRESULT lineLenRes = SendMessageW(g_hNoteEdit, EM_LINELENGTH, static_cast<WPARAM>(lineStartRes), 0);
            if (lineLenRes < 0) lineLenRes = 0;
            lineStart = static_cast<size_t>(lineStartRes);
            lineEnd = lineStart + static_cast<size_t>(lineLenRes);
            nextLineStart = lineEnd;
            if (line + 1 < lineCount) {
                LRESULT nextStartRes = SendMessageW(g_hNoteEdit, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
                if (nextStartRes >= 0) nextLineStart = static_cast<size_t>(nextStartRes);
            }
        }

        if (rawEnd <= lineStart) break;
        if (rawStart >= nextLineStart) continue;

        size_t segSelStart = std::max(rawStart, lineStart);
        size_t segSelEnd = std::min(rawEnd, lineEnd);
        if (segSelEnd > segSelStart) {
            const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
            for (const auto& seg : cache.segments) {
                if (seg.text.empty()) continue;
                size_t segStart = lineStart + seg.rawStart;
                size_t segEnd = segStart + SegmentRawLen(seg);
                size_t partStart = std::max(segSelStart, segStart);
                size_t partEnd = std::min(segSelEnd, segEnd);
                if (partEnd > partStart) {
                    std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
                    const bool decodeEscapes = SegmentDecodesMarkdownBackslashEscapes(cache, seg);
                    size_t visStart = VisibleCharsBeforeRawOffset(rawSeg, partStart - segStart, decodeEscapes);
                    size_t visEnd = VisibleCharsBeforeRawOffset(rawSeg, partEnd - segStart, decodeEscapes);
                    if (visEnd > visStart) {
                        out.append(seg.text.substr(visStart, visEnd - visStart));
                    }
                }
            }
        }

        if (rawEnd > lineEnd && rawStart < nextLineStart && line + 1 < lineCount) {
            out.append(L"\r\n");
        }
    }
    return out;
}

static bool PasteClipboardTextAtNormalCaret(HWND owner) {
    if (!g_hNoteEdit) return false;
    ReleaseNoteChangeSuppressionForUserEdit();
    auto clip = GetClipboardUnicodeText(owner);
    if (!clip || clip->empty()) return false;

    size_t caret = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    size_t selStart = caret;
    size_t selEnd = caret;
    if (g_noteNormalVisualMode) {
        auto range = NoteNormalSelectionRange();
        selStart = range.first;
        selEnd = range.second;
    }
    SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(selStart), static_cast<LPARAM>(selEnd));
    {
        const std::wstring normalized = NormalizeTextForNoteIndexing(*clip);
        const DWORD after = static_cast<DWORD>(
            std::min<size_t>(selStart + normalized.size(), static_cast<size_t>(std::numeric_limits<DWORD>::max())));
        RegisterExpectedCurrentNoteSelectionReplacement(g_hNoteEdit, *clip, after, after);
    }
    SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(clip->c_str()));

    DWORD newStart = 0, newEnd = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL, reinterpret_cast<WPARAM>(&newStart), reinterpret_cast<LPARAM>(&newEnd));
    g_noteNormalCaret = newEnd;
    g_noteNormalVisualMode = false;
    g_noteNormalPreferredX = -1;
    SyncNoteNormalSelectionToEdit();
    UpdateNotePreviewFromEdit(g_hNoteEdit);
    return true;
}

void OnEnterNoteNormalMode() {
    g_noteNormalVisualMode = false;
    g_noteNormalVisualAnchor = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    g_noteNormalPreferredX = -1;
    g_noteNormalPendingY = false;
    g_noteNormalPendingD = false;
    g_noteNormalPendingC = false;
    g_noteNormalPendingG = false;
    g_noteNormalPendingCount = 0;
    g_noteNormalCaret = static_cast<DWORD>(ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret)));
    if (g_hNoteEdit) {
        int line = FindLineForRaw(static_cast<size_t>(g_noteNormalCaret));
        HDC hdc = GetDC(g_hNoteEdit);
        if (hdc) {
            std::vector<RenderBoundary> boundaries;
            if (BuildRenderedBoundariesForLine(g_hNoteEdit, hdc, line, &boundaries) && !boundaries.empty()) {
                int idx = FindBoundaryIndexNearestRaw(boundaries, static_cast<size_t>(g_noteNormalCaret));
                if (idx >= 0) {
                    g_noteNormalCaret = static_cast<DWORD>(boundaries[static_cast<size_t>(idx)].raw);
                }
            }
            ReleaseDC(g_hNoteEdit, hdc);
        }
    }
    SyncNoteNormalSelectionToEdit();
    InvalidateNoteNormalStateViews();
}

void OnExitNoteNormalMode() {
    g_noteNormalVisualMode = false;
    g_noteNormalPreferredX = -1;
    g_noteNormalPendingY = false;
    g_noteNormalPendingD = false;
    g_noteNormalPendingC = false;
    g_noteNormalPendingG = false;
    g_noteNormalPendingCount = 0;
}

enum class NoteNormalInsertKind {
    KeepPositionPreferBeforeTags, // "i"
    KeepPositionPreferAfterTags,  // "a"
    AppendLineEnd                 // "A"
};

static bool FindHiddenTagGapAtLocalPos(const LineCache& cache,
                                      size_t localPos,
                                      size_t* outGapStart,
                                      size_t* outGapEnd) {
    if (!outGapStart || !outGapEnd) return false;
    localPos = std::min(localPos, cache.rawLine.size());

    // Segments cover rendered (visible) content. Any gap between segment ends and the next segment start
    // corresponds to markup tags that are hidden in render mode.
    size_t prevEnd = 0;
    size_t nextStart = cache.rawLine.size();
    for (const auto& seg : cache.segments) {
        size_t segStart = seg.rawStart;
        size_t segEnd = seg.rawStart + SegmentRawLen(seg);
        if (segEnd > cache.rawLine.size()) segEnd = cache.rawLine.size();

        if (localPos < segStart) {
            nextStart = segStart;
            break;
        }
        if (localPos >= segStart && localPos < segEnd) {
            return false; // inside visible content
        }
        if (segEnd >= prevEnd) prevEnd = segEnd;
    }

    if (prevEnd >= nextStart) return false;
    if (!(localPos >= prevEnd && localPos < nextStart)) return false;

    // Sanity: hidden gaps should start with a tag opener in the raw line.
    if (prevEnd >= cache.rawLine.size() || cache.rawLine[prevEnd] != L'<') return false;

    *outGapStart = prevEnd;
    *outGapEnd = nextStart;
    return true;
}

static void PrepareNoteInsertCaretFromNormal(NoteNormalInsertKind kind) {
    if (!g_hNoteEdit) return;
    size_t rawAbs = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    int line = FindLineForRaw(rawAbs);
    if (line < 0 || line >= static_cast<int>(g_lineCache.size())) return;
    size_t lineStart = 0;
    if (IsNoteRenderActive()) {
        std::wstring indexingText;
        std::vector<size_t> logicalStarts = GetNoteLogicalLineStarts(g_hNoteEdit, &indexingText);
        if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, line, &lineStart, nullptr, nullptr)) {
            return;
        }
    } else {
        LRESULT lineStartRes = SendMessageW(g_hNoteEdit, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
        if (lineStartRes < 0) return;
        lineStart = static_cast<size_t>(lineStartRes);
    }
    const LineCache& cache = g_lineCache[static_cast<size_t>(line)];

    size_t localPos = (rawAbs >= lineStart) ? (rawAbs - lineStart) : 0;
    if (localPos > cache.rawLine.size()) localPos = cache.rawLine.size();

    if (kind == NoteNormalInsertKind::AppendLineEnd) {
        // Append-line-end shortcut: go to the physical end of the raw line (after trailing tags like "</h1>").
        localPos = cache.rawLine.size();
        g_noteNormalCaret = static_cast<DWORD>(lineStart + localPos);
        return;
    }

    size_t gapStart = 0, gapEnd = 0;
    if (FindHiddenTagGapAtLocalPos(cache, localPos, &gapStart, &gapEnd)) {
        if (kind == NoteNormalInsertKind::KeepPositionPreferAfterTags && localPos == gapStart) {
            localPos = gapEnd;
        } else if (kind == NoteNormalInsertKind::KeepPositionPreferBeforeTags) {
            localPos = gapStart;
        }
    }

    g_noteNormalCaret = static_cast<DWORD>(lineStart + localPos);
}

static std::wstring ToLowerCopy(std::wstring s) {
    for (wchar_t& ch : s) {
        ch = static_cast<wchar_t>(std::towlower(ch));
    }
    return s;
}

static bool FindNoteSearchMatch(const std::wstring& textLower, const std::wstring& patLower,
                                size_t originRaw, bool forward, bool includeOrigin, size_t* outPos) {
    if (!outPos) return false;
    if (patLower.empty() || textLower.empty()) return false;

    const size_t n = textLower.size();
    originRaw = std::min(originRaw, n);

    if (forward) {
        const size_t searchStart = includeOrigin ? originRaw : std::min(n, originRaw + 1);
        size_t pos = textLower.find(patLower, searchStart);
        if (pos != std::wstring::npos) {
            *outPos = pos;
            return true;
        }
        pos = textLower.find(patLower, 0); // wrap
        if (pos != std::wstring::npos && pos < searchStart) {
            *outPos = pos;
            return true;
        }
        return false;
    }

    const size_t last = n - 1;
    bool hasFirstRange = true;
    size_t firstFrom = 0;
    if (includeOrigin) {
        firstFrom = std::min(originRaw, last);
    } else if (originRaw == 0) {
        hasFirstRange = false;
    } else {
        firstFrom = std::min(originRaw - 1, last);
    }

    if (hasFirstRange) {
        size_t pos = textLower.rfind(patLower, firstFrom);
        if (pos != std::wstring::npos) {
            *outPos = pos;
            return true;
        }
    }

    size_t pos = textLower.rfind(patLower, last); // wrap
    if (pos != std::wstring::npos && (!hasFirstRange || pos > firstFrom)) {
        *outPos = pos;
        return true;
    }
    return false;
}

static bool IsNoteEditSelectionExactly(size_t start, size_t end) {
    if (!g_hNoteEdit) return false;
    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    return static_cast<size_t>(selStart) == start && static_cast<size_t>(selEnd) == end;
}

static void ClearSearchHitHighlight(bool collapseSelectionIfStillOnHit) {
    if (!g_noteSearchHitActive) return;
    const size_t oldStart = g_noteSearchHitStart;
    const size_t oldEnd = g_noteSearchHitEnd;
    g_noteSearchHitActive = false;
    g_noteSearchHitStart = 0;
    g_noteSearchHitEnd = 0;
    g_noteSearchHitFromSearchWindow = false;

    if (collapseSelectionIfStillOnHit && g_hNoteEdit) {
        if (IsNoteEditSelectionExactly(oldStart, oldEnd)) {
            size_t caret = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
            SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(caret), static_cast<LPARAM>(caret));
        }
    }
    InvalidateNoteNormalStateViews();
}

void SetNoteSearchResultMarker(size_t start, size_t end) {
    if (end <= start) return;
    const size_t safeStart = ClampNoteRawIndex(start);
    const size_t safeEnd = ClampNoteRawIndex(end);
    if (safeEnd <= safeStart) return;
    g_noteSearchHitActive = true;
    g_noteSearchHitStart = safeStart;
    g_noteSearchHitEnd = safeEnd;
    g_noteSearchHitFromSearchWindow = true;
    g_noteNormalCaret = static_cast<DWORD>(
        std::min<size_t>(safeStart, static_cast<size_t>(std::numeric_limits<DWORD>::max())));
    if (g_hNoteEdit && IsWindow(g_hNoteEdit)) {
        SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(safeStart), static_cast<LPARAM>(safeEnd));
        SendMessageW(g_hNoteEdit, EM_SCROLLCARET, 0, 0);
    }
    InvalidateNoteNormalStateViews();
}

void ClearNoteSearchResultMarker() {
    if (!g_noteSearchHitFromSearchWindow) return;
    ClearSearchHitHighlight(true);
}

static bool JumpToNoteSearchResult(HWND owner, const std::wstring& pattern, bool forward,
                                   bool includeOrigin, bool updateSearchCommand = true) {
    if (!g_hNoteEdit) return false;
    std::wstring pat = TrimWhitespace(pattern);
    if (pat.empty()) return false;

    std::wstring text = GetEditTextForIndexing(g_hNoteEdit);
    if (text.empty()) return false;

    std::wstring textLower = ToLowerCopy(text);
    std::wstring patLower = ToLowerCopy(pat);

    size_t origin = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
    if (!includeOrigin && g_noteSearchHitActive) {
        origin = std::min(g_noteSearchHitStart, textLower.size());
    }

    size_t pos = 0;
    if (!FindNoteSearchMatch(textLower, patLower, origin, forward, includeOrigin, &pos)) {
        return false;
    }

    g_noteNormalPendingCount = 0;
    g_noteNormalPendingG = false;
    g_noteNormalPendingY = false;
    g_noteNormalPendingD = false;
    g_noteNormalPendingC = false;
    g_noteNormalVisualMode = false;
    g_noteNormalPreferredX = -1;

    g_noteNormalCaret = static_cast<DWORD>(pos);
    SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(pos), static_cast<LPARAM>(pos));
    SendMessageW(g_hNoteEdit, EM_SCROLLCARET, 0, 0);
    InvalidateNoteNormalStateViews();

    g_noteSearchHitActive = true;
    g_noteSearchHitStart = pos;
    g_noteSearchHitEnd = pos + pat.size();
    g_noteSearchHitFromSearchWindow = false;

    g_noteLastSearchPattern = pat;
    if (updateSearchCommand) {
        g_noteLastSearchForward = forward;
    }
    (void)owner;
    return true;
}

static void SyncNoteCmdlineBufferFromEdit() {
    if (!g_hNoteCmdlineEdit) return;
    std::wstring s = GetEditText(g_hNoteCmdlineEdit);
    if (s.size() > 180) s.resize(180);
    g_noteCmdlineBuffer = s;
}

static void SyncNoteCmdlineEditFromBuffer() {
    if (!g_hNoteCmdlineEdit || !IsWindow(g_hNoteCmdlineEdit)) return;
    std::wstring text = g_noteCmdlineBuffer;
    if (text.size() > 180) text.resize(180);
    SetWindowTextW(g_hNoteCmdlineEdit, text.c_str());
    int len = static_cast<int>(text.size());
    SendMessageW(g_hNoteCmdlineEdit, EM_SETSEL, len, len);
}

static std::wstring GetNoteCmdlineBufferSnapshot() {
    if (g_hNoteCmdlineEdit && IsWindow(g_hNoteCmdlineEdit)) {
        SyncNoteCmdlineBufferFromEdit();
    }
    return g_noteCmdlineBuffer;
}

static bool ExecuteNoteCmdlineSearch(HWND owner) {
    std::wstring pat = GetNoteCmdlineBufferSnapshot();
    if (!pat.empty()) {
        if (g_noteCmdlineHistory.empty() || g_noteCmdlineHistory.front() != pat) {
            g_noteCmdlineHistory.push_front(pat);
            if (g_noteCmdlineHistory.size() > 10) g_noteCmdlineHistory.pop_back();
        }
    }
    if (g_noteCmdlinePrompt == L':') {
        std::wstring cmd = TrimWhitespace(pat);
        if (cmd == L"w" || cmd == L"wq" || cmd == L"q" || cmd == L"q!") {
            if (cmd != L"q!") {
                SendMessageW(owner ? owner : g_hMainWnd, WM_COMMAND, ID_FILE_SAVE_NOTE, 0);
            }
            if (cmd == L"wq" || cmd == L"q" || cmd == L"q!") {
                if (g_currentNotePath.empty()) {
                    SendMessageW(g_hMainWnd, WM_CLOSE, 0, 0);
                } else {
                    ClearNoteEditorSilently(owner, L"");
                    if (g_hNoteList && IsWindow(g_hNoteList)) {
                        SetFocus(g_hNoteList);
                    }
                }
            }
        } else {
            bool isNumber = !cmd.empty() && std::all_of(cmd.begin(), cmd.end(), ::iswdigit);
            if (isNumber) {
                int line = std::stoi(cmd);
                if (line < 1) line = 1;
                int lineCount = static_cast<int>(SendMessageW(g_hNoteEdit, EM_GETLINECOUNT, 0, 0));
                if (line > lineCount) line = lineCount;
                LRESULT charIndex = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line - 1, 0);
                if (charIndex >= 0) {
                    g_noteNormalCaret = static_cast<DWORD>(charIndex);
                    SendMessageW(g_hNoteEdit, EM_SETSEL, charIndex, charIndex);
                    SendMessageW(g_hNoteEdit, EM_SCROLLCARET, 0, 0);
                    InvalidateNoteNormalStateViews();
                }
            } else if (cmd.size() >= 4 && (cmd.substr(0, 3) == L"%s/" || cmd.substr(0, 2) == L"s/")) {
                bool isGlobal = (cmd.substr(0, 3) == L"%s/");
                size_t startIdx = isGlobal ? 3 : 2;
                wchar_t delim = cmd[startIdx - 1];
                size_t first = cmd.find(delim, startIdx);
                if (first != std::wstring::npos) {
                    size_t second = cmd.find(delim, first + 1);
                    std::wstring search = cmd.substr(startIdx, first - startIdx);
                    std::wstring replace = (second != std::wstring::npos) ? cmd.substr(first + 1, second - first - 1) : cmd.substr(first + 1);
                    bool replaceAll = (second != std::wstring::npos && second + 1 < cmd.size() && cmd[second + 1] == L'g');

                    if (!search.empty() && g_hNoteEdit && IsWindow(g_hNoteEdit)) {
                        std::wstring text = GetEditText(g_hNoteEdit);
                        bool changed = false;
                        size_t pos = 0;
                        while ((pos = text.find(search, pos)) != std::wstring::npos) {
                            text.replace(pos, search.length(), replace);
                            pos += replace.length();
                            changed = true;
                            if (!replaceAll) break;
                        }
                        if (changed) {
                            ClearSearchHitHighlight(true);
                            SendMessageW(g_hNoteEdit, EM_SETSEL, 0, -1);
                            RegisterExpectedNoteTextEdit(g_hNoteEdit, 0, static_cast<DWORD>(GetWindowTextLengthW(g_hNoteEdit)), text.c_str(), 0, 0);
                            SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(text.c_str()));
                            SendMessageW(g_hNoteEdit, EM_SETSEL, 0, 0);
                            g_noteNormalCaret = 0;
                            SyncNoteNormalSelectionToEdit();
                            InvalidateNoteNormalStateViews();
                        } else {
                            SetNoteCmdlineFlash(IsEnglishUi() ? L"Pattern not found." : L"見つかりませんでした。");
                            CancelNoteCmdline();
                            return false;
                        }
                    }
                }
            }
        }
        CancelNoteCmdline();
        return true;
    }

    const bool typedNewPattern = !TrimWhitespace(pat).empty();
    if (!typedNewPattern) pat = g_noteLastSearchPattern;
    if (pat.empty()) {
        SetNoteCmdlineFlash(IsEnglishUi() ? L"Enter a search term." : L"検索語を入力してください。");
        CancelNoteCmdline();
        return false;
    }

    const bool forward = (g_noteCmdlinePrompt != L'?');
    DWORD startCaret = g_noteNormalCaret;
    bool isD = g_noteNormalPendingD;
    bool isC = g_noteNormalPendingC;
    bool isY = g_noteNormalPendingY;

    if (!JumpToNoteSearchResult(owner ? owner : g_hMainWnd, pat, forward, typedNewPattern, true)) {
        SetNoteCmdlineFlash(IsEnglishUi() ? L"Pattern not found." : L"見つかりませんでした。");
        CancelNoteCmdline();
        return false;
    }

    if (isD || isC) {
        PerformNoteNormalDelete(owner, startCaret, g_noteNormalCaret, isC);
    } else if (isY) {
        PerformNoteNormalYank(startCaret, g_noteNormalCaret);
        g_noteNormalCaret = startCaret;
        SyncNoteNormalSelectionToEdit();
        InvalidateNoteNormalStateViews();
    }

    CancelNoteCmdline();
    return true;
}

static void LayoutNoteCmdlineEdit(HWND hBottom, const RECT& barRc) {
    if (!hBottom || !g_hNoteCmdlineEdit) return;
    if (!g_noteVimModeEnabled || !g_noteNormalMode || !g_noteCmdlineActive) {
        ShowWindow(g_hNoteCmdlineEdit, SW_HIDE);
        return;
    }

    const int padX = ScaleY(hBottom, 8);
    const int promptW = ScaleY(hBottom, 16);
    const int barLeft = static_cast<int>(barRc.left);
    const int barRight = static_cast<int>(barRc.right);
    const int barTop = static_cast<int>(barRc.top);
    const int barBottom = static_cast<int>(barRc.bottom);
    const int barW = std::max<int>(0, barRight - barLeft);
    const int splitX = barLeft + (barW * 45) / 100;
    const int x = std::min(barRight, std::max(barLeft, splitX + padX + promptW));
    const int y = barTop + ScaleY(hBottom, 3);
    const int h = std::max<int>(1, (barBottom - barTop) - ScaleY(hBottom, 6));
    const int w = std::max<int>(1, barRight - x - padX);

    MoveWindow(g_hNoteCmdlineEdit, x, y, w, h, TRUE);
    ShowWindow(g_hNoteCmdlineEdit, SW_SHOWNA);
}

static LRESULT CALLBACK NoteCmdlineEditProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam,
                                            UINT_PTR, DWORD_PTR);

static void EnsureNoteCmdlineEdit(HWND hBottom) {
    if (!hBottom || !IsWindow(hBottom)) return;
    if (g_hNoteCmdlineEdit && IsWindow(g_hNoteCmdlineEdit)) return;

    g_hNoteCmdlineEdit = CreateWindowExW(0, L"EDIT", L"",
                                        WS_CHILD | WS_TABSTOP | ES_AUTOHSCROLL,
                                        0, 0, 1, 1,
                                        hBottom, nullptr, g_hInst, nullptr);
    if (!g_hNoteCmdlineEdit) return;

    SetUIFont(g_hNoteCmdlineEdit);
    SendMessageW(g_hNoteCmdlineEdit, EM_LIMITTEXT, 180, 0);
    SetWindowSubclass(g_hNoteCmdlineEdit, NoteCmdlineEditProc, 1, 0);
    ShowWindow(g_hNoteCmdlineEdit, SW_HIDE);
}

static LRESULT CALLBACK NoteCmdlineEditProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam,
                                            UINT_PTR, DWORD_PTR) {
    switch (msg) {
    case WM_KEYDOWN: {
        g_pendingCtrlInsertNavChar = 0;
        WPARAM navKey = 0;
        wchar_t suppressedChar = 0;
        if (ResolveCtrlInsertNavKey(hWnd, wParam, &navKey, &suppressedChar)) {
            g_pendingCtrlInsertNavChar = suppressedChar;
            if (IsNoteCmdlineImeComposing()) {
                ForwardImeNavigationKey(hWnd, navKey);
                return 0;
            }
            MoveEditCaretForInsertNav(hWnd, navKey);
            return 0;
        }
        if (wParam == VK_RETURN) {
            ExecuteNoteCmdlineSearch(g_hMainWnd);
            return 0;
        }
        if (wParam == VK_ESCAPE) {
            CancelNoteCmdline();
            return 0;
        }
        if (wParam == VK_UP || wParam == VK_DOWN) {
            if (!g_noteCmdlineHistory.empty()) {
                if (wParam == VK_UP) {
                    if (g_noteCmdlineHistoryIndex + 1 < static_cast<int>(g_noteCmdlineHistory.size())) {
                        g_noteCmdlineHistoryIndex++;
                        SetWindowTextW(hWnd, g_noteCmdlineHistory[g_noteCmdlineHistoryIndex].c_str());
                        int len = static_cast<int>(g_noteCmdlineHistory[g_noteCmdlineHistoryIndex].size());
                        SendMessageW(hWnd, EM_SETSEL, len, len);
                    }
                } else {
                    if (g_noteCmdlineHistoryIndex >= 0) {
                        g_noteCmdlineHistoryIndex--;
                        if (g_noteCmdlineHistoryIndex == -1) {
                            SetWindowTextW(hWnd, L"");
                        } else {
                            SetWindowTextW(hWnd, g_noteCmdlineHistory[g_noteCmdlineHistoryIndex].c_str());
                            int len = static_cast<int>(g_noteCmdlineHistory[g_noteCmdlineHistoryIndex].size());
                            SendMessageW(hWnd, EM_SETSEL, len, len);
                        }
                    }
                }
            }
            return 0;
        }
        MSG edgeNavMsg{};
        edgeNavMsg.hwnd = hWnd;
        edgeNavMsg.message = msg;
        edgeNavMsg.wParam = wParam;
        edgeNavMsg.lParam = lParam;
        if (ui::ConsumeNoOpEdgeNavKeyForMultilineEdit(edgeNavMsg)) return 0;
        break;
    }
    case WM_CHAR:
        if (g_pendingCtrlInsertNavChar != 0) {
            const wchar_t ch = static_cast<wchar_t>(wParam);
            const wchar_t suppressed = g_pendingCtrlInsertNavChar;
            g_pendingCtrlInsertNavChar = 0;
            if (ch == suppressed) {
                return 0;
            }
        }
        if (wParam == L'\r' || wParam == L'\n' || (!g_noteNormalMode && wParam == 27)) {
            return 0;
        }
        break;
    case WM_IME_COMPOSITION:
    case WM_IME_ENDCOMPOSITION:
    case WM_COMMAND:
        break;
    default:
        break;
    }

    LRESULT res = DefSubclassProc(hWnd, msg, wParam, lParam);

    if (msg == WM_CHAR || msg == WM_IME_COMPOSITION || msg == WM_IME_ENDCOMPOSITION) {
        SyncNoteCmdlineBufferFromEdit();
        if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
    return res;
}

static bool PerformNoteNormalDelete(HWND owner, DWORD startPos, DWORD endPos, bool enterInsert) {
    if (startPos > endPos) std::swap(startPos, endPos);
    if (startPos == endPos && !enterInsert) return false;
    ClearSearchHitHighlight(true);
    SendMessageW(g_hNoteEdit, EM_SETSEL, startPos, endPos);
    RegisterExpectedNoteTextEdit(g_hNoteEdit, startPos, endPos, L"", startPos, startPos);
    SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(L""));

    DWORD newStart = 0, newEnd = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL, reinterpret_cast<WPARAM>(&newStart), reinterpret_cast<LPARAM>(&newEnd));
    g_noteNormalCaret = newEnd;
    if (enterInsert) {
        PostMessageW(owner ? owner : g_hMainWnd, kMsgNoteEnterInsertMode, 0, 0);
    }
    SyncNoteNormalSelectionToEdit();
    InvalidateNoteNormalStateViews();
    return true;
}

static void PerformNoteNormalYank(DWORD startPos, DWORD endPos) {
    if (startPos > endPos) std::swap(startPos, endPos);
    if (startPos == endPos) return;
    SendMessageW(g_hNoteEdit, EM_SETSEL, startPos, endPos);
    SendMessageW(g_hNoteEdit, WM_COPY, 0, 0);
    g_noteNormalCaret = startPos;
    SyncNoteNormalSelectionToEdit();
    InvalidateNoteNormalStateViews();
}

bool HandleNoteNormalModeChar(HWND owner, wchar_t chRaw) {
    if (!g_noteVimModeEnabled || !g_noteNormalMode || !g_hNoteEdit) return false;

    if (g_noteCmdlineActive) {
        if (chRaw == L'\r' || chRaw == L'\n') {
            ExecuteNoteCmdlineSearch(owner);
            return true;
        }
        if (chRaw == L'\b') {
            if (!g_noteCmdlineBuffer.empty()) {
                g_noteCmdlineBuffer.pop_back();
                SyncNoteCmdlineEditFromBuffer();
                if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
            }
            return true;
        }
        if (chRaw == 27) {
            CancelNoteCmdline();
            return true;
        }
        if (chRaw >= 32 && chRaw != 127) {
            if (g_noteCmdlineBuffer.size() < 180) {
                g_noteCmdlineBuffer.push_back(chRaw);
                SyncNoteCmdlineEditFromBuffer();
                if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
            }
            return true;
        }
        return true;
    }
    if ((chRaw == L'\r' || chRaw == L'\n') && g_noteNormalVisualMode) {
        CopyNoteNormalVisualSelection(owner, false);
        return true;
    }
    if (chRaw == L'\r' || chRaw == L'\n') {
        ClearSearchHitHighlight(true);
        g_noteNormalPendingCount = 0;
        g_noteNormalPendingG = false;
        g_noteNormalPendingY = false;
        g_noteNormalPendingD = false;
        g_noteNormalPendingC = false;
        size_t caret = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
        if (auto linkId = LinkIdAtCharIndex(g_hNoteEdit, caret)) {
            HandleLinkIdJump(*linkId, owner ? owner : g_hMainWnd, g_currentNotePath, caret);
        }
        return true;
    }

    if (chRaw >= L'1' && chRaw <= L'9') {
        int digit = static_cast<int>(chRaw - L'0');
        if (g_noteNormalPendingCount > 100000000) {
            g_noteNormalPendingCount = 100000000;
        } else {
            g_noteNormalPendingCount = g_noteNormalPendingCount * 10 + digit;
        }
        return true;
    }
    if (chRaw == L'0' && g_noteNormalPendingCount > 0) {
        g_noteNormalPendingCount = g_noteNormalPendingCount * 10;
        return true;
    }

    bool handled = true;
    bool changed = false;
    auto consumeCount = [&]() -> int {
        int count = (g_noteNormalPendingCount > 0) ? g_noteNormalPendingCount : 1;
        g_noteNormalPendingCount = 0;
        return std::max(1, count);
    };

    if (chRaw != L'y') g_noteNormalPendingY = false;
    if (chRaw != L'g' && chRaw != L'G') g_noteNormalPendingG = false;
    if (chRaw != L'd') g_noteNormalPendingD = false;
    if (chRaw != L'c') g_noteNormalPendingC = false;

    switch (chRaw) {
    case L':':
    case L'/':
    case L'?': {
        ClearSearchHitHighlight(true);
        if (chRaw == L':') {
            g_noteNormalPendingCount = 0;
            g_noteNormalPendingG = false;
            g_noteNormalPendingY = false;
            g_noteNormalPendingD = false;
            g_noteNormalPendingC = false;
        }
        g_noteCmdlineActive = true;
        g_noteCmdlinePrompt = chRaw;
        g_noteCmdlineBuffer.clear();
        g_noteCmdlineHistoryIndex = -1;
        g_noteCmdlineFlash.clear();
        g_noteCmdlineFlashUntilTick = 0;
        EnsureNoteCmdlineEdit(g_hBottomNote);
        if (g_hNoteCmdlineEdit) {
            SetWindowTextW(g_hNoteCmdlineEdit, L"");
            SendMessageW(g_hNoteCmdlineEdit, EM_SETCUEBANNER, FALSE, reinterpret_cast<LPARAM>(L""));
            SendMessageW(g_hNoteCmdlineEdit, EM_SETSEL, 0, -1);
            SetFocus(g_hNoteCmdlineEdit);
        }
        if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
        return true;
    }
    case L'n':
    case L'N': {
        const int repeat = consumeCount();
        if (g_noteLastSearchPattern.empty()) {
            SetNoteCmdlineFlash(IsEnglishUi() ? L"No search history." : L"検索履歴がありません。");
            return true;
        }
        bool found = true;
        bool forward = (chRaw == L'n') ? g_noteLastSearchForward : !g_noteLastSearchForward;
        for (int i = 0; i < repeat; ++i) {
            if (!JumpToNoteSearchResult(owner ? owner : g_hMainWnd, g_noteLastSearchPattern,
                                        forward, false, false)) {
                found = false;
                break;
            }
        }
        if (!found) {
            SetNoteCmdlineFlash(IsEnglishUi() ? L"Pattern not found." : L"見つかりませんでした。");
        }
        return true;
    }
    case L'I':
    case L'i':
        ClearSearchHitHighlight(true);
        g_noteNormalPendingCount = 0;
        if (chRaw == L'I') {
            LRESULT line = SendMessageW(g_hNoteEdit, EM_LINEFROMCHAR, static_cast<WPARAM>(g_noteNormalCaret), 0);
            LRESULT start = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line, 0);
            if (start >= 0) g_noteNormalCaret = static_cast<DWORD>(start);
        }
        PrepareNoteInsertCaretFromNormal(NoteNormalInsertKind::KeepPositionPreferBeforeTags);
        PostMessageW(owner ? owner : g_hMainWnd, kMsgNoteEnterInsertMode, 0, 0);
        return true;
    case L'A':
    case L'a':
        ClearSearchHitHighlight(true);
        g_noteNormalPendingCount = 0;
        if (chRaw == L'A') {
            PrepareNoteInsertCaretFromNormal(NoteNormalInsertKind::AppendLineEnd);
        } else {
            PrepareNoteInsertCaretFromNormal(NoteNormalInsertKind::KeepPositionPreferAfterTags);
        }
        PostMessageW(owner ? owner : g_hMainWnd, kMsgNoteEnterInsertMode, 0, 0);
        return true;
    case L'O':
    case L'o': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        repeat = std::clamp(repeat, 1, 1000);
        ReleaseNoteChangeSuppressionForUserEdit();

        size_t caret = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
        int line = FindLineForRaw(caret);
        if (line < 0) line = 0;

        LRESULT insertPos = 0;
        if (chRaw == L'O') {
            LRESULT lineStartRes = SendMessageW(g_hNoteEdit, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineStartRes < 0) lineStartRes = 0;
            insertPos = lineStartRes;
        } else {
            LRESULT lineStartRes = SendMessageW(g_hNoteEdit, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineStartRes < 0) lineStartRes = 0;
            LRESULT lineLenRes = SendMessageW(g_hNoteEdit, EM_LINELENGTH, static_cast<WPARAM>(lineStartRes), 0);
            if (lineLenRes < 0) lineLenRes = 0;
            insertPos = lineStartRes + lineLenRes;
        }

        int textLen = GetWindowTextLengthW(g_hNoteEdit);
        if (textLen < 0) textLen = 0;
        insertPos = std::clamp<LRESULT>(insertPos, 0, static_cast<LRESULT>(textLen));

        std::wstring toInsert;
        toInsert.reserve(static_cast<size_t>(repeat) * 2);
        for (int i = 0; i < repeat; ++i) {
            toInsert.append(L"\r\n");
        }

        SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(insertPos), static_cast<LPARAM>(insertPos));
        RegisterExpectedCurrentNoteSelectionReplacement(
            g_hNoteEdit, toInsert,
            static_cast<DWORD>(insertPos + repeat),
            static_cast<DWORD>(insertPos + repeat));
        SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(toInsert.c_str()));

        if (chRaw == L'O') {
            g_noteNormalCaret = insertPos;
        } else {
            DWORD newStart = 0, newEnd = 0;
            SendMessageW(g_hNoteEdit, EM_GETSEL, reinterpret_cast<WPARAM>(&newStart), reinterpret_cast<LPARAM>(&newEnd));
            g_noteNormalCaret = newEnd;
        }

        g_noteNormalVisualMode = false;
        g_noteNormalPreferredX = -1;
        SyncNoteNormalSelectionToEdit();
        UpdateNotePreviewFromEdit(g_hNoteEdit);

        PostMessageW(owner ? owner : g_hMainWnd, kMsgNoteEnterInsertMode, 0, 0);
        return true;
    }
    case L'h': {
        ClearSearchHitHighlight(true);
        size_t caret = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));
        if (!g_noteNormalVisualMode && caret == 0 && g_hNoteList && IsWindow(g_hNoteList)) {
            g_noteNormalMode = false;
            OnExitNoteNormalMode();
            if (g_hNoteEdit) InvalidateRect(g_hNoteEdit, nullptr, FALSE);
            if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
            SetFocus(g_hNoteList);
            return true;
        }
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretHorizontal(-1)) break;
            changed = true;
        }
        break;
    }
    case L'l': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretHorizontal(+1)) break;
            changed = true;
        }
        break;
    }
    case L'j': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretVertical(+1)) break;
            changed = true;
        }
        break;
    }
    case L'k': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretVertical(-1)) break;
            changed = true;
        }
        break;
    }
    case L'w': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        DWORD startCaret = g_noteNormalCaret;
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretWordForward()) break;
            changed = true;
        }
        if (g_noteNormalPendingD || g_noteNormalPendingC) {
            bool isC = g_noteNormalPendingC;
            g_noteNormalPendingD = g_noteNormalPendingC = false;
            if (changed) {
                if (PerformNoteNormalDelete(owner, startCaret, g_noteNormalCaret, isC)) changed = true;
            }
        }
        break;
    }
    case L'b': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretWordBackward()) break;
            changed = true;
        }
        break;
    }
    case L'e': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!MoveRenderedNormalCaretWordEnd()) break;
            changed = true;
        }
        break;
    }
    case L'0':
    case L'^': {
        ClearSearchHitHighlight(true);
        LRESULT line = SendMessageW(g_hNoteEdit, EM_LINEFROMCHAR, static_cast<WPARAM>(g_noteNormalCaret), 0);
        LRESULT lineStart = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line, 0);
        if (lineStart >= 0) {
            g_noteNormalCaret = static_cast<DWORD>(lineStart);
            changed = true;
        }
        break;
    }
    case L'$': {
        ClearSearchHitHighlight(true);
        DWORD startCaret = g_noteNormalCaret;
        LRESULT line = SendMessageW(g_hNoteEdit, EM_LINEFROMCHAR, static_cast<WPARAM>(g_noteNormalCaret), 0);
        LRESULT lineStart = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line, 0);
        LRESULT lineLen = SendMessageW(g_hNoteEdit, EM_LINELENGTH, static_cast<WPARAM>(lineStart), 0);
        if (lineStart >= 0 && lineLen >= 0) {
            g_noteNormalCaret = static_cast<DWORD>(lineStart + lineLen);
            changed = true;
        }
        if (g_noteNormalPendingD || g_noteNormalPendingC) {
            bool isC = g_noteNormalPendingC;
            g_noteNormalPendingD = g_noteNormalPendingC = false;
            if (changed) {
                if (PerformNoteNormalDelete(owner, startCaret, g_noteNormalCaret, isC)) changed = true;
            }
        }
        break;
    }
    case L'g':
    case L'G':
        ClearSearchHitHighlight(true);
        if (chRaw == L'G') {
            int targetLine = (g_noteNormalPendingCount > 0) ? consumeCount() : NoteLineCount();
            changed = MoveRenderedNormalCaretToLine(targetLine);
            g_noteNormalPendingG = false;
        } else if (g_noteNormalPendingCount > 0) {
            int targetLine = consumeCount();
            changed = MoveRenderedNormalCaretToLine(targetLine);
            g_noteNormalPendingG = false;
        } else if (g_noteNormalPendingG) {
            g_noteNormalPendingG = false;
            changed = MoveRenderedNormalCaretToLine(1);
        } else {
            g_noteNormalPendingG = true;
        }
        break;
    case L'V':
    case L'v':
        ClearSearchHitHighlight(true);
        g_noteNormalPendingCount = 0;
        if (g_noteNormalVisualMode) {
            ClearNoteNormalVisualMode();
        } else {
            g_noteNormalVisualMode = true;
            g_noteNormalVisualAnchor = ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret));

            if (chRaw == L'V') {
                LRESULT line = SendMessageW(g_hNoteEdit, EM_LINEFROMCHAR, static_cast<WPARAM>(g_noteNormalCaret), 0);
                LRESULT lineStart = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line, 0);
                LRESULT lineLen = SendMessageW(g_hNoteEdit, EM_LINELENGTH, static_cast<WPARAM>(lineStart), 0);
                if (lineStart >= 0 && lineLen >= 0) {
                    g_noteNormalVisualAnchor = static_cast<size_t>(lineStart);
                    g_noteNormalCaret = static_cast<DWORD>(lineStart + lineLen);
                }
            }
        }
        changed = true;
        break;
    case L'x':
    case L's': {
        ClearSearchHitHighlight(true);
        int count = consumeCount();
        bool isS = (chRaw == L's');
        if (g_noteNormalVisualMode) {
            auto range = NoteNormalSelectionRange();
            g_noteNormalVisualMode = false;
            changed = PerformNoteNormalDelete(owner, static_cast<DWORD>(range.first), static_cast<DWORD>(range.second), isS);
        } else {
            DWORD start = g_noteNormalCaret;
            DWORD end = start + count;
            int textLen = GetWindowTextLengthW(g_hNoteEdit);
            if (end > static_cast<DWORD>(textLen)) end = static_cast<DWORD>(textLen);
            changed = PerformNoteNormalDelete(owner, start, end, isS);
        }
        break;
    }
    case L'D':
    case L'C': {
        ClearSearchHitHighlight(true);
        bool isC = (chRaw == L'C');
        DWORD start = g_noteNormalCaret;
        LRESULT line = SendMessageW(g_hNoteEdit, EM_LINEFROMCHAR, static_cast<WPARAM>(start), 0);
        LRESULT lineStart = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line, 0);
        LRESULT lineLen = SendMessageW(g_hNoteEdit, EM_LINELENGTH, static_cast<WPARAM>(lineStart), 0);
        DWORD end = static_cast<DWORD>(lineStart + lineLen);
        changed = PerformNoteNormalDelete(owner, start, end, isC);
        break;
    }
    case L'd':
    case L'c': {
        ClearSearchHitHighlight(true);
        bool isC = (chRaw == L'c');
        bool &pending = isC ? g_noteNormalPendingC : g_noteNormalPendingD;

        if (pending) {
            int line = FindLineForRaw(static_cast<size_t>(g_noteNormalCaret));
            int count = consumeCount();
            int lineCount = NoteLineCount();

            LRESULT startPos = SendMessageW(g_hNoteEdit, EM_LINEINDEX, line, 0);
            int endLine = std::clamp(line + count - 1, 0, std::max(0, lineCount - 1));
            LRESULT endPosStart = SendMessageW(g_hNoteEdit, EM_LINEINDEX, endLine, 0);
            LRESULT endPosLen = SendMessageW(g_hNoteEdit, EM_LINELENGTH, endPosStart, 0);
            LRESULT endPos = endPosStart + endPosLen;

            int textLen = GetWindowTextLengthW(g_hNoteEdit);
            if (endPos + 2 <= textLen) endPos += 2;
            else if (endPos + 1 <= textLen) endPos += 1;

            changed = PerformNoteNormalDelete(owner, static_cast<DWORD>(startPos), static_cast<DWORD>(endPos), isC);
            pending = false;
        } else if (g_noteNormalVisualMode) {
            g_noteNormalPendingCount = 0;
            auto range = NoteNormalSelectionRange();
            g_noteNormalVisualMode = false;
            changed = PerformNoteNormalDelete(owner, static_cast<DWORD>(range.first), static_cast<DWORD>(range.second), isC);
        } else {
            pending = true;
        }
        break;
    }
    case L'y':
        ClearSearchHitHighlight(true);
        if (g_noteNormalPendingY) {
            int line = FindLineForRaw(static_cast<size_t>(g_noteNormalCaret));
            int count = consumeCount();
            std::wstring outText;
            int lineCount = NoteLineCount();
            for (int i = 0; i < count; ++i) {
                int curLine = std::clamp(line + i, 0, std::max(0, lineCount - 1));
                std::wstring lineText = ExtractRenderedLineText(curLine);
                outText.append(lineText);
                outText.append(L"\r\n");
                if (curLine >= lineCount - 1) break;
            }
            if ((!outText.empty() || line >= 0) && SetClipboardUnicodeText(owner, outText)) {
                ShowNoteCopySuccessNotice(owner);
            }
            g_noteNormalPendingY = false;
            g_noteNormalVisualMode = false;
            changed = true;
        } else if (g_noteNormalVisualMode) {
            g_noteNormalPendingCount = 0;
            auto range = NoteNormalSelectionRange();
            std::wstring copied = ExtractRenderedTextRange(range.first, range.second);
            if (SetClipboardUnicodeText(owner, copied)) {
                ShowNoteCopySuccessNotice(owner);
            }
            g_noteNormalVisualMode = false;
            changed = true;
        } else {
            g_noteNormalPendingY = true;
        }
        break;
    case L'p': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for (int i = 0; i < repeat; ++i) {
            if (!PasteClipboardTextAtNormalCaret(owner)) break;
            changed = true;
        }
        break;
    }
    case L'u': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for(int i = 0; i < repeat; ++i) {
            if (!ExecuteNoteUndoRedoFromFocus(owner, true)) break;
            changed = true;
        }
        break;
    }
    case 18:
    case L'U': {
        ClearSearchHitHighlight(true);
        int repeat = consumeCount();
        for(int i = 0; i < repeat; ++i) {
            if (!ExecuteNoteUndoRedoFromFocus(owner, false)) break;
            changed = true;
        }
        break;
    }
    case 27: // ESC
        ClearSearchHitHighlight(true);
        g_noteNormalPendingCount = 0;
        g_noteNormalPendingG = false;
        g_noteNormalPendingY = false;
        g_noteNormalPendingD = false;
        g_noteNormalPendingC = false;
        if (g_noteNormalVisualMode) {
            ClearNoteNormalVisualMode();
        }
        changed = true;
        break;
    default:
        g_noteNormalPendingCount = 0;
        handled = false;
        break;
    }

    if (!handled) return false;
    if (changed) {
        SyncNoteNormalSelectionToEdit();
        InvalidateNoteNormalStateViews();
    }
    return true;
}

static bool ColorSpecEquals(const ColorSpec& a, const ColorSpec& b) {
    return a.mode == b.mode && a.color == b.color;
}

static bool StyleEquals(const StyleState& a, const StyleState& b) {
    return a.bold == b.bold &&
           a.italic == b.italic &&
           a.underline == b.underline &&
           a.strike == b.strike &&
           a.indent == b.indent &&
           a.anchor == b.anchor &&
           a.anchorOffsetChars == b.anchorOffsetChars &&
           a.headingLevel == b.headingLevel &&
           a.linkId == b.linkId &&
           a.linkAccent == b.linkAccent &&
           a.linkUnderline == b.linkUnderline &&
           a.hasFontSize == b.hasFontSize &&
           a.fontSizePx == b.fontSizePx &&
           a.hasFontFace == b.hasFontFace &&
           a.fontFace == b.fontFace &&
           a.hasLineHeight == b.hasLineHeight &&
           a.lineHeightPermille == b.lineHeightPermille &&
           ColorSpecEquals(a.text, b.text) &&
           ColorSpecEquals(a.back, b.back);
}

static bool TagStyleEquals(const TagStyle& a, const TagStyle& b) {
    if (a.bold != b.bold || a.italic != b.italic || a.underline != b.underline ||
        a.strike != b.strike || a.headingLevel != b.headingLevel ||
        a.hasTextColor != b.hasTextColor || a.hasBackColor != b.hasBackColor ||
        a.hasIndent != b.hasIndent || a.anchor != b.anchor ||
        a.anchorOffsetChars != b.anchorOffsetChars || a.hasLink != b.hasLink ||
        a.hasFontSize != b.hasFontSize || a.fontSizePx != b.fontSizePx ||
        a.hasFontFace != b.hasFontFace ||
        a.hasLineHeight != b.hasLineHeight || a.lineHeightPermille != b.lineHeightPermille) {
        return false;
    }
    if (a.hasTextColor && !ColorSpecEquals(a.textColor, b.textColor)) return false;
    if (a.hasBackColor && !ColorSpecEquals(a.backColor, b.backColor)) return false;
    if (a.hasIndent && a.indent != b.indent) return false;
    if (a.hasLink) {
        if (a.linkId != b.linkId) return false;
        if (a.linkAccent != b.linkAccent) return false;
        if (a.linkUnderline != b.linkUnderline) return false;
    }
    if (a.hasFontFace && a.fontFace != b.fontFace) return false;
    return true;
}

static bool TagFrameEquals(const TagFrame& a, const TagFrame& b) {
    return a.startLine == b.startLine &&
           a.startSegment == b.startSegment &&
           a.isMathBlock == b.isMathBlock &&
           a.isCodeFenceBlock == b.isCodeFenceBlock &&
           a.codeFenceMarker == b.codeFenceMarker &&
           a.codeFenceLanguage == b.codeFenceLanguage &&
           a.closeAliases == b.closeAliases &&
           TagStyleEquals(a.style, b.style);
}

static bool SegmentEquals(const Segment& a, const Segment& b) {
    return a.rawStart == b.rawStart &&
           a.rawLen == b.rawLen &&
           a.isMath == b.isMath &&
           a.isMarkupMath == b.isMarkupMath &&
           a.mathDisplay == b.mathDisplay &&
           a.isMarkdownLink == b.isMarkdownLink &&
           a.isInlineCode == b.isInlineCode &&
           a.text == b.text &&
           a.mathText == b.mathText &&
           StyleEquals(a.style, b.style);
}

static bool LineCacheEquals(const LineCache& a, const LineCache& b) {
    if (a.rawLine != b.rawLine || a.headingLevel != b.headingLevel ||
        a.headingPrefixLevel != b.headingPrefixLevel ||
        a.hasFontSize != b.hasFontSize ||
        a.fontSizePx != b.fontSizePx ||
        a.hasLineHeight != b.hasLineHeight ||
        a.lineHeightPermille != b.lineHeightPermille ||
        a.isCodeBlockLine != b.isCodeBlockLine ||
        a.isHorizontalRuleLine != b.isHorizontalRuleLine ||
        a.isCodeFenceLine != b.isCodeFenceLine ||
        a.isCodeFenceOpening != b.isCodeFenceOpening ||
        a.isCodeFenceClosing != b.isCodeFenceClosing ||
        a.codeFenceMarker != b.codeFenceMarker ||
        a.codeFenceLanguage != b.codeFenceLanguage ||
        a.isCustomContainerLine != b.isCustomContainerLine ||
        a.isCustomContainerFenceLine != b.isCustomContainerFenceLine ||
        a.isCustomContainerOpening != b.isCustomContainerOpening ||
        a.isCustomContainerClosing != b.isCustomContainerClosing ||
        a.customContainerFenceCount != b.customContainerFenceCount ||
        a.customContainerKind != b.customContainerKind ||
        a.segments.size() != b.segments.size() || a.endStack.size() != b.endStack.size()) {
        return false;
    }
    for (size_t i = 0; i < a.segments.size(); ++i) {
        if (!SegmentEquals(a.segments[i], b.segments[i])) return false;
    }
    for (size_t i = 0; i < a.endStack.size(); ++i) {
        if (!TagFrameEquals(a.endStack[i], b.endStack[i])) return false;
    }
    return true;
}

static bool ParseColorSpec(const std::wstring& value, ColorSpec& out) {
    std::wstring v = ToLowerAscii(value);
    if (v == L"hicont" || v == L"hi-contrast" || v == L"highcontrast" || v == L"high-contrast") {
        out.mode = ColorMode::HiContrast;
        return true;
    }
    COLORREF c{};
    if (ParseHexColor(value, c)) {
        out.mode = ColorMode::Explicit;
        out.color = c;
        return true;
    }
    return false;
}

static int ParseHeadingKey(const std::wstring& key) {
    if (key.size() < 2) return 0;
    if (key[0] != L'h') return 0;
    int level = 0;
    for (size_t i = 1; i < key.size(); ++i) {
        wchar_t ch = key[i];
        if (ch < L'0' || ch > L'9') return 0;
        level = level * 10 + (ch - L'0');
    }
    return level;
}

static int ParseHashHeadingCloseSelector(const std::wstring& selector) {
    if (selector.empty()) return 0;
    int level = 0;
    for (wchar_t ch : selector) {
        if (ch != L'#') return 0;
        if (level < 1000) ++level;
    }
    return level;
}

static void AddUniqueCloseAlias(std::vector<std::wstring>* aliases, const std::wstring& alias) {
    if (!aliases || alias.empty()) return;
    if (std::find(aliases->begin(), aliases->end(), alias) != aliases->end()) return;
    aliases->push_back(alias);
}

static void AddUniqueCloseAlias(std::vector<std::wstring>* aliases, const wchar_t* alias) {
    if (!aliases || !alias || !*alias) return;
    AddUniqueCloseAlias(aliases, std::wstring(alias));
}

static bool TryParseMarkupTag(const std::wstring& text,
                              size_t openPos,
                              size_t limit,
                              size_t* outTagEnd,
                              std::wstring* outContent) {
    if (outTagEnd) *outTagEnd = std::wstring::npos;
    if (outContent) outContent->clear();
    if (openPos >= text.size() || openPos >= limit || text[openPos] != L'<') return false;
    size_t tagEnd = text.find(L'>', openPos + 1);
    if (tagEnd == std::wstring::npos || tagEnd >= limit) return false;
    if (outTagEnd) *outTagEnd = tagEnd;
    if (outContent) *outContent = text.substr(openPos + 1, tagEnd - (openPos + 1));
    return true;
}

static bool ParseClosingTagSelector(const std::wstring& content, std::wstring* outSelector) {
    if (outSelector) outSelector->clear();
    size_t trim = 0;
    while (trim < content.size() && iswspace(content[trim])) ++trim;
    if (trim >= content.size() || content[trim] != L'/') return false;
    ++trim;
    while (trim < content.size() && iswspace(content[trim])) ++trim;
    size_t start = trim;
    while (trim < content.size() && !iswspace(content[trim]) && content[trim] != L',' && content[trim] != L'=') {
        ++trim;
    }
    if (outSelector && trim > start) {
        *outSelector = ToLowerAscii(content.substr(start, trim - start));
    }
    return true;
}

static bool TagFrameMatchesCloseSelector(const TagFrame& frame, const std::wstring& selector) {
    if (selector.empty()) return true;
    return std::find(frame.closeAliases.begin(), frame.closeAliases.end(), selector) != frame.closeAliases.end();
}

static bool FindMatchingCloseTagForFrame(const std::wstring& text,
                                         size_t from,
                                         size_t limit,
                                         const TagFrame& frame,
                                         size_t* outOpenPos,
                                         size_t* outTagLen) {
    if (outOpenPos) *outOpenPos = std::wstring::npos;
    if (outTagLen) *outTagLen = 0;
    size_t search = from;
    while (search < limit) {
        if (IsLiteralEscapeLeadAt(text, search)) {
            search += 3;
            continue;
        }
        if (text[search] != L'<') {
            ++search;
            continue;
        }
        size_t tagEnd = std::wstring::npos;
        std::wstring content;
        if (!TryParseMarkupTag(text, search, limit, &tagEnd, &content)) {
            ++search;
            continue;
        }
        std::wstring selector;
        if (ParseClosingTagSelector(content, &selector) && TagFrameMatchesCloseSelector(frame, selector)) {
            if (outOpenPos) *outOpenPos = search;
            if (outTagLen) *outTagLen = (tagEnd - search) + 1;
            return true;
        }
        search = tagEnd + 1;
    }
    return false;
}

static bool ParseUserCustomTagIndex(const std::wstring& keyLower, int* outIndex) {
    if (outIndex) *outIndex = -1;
    if (keyLower.empty() || keyLower[0] != L'c') return false;
    if (keyLower.size() == 1) return false;
    int index = 0;
    for (size_t i = 1; i < keyLower.size(); ++i) {
        wchar_t ch = keyLower[i];
        if (ch < L'0' || ch > L'9') return false;
        index = index * 10 + (ch - L'0');
        if (index > 9999) return false;
    }
    if (index <= 0) return false;
    if (outIndex) *outIndex = index;
    return true;
}

static int CustomTagStyleMaskForIndex(int tagIndex) {
    if (tagIndex <= 0) {
        int mask = 0;
        if (g_config.noteCustomTagBold) mask |= kNoteCustomTagStyleBold;
        if (g_config.noteCustomTagItalic) mask |= kNoteCustomTagStyleItalic;
        if (g_config.noteCustomTagUnderline) mask |= kNoteCustomTagStyleUnderline;
        if (g_config.noteCustomTagStrike) mask |= kNoteCustomTagStyleStrike;
        if (g_config.noteCustomTagBackColor) mask |= kNoteCustomTagStyleBackColor;
        if (g_config.noteCustomTagTextColor) mask |= kNoteCustomTagStyleTextColor;
        return mask;
    }
    if (tagIndex <= kNoteCustomTagPresetCount) {
        int slot = tagIndex - 1;
        return g_config.noteCustomTagPresetMasks[static_cast<size_t>(slot)] & kNoteCustomTagStyleAllMask;
    }
    return 0;
}

static int ComputeHeadingExtraPx(int headingLevel, int baseFontHeight) {
    if (headingLevel <= 0) return 0;
    baseFontHeight = std::max(1, baseFontHeight);
    const int level = std::clamp(headingLevel, 1, 6);
    static constexpr int kHeadingExtraScalePermille[6] = {
        1000, 780, 600, 450, 320, 220
    };
    const int baseExtra = (g_headingFontPx > 0)
        ? std::max(0, g_headingFontPx - baseFontHeight)
        : std::max(2, (baseFontHeight * 7) / 20);
    const int scaledExtra =
        (baseExtra * kHeadingExtraScalePermille[static_cast<size_t>(level - 1)] + 500) / 1000;
    return (level <= 3) ? std::max(1, scaledExtra) : std::max(0, scaledExtra);
}

static int ComputeSegmentFontExtraPx(int headingLevel, const StyleState& style, int baseFontHeight) {
    baseFontHeight = std::max(1, baseFontHeight);
    if (style.hasFontSize) return style.fontSizePx - baseFontHeight;
    return ComputeHeadingExtraPx(headingLevel, baseFontHeight);
}

static COLORREF ComputeHeadingLeftBarColor(COLORREF headingDecorColor,
                                           COLORREF baseBack,
                                           int headingLevel) {
    if (headingLevel <= 1) return headingDecorColor;
    const int level = std::clamp(headingLevel, 1, 6);
    static constexpr int kHeadingBarFadePermille[6] = {
        0, 150, 300, 440, 570, 680
    };
    return BlendColor(headingDecorColor,
                      baseBack,
                      static_cast<double>(kHeadingBarFadePermille[static_cast<size_t>(level - 1)]) / 1000.0);
}

static std::wstring TrimWhitespaceCopy(const std::wstring& value) {
    return TrimWhitespace(value);
}

static bool ParseHorizontalAnchorSpec(const std::wstring& value,
                                      HorizontalAnchor* outAnchor,
                                      int* outOffsetChars) {
    if (outAnchor) *outAnchor = HorizontalAnchor::None;
    if (outOffsetChars) *outOffsetChars = 0;
    std::wstring v = ToLowerAscii(TrimWhitespaceCopy(value));
    if (v.empty()) return false;

    HorizontalAnchor anchor = HorizontalAnchor::None;
    size_t prefixLen = 0;
    if (StartsWithAsciiNoCase(v, L"left")) {
        anchor = HorizontalAnchor::Left;
        prefixLen = 4;
    } else if (StartsWithAsciiNoCase(v, L"center")) {
        anchor = HorizontalAnchor::Center;
        prefixLen = 6;
    } else if (StartsWithAsciiNoCase(v, L"right")) {
        anchor = HorizontalAnchor::Right;
        prefixLen = 5;
    } else {
        return false;
    }

    int offsetChars = 0;
    std::wstring suffix = TrimWhitespaceCopy(v.substr(prefixLen));
    if (!suffix.empty()) {
        wchar_t* end = nullptr;
        long parsed = wcstol(suffix.c_str(), &end, 10);
        if (end == suffix.c_str() || *end != L'\0') return false;
        offsetChars = static_cast<int>(parsed);
    }

    if (outAnchor) *outAnchor = anchor;
    if (outOffsetChars) *outOffsetChars = offsetChars;
    return true;
}

static bool ParseTagContent(const std::wstring& attrs,
                            TagStyle& style,
                            const StyleState* currentStyle,
                            int baseFontHeightPx,
                            std::vector<std::wstring>* outCloseAliases = nullptr) {
    style = TagStyle{};
    if (outCloseAliases) outCloseAliases->clear();
    bool recognized = false;
    size_t i = 0;
    constexpr int kLineHeightBasePermille = 1000;
    constexpr int kLineHeightUnitPermille = 100;   // 1 unit = 0.1 line
    constexpr int kDefaultLineHeightUnits = 5;     // <m> => +0.5 line total margin
    constexpr double kMaxLineHeightUnits = 60.0;   // up to +6.0 line margin
    constexpr int kMinFontSizePx = 6;
    constexpr int kMaxFontSizePx = 256;
    const int currentLineHeightPermille =
        (currentStyle && currentStyle->hasLineHeight) ? std::max(1000, currentStyle->lineHeightPermille) : 1000;
    const int currentFontSizePx =
        (currentStyle && currentStyle->hasFontSize) ? std::max(0, currentStyle->fontSizePx) : 0;
    if (baseFontHeightPx <= 0) {
        baseFontHeightPx = kMinFontSizePx;
    }
    auto setLineHeight = [&](const std::wstring& v, bool* has, int* outPermille) -> bool {
        if (v.empty()) return false;
        wchar_t* end = nullptr;
        double units = wcstod(v.c_str(), &end);
        if (end == v.c_str() || *end != L'\0') return false;
        if (units < 0.0) return false;
        units = std::clamp(units, 0.0, kMaxLineHeightUnits);
        *outPermille = kLineHeightBasePermille +
                       static_cast<int>(std::lround(units * static_cast<double>(kLineHeightUnitPermille)));
        *has = true;
        return true;
    };
    auto setLineHeightRelative = [&](const std::wstring& v, bool* has, int* outPermille) -> bool {
        std::wstring vv = TrimWhitespace(v);
        if (vv.empty()) return false;
        wchar_t* end = nullptr;
        double deltaUnits = wcstod(vv.c_str(), &end);
        if (end == vv.c_str() || *end != L'\0') return false;
        double baseUnits =
            static_cast<double>(currentLineHeightPermille - kLineHeightBasePermille) / kLineHeightUnitPermille;
        if (baseUnits < 0.0) baseUnits = 0.0;
        double units = baseUnits + deltaUnits;
        units = std::clamp(units, 0.0, kMaxLineHeightUnits);
        *outPermille = kLineHeightBasePermille +
                       static_cast<int>(std::lround(units * static_cast<double>(kLineHeightUnitPermille)));
        *has = true;
        return true;
    };
    auto setFontSizePx = [&](const std::wstring& v, bool* has, int* outPx) -> bool {
        if (v.empty()) return false;
        std::wstring vv = ToLowerAscii(v);
        if (EndsWithAsciiNoCase(vv, L"px")) {
            vv = vv.substr(0, vv.size() - 2);
        }
        wchar_t* end = nullptr;
        double px = wcstod(vv.c_str(), &end);
        if (end == vv.c_str() || *end != L'\0') return false;
        if (!(px > 0.0)) return false;
        int ipx = static_cast<int>(std::lround(px));
        ipx = std::clamp(ipx, kMinFontSizePx, kMaxFontSizePx);
        *outPx = ipx;
        *has = true;
        return true;
    };
    auto setFontSizePxRelative = [&](const std::wstring& v, bool* has, int* outPx) -> bool {
        if (v.empty()) return false;
        std::wstring vv = ToLowerAscii(TrimWhitespace(v));
        if (EndsWithAsciiNoCase(vv, L"px")) {
            vv = vv.substr(0, vv.size() - 2);
        }
        wchar_t* end = nullptr;
        double px = wcstod(vv.c_str(), &end);
        if (end == vv.c_str() || *end != L'\0') return false;
        int deltaPx = static_cast<int>(std::lround(px));
        int basePx = (currentFontSizePx > 0) ? currentFontSizePx : baseFontHeightPx;
        int targetPx = basePx + deltaPx;
        targetPx = std::clamp(targetPx, kMinFontSizePx, kMaxFontSizePx);
        *outPx = targetPx;
        *has = true;
        return true;
    };
    auto setFontFace = [&](const std::wstring& v, bool* has, std::wstring* outFace) -> bool {
        std::wstring face = TrimWhitespace(v);
        if (face.empty()) return false;
        // Normalize common display names to face names where possible.
        face = ResolveFontFaceName(face);
        if (face.empty()) return false;
        *outFace = std::move(face);
        *has = true;
        return true;
    };
    auto setColor = [&](const std::wstring& v, bool* has, ColorSpec* out) {
        ColorSpec c{};
        if (ParseColorSpec(v, c)) {
            *out = c;
            *has = true;
        }
    };
    auto setIndent = [&](const std::wstring& v, bool* has, int* out) {
        if (v.empty()) return false;
        wchar_t* end = nullptr;
        long val = wcstol(v.c_str(), &end, 10);
        if (end == v.c_str() || *end != L'\0') return false;
        *out = static_cast<int>(val);
        *has = true;
        return true;
    };
    auto parseBool = [&](const std::wstring& v, bool* out) -> bool {
        std::wstring lv = ToLowerAscii(v);
        if (lv == L"1" || lv == L"true" || lv == L"on" || lv == L"yes") { *out = true; return true; }
        if (lv == L"0" || lv == L"false" || lv == L"off" || lv == L"no") { *out = false; return true; }
        return false;
    };
    auto addAliases = [&](std::initializer_list<const wchar_t*> names) {
        for (const wchar_t* name : names) {
            AddUniqueCloseAlias(outCloseAliases, name);
        }
    };
    while (i < attrs.size()) {
        while (i < attrs.size() && (iswspace(attrs[i]) || attrs[i] == L',')) ++i;
        if (i >= attrs.size()) break;
        size_t keyStart = i;
        while (i < attrs.size() && !iswspace(attrs[i]) && attrs[i] != L'=' && attrs[i] != L',') ++i;
        std::wstring key = attrs.substr(keyStart, i - keyStart);
        if (key.empty()) { ++i; continue; }
        std::optional<std::wstring> value;
        if (i < attrs.size() && attrs[i] == L'=') {
            ++i;
            while (i < attrs.size() && iswspace(attrs[i])) ++i;
            if (i < attrs.size() && (attrs[i] == L'\"' || attrs[i] == L'\'')) {
                wchar_t quote = attrs[i++];
                size_t valStart = i;
                while (i < attrs.size() && attrs[i] != quote) ++i;
                value = attrs.substr(valStart, i - valStart);
                if (i < attrs.size() && attrs[i] == quote) ++i;
            } else {
                size_t valStart = i;
                while (i < attrs.size() && !iswspace(attrs[i]) && attrs[i] != L',') ++i;
                value = attrs.substr(valStart, i - valStart);
            }
        }
        if (!value && key.size() >= 2 && (key[1] == L'+' || key[1] == L'-')) {
            wchar_t head = key[0];
            if (head == L'm' || head == L'M' || head == L's' || head == L'S') {
                value = key.substr(1);
                key = key.substr(0, 1);
            }
        }
        std::wstring k = ToLowerAscii(key);
        if (!value) {
            int heading = ParseHeadingKey(k);
            if (heading > 0) {
                style.headingLevel = (style.headingLevel == 0) ? heading : std::min(style.headingLevel, heading);
                recognized = true;
                AddUniqueCloseAlias(outCloseAliases, k);
            }
            else {
                int customTagIndex = -1;
                if (!ParseUserCustomTagIndex(k, &customTagIndex)) {
                    customTagIndex = -1;
                }
                if (customTagIndex >= 0) {
                    int mask = CustomTagStyleMaskForIndex(customTagIndex);
                    if (mask & kNoteCustomTagStyleBold) style.bold = true;
                    if (mask & kNoteCustomTagStyleItalic) style.italic = true;
                    if (mask & kNoteCustomTagStyleUnderline) style.underline = true;
                    if (mask & kNoteCustomTagStyleStrike) style.strike = true;
                    if (mask & kNoteCustomTagStyleBackColor) {
                        style.hasBackColor = true;
                        style.backColor.mode = ColorMode::Explicit;
                        style.backColor.color = g_noteShortcutBackColor;
                    }
                    if (mask & kNoteCustomTagStyleTextColor) {
                        style.hasTextColor = true;
                        style.textColor.mode = ColorMode::Explicit;
                        style.textColor.color = g_noteShortcutTextColor;
                    }
                    recognized = true;
                    AddUniqueCloseAlias(outCloseAliases, k);
                }
                else if (k == L"b") { style.bold = true; recognized = true; addAliases({L"b"}); }
                else if (k == L"i") { style.italic = true; recognized = true; addAliases({L"i"}); }
                else if (k == L"u") { style.underline = true; recognized = true; addAliases({L"u"}); }
                else if (k == L"x") { style.strike = true; recognized = true; addAliases({L"x"}); }
                else if (k == L"la" || k == L"linkaccent") {
                    style.linkAccent = true;
                    recognized = true;
                    addAliases({L"la", L"linkaccent"});
                }
                else if (k == L"lu" || k == L"linkunderline") {
                    style.linkUnderline = true;
                    recognized = true;
                    addAliases({L"lu", L"linkunderline"});
                }
                else if (k == L"m") {
                    style.hasLineHeight = true;
                    style.lineHeightPermille = kLineHeightBasePermille +
                                               kDefaultLineHeightUnits * kLineHeightUnitPermille;
                    recognized = true;
                    addAliases({L"m"});
                }
            }
        } else {
            const std::wstring& v = *value;
            int heading = ParseHeadingKey(k);
            if (heading > 0) {
                style.headingLevel = (style.headingLevel == 0) ? heading : std::min(style.headingLevel, heading);
                recognized = true;
                AddUniqueCloseAlias(outCloseAliases, k);
            } else if (k == L"char" || k == L"c") {
                setColor(v, &style.hasTextColor, &style.textColor);
                recognized = true;
                addAliases({L"char", L"c"});
            } else if (k == L"back" || k == L"b") {
                setColor(v, &style.hasBackColor, &style.backColor);
                recognized = true;
                addAliases({L"back", L"b"});
            } else if (k == L"d") {
                HorizontalAnchor anchor = HorizontalAnchor::None;
                int anchorOffsetChars = 0;
                if (ParseHorizontalAnchorSpec(v, &anchor, &anchorOffsetChars)) {
                    style.anchor = anchor;
                    style.anchorOffsetChars = anchorOffsetChars;
                    recognized = true;
                    addAliases({L"d"});
                } else if (setIndent(v, &style.hasIndent, &style.indent)) {
                    recognized = true;
                    addAliases({L"d"});
                }
            } else if (k == L"l" || k == L"link") {
                style.linkId = v;
                style.hasLink = !style.linkId.empty();
                recognized = style.hasLink;
                if (recognized) addAliases({L"l", L"link"});
            } else if (k == L"m") {
                std::wstring vv = TrimWhitespace(v);
                if (!vv.empty() && (vv[0] == L'+' || vv[0] == L'-')) {
                    if (setLineHeightRelative(vv, &style.hasLineHeight, &style.lineHeightPermille)) {
                        recognized = true;
                        addAliases({L"m"});
                    }
                } else if (setLineHeight(v, &style.hasLineHeight, &style.lineHeightPermille)) {
                    recognized = true;
                    addAliases({L"m"});
                }
            } else if (k == L"s" || k == L"fs" || k == L"size") {
                std::wstring vv = TrimWhitespace(v);
                if (!vv.empty() && (vv[0] == L'+' || vv[0] == L'-')) {
                    if (setFontSizePxRelative(vv, &style.hasFontSize, &style.fontSizePx)) {
                        recognized = true;
                        addAliases({L"s", L"fs", L"size"});
                    }
                } else if (setFontSizePx(v, &style.hasFontSize, &style.fontSizePx)) {
                    recognized = true;
                    addAliases({L"s", L"fs", L"size"});
                }
            } else if (k == L"font" || k == L"f") {
                if (setFontFace(v, &style.hasFontFace, &style.fontFace)) {
                    recognized = true;
                    addAliases({L"font", L"f"});
                }
            } else if (k == L"la" || k == L"linkaccent") {
                if (parseBool(v, &style.linkAccent)) {
                    recognized = true;
                    addAliases({L"la", L"linkaccent"});
                }
            } else if (k == L"lu" || k == L"linkunderline") {
                if (parseBool(v, &style.linkUnderline)) {
                    recognized = true;
                    addAliases({L"lu", L"linkunderline"});
                }
            } else if (k == L"i") {
                style.italic = true;
                recognized = true;
                addAliases({L"i"});
            } else if (k == L"u") {
                style.underline = true;
                recognized = true;
                addAliases({L"u"});
            } else if (k == L"x") {
                style.strike = true;
                recognized = true;
                addAliases({L"x"});
            }
        }
    }
    return recognized;
}

static bool TryParseCodeFenceLine(const std::wstring& line, wchar_t* outMarker, std::wstring* outLang) {
    if (outMarker) *outMarker = 0;
    if (outLang) outLang->clear();
    if (line.size() < 3) return false;
    const wchar_t marker = line[0];
    if (marker != L'`' && marker != L'~') return false;
    if (!(line[1] == marker && line[2] == marker)) return false;
    if (outMarker) *outMarker = marker;
    if (outLang) {
        *outLang = TrimWhitespace(line.substr(3));
    }
    return true;
}

static bool TryParseCustomContainerFenceLine(const std::wstring& line,
                                             int* outFenceCount,
                                             std::wstring* outKind) {
    if (outFenceCount) *outFenceCount = 0;
    if (outKind) outKind->clear();

    size_t pos = 0;
    while (pos < line.size() && (line[pos] == L' ' || line[pos] == L'\t')) {
        ++pos;
    }
    if (pos + 3 > line.size()) return false;

    size_t count = 0;
    while (pos + count < line.size() && line[pos + count] == L':') {
        ++count;
    }
    if (count < 3) return false;

    if (outFenceCount) *outFenceCount = static_cast<int>(count);
    if (outKind) {
        *outKind = TrimWhitespace(line.substr(pos + count));
    }
    return true;
}

static const std::wstring* EffectiveSegmentFontFaceOverride(const LineCache& cache, const Segment& seg) {
    static const std::wstring kCodeFenceFontFace = L"Consolas";
    if (cache.isCodeBlockLine || seg.isInlineCode) return &kCodeFenceFontFace;
    if (seg.style.fontFace.empty()) return nullptr;
    return &seg.style.fontFace;
}

static int EffectiveSegmentHeadingLevel(const LineCache& cache, const Segment& seg) {
    if (cache.isCodeBlockLine) return 0;
    return ResolveHeadingLevel(cache, seg);
}

static bool IsCommentLineAt(const std::wstring& text, size_t start, size_t end) {
    size_t i = start;
    while (i < end) {
        wchar_t ch = text[i];
        if (ch != L' ' && ch != L'\t') break;
        ++i;
    }
    return (i + 1 < end && text[i] == L'/' && text[i + 1] == L'/');
}

static int Luma(COLORREF c) {
    return (GetRValue(c) * 299 + GetGValue(c) * 587 + GetBValue(c) * 114) / 1000;
}

static std::wstring ColorToHexW(COLORREF c) {
    wchar_t buf[16]{};
    unsigned int v = (static_cast<unsigned int>(GetRValue(c)) << 16) |
                     (static_cast<unsigned int>(GetGValue(c)) << 8) |
                     static_cast<unsigned int>(GetBValue(c));
    swprintf_s(buf, L"#%06X", v);
    return buf;
}

static COLORREF MutedTextColor(COLORREF base) {
    return (Luma(base) >= 128) ? RGB(120, 120, 120) : RGB(160, 160, 160);
}

static COLORREF HighContrastText(COLORREF bg) {
    return (Luma(bg) >= 128) ? RGB(0, 0, 0) : RGB(255, 255, 255);
}

static COLORREF HighContrastBack(COLORREF fg) {
    return (Luma(fg) >= 128) ? RGB(0, 0, 0) : RGB(255, 255, 255);
}

COLORREF AdjustColorBrightness(COLORREF base, int delta) {
    auto clamp = [](int value) -> BYTE {
        if (value < 0) return 0;
        if (value > 255) return 255;
        return static_cast<BYTE>(value);
    };
    int r = clamp(static_cast<int>(GetRValue(base)) + delta);
    int g = clamp(static_cast<int>(GetGValue(base)) + delta);
    int b = clamp(static_cast<int>(GetBValue(base)) + delta);
    return RGB(r, g, b);
}

COLORREF BlendColor(COLORREF a, COLORREF b, double t) {
    t = std::clamp(t, 0.0, 1.0);
    auto lerp = [&](BYTE av, BYTE bv) -> BYTE {
        double v = static_cast<double>(av) + (static_cast<double>(bv) - static_cast<double>(av)) * t;
        if (v < 0.0) v = 0.0;
        if (v > 255.0) v = 255.0;
        return static_cast<BYTE>(std::lround(v));
    };
    return RGB(lerp(GetRValue(a), GetRValue(b)),
               lerp(GetGValue(a), GetGValue(b)),
               lerp(GetBValue(a), GetBValue(b)));
}

static ResolvedColors ResolveColors(const StyleState& style, COLORREF baseText, COLORREF baseBack) {
    ResolvedColors out;
    out.text = baseText;
    out.back = baseBack;
    out.hasBack = (style.back.mode != ColorMode::None);

    bool textHi = (style.text.mode == ColorMode::HiContrast);
    bool backHi = (style.back.mode == ColorMode::HiContrast);

    if (style.text.mode == ColorMode::Explicit) {
        out.text = style.text.color;
    }
    if (style.back.mode == ColorMode::Explicit) {
        out.back = style.back.color;
    }

    if (textHi && backHi) {
        out.back = GetSysColor(COLOR_HIGHLIGHT);
        out.text = GetSysColor(COLOR_HIGHLIGHTTEXT);
        out.hasBack = true;
    } else if (backHi) {
        if (style.text.mode == ColorMode::Explicit) {
            out.back = HighContrastBack(out.text);
        } else {
            out.back = HighContrastBack(baseBack);
            out.text = HighContrastText(out.back);
        }
        out.hasBack = true;
    } else if (textHi) {
        out.text = HighContrastText(out.back);
    }
    return out;
}

static COLORREF NoteConfigColorToRef(int rgb) {
    return RGB((rgb >> 16) & 0xFF, (rgb >> 8) & 0xFF, rgb & 0xFF);
}

static ResolvedColors ApplyInlineCodeColors(const Segment& seg,
                                            ResolvedColors colors,
                                            COLORREF baseText,
                                            COLORREF baseBack) {
    if (!seg.isInlineCode) return colors;
    if (seg.style.back.mode == ColorMode::None) {
        const bool brightBack = (Luma(baseBack) >= 128);
        const COLORREF target = BlendColor(g_theme.accent,
                                           brightBack ? RGB(228, 224, 214) : RGB(86, 92, 102),
                                           brightBack ? 0.72 : 0.48);
        colors.back = BlendColor(baseBack, target, brightBack ? 0.42 : 0.46);
        colors.hasBack = true;
    }
    if (seg.style.text.mode == ColorMode::None) {
        colors.text = BlendColor(baseText, g_theme.accent, (Luma(baseBack) >= 128) ? 0.10 : 0.18);
    }
    return colors;
}

static int ComputeNoteRenderBaseFontHeightPx() {
    int baseFontHeightPx = 0;
    HWND basis = g_hNoteEdit;
    int dpi = basis ? GetDpiY(basis) : 96;
    if (dpi <= 0) dpi = 96;
    double pt = (g_noteFontPt > 0.0) ? g_noteFontPt : 10.0;
    baseFontHeightPx = std::max(8, static_cast<int>(std::lround(pt * dpi / 72.0)));
    if (!basis) {
        return baseFontHeightPx;
    }

    HDC hdc = GetDC(basis);
    if (!hdc) {
        return baseFontHeightPx;
    }
    HFONT font = GetActiveNoteFont();
    HFONT old = font ? static_cast<HFONT>(SelectObject(hdc, font)) : nullptr;
    TEXTMETRICW tm{};
    if (GetTextMetricsW(hdc, &tm)) {
        baseFontHeightPx = std::max(baseFontHeightPx, static_cast<int>(tm.tmHeight));
    }
    if (old) SelectObject(hdc, old);
    ReleaseDC(basis, hdc);
    return baseFontHeightPx;
}

static std::vector<NoteRenderLineInfo> BuildNoteRenderLineInfos(const std::wstring& text,
                                                                const std::vector<std::wstring>& lines) {
    std::vector<NoteRenderLineInfo> infos;
    infos.reserve(lines.size());
    size_t pos = 0;
    for (size_t i = 0; i < lines.size(); ++i) {
        const size_t start = pos;
        pos += lines[i].size();
        infos.push_back(NoteRenderLineInfo{start, pos});
        if (pos >= text.size()) {
            continue;
        }
        if (text[pos] == L'\r') {
            ++pos;
            if (pos < text.size() && text[pos] == L'\n') {
                ++pos;
            }
        } else if (text[pos] == L'\n') {
            ++pos;
        }
    }
    return infos;
}

static void RebuildRenderLineIndex(const std::wstring& text) {
    g_renderTextCache = text;
    g_renderLines = SplitLines(text);
    g_renderLineInfos = BuildNoteRenderLineInfos(text, g_renderLines);
}

static bool TextEditMatchesRenderText(const std::wstring& text, const note::TextEdit& edit) {
    const std::wstring& before = g_renderTextCache;
    if (edit.start.value > before.size()) return false;
    if (edit.deleted_len > before.size() - edit.start.value) return false;
    const size_t oldSuffixStart = edit.start.value + edit.deleted_len;
    const size_t newSuffixStart = edit.start.value + edit.inserted_text.size();
    if (before.size() - edit.deleted_len + edit.inserted_text.size() != text.size()) {
        return false;
    }
    if (!std::equal(before.begin(), before.begin() + edit.start.value, text.begin())) {
        return false;
    }
    if (!std::equal(edit.inserted_text.begin(), edit.inserted_text.end(),
                    text.begin() + edit.start.value)) {
        return false;
    }
    return std::equal(before.begin() + oldSuffixStart, before.end(),
                      text.begin() + newSuffixStart);
}

static size_t FindRenderLineByOffset(const std::vector<NoteRenderLineInfo>& infos, size_t offset) {
    if (infos.empty()) return 0;
    size_t lo = 0;
    size_t hi = infos.size();
    while (lo + 1 < hi) {
        size_t mid = lo + (hi - lo) / 2;
        if (infos[mid].start <= offset) {
            lo = mid;
        } else {
            hi = mid;
        }
    }
    if (offset > infos[lo].end && lo + 1 < infos.size() && infos[lo + 1].start <= offset) {
        ++lo;
    }
    return lo;
}

static size_t AdvanceRenderLineBreak(const std::wstring& text, size_t pos) {
    if (pos >= text.size()) return pos;
    if (text[pos] == L'\r' && pos + 1 < text.size() && text[pos + 1] == L'\n') return pos + 2;
    if (text[pos] == L'\r' || text[pos] == L'\n') return pos + 1;
    return pos;
}

static void BuildRenderLinesForRange(const std::wstring& text,
                                     size_t start,
                                     size_t end,
                                     std::vector<std::wstring>* outLines,
                                     std::vector<NoteRenderLineInfo>* outInfos) {
    if (outLines) outLines->clear();
    if (outInfos) outInfos->clear();
    start = std::min(start, text.size());
    end = std::min(end, text.size());
    size_t pos = start;
    bool endedWithBreak = false;
    for (;;) {
        size_t lineEnd = pos;
        while (lineEnd < end && text[lineEnd] != L'\r' && text[lineEnd] != L'\n') {
            ++lineEnd;
        }
        if (outLines) outLines->push_back(text.substr(pos, lineEnd - pos));
        if (outInfos) outInfos->push_back(NoteRenderLineInfo{pos, lineEnd});
        if (lineEnd >= end) {
            endedWithBreak = false;
            break;
        }
        endedWithBreak = true;
        pos = AdvanceRenderLineBreak(text, lineEnd);
        if (pos > end) pos = end;
        if (pos == end) break;
    }
    if (endedWithBreak) {
        if (outLines) outLines->push_back(L"");
        if (outInfos) outInfos->push_back(NoteRenderLineInfo{end, end});
    }
    if (outLines && outLines->empty()) outLines->push_back(L"");
    if (outInfos && outInfos->empty()) outInfos->push_back(NoteRenderLineInfo{start, start});
}

static bool FindCurrentRenderLineRangeForEdit(const std::wstring& text,
                                              const note::TextEdit& edit,
                                              size_t* outStart,
                                              size_t* outEnd) {
    if (!outStart || !outEnd) return false;
    size_t anchor = std::min(edit.start.value + edit.inserted_text.size(), text.size());
    size_t start = std::min(edit.start.value, text.size());
    while (start > 0) {
        wchar_t prev = text[start - 1];
        if (prev == L'\r' || prev == L'\n') break;
        --start;
    }
    size_t end = anchor;
    if (end < start) end = start;
    while (end < text.size() && text[end] != L'\r' && text[end] != L'\n') {
        ++end;
    }
    *outStart = start;
    *outEnd = end;
    return true;
}

static bool TryApplyRenderLineIndexEdit(const std::wstring& text,
                                        const note::TextEdit& edit,
                                        size_t* outFirstLine,
                                        size_t* outLastLine) {
    if (!outFirstLine || !outLastLine) return false;
    if (g_renderLines.empty() || g_renderLineInfos.empty()) return false;
    if (!TextEditMatchesRenderText(text, edit)) return false;

    const size_t oldSize = g_renderTextCache.size();
    const size_t oldStart = std::min(edit.start.value, oldSize);
    const size_t oldEnd = std::min(edit.start.value + edit.deleted_len, oldSize);
    size_t oldFirstLine = FindRenderLineByOffset(g_renderLineInfos, oldStart);
    size_t oldLastLine = FindRenderLineByOffset(g_renderLineInfos, oldEnd);
    if (oldFirstLine >= g_renderLineInfos.size() || oldLastLine >= g_renderLineInfos.size()) {
        return false;
    }
    if (oldLastLine < oldFirstLine) oldLastLine = oldFirstLine;

    size_t newRangeStart = 0;
    size_t newRangeEnd = 0;
    if (!FindCurrentRenderLineRangeForEdit(text, edit, &newRangeStart, &newRangeEnd)) {
        return false;
    }

    std::vector<std::wstring> replacementLines;
    std::vector<NoteRenderLineInfo> replacementInfos;
    BuildRenderLinesForRange(text, newRangeStart, newRangeEnd,
                             &replacementLines, &replacementInfos);
    if (replacementLines.size() != replacementInfos.size() || replacementLines.empty()) {
        return false;
    }

    const size_t eraseFirst = oldFirstLine;
    const size_t eraseLastExclusive = oldLastLine + 1;
    g_renderLines.erase(g_renderLines.begin() + eraseFirst,
                        g_renderLines.begin() + eraseLastExclusive);
    g_renderLines.insert(g_renderLines.begin() + eraseFirst,
                         replacementLines.begin(), replacementLines.end());

    g_renderLineInfos.erase(g_renderLineInfos.begin() + eraseFirst,
                            g_renderLineInfos.begin() + eraseLastExclusive);
    g_renderLineInfos.insert(g_renderLineInfos.begin() + eraseFirst,
                             replacementInfos.begin(), replacementInfos.end());

    const ptrdiff_t delta = static_cast<ptrdiff_t>(text.size()) -
                            static_cast<ptrdiff_t>(oldSize);
    const size_t shiftStart = eraseFirst + replacementInfos.size();
    for (size_t i = shiftStart; i < g_renderLineInfos.size(); ++i) {
        g_renderLineInfos[i].start = static_cast<size_t>(
            static_cast<ptrdiff_t>(g_renderLineInfos[i].start) + delta);
        g_renderLineInfos[i].end = static_cast<size_t>(
            static_cast<ptrdiff_t>(g_renderLineInfos[i].end) + delta);
    }

    g_renderTextCache = text;
    *outFirstLine = eraseFirst;
    *outLastLine = eraseFirst + replacementInfos.size() - 1;
    return true;
}

static bool IntersectsRawRange(note::Span span, size_t start, size_t end) {
    return span.start.value < end && span.end.value > start;
}

static bool RawPositionIsOnRenderLine(size_t pos, size_t lineStart, size_t lineEnd) {
    return pos >= lineStart && pos <= lineEnd;
}

static const note::MathSpan* FindBlockMathForRenderLine(const std::vector<const note::MathSpan*>& lineMathSpans) {
    for (const note::MathSpan* mathSpan : lineMathSpans) {
        if (mathSpan && mathSpan->kind == note::MathKind::Block) {
            return mathSpan;
        }
    }
    return nullptr;
}

static void AppendBlockMathRepresentativeSegment(const note::MathSpan& mathSpan,
                                                 size_t lineStart,
                                                 size_t lineEnd,
                                                 LineCache* cache) {
    if (!cache) return;
    if (!RawPositionIsOnRenderLine(mathSpan.span.start.value, lineStart, lineEnd)) return;

    Segment seg;
    seg.text = mathSpan.normalized_tex.empty()
        ? DecodeLiteralEscapes(cache->rawLine)
        : mathSpan.normalized_tex;
    seg.mathText = mathSpan.normalized_tex;
    seg.rawStart = std::min(mathSpan.span.start.value - lineStart, cache->rawLine.size());
    const size_t rawEnd = std::min(lineEnd, mathSpan.span.end.value);
    seg.rawLen = (rawEnd > mathSpan.span.start.value) ? (rawEnd - mathSpan.span.start.value) : 0;
    if (seg.rawLen == 0 && seg.rawStart < cache->rawLine.size()) {
        seg.rawLen = std::min<size_t>(2, cache->rawLine.size() - seg.rawStart);
    }
    seg.isMath = true;
    seg.isMarkupMath = (mathSpan.delimiter == note::MathDelimiter::LegacyMathTag);
    seg.mathDisplay = true;
    ApplyDefaultMathSegmentLayout(&seg);
    if (!seg.text.empty()) {
        cache->segments.push_back(std::move(seg));
    }
}

static std::optional<size_t> MarkdownOpeningRunStart(const std::wstring& text,
                                                     size_t lineStart,
                                                     size_t sliceEnd,
                                                     wchar_t marker,
                                                     size_t minRun) {
    if (sliceEnd > text.size()) return std::nullopt;
    size_t markerStart = sliceEnd;
    while (markerStart > lineStart && text[markerStart - 1] == marker) {
        --markerStart;
    }
    if (sliceEnd - markerStart >= minRun) return markerStart;
    return std::nullopt;
}

static std::optional<size_t> MarkdownLinkOpeningStart(const std::wstring& text,
                                                      size_t lineStart,
                                                      size_t sliceEnd,
                                                      bool image) {
    if (sliceEnd > text.size()) return std::nullopt;
    size_t pos = sliceEnd;
    while (pos > lineStart) {
        const wchar_t ch = text[pos - 1];
        if (ch == L'[') {
            if (!image) return pos - 1;
            if (pos - 1 > lineStart && text[pos - 2] == L'!') return pos - 2;
            return std::nullopt;
        }
        if (ch == L'*' || ch == L'_' || ch == L'`' || ch == L'~') {
            --pos;
            continue;
        }
        break;
    }
    return std::nullopt;
}

static size_t HideMarkdownOpeningMarkerEnd(const std::wstring& text,
                                           size_t lineStart,
                                           size_t sliceEnd,
                                           const std::vector<const note::InlineNode*>& overlays) {
    size_t visibleEnd = sliceEnd;
    for (const note::InlineNode* overlay : overlays) {
        if (!overlay) continue;
        if (overlay->span.start.value != sliceEnd) continue;

        std::optional<size_t> markerStart;
        switch (overlay->kind) {
        case note::InlineKind::Emphasis:
            markerStart = MarkdownOpeningRunStart(text, lineStart, sliceEnd, L'*', 1);
            if (!markerStart) {
                markerStart = MarkdownOpeningRunStart(text, lineStart, sliceEnd, L'_', 1);
            }
            break;
        case note::InlineKind::Strong:
            markerStart = MarkdownOpeningRunStart(text, lineStart, sliceEnd, L'*', 2);
            if (!markerStart) {
                markerStart = MarkdownOpeningRunStart(text, lineStart, sliceEnd, L'_', 2);
            }
            break;
        case note::InlineKind::Strike:
            markerStart = MarkdownOpeningRunStart(text, lineStart, sliceEnd, L'~', 2);
            break;
        case note::InlineKind::Code:
            markerStart = MarkdownOpeningRunStart(text, lineStart, sliceEnd, L'`', 1);
            break;
        case note::InlineKind::Link:
            markerStart = MarkdownLinkOpeningStart(text, lineStart, sliceEnd, false);
            break;
        case note::InlineKind::Image:
            markerStart = MarkdownLinkOpeningStart(text, lineStart, sliceEnd, true);
            break;
        default:
            break;
        }
        if (markerStart && *markerStart < visibleEnd) {
            visibleEnd = *markerStart;
        }
    }
    return visibleEnd;
}

static bool IsLegacyStyleCloseSelector(const std::wstring& selector) {
    if (selector.empty()) return true;
    if (ParseHeadingKey(selector) > 0) return true;
    if (ParseHashHeadingCloseSelector(selector) > 0) return true;
    int customTagIndex = -1;
    if (ParseUserCustomTagIndex(selector, &customTagIndex) && customTagIndex >= 0) {
        return true;
    }
    static const wchar_t* const kSelectors[] = {
        L"b", L"i", L"u", L"x",
        L"char", L"c",
        L"back",
        L"font", L"f",
        L"s", L"fs", L"size",
        L"m",
        L"d",
        L"l", L"link",
        L"la", L"linkaccent",
        L"lu", L"linkunderline",
    };
    for (const wchar_t* candidate : kSelectors) {
        if (selector == candidate) return true;
    }
    return false;
}

static bool IsLegacyStyleTagAt(const std::wstring& text,
                               size_t pos,
                               size_t limit,
                               int baseFontHeightPx,
                               size_t* outTagEndExclusive) {
    if (outTagEndExclusive) *outTagEndExclusive = std::wstring::npos;
    size_t tagEnd = std::wstring::npos;
    std::wstring content;
    if (!TryParseMarkupTag(text, pos, limit, &tagEnd, &content)) {
        return false;
    }

    const std::wstring trimmed = TrimWhitespaceCopy(content);
    if (trimmed == L"/") {
        if (outTagEndExclusive) *outTagEndExclusive = tagEnd + 1;
        return true;
    }

    std::wstring selector;
    if (ParseClosingTagSelector(content, &selector) && IsLegacyStyleCloseSelector(selector)) {
        if (outTagEndExclusive) *outTagEndExclusive = tagEnd + 1;
        return true;
    }

    TagStyle style;
    std::vector<std::wstring> closeAliases;
    if (ParseTagContent(content, style, nullptr, baseFontHeightPx, &closeAliases)) {
        if (outTagEndExclusive) *outTagEndExclusive = tagEnd + 1;
        return true;
    }
    return false;
}

static std::vector<note::Span> CollectVisibleRawSlicesForNoteDocument(const std::wstring& text,
                                                                      note::Span span,
                                                                      int baseFontHeightPx) {
    std::vector<note::Span> out;
    const size_t start = std::min(span.start.value, text.size());
    const size_t end = std::min(span.end.value, text.size());
    if (end <= start) return out;

    size_t cursor = start;
    size_t chunkStart = start;
    while (cursor < end) {
        if (text[cursor] == L'<') {
            size_t tagEndExclusive = std::wstring::npos;
            if (IsLegacyStyleTagAt(text, cursor, end, baseFontHeightPx, &tagEndExclusive)) {
                if (cursor > chunkStart) {
                    out.push_back(note::Span{{chunkStart}, {cursor}});
                }
                cursor = std::min(tagEndExclusive, end);
                chunkStart = cursor;
                continue;
            }
        }
        ++cursor;
    }

    if (chunkStart < end) {
        out.push_back(note::Span{{chunkStart}, {end}});
    }
    return out;
}

static void ApplyNoteStyleSpanToStyle(const note::StyleSpan& source,
                                      int baseFontHeightPx,
                                      StyleState* style) {
    if (!style) return;

    constexpr int kLineHeightBasePermille = 1000;
    constexpr int kLineHeightUnitPermille = 100;
    constexpr double kMaxLineHeightUnits = 60.0;
    constexpr int kMinFontSizePx = 6;
    constexpr int kMaxFontSizePx = 256;
    if (baseFontHeightPx <= 0) {
        baseFontHeightPx = kMinFontSizePx;
    }

    auto trimValue = [&]() {
        return TrimWhitespaceCopy(source.value);
    };
    auto parseLongValue = [](const std::wstring& value, int* out) -> bool {
        if (!out) return false;
        wchar_t* end = nullptr;
        long parsed = wcstol(value.c_str(), &end, 10);
        if (end == value.c_str() || *end != L'\0') return false;
        *out = static_cast<int>(parsed);
        return true;
    };
    auto setLineHeightValue = [&](const std::wstring& value) -> bool {
        wchar_t* end = nullptr;
        double units = wcstod(value.c_str(), &end);
        if (end == value.c_str() || *end != L'\0') return false;
        if (units < 0.0) return false;
        units = std::clamp(units, 0.0, kMaxLineHeightUnits);
        style->hasLineHeight = true;
        style->lineHeightPermille = kLineHeightBasePermille +
                                    static_cast<int>(std::lround(units * static_cast<double>(kLineHeightUnitPermille)));
        return true;
    };
    auto setLineHeightRelative = [&](const std::wstring& value) -> bool {
        wchar_t* end = nullptr;
        double deltaUnits = wcstod(value.c_str(), &end);
        if (end == value.c_str() || *end != L'\0') return false;
        double baseUnits = style->hasLineHeight
            ? static_cast<double>(std::max(1000, style->lineHeightPermille) - kLineHeightBasePermille) / kLineHeightUnitPermille
            : 0.0;
        double units = std::clamp(baseUnits + deltaUnits, 0.0, kMaxLineHeightUnits);
        style->hasLineHeight = true;
        style->lineHeightPermille = kLineHeightBasePermille +
                                    static_cast<int>(std::lround(units * static_cast<double>(kLineHeightUnitPermille)));
        return true;
    };
    auto setFontSizeValue = [&](std::wstring value) -> bool {
        value = ToLowerAscii(value);
        if (EndsWithAsciiNoCase(value, L"px")) {
            value = value.substr(0, value.size() - 2);
        }
        wchar_t* end = nullptr;
        double px = wcstod(value.c_str(), &end);
        if (end == value.c_str() || *end != L'\0') return false;
        if (!(px > 0.0)) return false;
        style->hasFontSize = true;
        style->fontSizePx = std::clamp(static_cast<int>(std::lround(px)), kMinFontSizePx, kMaxFontSizePx);
        return true;
    };
    auto setFontSizeRelative = [&](std::wstring value) -> bool {
        value = ToLowerAscii(TrimWhitespaceCopy(value));
        if (EndsWithAsciiNoCase(value, L"px")) {
            value = value.substr(0, value.size() - 2);
        }
        wchar_t* end = nullptr;
        double px = wcstod(value.c_str(), &end);
        if (end == value.c_str() || *end != L'\0') return false;
        const int basePx = style->hasFontSize ? style->fontSizePx : baseFontHeightPx;
        style->hasFontSize = true;
        style->fontSizePx = std::clamp(basePx + static_cast<int>(std::lround(px)), kMinFontSizePx, kMaxFontSizePx);
        return true;
    };

    const std::wstring value = trimValue();
    switch (source.kind) {
    case note::StyleKind::Underline:
        style->underline = true;
        break;
    case note::StyleKind::TextColor: {
        ColorSpec spec{};
        if (ParseColorSpec(value, spec)) {
            style->text = spec;
        }
        break;
    }
    case note::StyleKind::BackgroundColor: {
        ColorSpec spec{};
        if (ParseColorSpec(value, spec)) {
            style->back = spec;
        }
        break;
    }
    case note::StyleKind::FontFamily: {
        std::wstring face = ResolveFontFaceName(value);
        if (!face.empty()) {
            style->hasFontFace = true;
            style->fontFace = std::move(face);
        }
        break;
    }
    case note::StyleKind::FontSize:
        if (!value.empty() && (value[0] == L'+' || value[0] == L'-')) {
            setFontSizeRelative(value);
        } else {
            setFontSizeValue(value);
        }
        break;
    case note::StyleKind::LineHeight:
        if (!value.empty() && (value[0] == L'+' || value[0] == L'-')) {
            setLineHeightRelative(value);
        } else {
            setLineHeightValue(value);
        }
        break;
    case note::StyleKind::Indent: {
        int indent = 0;
        if (parseLongValue(value, &indent)) {
            style->indent = indent;
        }
        break;
    }
    case note::StyleKind::Anchor: {
        HorizontalAnchor anchor = HorizontalAnchor::None;
        int offsetChars = 0;
        if (ParseHorizontalAnchorSpec(value, &anchor, &offsetChars)) {
            style->anchor = anchor;
            style->anchorOffsetChars = offsetChars;
        }
        break;
    }
    case note::StyleKind::LinkId: {
        style->linkId = value;
        break;
    }
    case note::StyleKind::LinkAccent:
        style->linkAccent = true;
        break;
    case note::StyleKind::LinkUnderline:
        style->linkUnderline = true;
        break;
    default:
        break;
    }
}

struct MarkdownFenceState {
    bool insideFence = false;
    wchar_t activeFenceMarker = 0;
    std::wstring activeFenceLanguage;
    bool insideCustomContainer = false;
    int activeCustomContainerFenceCount = 0;
    std::wstring activeCustomContainerKind;
};

static void ResetMarkdownRenderDerivedState(const std::wstring& text,
                                            int baseFontHeightPx,
                                            bool invalidateHorizontalExtent = false) {
    g_lastParsedMarkupLength = text.size();
    g_lastParsedMarkupBaseFontHeightPx = baseFontHeightPx;
    // Math nodes are keyed only by the stripped formula body. Keep them across
    // normal render-cache refreshes so unrelated edits do not reparse every
    // visible formula; ClearLegacyRenderCache still clears them on full resets.
    if (invalidateHorizontalExtent) {
        // Do not clear the committed canvas width here. Until the refreshed cache has
        // been measured, the previous extent is safer than collapsing to the viewport.
        g_noteRenderedHorizontalExtentDirty = true;
    }
}

static void SeedMarkdownFenceStateFromPreviousLine(const std::vector<LineCache>& caches,
                                                   size_t startLine,
                                                   MarkdownFenceState* outState) {
    if (!outState || startLine == 0 || startLine > caches.size()) return;
    const LineCache& prev = caches[startLine - 1];
    if (prev.isCodeBlockLine && !prev.isCodeFenceClosing) {
        outState->insideFence = true;
        outState->activeFenceMarker = prev.codeFenceMarker;
        outState->activeFenceLanguage = prev.codeFenceLanguage;
    }
    if (prev.isCustomContainerLine && !prev.isCustomContainerClosing) {
        outState->insideCustomContainer = true;
        outState->activeCustomContainerFenceCount = prev.customContainerFenceCount;
        outState->activeCustomContainerKind = prev.customContainerKind;
    }
}

static LineCache BuildMarkdownRenderCacheLine(const std::wstring& text,
                                             const std::vector<std::wstring>& lines,
                                             const std::vector<NoteRenderLineInfo>& lineInfos,
                                             size_t lineIndex,
                                             int baseFontHeightPx,
                                             MarkdownFenceState* fenceState) {
    LineCache cache;
    if (lineIndex >= lines.size()) return cache;
    cache.rawLine = lines[lineIndex];
    cache.headingLevel = 0;
    cache.headingPrefixLevel = 0;
    cache.lineHeightPermille = 1000;

    const size_t lineStart = (lineIndex < lineInfos.size()) ? lineInfos[lineIndex].start : 0;
    const size_t lineEnd = (lineIndex < lineInfos.size()) ? lineInfos[lineIndex].end : lineStart;

    bool insideFence = fenceState ? fenceState->insideFence : false;
    wchar_t activeFenceMarker = fenceState ? fenceState->activeFenceMarker : 0;
    std::wstring activeFenceLanguage = fenceState ? fenceState->activeFenceLanguage : std::wstring();
    bool insideCustomContainer = fenceState ? fenceState->insideCustomContainer : false;
    int activeCustomContainerFenceCount = fenceState ? fenceState->activeCustomContainerFenceCount : 0;
    std::wstring activeCustomContainerKind =
        fenceState ? fenceState->activeCustomContainerKind : std::wstring();

    wchar_t fenceMarker = 0;
    std::wstring fenceLanguage;
    const bool isFenceLine = TryParseCodeFenceLine(cache.rawLine, &fenceMarker, &fenceLanguage);
    int customFenceCount = 0;
    std::wstring customContainerKind;
    const bool isCustomContainerFenceLine =
        TryParseCustomContainerFenceLine(cache.rawLine, &customFenceCount, &customContainerKind);
    if (insideFence) {
        cache.isCodeBlockLine = true;
        cache.codeFenceMarker = activeFenceMarker;
        cache.codeFenceLanguage = activeFenceLanguage;
        if (isFenceLine && fenceMarker == activeFenceMarker) {
            cache.isCodeFenceLine = true;
            cache.isCodeFenceClosing = true;
            if (cache.codeFenceLanguage.empty()) {
                cache.codeFenceLanguage = fenceLanguage;
            }
            insideFence = false;
            activeFenceMarker = 0;
            activeFenceLanguage.clear();
        }
    } else if (isFenceLine) {
        cache.isCodeBlockLine = true;
        cache.isCodeFenceLine = true;
        cache.isCodeFenceOpening = true;
        cache.codeFenceMarker = fenceMarker;
        cache.codeFenceLanguage = fenceLanguage;
        insideFence = true;
        activeFenceMarker = fenceMarker;
        activeFenceLanguage = fenceLanguage;
    }

    if (insideCustomContainer) {
        cache.isCustomContainerLine = true;
        cache.customContainerFenceCount = activeCustomContainerFenceCount;
        cache.customContainerKind = activeCustomContainerKind;
        if (!insideFence && isCustomContainerFenceLine && customContainerKind.empty() &&
            customFenceCount >= std::max(3, activeCustomContainerFenceCount)) {
            cache.isCustomContainerFenceLine = true;
            cache.isCustomContainerClosing = true;
            insideCustomContainer = false;
            activeCustomContainerFenceCount = 0;
            activeCustomContainerKind.clear();
        }
    } else if (!insideFence && isCustomContainerFenceLine) {
        cache.isCustomContainerLine = true;
        cache.isCustomContainerFenceLine = true;
        cache.isCustomContainerOpening = true;
        cache.customContainerFenceCount = customFenceCount;
        cache.customContainerKind = customContainerKind;
        insideCustomContainer = true;
        activeCustomContainerFenceCount = customFenceCount;
        activeCustomContainerKind = customContainerKind;
    }

    std::vector<const note::InlineNode*> lineTextNodes;
    std::vector<const note::InlineNode*> lineOverlayNodes;
    std::vector<const note::StyleSpan*> lineStyleSpans;
    std::vector<const note::MathSpan*> lineMathSpans;

    for (const auto& block : CurrentNoteDocument().blocks) {
        if (!IntersectsRawRange(block.span, lineStart, lineEnd)) continue;
        if (block.kind == note::BlockKind::Heading) {
            cache.headingLevel = std::max(cache.headingLevel, block.level);
            cache.headingPrefixLevel = std::max(cache.headingPrefixLevel, block.level);
        } else if (block.kind == note::BlockKind::HorizontalRule) {
            cache.isHorizontalRuleLine = true;
        }
    }

    for (const auto& inlineNode : CurrentNoteDocument().inlines) {
        if (!IntersectsRawRange(inlineNode.span, lineStart, lineEnd)) continue;
        if (inlineNode.kind == note::InlineKind::Text) {
            lineTextNodes.push_back(&inlineNode);
        } else {
            lineOverlayNodes.push_back(&inlineNode);
        }
    }
    for (const auto& styleSpan : CurrentNoteDocument().style_spans) {
        if (IntersectsRawRange(styleSpan.span, lineStart, lineEnd)) {
            lineStyleSpans.push_back(&styleSpan);
        }
    }
    std::stable_sort(lineStyleSpans.begin(), lineStyleSpans.end(), [](const note::StyleSpan* a, const note::StyleSpan* b) {
        size_t lenA = a->span.end > a->span.start ? a->span.end - a->span.start : 0;
        size_t lenB = b->span.end > b->span.start ? b->span.end - b->span.start : 0;
        return lenA > lenB;
    });
    for (const auto& mathSpan : CurrentNoteDocument().math_spans) {
        if (IntersectsRawRange(mathSpan.span, lineStart, lineEnd)) {
            lineMathSpans.push_back(&mathSpan);
        }
    }

    std::sort(lineTextNodes.begin(), lineTextNodes.end(), [](const note::InlineNode* lhs, const note::InlineNode* rhs) {
        if (lhs->span.start != rhs->span.start) return lhs->span.start < rhs->span.start;
        return lhs->span.end < rhs->span.end;
    });

    const note::MathSpan* blockMathSpan = FindBlockMathForRenderLine(lineMathSpans);
    if (blockMathSpan) {
        AppendBlockMathRepresentativeSegment(*blockMathSpan, lineStart, lineEnd, &cache);
    }

    if (!blockMathSpan) {
    size_t firstVisibleRaw = lineEnd;
    for (const note::InlineNode* inlineNode : lineTextNodes) {
        if (!inlineNode) continue;
        note::Span clipped{
            {std::max(inlineNode->span.start.value, lineStart)},
            {std::min(inlineNode->span.end.value, lineEnd)}
        };
        if (clipped.end <= clipped.start) continue;
        const std::vector<note::Span> visibleSlices =
            CollectVisibleRawSlicesForNoteDocument(text, clipped, baseFontHeightPx);
        if (!visibleSlices.empty()) {
            firstVisibleRaw = std::min(firstVisibleRaw, visibleSlices.front().start.value);
        }
    }

    if (cache.headingLevel == 0 && firstVisibleRaw > lineStart && firstVisibleRaw <= lineEnd) {
        const std::vector<note::Span> prefixSlices =
            CollectVisibleRawSlicesForNoteDocument(text,
                                                   note::Span{lineStart, firstVisibleRaw},
                                                   baseFontHeightPx);
        for (const auto& slice : prefixSlices) {
            if (slice.end.value <= slice.start.value) continue;
            const size_t visibleEnd = HideMarkdownOpeningMarkerEnd(text, lineStart, slice.end.value, lineOverlayNodes);
            if (visibleEnd <= slice.start.value) continue;
            Segment seg;
            seg.text = DecodeLiteralEscapes(note::DecodeMarkdownBackslashEscapes(
                text.substr(slice.start.value, visibleEnd - slice.start.value)));
            seg.rawStart = slice.start.value - lineStart;
            seg.rawLen = visibleEnd - slice.start.value;
            if (!seg.text.empty()) {
                cache.segments.push_back(std::move(seg));
            }
        }
    }

    for (const note::InlineNode* inlineNode : lineTextNodes) {
        if (!inlineNode) continue;
        note::Span clipped{
            {std::max(inlineNode->span.start.value, lineStart)},
            {std::min(inlineNode->span.end.value, lineEnd)}
        };
        if (clipped.end <= clipped.start) continue;

        const std::vector<note::Span> visibleSlices =
            CollectVisibleRawSlicesForNoteDocument(text, clipped, baseFontHeightPx);
        for (const auto& slice : visibleSlices) {
            if (slice.end.value <= slice.start.value) continue;
            std::vector<size_t> cuts{slice.start.value, slice.end.value};
            for (const note::InlineNode* overlay : lineOverlayNodes) {
                if (!overlay || !IntersectsRawRange(overlay->span, slice.start.value, slice.end.value)) continue;
                if (overlay->span.start.value > slice.start.value && overlay->span.start.value < slice.end.value) {
                    cuts.push_back(overlay->span.start.value);
                }
                if (overlay->span.end.value > slice.start.value && overlay->span.end.value < slice.end.value) {
                    cuts.push_back(overlay->span.end.value);
                }
            }
            for (const note::StyleSpan* styleSpan : lineStyleSpans) {
                if (!styleSpan || !IntersectsRawRange(styleSpan->span, slice.start.value, slice.end.value)) continue;
                if (styleSpan->span.start.value > slice.start.value && styleSpan->span.start.value < slice.end.value) {
                    cuts.push_back(styleSpan->span.start.value);
                }
                if (styleSpan->span.end.value > slice.start.value && styleSpan->span.end.value < slice.end.value) {
                    cuts.push_back(styleSpan->span.end.value);
                }
            }
            for (const note::MathSpan* mathSpan : lineMathSpans) {
                if (!mathSpan || !IntersectsRawRange(mathSpan->span, slice.start.value, slice.end.value)) continue;
                if (mathSpan->span.start.value > slice.start.value && mathSpan->span.start.value < slice.end.value) {
                    cuts.push_back(mathSpan->span.start.value);
                }
                if (mathSpan->span.end.value > slice.start.value && mathSpan->span.end.value < slice.end.value) {
                    cuts.push_back(mathSpan->span.end.value);
                }
            }
            std::sort(cuts.begin(), cuts.end());
            cuts.erase(std::unique(cuts.begin(), cuts.end()), cuts.end());

            for (size_t i = 0; i + 1 < cuts.size(); ++i) {
                const size_t segStart = cuts[i];
                const size_t segEnd = cuts[i + 1];
                if (segEnd <= segStart) continue;

                Segment seg;
                seg.rawStart = segStart - lineStart;
                seg.rawLen = segEnd - segStart;

                for (const note::InlineNode* overlay : lineOverlayNodes) {
                    if (!overlay) continue;
                    if (overlay->span.start.value > segStart || overlay->span.end.value < segEnd) continue;
                    switch (overlay->kind) {
                    case note::InlineKind::Emphasis:
                        seg.style.italic = true;
                        break;
                    case note::InlineKind::Strong:
                        seg.style.bold = true;
                        break;
                    case note::InlineKind::Strike:
                        seg.style.strike = true;
                        break;
                    case note::InlineKind::Link:
                        seg.isMarkdownLink = true;
                        break;
                    case note::InlineKind::Image:
                        seg.isMarkdownLink = true;
                        break;
                    case note::InlineKind::Code:
                        seg.isInlineCode = true;
                        break;
                    default:
                        break;
                    }
                }

                for (const note::StyleSpan* styleSpan : lineStyleSpans) {
                    if (!styleSpan) continue;
                    if (styleSpan->span.start.value > segStart || styleSpan->span.end.value < segEnd) continue;
                    ApplyNoteStyleSpanToStyle(*styleSpan, baseFontHeightPx, &seg.style);
                }

                for (const note::MathSpan* mathSpan : lineMathSpans) {
                    if (!mathSpan) continue;
                    if (mathSpan->span.start.value > segStart || mathSpan->span.end.value < segEnd) continue;
                    seg.isMath = true;
                    seg.isMarkupMath = (mathSpan->delimiter == note::MathDelimiter::LegacyMathTag);
                    seg.mathDisplay = (mathSpan->kind == note::MathKind::Block);
                    const size_t contentStart = std::max(mathSpan->content_span.start.value, segStart);
                    const size_t contentEnd = std::min(mathSpan->content_span.end.value, segEnd);
                    if (contentEnd > contentStart) {
                        seg.mathText = text.substr(contentStart, contentEnd - contentStart);
                    }
                    ApplyDefaultMathSegmentLayout(&seg);
                    break;
                }

                const std::wstring rawSegment = text.substr(segStart, segEnd - segStart);
                seg.text = DecodeLiteralEscapes(
                    SegmentDecodesMarkdownBackslashEscapes(cache, seg)
                        ? note::DecodeMarkdownBackslashEscapes(rawSegment)
                        : rawSegment);

                if (!seg.text.empty()) {
                    cache.segments.push_back(std::move(seg));
                }
            }
        }
    }

    if (cache.segments.empty() && cache.isCodeFenceLine && !cache.rawLine.empty()) {
        Segment seg;
        seg.text = DecodeLiteralEscapes(cache.rawLine);
        seg.rawStart = 0;
        seg.rawLen = cache.rawLine.size();
        cache.segments.push_back(std::move(seg));
    }
    }

    for (const auto& seg : cache.segments) {
        if (seg.style.hasFontSize) {
            cache.hasFontSize = true;
            cache.fontSizePx = std::max(cache.fontSizePx, seg.style.fontSizePx);
        }
        if (seg.style.hasLineHeight) {
            cache.hasLineHeight = true;
            cache.lineHeightPermille = std::max(cache.lineHeightPermille,
                                                std::max(1000, seg.style.lineHeightPermille));
        }
    }

    if (fenceState) {
        fenceState->insideFence = insideFence;
        fenceState->activeFenceMarker = activeFenceMarker;
        fenceState->activeFenceLanguage = activeFenceLanguage;
        fenceState->insideCustomContainer = insideCustomContainer;
        fenceState->activeCustomContainerFenceCount = activeCustomContainerFenceCount;
        fenceState->activeCustomContainerKind = activeCustomContainerKind;
    }
    return cache;
}

static void RebuildMarkdownRenderCache(const std::wstring& text) {
    const int baseFontHeightPx = ComputeNoteRenderBaseFontHeightPx();
    RebuildRenderLineIndex(text);
    const std::vector<std::wstring>& lines = g_renderLines;
    const std::vector<NoteRenderLineInfo>& lineInfos = g_renderLineInfos;
    std::vector<LineCache> nextCache(lines.size());
    MarkdownFenceState fenceState;
    for (size_t lineIndex = 0; lineIndex < lines.size(); ++lineIndex) {
        nextCache[lineIndex] = BuildMarkdownRenderCacheLine(text, lines, lineInfos, lineIndex,
                                                            baseFontHeightPx, &fenceState);
    }
    g_lineCache = std::move(nextCache);
    SetLineCacheSourceRevision(CurrentNoteSyntaxSource().revision);
    ResetMarkdownRenderDerivedState(text, baseFontHeightPx, true);
}

static bool FindCachedRenderLineForRawEdit(const note::TextEdit& edit,
                                           size_t* outLine,
                                           size_t* outLineStart,
                                           size_t* outLineEnd) {
    if (!outLine || !outLineStart || !outLineEnd || g_lineCache.empty()) return false;
    size_t cursor = 0;
    for (size_t i = 0; i < g_lineCache.size(); ++i) {
        const size_t lineStart = cursor;
        const size_t lineEnd = lineStart + g_lineCache[i].rawLine.size();
        if (edit.start.value <= lineEnd || i + 1 == g_lineCache.size()) {
            if (edit.start.value < lineStart) return false;
            if (edit.start.value + edit.deleted_len > lineEnd) return false;
            *outLine = i;
            *outLineStart = lineStart;
            *outLineEnd = lineEnd;
            return true;
        }
        cursor = lineEnd + 1;
    }
    return false;
}

static bool TryRefreshMarkdownRenderCacheForDirtyGraph(const std::wstring& text,
                                                       int baseFontHeightPx,
                                                       const note::NoteDirtyGraph& graph) {
    if (g_lineCache.empty()) return false;
    if (!graph.has_edit || !graph.render_dirty) return false;
    const note::TextEdit& edit = graph.edit;
    if (CurrentNoteSyntaxSource().revision == 0 ||
        !LineCacheMatchesSourceRevision(CurrentNoteSyntaxSource().revision - 1)) {
        return false;
    }

    std::vector<LineCache> oldCache = g_lineCache;
    size_t firstLine = 0;
    size_t lastLine = 0;
    if (!TryApplyRenderLineIndexEdit(text, edit, &firstLine, &lastLine)) {
        return false;
    }
    if (graph.stale_lines.valid) {
        firstLine = std::min(firstLine, graph.stale_lines.first);
        lastLine = std::max(lastLine, graph.stale_lines.last);
    }

    const size_t oldCount = oldCache.size();
    const size_t newCount = g_renderLines.size();
    if (g_renderLineInfos.size() != newCount) {
        RebuildMarkdownRenderCache(text);
        MarkNoteRenderDirtyAll(true);
        return true;
    }

    g_lineCache.resize(newCount);
    const size_t startLine = std::min(firstLine, newCount);
    MarkdownFenceState fenceState;
    SeedMarkdownFenceStateFromPreviousLine(oldCache, startLine, &fenceState);

    const bool lineCountChanged = oldCount != newCount;
    const bool allowEarlyStop =
        note::NoteDirtyGraphAllowsRenderEarlyStop(graph, lineCountChanged);
    const ptrdiff_t oldIndexShift =
        static_cast<ptrdiff_t>(oldCount) - static_cast<ptrdiff_t>(newCount);
    auto oldIndexForNewLine = [&](size_t lineIndex) -> std::optional<size_t> {
        const ptrdiff_t oldIndex = static_cast<ptrdiff_t>(lineIndex) + oldIndexShift;
        if (oldIndex < 0 || oldIndex >= static_cast<ptrdiff_t>(oldCount)) {
            return std::nullopt;
        }
        return static_cast<size_t>(oldIndex);
    };
    auto tryReuseShiftedTail = [&](size_t firstTailLine) -> bool {
        for (size_t lineIndex = firstTailLine; lineIndex < newCount; ++lineIndex) {
            if (!oldIndexForNewLine(lineIndex).has_value()) {
                return false;
            }
        }
        for (size_t lineIndex = firstTailLine; lineIndex < newCount; ++lineIndex) {
            g_lineCache[lineIndex] = oldCache[*oldIndexForNewLine(lineIndex)];
        }
        return true;
    };
    bool rebuiltAny = false;
    size_t rebuiltLastLine = startLine;
    for (size_t lineIndex = startLine; lineIndex < g_renderLines.size(); ++lineIndex) {
        LineCache nextCache = BuildMarkdownRenderCacheLine(text, g_renderLines, g_renderLineInfos,
                                                           lineIndex, baseFontHeightPx, &fenceState);
        std::optional<size_t> compareOldIndex;
        if (!lineCountChanged) {
            if (lineIndex < oldCount) compareOldIndex = lineIndex;
        } else if (lineIndex > lastLine) {
            compareOldIndex = oldIndexForNewLine(lineIndex);
        }
        bool matchesOld = compareOldIndex.has_value() &&
                          LineCacheEquals(nextCache, oldCache[*compareOldIndex]);
        g_lineCache[lineIndex] = std::move(nextCache);
        rebuiltAny = true;
        rebuiltLastLine = lineIndex;
        if (allowEarlyStop && lineIndex >= lastLine && matchesOld) {
            break;
        }
        if (lineCountChanged && lineIndex > lastLine && matchesOld &&
            tryReuseShiftedTail(lineIndex + 1)) {
            break;
        }
    }
    if (rebuiltAny) {
        MarkNoteRenderDirtyLines(startLine, rebuiltLastLine, lineCountChanged);
    } else if (lineCountChanged) {
        MarkNoteRenderDirtyAll(true);
    }
    SetLineCacheSourceRevision(CurrentNoteSyntaxSource().revision);
    ResetMarkdownRenderDerivedState(text, baseFontHeightPx, true);
    return true;
}

static void RefreshMarkdownRenderCache(const std::wstring& text, std::optional<note::NoteDirtyGraph> pendingGraph) {
    const int baseFontHeightPx = ComputeNoteRenderBaseFontHeightPx();
    const bool hasPendingRenderGraph = pendingGraph.has_value();
    const bool fontProfileChanged =
        (baseFontHeightPx != g_lastParsedMarkupBaseFontHeightPx) || g_lineCache.empty();
    if (!fontProfileChanged && hasPendingRenderGraph) {
        const note::NoteDirtyGraph graph = *pendingGraph;
        if (TryRefreshMarkdownRenderCacheForDirtyGraph(text, baseFontHeightPx, graph)) {
            return;
        }
    }
    if (fontProfileChanged || (!g_lineCache.empty() && !LineCacheMatchesCurrentTextCore())) {
        RebuildMarkdownRenderCache(text);
        MarkNoteRenderDirtyAll(true);
        return;
    }
    RebuildRenderLineIndex(text);
    const std::vector<std::wstring>& lines = g_renderLines;
    const std::vector<NoteRenderLineInfo>& lineInfos = g_renderLineInfos;
    if (lines.empty()) {
        ClearLegacyRenderCache();
        return;
    }
    std::vector<LineCache> oldCache = g_lineCache;
    size_t oldCount = g_lineCache.size();
    size_t newCount = lines.size();
    size_t minCount = std::min(oldCount, newCount);
    size_t firstDiff = 0;
    while (firstDiff < minCount && lines[firstDiff] == g_lineCache[firstDiff].rawLine) {
        ++firstDiff;
    }
    if (firstDiff == newCount && firstDiff == oldCount) {
        SetLineCacheSourceRevision(CurrentNoteSyntaxSource().revision);
        ResetMarkdownRenderDerivedState(text, baseFontHeightPx, false);
        return;
    }

    bool lineCountChanged = (oldCount != newCount);
    size_t lastDiff = (newCount > 0) ? (newCount - 1) : 0;
    if (newCount > 0) {
        size_t oldTail = oldCount;
        size_t newTail = newCount;
        while (oldTail > firstDiff && newTail > firstDiff &&
               lines[newTail - 1] == g_lineCache[oldTail - 1].rawLine) {
            --oldTail;
            --newTail;
        }
        if (newTail > 0) lastDiff = newTail - 1;
    }

    g_lineCache.resize(newCount);
    size_t startLine = firstDiff;
    MarkdownFenceState fenceState;
    SeedMarkdownFenceStateFromPreviousLine(oldCache, startLine, &fenceState);

    const ptrdiff_t oldIndexShift = static_cast<ptrdiff_t>(oldCount) - static_cast<ptrdiff_t>(newCount);
    auto oldIndexForNewLine = [&](size_t lineIndex) -> std::optional<size_t> {
        const ptrdiff_t oldIndex = static_cast<ptrdiff_t>(lineIndex) + oldIndexShift;
        if (oldIndex < 0 || oldIndex >= static_cast<ptrdiff_t>(oldCount)) return std::nullopt;
        return static_cast<size_t>(oldIndex);
    };

    bool rebuiltAny = false;
    size_t rebuiltLastLine = startLine;
    for (size_t lineIndex = startLine; lineIndex < lines.size(); ++lineIndex) {
        LineCache nextCache = BuildMarkdownRenderCacheLine(text, lines, lineInfos, lineIndex,
                                                           baseFontHeightPx, &fenceState);
        std::optional<size_t> compareOldIndex;
        if (!lineCountChanged) {
            if (lineIndex < oldCount) compareOldIndex = lineIndex;
        } else if (lineIndex > lastDiff) {
            compareOldIndex = oldIndexForNewLine(lineIndex);
        }
        bool matchesOld = compareOldIndex.has_value() &&
                          LineCacheEquals(nextCache, oldCache[*compareOldIndex]);
        g_lineCache[lineIndex] = std::move(nextCache);
        rebuiltAny = true;
        rebuiltLastLine = lineIndex;
        if (!lineCountChanged && lineIndex >= lastDiff && matchesOld) {
            break;
        }
        if (lineCountChanged && lineIndex > lastDiff && matchesOld) {
            bool tailMatchValid = true;
            for (size_t tail = lineIndex + 1; tail < newCount; ++tail) {
                if (!oldIndexForNewLine(tail).has_value()) {
                    tailMatchValid = false;
                    break;
                }
            }
            if (tailMatchValid) {
                for (size_t tail = lineIndex + 1; tail < newCount; ++tail) {
                    g_lineCache[tail] = oldCache[*oldIndexForNewLine(tail)];
                }
                break;
            }
        }
    }
    if (rebuiltAny) {
        MarkNoteRenderDirtyLines(startLine, rebuiltLastLine, lineCountChanged);
    } else if (lineCountChanged) {
        MarkNoteRenderDirtyAll(true);
    }
    SetLineCacheSourceRevision(CurrentNoteSyntaxSource().revision);
    ResetMarkdownRenderDerivedState(text, baseFontHeightPx, true);
}



static std::wstring MathEntryDelimLabel(const MathEntry& entry) {
    if (entry.kind == MathKind::Markup) {
        return L"<math>...</>";
    }
    const std::wstring& raw = entry.text;
    if (raw.size() >= 4 && raw[0] == L'$' && raw[1] == L'$' &&
        raw[raw.size() - 2] == L'$' && raw[raw.size() - 1] == L'$') {
        return L"$$...$$";
    }
    if (raw.size() >= 2 && raw.front() == L'$' && raw.back() == L'$') {
        return L"$...$";
    }
    if (raw.size() >= 4 && raw[0] == L'\\' && raw[1] == L'[' &&
        raw[raw.size() - 2] == L'\\' && raw[raw.size() - 1] == L']') {
        return L"\\[...\\]";
    }
    if (raw.size() >= 4 && raw[0] == L'\\' && raw[1] == L'(' &&
        raw[raw.size() - 2] == L'\\' && raw[raw.size() - 1] == L')') {
        return L"\\(...\\)";
    }
    return L"LaTeX";
}

// v0-only note view: keep the edit control visible and standard.

void RefreshBottomPaneView() {
    if (!g_hBottomNote || !g_hBottomMath) return;
    auto redrawBottomPaneHost = [&]() {
        HWND parent = GetParent(g_hBottomNote);
        if (!parent) return;
        HWND basis = (g_bottomPanePin == BottomPanePin::Math) ? g_hBottomMath : g_hBottomNote;
        if (!basis) return;
        RECT wr{};
        if (!GetWindowRect(basis, &wr)) return;
        POINT tl{ wr.left, wr.top };
        POINT br{ wr.right, wr.bottom };
        if (!ScreenToClient(parent, &tl) || !ScreenToClient(parent, &br)) return;
        RECT rc{ tl.x, tl.y, br.x, br.y };
        RedrawWindow(parent, &rc, nullptr, RDW_INVALIDATE | RDW_UPDATENOW);
    };
    auto redrawChildNow = [](HWND child) {
        if (!child || !IsWindowVisible(child)) return;
        RedrawWindow(child, nullptr, nullptr,
                     RDW_INVALIDATE | RDW_ERASE | RDW_FRAME | RDW_UPDATENOW);
    };
    if (g_bottomPanePin == BottomPanePin::Math) {
        ShowWindow(g_hBottomNote, SW_HIDE);
        ShowWindow(g_hBottomMath, SW_SHOW);
        redrawBottomPaneHost();
        redrawChildNow(g_hBottomMath);
        return;
    }
    ShowWindow(g_hBottomMath, SW_HIDE);
    if (g_bottomNoteMode == BottomNoteMode::Legacy) {
        ShowWindow(g_hBottomNote, SW_HIDE);
        redrawBottomPaneHost();
        return;
    }
    if (!ShouldShowBottomNotePane()) {
        ShowWindow(g_hBottomNote, SW_HIDE);
        redrawBottomPaneHost();
        return;
    }
    ShowWindow(g_hBottomNote, SW_SHOW);
    redrawBottomPaneHost();
    redrawChildNow(g_hBottomNote);
}

void UpdateNoteViewMode() {
    if (!g_hNoteEdit) return;
    ShowScrollBar(g_hNoteEdit, SB_VERT, TRUE);
    ShowWindow(g_hNoteEdit, SW_SHOW);
    UpdateNoteFormatRect(g_hNoteEdit);
    HWND owner = g_hMainWnd ? g_hMainWnd : GetParent(g_hNoteEdit);
    SyncNoteWrapMenuState(owner);
    UpdateNoteEditAvailability();
}

static bool TryResolveNoteRenderedHorizontalExtent(HWND hWnd, int* outRightPx) {
    if (!outRightPx) return false;
    if (!IsNoteRenderActive()) {
        *outRightPx = 0;
        g_noteRenderedHorizontalExtentDirty = false;
        return true;
    }
    if (!CanReadStableRenderDerivedState()) {
        return false;
    }

    HDC hdc = GetDC(hWnd);
    if (!hdc) {
        // Keep the last committed extent and retain dirty state for the next pass.
        return false;
    }
    *outRightPx = MeasureRenderedContentRightPx(hWnd, hdc);
    ReleaseDC(hWnd, hdc);
    g_noteRenderedHorizontalExtentDirty = false;
    return true;
}

void UpdateNoteLineSpacing(std::optional<note::NoteDirtyGraph> pendingGraph) {
    g_noteLineSpacingInvalidatedNote = false;
    if (!g_hNoteEdit) return;
    if (g_noteApplyingLineSpacing) return;
    if (!IsRichEditControl(g_hNoteEdit)) {
        InvalidateRect(g_hNoteEdit, nullptr, FALSE);
        g_noteLineSpacingInvalidatedNote = true;
        return;
    }
    std::optional<NoteRenderDirtyLineRange> dirtyRange = TakeNoteRenderDirtyLines();
    const note::NoteDerivedSnapshotIdentity layoutSourceIdentity{
        CurrentNoteTextCoreOwner(), CurrentNoteTextCoreModel().revision};

    auto lineNeedsFullSpacingEvaluation = [](const LineCache& cache) -> bool {
        if (cache.headingLevel > 0 || cache.headingPrefixLevel > 0 ||
            cache.hasFontSize || cache.hasLineHeight ||
            cache.isCodeBlockLine || cache.isCustomContainerLine) {
            return true;
        }
        for (const auto& seg : cache.segments) {
            if (seg.style.hasFontSize || seg.style.hasLineHeight || ShouldRenderMathSegment(seg)) {
                return true;
            }
        }
        return false;
    };
    std::optional<note::NoteDirtyGraph> lineSpacingGraph;
    if (IsNoteRenderActive() && pendingGraph.has_value()) {
        lineSpacingGraph = *pendingGraph;
        const note::TextEdit edit = lineSpacingGraph->edit;
        if (note::NoteDirtyGraphAllowsLineSpacingFastPath(*lineSpacingGraph)) {
            size_t lineIndex = 0;
            size_t oldLineStart = 0;
            size_t oldLineEnd = 0;
            if (FindCachedRenderLineForRawEdit(edit, &lineIndex, &oldLineStart, &oldLineEnd) &&
                lineIndex < g_lineCache.size() &&
                !lineNeedsFullSpacingEvaluation(g_lineCache[lineIndex])) {
                // Paragraph spacing can stay unchanged, but rendered width cannot: ordinary
                // typing or completion of an anchor tag can change the canvas extent.
                int nextRenderedContentRightPx = g_noteRenderedContentRightPx;
                if (TryResolveNoteRenderedHorizontalExtent(g_hNoteEdit, &nextRenderedContentRightPx) &&
                    nextRenderedContentRightPx != g_noteRenderedContentRightPx) {
                    g_noteRenderedContentRightPx = nextRenderedContentRightPx;
                    UpdateNoteFormatRect(g_hNoteEdit);
                }
                if (!InvalidateNoteRenderDirtyLines(g_hNoteEdit, dirtyRange, 24, false)) {
                    InvalidateRect(g_hNoteEdit, nullptr, FALSE);
                }
                g_noteLineSpacingInvalidatedNote = true;
                return;
            }
        }
    }

    const bool manageRedraw = !IsNoteRenderSwitchInProgress();
    if (manageRedraw) {
        SendMessageW(g_hNoteEdit, WM_SETREDRAW, FALSE, 0);
    }

    auto pxToTwipsY = [](HWND hWnd, int px) -> LONG {
        int dpi = GetDpiY(hWnd);
        if (dpi <= 0) dpi = 96;
        px = std::max(0, px);
        return static_cast<LONG>(MulDiv(px, 1440, dpi));
    };
    auto computeBaseLinePx = [](HWND hWnd) -> int {
        int dpi = GetDpiY(hWnd);
        if (dpi <= 0) dpi = 96;
        double pt = (g_noteFontPt > 0.0) ? g_noteFontPt : 10.0;
        int fallbackPx = std::max(8, static_cast<int>(std::lround(pt * dpi / 72.0)));
        HDC hdc = GetDC(hWnd);
        if (!hdc) {
            return fallbackPx;
        }
        HFONT font = GetActiveNoteFont();
        HFONT old = font ? static_cast<HFONT>(SelectObject(hdc, font)) : nullptr;
        TEXTMETRICW tm{};
        int measuredPx = fallbackPx;
        if (GetTextMetricsW(hdc, &tm)) {
            int height = std::max<int>(1, static_cast<int>(tm.tmHeight));
            measuredPx = std::max(measuredPx, height);
        }
        if (old) SelectObject(hdc, old);
        ReleaseDC(hWnd, hdc);
        return measuredPx;
    };

    BYTE lineRule = 0;
    LONG lineTwips = 0;
    int basePx = computeBaseLinePx(g_hNoteEdit);
    if (IsNoteRenderActive()) {
        lineRule = 4; // exact
        lineTwips = pxToTwipsY(g_hNoteEdit, basePx);
    }
    if (IsNoteRenderActive() && lineSpacingGraph.has_value() && dirtyRange.has_value() &&
        dirtyRange->lineCountChanged && !dirtyRange->full &&
        g_noteLineSpacingRuleCache == lineRule &&
        g_noteLineSpacingTwipsCache == lineTwips &&
        note::CanAdvanceLayoutSnapshot(g_noteAppliedLayoutSnapshot,
                                       layoutSourceIdentity)) {
        const int oldCount = static_cast<int>(g_noteAppliedLayoutSnapshot.lines.size());
        const int newCount = static_cast<int>(g_lineCache.size());
        const int delta = newCount - oldCount;
        if ((delta == -1 || delta == 1) && newCount > 0 && oldCount > 0) {
            const int maxLine = newCount - 1;
            int localFirst = static_cast<int>(std::min(dirtyRange->first, static_cast<size_t>(maxLine)));
            int localLast = static_cast<int>(std::min(dirtyRange->last, static_cast<size_t>(maxLine)));
            if (localLast < localFirst) std::swap(localFirst, localLast);
            localFirst = std::max(0, localFirst - 1);
            localLast = std::min(maxLine, localLast + 1);

            bool localNeedsFullSpacing = false;
            for (int line = localFirst; line <= localLast; ++line) {
                if (lineNeedsFullSpacingEvaluation(g_lineCache[static_cast<size_t>(line)])) {
                    localNeedsFullSpacing = true;
                    break;
                }
            }
            auto mapOldLine = [&](int newLine) -> int {
                if (newLine < localFirst) return newLine;
                if (newLine > localLast) return newLine - delta;
                return -1;
            };
            auto canMapUnchangedTail = [&]() -> bool {
                for (int line = 0; line < newCount; ++line) {
                    int oldLine = mapOldLine(line);
                    if (oldLine < 0) continue;
                    if (oldLine >= oldCount) return false;
                }
                return true;
            };
            if (!localNeedsFullSpacing && canMapUnchangedTail()) {
                auto shiftProfile = [&]() {
                    std::vector<note::NoteLayoutLineMetrics> next(
                        static_cast<size_t>(newCount));
                    for (int line = 0; line < newCount; ++line) {
                        int oldLine = mapOldLine(line);
                        if (oldLine >= 0) {
                            next[static_cast<size_t>(line)] =
                                g_noteAppliedLayoutSnapshot.lines[static_cast<size_t>(oldLine)];
                        }
                    }
                    return next;
                };

                std::vector<note::NoteLayoutLineMetrics> shifted = shiftProfile();
                g_noteAppliedLayoutSnapshot.Commit(layoutSourceIdentity, shifted);
                g_noteMeasuredLayoutSnapshot.Commit(layoutSourceIdentity,
                                                    std::move(shifted));

                g_noteRenderedContentBottomPx = std::max(0, g_noteRenderedContentBottomPx + delta * basePx);
                UpdateNoteFormatRect(g_hNoteEdit);
                if (!InvalidateNoteRenderDirtyLines(g_hNoteEdit, dirtyRange, basePx, false)) {
                    InvalidateRect(g_hNoteEdit, nullptr, FALSE);
                }
                g_noteLineSpacingInvalidatedNote = true;
                return;
            }
        }
    }
    const int wantFirstVisibleLine =
        static_cast<int>(SendMessageW(g_hNoteEdit, EM_GETFIRSTVISIBLELINE, 0, 0));
    const NoteRenderViewportAnchor renderViewportAnchor =
        CaptureNoteRenderViewportAnchor(g_hNoteEdit, basePx);
    auto restoreViewportAfterFormatUpdate = [&]() {
        if (RestoreNoteRenderViewportAnchor(g_hNoteEdit, renderViewportAnchor)) {
            return;
        }
        const int nowFirstVisibleLine =
            static_cast<int>(SendMessageW(g_hNoteEdit, EM_GETFIRSTVISIBLELINE, 0, 0));
        if (wantFirstVisibleLine >= 0 && nowFirstVisibleLine >= 0 &&
            wantFirstVisibleLine != nowFirstVisibleLine) {
            SendMessageW(g_hNoteEdit, EM_LINESCROLL, 0,
                         static_cast<LPARAM>(wantFirstVisibleLine - nowFirstVisibleLine));
        }
    };

    // IMPORTANT:
    // EM_GETLINECOUNT / EM_LINEINDEX operate on *display lines* (soft wraps included).
    // Markup spacing is a *logical-line / paragraph* property. If the control wraps (e.g. after <s=>),
    // iterating display lines can re-apply base spacing mid-paragraph and effectively cancel <m>/<s> expansions.
    // Therefore, apply paragraph-format spacing by hard-line start indices. In rendered mode those
    // starts come from the render line index; otherwise fall back to RichEdit-compatible text.
    std::vector<size_t> paraStarts;
    if (IsNoteRenderActive() && !g_renderLineInfos.empty() &&
        g_renderLineInfos.size() == g_lineCache.size()) {
        paraStarts.reserve(g_renderLineInfos.size());
        for (const auto& info : g_renderLineInfos) {
            if (paraStarts.empty() || paraStarts.back() != info.start) {
                paraStarts.push_back(info.start);
            }
        }
    } else {
        const std::wstring indexingText = GetEditTextForIndexing(g_hNoteEdit);
        paraStarts.reserve(256);
        paraStarts.push_back(0);
        for (size_t i = 0; i < indexingText.size();) {
            wchar_t ch = indexingText[i];
            if (ch == L'\r') {
                size_t next = i + 1;
                if (next < indexingText.size() && indexingText[next] == L'\n') {
                    ++next;
                }
                if (next <= indexingText.size() && paraStarts.back() != next) {
                    paraStarts.push_back(next);
                }
                i = next;
                continue;
            }
            if (ch == L'\n') {
                size_t next = i + 1;
                if (next <= indexingText.size() && paraStarts.back() != next) {
                    paraStarts.push_back(next);
                }
            }
            ++i;
        }
    }
    if (paraStarts.empty()) {
        paraStarts.push_back(0);
    }

    int cacheCount = std::max<int>(1, static_cast<int>(g_lineCache.size()));
    int logicalCount = std::max<int>(cacheCount, static_cast<int>(paraStarts.size()));
    if (!IsNoteRenderActive()) {
        int richLineCount = static_cast<int>(SendMessageW(g_hNoteEdit, EM_GETLINECOUNT, 0, 0));
        if (richLineCount <= 0) richLineCount = 1;
        logicalCount = std::max(logicalCount, richLineCount);
    }

    std::vector<note::NoteLayoutLineMetrics> effectiveLines(
        static_cast<size_t>(logicalCount));
    int nextRenderedContentRightPx = g_noteRenderedContentRightPx;

    // Render OFF: do not apply markup-driven line height / font metrics.
    // Show raw text only, with default RichEdit spacing.
    if (!IsNoteRenderActive()) {
        // Keep effective* as defaults (1000 / 0 / 0).
    } else if (!g_lineCache.empty()) {
        int usable = std::min<int>(logicalCount, static_cast<int>(g_lineCache.size()));
        for (int line = 0; line < usable; ++line) {
            const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
            note::NoteLayoutLineMetrics& metrics = effectiveLines[static_cast<size_t>(line)];
            metrics.line_height_permille = ResolveLineHeightPermille(cache);
            metrics.max_font_px = ResolveLineMaxFontSizePx(cache);
        }

        // Auto-adjust per-line top margin distribution for large <s=> fonts.
        // If the top margin cannot be satisfied even with the maximum top ratio, increase the line height (m) for that line.
        {
            HDC hdc = GetDC(g_hNoteEdit);
            if (hdc) {
                MarkupFontProvider fonts;
                fonts.Initialize(hdc, GetActiveNoteFont());
                if (fonts.baseFont) {
                    int baseLineHeight = fonts.baseMetrics.tmHeight;
                    if (baseLineHeight <= 0) baseLineHeight = 1;
                    int baseAscent = fonts.baseAscent;
                    int baseDescent = std::max(1, baseLineHeight - baseAscent);
                    const int innerPad = std::max(1, baseLineHeight / 12);
                    const int renderYOffset = 1;
                    const int configTopPercent = std::clamp(g_config.noteMathMarginTopPercent, 5, 95);
                    const int kMaxTopPercent = 95;
                    constexpr int kMaxPermille = 7000;

                    auto ceilDiv = [](int a, int b) -> int {
                        if (b <= 0) return 0;
                        if (a <= 0) return 0;
                        return (a + b - 1) / b;
                    };

                    for (int line = 0; line < usable; ++line) {
                        const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
                        note::NoteLayoutLineMetrics& metrics =
                            effectiveLines[static_cast<size_t>(line)];
                        int permille = metrics.line_height_permille;
                        int requestedFontPx = metrics.max_font_px;

                        int maxAscent = baseAscent;
                        int maxDescent = baseDescent;
                        for (const auto& seg : cache.segments) {
                            if (seg.text.empty()) continue;
                            int segHeading = EffectiveSegmentHeadingLevel(cache, seg);
                            int extraPx = ComputeSegmentFontExtraPx(segHeading, seg.style, baseLineHeight);
                            bool effectiveBold = seg.style.bold || (segHeading > 0 && g_config.headingBold);
                            const std::wstring* fontFaceOverride = EffectiveSegmentFontFaceOverride(cache, seg);

                            TEXTMETRICW tmLat{};
                            fonts.Acquire(hdc, effectiveBold, seg.style.italic, extraPx, &tmLat,
                                          /*japanese=*/false, fontFaceOverride);
                            maxAscent = std::max(maxAscent, static_cast<int>(tmLat.tmAscent));
                            maxDescent = std::max(maxDescent,
                                                  std::max(1, static_cast<int>(tmLat.tmHeight - tmLat.tmAscent)));

                            bool hasJp = false;
                            for (wchar_t ch : seg.text) {
                                if (IsJapaneseRenderChar(ch)) { hasJp = true; break; }
                            }
                            if (hasJp) {
                                TEXTMETRICW tmJp{};
                                fonts.Acquire(hdc, effectiveBold, seg.style.italic, extraPx, &tmJp,
                                              /*japanese=*/true, fontFaceOverride);
                                maxAscent = std::max(maxAscent, static_cast<int>(tmJp.tmAscent));
                                maxDescent = std::max(maxDescent,
                                                      std::max(1, static_cast<int>(tmJp.tmHeight - tmJp.tmAscent)));
                            }

                            if (ShouldRenderMathSegment(seg)) {
                                std::wstring mathBody = GetSegmentMathBody(seg);
                                if (const mathrender::Node* node = GetCachedMathNode(mathBody)) {
                                    auto layout = MeasureCachedMathLayout(*node,
                                                                          hdc,
                                                                          mathBody,
                                                                          std::max(1, static_cast<int>(tmLat.tmHeight)),
                                                                          seg.mathDisplay ? mathrender::RenderStyle::Display
                                                                                          : mathrender::RenderStyle::Inline);
                                    const int displayPad = seg.mathDisplay
                                        ? std::max(4, static_cast<int>(tmLat.tmHeight) / 4)
                                        : 0;
                                    maxAscent = std::max(maxAscent, std::max(0, layout.baseline) + displayPad);
                                    maxDescent = std::max(maxDescent,
                                                          std::max(1, layout.height - std::max(0, layout.baseline)) +
                                                              displayPad);
                                }
                            }
                        }

                        const bool lineExtendsBaseMetrics =
                            (maxAscent > baseAscent) || (maxDescent > baseDescent) ||
                            (requestedFontPx > baseLineHeight);
                        const int visualSafetyPad = lineExtendsBaseMetrics
                            ? std::max(1, baseLineHeight / 10)
                            : 0;
                        const int specialLinePad = ResolveSpecialLineVisualPadPx(cache, baseLineHeight);
                        const int totalVisualPad = visualSafetyPad + specialLinePad;
                        const int paddedAscent = std::max(1, maxAscent + totalVisualPad);
                        const int paddedDescent = std::max(1, maxDescent + totalVisualPad);

                        metrics.visual_ascent_px = paddedAscent;
                        metrics.visual_descent_px = paddedDescent;

                        int requiredTop = paddedAscent - baseAscent - innerPad - renderYOffset + 1;
                        int baseBottom = std::max(0, baseLineHeight - baseAscent - innerPad - renderYOffset);
                        int requiredBottom = paddedDescent - baseBottom + 1;
                        requiredTop = std::max(0, requiredTop);
                        requiredBottom = std::max(0, requiredBottom);

                        int chosenPercent = 0;
                        int minExtra = 0;
                        if (requiredTop > 0 || requiredBottom > 0) {
                            if (requiredTop > 0 && requiredBottom > 0) {
                                int totalRequired = requiredTop + requiredBottom;
                                chosenPercent = std::clamp(
                                    static_cast<int>(std::lround(static_cast<double>(requiredTop) * 100.0 /
                                                                 static_cast<double>(totalRequired))),
                                    5, kMaxTopPercent);
                            } else if (requiredTop > 0) {
                                chosenPercent = kMaxTopPercent;
                            } else {
                                chosenPercent = 5;
                            }
                            int bottomPercent = std::max(1, 100 - chosenPercent);
                            int needTopExtra = ceilDiv(requiredTop * 100, chosenPercent);
                            int needBottomExtra = ceilDiv(requiredBottom * 100, bottomPercent);
                            minExtra = std::max(needTopExtra, needBottomExtra);
                        }

                        if (minExtra > 0 && permille <= 1000) {
                            // Enable "margin distribution" mode so we can bias extra space toward the top.
                            permille = 1001;
                        }

                        int targetPx = basePx;
                        if (permille > 1000) {
                            int want = static_cast<int>(std::lround(
                                static_cast<double>(basePx) * static_cast<double>(permille) / 1000.0));
                            targetPx = std::max(targetPx, want);
                        }
                        targetPx = std::max(targetPx, requestedFontPx);
                        if (minExtra > 0) {
                            targetPx = std::max(targetPx, baseLineHeight + minExtra);
                        }
                        targetPx = std::max(targetPx, paddedAscent + paddedDescent + 1);

                        if (chosenPercent > 0 && chosenPercent != configTopPercent) {
                            metrics.top_margin_percent_override = chosenPercent;
                        } else if (chosenPercent == 0 && configTopPercent != 0) {
                            metrics.top_margin_percent_override = 0;
                        }

                        metrics.max_font_px = std::max(metrics.max_font_px, targetPx);

                        if (basePx > 0 && permille > 1000) {
                            int needPermille = static_cast<int>(std::ceil(static_cast<double>(targetPx) * 1000.0 /
                                                                          static_cast<double>(basePx)));
                            needPermille = std::clamp(needPermille, 1001, kMaxPermille);
                            permille = std::max(permille, needPermille);
                        }
                        metrics.line_height_permille = permille;
                    }
                }
                ReleaseDC(g_hNoteEdit, hdc);
            }
        }

        g_noteMeasuredLayoutSnapshot.Commit(layoutSourceIdentity, effectiveLines);
    } else if (IsNoteRenderActive() &&
               g_noteMeasuredLayoutSnapshot.Matches(layoutSourceIdentity)) {
        const size_t copyCount = std::min(effectiveLines.size(),
                                          g_noteMeasuredLayoutSnapshot.lines.size());
        std::copy_n(g_noteMeasuredLayoutSnapshot.lines.begin(), copyCount,
                    effectiveLines.begin());
    }

    if (!TryResolveNoteRenderedHorizontalExtent(g_hNoteEdit, &nextRenderedContentRightPx) &&
        g_noteRenderedHorizontalExtentDirty) {
        // No new authoritative extent is available. Retain the committed extent rather
        // than publishing an unmeasured zero-width canvas.
        nextRenderedContentRightPx = g_noteRenderedContentRightPx;
    }

    const bool appliedLayoutCanAdvance =
        note::CanAdvanceLayoutSnapshot(g_noteAppliedLayoutSnapshot,
                                       layoutSourceIdentity);
    bool spacingProfileUnchanged =
        appliedLayoutCanAdvance &&
        (lineRule == g_noteLineSpacingRuleCache) &&
        (lineTwips == g_noteLineSpacingTwipsCache) &&
        note::SameParagraphSpacing(effectiveLines,
                                   g_noteAppliedLayoutSnapshot.lines);
    bool renderedWidthUnchanged = (nextRenderedContentRightPx == g_noteRenderedContentRightPx);

    const bool visualProfileUnchanged =
        appliedLayoutCanAdvance &&
        note::SameVisualMetrics(effectiveLines,
                                g_noteAppliedLayoutSnapshot.lines);
    if (spacingProfileUnchanged) {
        bool needsRepaint = !visualProfileUnchanged;
        bool needsFormatUpdate = false;
        g_noteAppliedLayoutSnapshot.Commit(layoutSourceIdentity, effectiveLines);
        if (!renderedWidthUnchanged) {
            g_noteRenderedContentRightPx = nextRenderedContentRightPx;
            needsRepaint = true;
            needsFormatUpdate = true;
        }
        if (IsNoteRenderActive() && CanReadStableRenderDerivedState()) {
            HDC hdc = GetDC(g_hNoteEdit);
            if (hdc) {
                int nextRenderedContentBottomPx = MeasureRenderedContentBottomPx(g_hNoteEdit, hdc);
                ReleaseDC(g_hNoteEdit, hdc);
                if (nextRenderedContentBottomPx != g_noteRenderedContentBottomPx) {
                    g_noteRenderedContentBottomPx = nextRenderedContentBottomPx;
                    needsRepaint = true;
                    needsFormatUpdate = true;
                }
            }
        } else if (g_noteRenderedContentBottomPx != 0) {
            g_noteRenderedContentBottomPx = 0;
            needsFormatUpdate = true;
        }
        if (needsFormatUpdate) {
            UpdateNoteFormatRect(g_hNoteEdit);
            restoreViewportAfterFormatUpdate();
        }
        if (dirtyRange.has_value()) {
            needsRepaint = true;
        }
        if (needsRepaint) {
            if (!needsFormatUpdate &&
                InvalidateNoteRenderDirtyLines(g_hNoteEdit, dirtyRange, basePx, false)) {
                g_noteLineSpacingInvalidatedNote = true;
            } else {
                InvalidateRect(g_hNoteEdit, nullptr, FALSE);
                g_noteLineSpacingInvalidatedNote = true;
            }
        }
        if (manageRedraw) {
            SendMessageW(g_hNoteEdit, WM_SETREDRAW, TRUE, 0);
        }
        return;
    }

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    POINT scroll{};
    bool hasScroll = QueryEditScrollPos(g_hNoteEdit, &scroll);
    DWORD eventMask = static_cast<DWORD>(SendMessageW(g_hNoteEdit, EM_GETEVENTMASK, 0, 0));
    auto applyLineSpacingSelection = [&](LONG from, LONG to, BYTE rule, LONG twips) {
        PARAFORMAT2 pf{};
        pf.cbSize = sizeof(pf);
        pf.dwMask = PFM_LINESPACING;
        pf.bLineSpacingRule = rule;
        pf.dyLineSpacing = twips;
        SendMessageW(g_hNoteEdit, EM_SETSEL, static_cast<WPARAM>(from), static_cast<LPARAM>(to));
        SendMessageW(g_hNoteEdit, EM_SETPARAFORMAT, 0, reinterpret_cast<LPARAM>(&pf));
    };
    constexpr BYTE kExpandedLineRule = 4; // exact
    auto lineStartIndex = [&](int logicalLine) -> LONG {
        if (logicalLine < 0) return 0;
        if (logicalLine < static_cast<int>(paraStarts.size())) {
            return static_cast<LONG>(paraStarts[static_cast<size_t>(logicalLine)]);
        }
        LRESULT idx = SendMessageW(g_hNoteEdit, EM_LINEINDEX, logicalLine, 0);
        if (idx < 0) return -1;
        return static_cast<LONG>(idx);
    };
    auto lineSpacingTarget = [&](int line) -> std::pair<BYTE, LONG> {
        const note::NoteLayoutLineMetrics& metrics =
            effectiveLines[static_cast<size_t>(line)];
        int permille = metrics.line_height_permille;
        LONG targetTwips = lineTwips;
        int px = basePx;
        if (permille > 1000) {
            px = std::max(px, static_cast<int>(std::lround(
                static_cast<double>(basePx) * static_cast<double>(permille) / 1000.0)));
        }
        int fontPx = metrics.max_font_px;
        if (fontPx > 0) {
            px = std::max(px, fontPx);
        }
        if (px > basePx) {
            targetTwips = pxToTwipsY(g_hNoteEdit, px);
        }
        if (permille > 1000 && targetTwips <= lineTwips) {
            targetTwips = lineTwips + 1;
        }
        if (targetTwips == lineTwips) {
            return std::make_pair(lineRule, lineTwips);
        }
        return std::make_pair(kExpandedLineRule, targetTwips);
    };

    bool canApplyDirtyLineSpacing = false;
    int dirtyApplyFirst = 0;
    int dirtyApplyLast = -1;
    if (dirtyRange.has_value() && IsNoteRenderActive() && !dirtyRange->full &&
        !dirtyRange->lineCountChanged &&
        lineRule == g_noteLineSpacingRuleCache &&
        lineTwips == g_noteLineSpacingTwipsCache &&
        appliedLayoutCanAdvance &&
        g_noteAppliedLayoutSnapshot.lines.size() == effectiveLines.size() &&
        logicalCount > 0) {
        const int maxLine = logicalCount - 1;
        dirtyApplyFirst = static_cast<int>(std::min(dirtyRange->first, static_cast<size_t>(maxLine)));
        dirtyApplyLast = static_cast<int>(std::min(dirtyRange->last, static_cast<size_t>(maxLine)));
        if (dirtyApplyLast < dirtyApplyFirst) std::swap(dirtyApplyFirst, dirtyApplyLast);
        dirtyApplyFirst = std::max(0, dirtyApplyFirst - 1);
        dirtyApplyLast = std::min(maxLine, dirtyApplyLast + 1);

        canApplyDirtyLineSpacing =
            note::LayoutMetricsUnchangedOutsideRange(
                g_noteAppliedLayoutSnapshot.lines, effectiveLines,
                static_cast<size_t>(dirtyApplyFirst),
                static_cast<size_t>(dirtyApplyLast));
    }

    if (canApplyDirtyLineSpacing) {
        g_noteApplyingLineSpacing = true;
        const note::NoteTransactionToken spacingTransaction =
            BeginSuppressedNoteChange(note::NoteChangeOrigin::PresentationUpdate, false);
        SendMessageW(g_hNoteEdit, EM_SETEVENTMASK, 0,
                     static_cast<LPARAM>(eventMask & ~ENM_CHANGE));

        int runStartLine = -1;
        BYTE runRule = lineRule;
        LONG runTwips = lineTwips;
        for (int line = dirtyApplyFirst; line <= dirtyApplyLast; ++line) {
            const auto target = lineSpacingTarget(line);
            if (runStartLine >= 0 && runRule == target.first && runTwips == target.second) {
                continue;
            }
            if (runStartLine >= 0) {
                LONG startIdx = lineStartIndex(runStartLine);
                LONG endIdx = (line < logicalCount - 1) ? lineStartIndex(line) : -1;
                if (startIdx >= 0 && (endIdx == -1 || endIdx >= startIdx)) {
                    applyLineSpacingSelection(startIdx, endIdx, runRule, runTwips);
                }
            }
            runStartLine = line;
            runRule = target.first;
            runTwips = target.second;
        }
        if (runStartLine >= 0) {
            LONG startIdx = lineStartIndex(runStartLine);
            LONG endIdx = (dirtyApplyLast < logicalCount - 1) ? lineStartIndex(dirtyApplyLast + 1) : -1;
            if (startIdx >= 0 && (endIdx == -1 || endIdx >= startIdx)) {
                applyLineSpacingSelection(startIdx, endIdx, runRule, runTwips);
            }
        }

        SendMessageW(g_hNoteEdit, EM_SETSEL, selStart, selEnd);
        if (hasScroll) {
            POINT nativeRestore = scroll;
            if (IsNoteRenderActive() || g_noteWrapEnabled) {
                nativeRestore.x = 0;
            }
            if (!SendMessageW(g_hNoteEdit, EM_SETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&nativeRestore))) {
                SetScrollPos(g_hNoteEdit, SB_VERT, nativeRestore.y, TRUE);
                if (!IsNoteRenderActive() && !g_noteWrapEnabled) {
                    SetScrollPos(g_hNoteEdit, SB_HORZ, nativeRestore.x, TRUE);
                    SendMessageW(g_hNoteEdit, WM_HSCROLL, MAKEWPARAM(SB_THUMBPOSITION, nativeRestore.x), 0);
                }
                SendMessageW(g_hNoteEdit, WM_VSCROLL, MAKEWPARAM(SB_THUMBPOSITION, nativeRestore.y), 0);
            }
        }
        SendMessageW(g_hNoteEdit, EM_SETEVENTMASK, 0, static_cast<LPARAM>(eventMask));
        g_noteTransactions.Commit(spacingTransaction);
        g_noteApplyingLineSpacing = false;

        g_noteLineSpacingRuleCache = lineRule;
        g_noteLineSpacingTwipsCache = lineTwips;
        g_noteAppliedLayoutSnapshot.Commit(layoutSourceIdentity, effectiveLines);
        g_noteRenderedContentRightPx = nextRenderedContentRightPx;

        bool needsFormatUpdate = !renderedWidthUnchanged;
        if (IsNoteRenderActive() && CanReadStableRenderDerivedState()) {
            HDC hdc = GetDC(g_hNoteEdit);
            if (hdc) {
                int nextRenderedContentBottomPx = MeasureRenderedContentBottomPx(g_hNoteEdit, hdc);
                ReleaseDC(g_hNoteEdit, hdc);
                if (nextRenderedContentBottomPx != g_noteRenderedContentBottomPx) {
                    g_noteRenderedContentBottomPx = nextRenderedContentBottomPx;
                    needsFormatUpdate = true;
                }
            }
        } else if (g_noteRenderedContentBottomPx != 0) {
            g_noteRenderedContentBottomPx = 0;
            needsFormatUpdate = true;
        }

        if (needsFormatUpdate) {
            UpdateNoteFormatRect(g_hNoteEdit);
            restoreViewportAfterFormatUpdate();
        }

        if (manageRedraw) {
            SendMessageW(g_hNoteEdit, WM_SETREDRAW, TRUE, 0);
        }

        NoteRenderDirtyLineRange repaintRange = *dirtyRange;
        repaintRange.first = static_cast<size_t>(dirtyApplyFirst);
        repaintRange.last = static_cast<size_t>(dirtyApplyLast);
        std::optional<NoteRenderDirtyLineRange> repaintDirty = repaintRange;
        if (!needsFormatUpdate &&
            InvalidateNoteRenderDirtyLines(g_hNoteEdit, repaintDirty, basePx, false)) {
            g_noteLineSpacingInvalidatedNote = true;
        } else {
            InvalidateRect(g_hNoteEdit, nullptr, FALSE);
            g_noteLineSpacingInvalidatedNote = true;
        }
        return;
    }

    g_noteApplyingLineSpacing = true;
    const note::NoteTransactionToken spacingTransaction =
        BeginSuppressedNoteChange(note::NoteChangeOrigin::PresentationUpdate, false);
    SendMessageW(g_hNoteEdit, EM_SETEVENTMASK, 0,
                 static_cast<LPARAM>(eventMask & ~ENM_CHANGE));
    // 1) Reset all lines to base/default spacing first.
    applyLineSpacingSelection(0, -1, lineRule, lineTwips);
    // 2) Apply per-line expansion for <m>.
    {
        int maxLine = logicalCount - 1;
        int runStartLine = -1;
        LONG runTwips = lineTwips;
        for (int line = 0; line <= maxLine; ++line) {
            const note::NoteLayoutLineMetrics& metrics =
                effectiveLines[static_cast<size_t>(line)];
            int permille = metrics.line_height_permille;
            LONG targetTwips = lineTwips;
            int px = basePx;
            if (permille > 1000) {
                px = std::max(px, static_cast<int>(std::lround(
                    static_cast<double>(basePx) * static_cast<double>(permille) / 1000.0)));
            }
            int fontPx = metrics.max_font_px;
            if (fontPx > 0) {
                px = std::max(px, fontPx);
            }
            if (px > basePx) {
                targetTwips = pxToTwipsY(g_hNoteEdit, px);
            }
            if (permille > 1000 && targetTwips <= lineTwips) {
                targetTwips = lineTwips + 1;
            }
            if (targetTwips == lineTwips) {
                if (runStartLine >= 0) {
                    LONG startIdx = lineStartIndex(runStartLine);
                    LONG endIdx = lineStartIndex(line);
                    if (startIdx >= 0 && endIdx >= 0 && endIdx >= startIdx) {
                        applyLineSpacingSelection(startIdx, endIdx, kExpandedLineRule, runTwips);
                    }
                    runStartLine = -1;
                }
                continue;
            }
            if (runStartLine >= 0 && runTwips == targetTwips) {
                continue;
            }
            if (runStartLine >= 0) {
                LONG startIdx = lineStartIndex(runStartLine);
                LONG endIdx = lineStartIndex(line);
                if (startIdx >= 0 && endIdx >= 0 && endIdx >= startIdx) {
                    applyLineSpacingSelection(startIdx, endIdx, kExpandedLineRule, runTwips);
                }
            }
            runStartLine = line;
            runTwips = targetTwips;
        }
        if (runStartLine >= 0) {
            LONG startIdx = lineStartIndex(runStartLine);
            if (startIdx >= 0) {
                applyLineSpacingSelection(startIdx, -1, kExpandedLineRule, runTwips);
            }
        }
    }
    SendMessageW(g_hNoteEdit, EM_SETSEL, selStart, selEnd);
    if (hasScroll) {
        POINT nativeRestore = scroll;
        if (IsNoteRenderActive() || g_noteWrapEnabled) {
            nativeRestore.x = 0;
        }
        if (!SendMessageW(g_hNoteEdit, EM_SETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&nativeRestore))) {
            SetScrollPos(g_hNoteEdit, SB_VERT, nativeRestore.y, TRUE);
            if (!IsNoteRenderActive() && !g_noteWrapEnabled) {
                SetScrollPos(g_hNoteEdit, SB_HORZ, nativeRestore.x, TRUE);
                SendMessageW(g_hNoteEdit, WM_HSCROLL, MAKEWPARAM(SB_THUMBPOSITION, nativeRestore.x), 0);
            }
            SendMessageW(g_hNoteEdit, WM_VSCROLL, MAKEWPARAM(SB_THUMBPOSITION, nativeRestore.y), 0);
        }
    }
    SendMessageW(g_hNoteEdit, EM_SETEVENTMASK, 0, static_cast<LPARAM>(eventMask));
    g_noteTransactions.Commit(spacingTransaction);
    g_noteApplyingLineSpacing = false;
    g_noteLineSpacingRuleCache = lineRule;
    g_noteLineSpacingTwipsCache = lineTwips;
    g_noteAppliedLayoutSnapshot.Commit(layoutSourceIdentity, std::move(effectiveLines));
    g_noteRenderedContentRightPx = nextRenderedContentRightPx;
    if (IsNoteRenderActive() && CanReadStableRenderDerivedState()) {
        HDC hdc = GetDC(g_hNoteEdit);
        if (hdc) {
            g_noteRenderedContentBottomPx = MeasureRenderedContentBottomPx(g_hNoteEdit, hdc);
            ReleaseDC(g_hNoteEdit, hdc);
        }
    } else {
        g_noteRenderedContentBottomPx = 0;
    }

    UpdateNoteFormatRect(g_hNoteEdit);

    // EM_SETRECTNP/EM_REQUESTRESIZE can recompute RichEdit layout again. Restore
    // the rendered logical-line anchor after this final rectangle update.
    restoreViewportAfterFormatUpdate();

    if (manageRedraw) {
        SendMessageW(g_hNoteEdit, WM_SETREDRAW, TRUE, 0);
        RedrawWindow(g_hNoteEdit, nullptr, nullptr, RDW_INVALIDATE | RDW_NOERASE);
        g_noteLineSpacingInvalidatedNote = true;
        return;
    }

    InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    g_noteLineSpacingInvalidatedNote = true;
}
