static bool NoteLayoutFrameMatchesRenderSnapshot(const NoteLayoutFrame& frame, bool requireExactRevision = true) {
    if (!frame.sourceIdentity.valid() || !g_noteRenderSnapshot.sourceIdentity.valid()) return false;
    if (frame.sourceIdentity.note_id != g_noteRenderSnapshot.sourceIdentity.note_id) return false;
    return !requireExactRevision || frame.sourceIdentity.source_revision == g_noteRenderSnapshot.sourceIdentity.source_revision;
}

static const note::NoteLayoutLineMetrics* FindAppliedNoteLayoutLineMetrics(int line) {
    if (line < 0 ||
        !g_noteAppliedLayoutSnapshot.Matches(g_noteRenderSnapshot.sourceIdentity) ||
        static_cast<size_t>(line) >= g_noteAppliedLayoutSnapshot.lines.size()) {
        return nullptr;
    }
    return &g_noteAppliedLayoutSnapshot.lines[static_cast<size_t>(line)];
}
static constexpr COLORREF kMathCaretHighlight = RGB(255, 250, 220);
static constexpr COLORREF kSearchHitHighlight = RGB(255, 255, 200);


static note::NoteTransactionCore g_noteTransactions;

static void SetLineCacheSourceRevision(uint64_t sourceRevision) {
    g_noteRenderSnapshot.CommitIdentity(
        CurrentNoteTextCoreOwner(), sourceRevision);
    for (auto& cache : g_lineCache) {
        cache.source_revision = sourceRevision;
    }
}

static bool LineCacheMatchesSourceRevision(uint64_t sourceRevision) {
    const note::NoteTextCore* core = CurrentNoteTextCore();
    if (!core ||
        !g_noteRenderSnapshot.Matches(
            core->note_id(), sourceRevision)) {
        return false;
    }
    for (const auto& cache : g_lineCache) {
        if (cache.source_revision != sourceRevision) return false;
    }
    return true;
}

static bool LineCacheMatchesCurrentTextCore() {
    return LineCacheMatchesSourceRevision(CurrentNoteTextCoreModel().revision);
}

static bool HasCurrentLineCache() {
    return !g_lineCache.empty() && LineCacheMatchesCurrentTextCore();
}

static bool CanReadStableRenderDerivedState(bool requireExactRevision = true) {
    const note::NoteTextCore* core = CurrentNoteTextCore();
    const note::LocalNoteKernel* kernel = CurrentNoteKernel();
    if (!core) return false;

    auto decision = note::ResolveNoteDerivedRead(
        note::NoteDerivedSnapshotState{
            g_noteRenderSnapshot.sourceIdentity,
            !g_lineCache.empty(),
        },
        note::NoteDerivedReadContext{
            core->note_id(),
            core->content_revision(),
            kernel && kernel->has_pending_edit(),
            kernel && kernel->has_deferred_full_refresh(),
        });

    if (decision == note::NoteDerivedReadDecision::Current) return true;
    if (!requireExactRevision) {
        return decision == note::NoteDerivedReadDecision::RevisionMismatch ||
               decision == note::NoteDerivedReadDecision::BlockedByPendingEdit ||
               decision == note::NoteDerivedReadDecision::BlockedByDeferredRefresh;
    }
    return false;
}

static note::NoteTransactionToken BeginSuppressedNoteChange(
    note::NoteChangeOrigin origin,
    bool untilUserInput,
    note::NoteId ownerNoteId = {}) {
    return g_noteTransactions.Begin(origin, ownerNoteId, untilUserInput);
}

static const note::MathSpan* GetNoteRenderMathEditSnapshot() {
    if (!CanReadStableParsedNoteDocument() || !g_hNoteEdit) return nullptr;

    DWORD selStartDw = 0;
    DWORD selEndDw = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStartDw),
                 reinterpret_cast<LPARAM>(&selEndDw));
    const size_t selStart = std::min<size_t>(static_cast<size_t>(selStartDw), CurrentNoteSyntaxSource().raw.size());
    const size_t selEnd = std::min<size_t>(static_cast<size_t>(selEndDw), CurrentNoteSyntaxSource().raw.size());
    const size_t rawStart = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, selStart);
    const size_t rawEnd = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, selEnd);
    const bool hasSelection = (selEnd > selStart);
    return FindSelectedNoteDocumentMathSpan(rawStart,
                                         hasSelection ? rawEnd : rawStart,
                                         hasSelection);
}

NoteUiSnapshot CaptureNoteUiSnapshot() {
    NoteUiSnapshot snapshot;
    snapshot.viewIdentity = CurrentActiveNoteViewIdentity();
    snapshot.sourceIdentity = CurrentActiveNoteSnapshotIdentity();
    const note::NoteTransactionSnapshot transaction = g_noteTransactions.Snapshot();
    snapshot.changeSuppressed = transaction.suppress_change;
    snapshot.programMutationActive = transaction.program_mutation_active;
    snapshot.waitingForUserInput = transaction.waiting_for_user_input;
    snapshot.transactionDepth = transaction.depth;
    snapshot.transactionSequence = transaction.sequence;
    snapshot.transactionOwnerNoteId = transaction.owner_note_id;
    snapshot.markdownRoute = (CurrentNoteContentRoute() == NoteContentRoute::MarkdownMd4c);
    snapshot.renderOverlayActive = CurrentNoteSupportsRenderOverlay() && IsNoteRenderActive();
    const bool parsedDocumentReady = CanReadStableParsedNoteDocument();
    snapshot.documentReady = parsedDocumentReady;

    if (parsedDocumentReady) {
        snapshot.mathSpanCount = CurrentNoteDocument().math_spans.size();
        snapshot.diagnosticCount = CurrentNoteDocument().diagnostics.size();
    }

    if (CanReadStableRenderDerivedState()) {
        for (size_t lineIndex = 0; lineIndex < g_lineCache.size(); ++lineIndex) {
            const LineCache& line = g_lineCache[lineIndex];
            if (lineIndex > 0) {
                snapshot.renderedText.push_back(L'\n');
            }
            snapshot.renderedText += ExtractRenderedLineText(static_cast<int>(lineIndex));
            for (const Segment& seg : line.segments) {
                if (!ShouldRenderMathSegment(seg)) continue;
                ++snapshot.renderedMathSegmentCount;
                if (IsDisplayMathSegment(seg)) {
                    ++snapshot.renderedDisplayMathSegmentCount;
                }
            }
        }
    }

    const note::MathSpan* selectedMath = GetNoteRenderMathEditSnapshot();
    if (!selectedMath) return snapshot;

    snapshot.selectedMathFound = true;
    snapshot.selectedMathIsBlock = (selectedMath->kind == note::MathKind::Block);
    snapshot.selectedMathDelimiter = note::MathDelimiterLabel(selectedMath->delimiter);
    snapshot.selectedMathNormalizedText = selectedMath->normalized_tex;
    return snapshot;
}

static void MaybeReleaseNoteChangeSuppression(HWND hWnd) {
    if (!g_noteTransactions.ObserveUserInput()) return;
    SendMessageW(hWnd, EM_SETMODIFY, FALSE, 0);
    // g_noteDirty = false; // Fix: Prevent save omission
}
