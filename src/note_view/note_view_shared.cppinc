static std::wstring StripMathDelims(const std::wstring& raw) {
    if (raw.size() >= 4 && raw[0] == L'\\' && raw[1] == L'[' &&
        raw[raw.size() - 2] == L'\\' && raw[raw.size() - 1] == L']') {
        return raw.substr(2, raw.size() - 4);
    }
    if (raw.size() >= 4 && raw[0] == L'\\' && raw[1] == L'(' &&
        raw[raw.size() - 2] == L'\\' && raw[raw.size() - 1] == L')') {
        return raw.substr(2, raw.size() - 4);
    }
    if (raw.size() >= 2 && raw.front() == L'$' && raw.back() == L'$') {
        if (raw.size() >= 4 && raw[1] == L'$' && raw[raw.size() - 2] == L'$') {
            return raw.substr(2, raw.size() - 4);
        }
        return raw.substr(1, raw.size() - 2);
    }
    if (raw.size() >= 9 && StartsWithAsciiNoCase(raw, L"<math>")) {
        if (EndsWithAsciiNoCase(raw, L"</>")) {
            return raw.substr(6, raw.size() - 9);
        }
        if (EndsWithAsciiNoCase(raw, L"</math>")) {
            return raw.substr(6, raw.size() - 13);
        }
    }
    return raw;
}

static bool HandleLinkIdJump(const std::wstring& linkId,
                             HWND hWnd,
                             const std::wstring& sourceNotePath = L"",
                             std::optional<size_t> sourcePos = std::nullopt) {
    if (linkId.empty()) return false;

    for (const auto& ann : g_annots) {
        if (ann.type != Annotation::Type::LinkMarker) continue;
        if (ann.linkId != linkId) continue;
        if (g_hPdfView) {
            JumpToPdfPoint(g_hPdfView, ann.pageIndex, ann.x1, ann.y1);
            SetFocus(g_hPdfView);
            return true;
        }
    }
    std::wstring targetPdf;
    Annotation hit{};
    if (FindPdfLinkHit(linkId, targetPdf, hit)) {
        HWND owner = g_hPdfView ? GetParent(g_hPdfView) : nullptr;
        if (!owner) owner = g_hMainWnd;
        EndIntegratedPdfPreviewMode(owner, true);
        if (OpenPdfWithAnnotations(owner, targetPdf)) {
            Annotation latest{};
            if (FindLinkAnnotation(g_annots, linkId, &latest)) {
                hit = latest;
            }
            if (g_hPdfView) {
                JumpToPdfPoint(g_hPdfView, hit.pageIndex, hit.x1, hit.y1);
                SetFocus(g_hPdfView);
                return true;
            }
        }
    }

    // 3. Try note jump
    if (JumpToNoteLinkId(linkId, L"", false, sourceNotePath, sourcePos)) return true;

    if (hWnd) {
        ShowSoftNotice(hWnd, IsEnglishUi() ? L"Link target not found." : L"リンク先が見つかりませんでした。");
    }
    return false;
}

enum class LinkVerifyState { Unknown, Known };

struct LinkVerifyEntry {
    LinkVerifyState state = LinkVerifyState::Unknown;
    bool exists = false;
    ULONGLONG checkedAt = 0;
};

static std::unordered_map<std::wstring, LinkVerifyEntry> g_linkVerifyCache;
// A cache refresh invalidates the measurement, not the last usable canvas extent.
// Keep displaying the committed extent until a fresh measurement succeeds.

static bool CurrentPdfHasLinkMarker(const std::wstring& linkId) {
    if (linkId.empty()) return false;
    for (const auto& ann : g_annots) {
        if (ann.type != Annotation::Type::LinkMarker) continue;
        if (ann.linkId != linkId) continue;
        return true;
    }
    return false;
}

static bool ComputeLinkTargetExistsNow(const std::wstring& linkId) {
    if (linkId.empty()) return false;
    // 1) currently loaded PDF markers.
    if (CurrentPdfHasLinkMarker(linkId)) return true;
    // 2) other PDFs (annotation files; may hit disk)
    std::wstring pdfPath;
    Annotation out{};
    if (FindPdfLinkHit(linkId, pdfPath, out)) return true;
    // 3) other notes (scan files; may hit disk)
    if (FindNoteTargetForLinkId(linkId, g_currentNotePath)) return true;
    return false;
}

static bool PdfLinkTargetExistsCachedOrQueue(HWND hWnd, const std::wstring& linkId) {
    (void)hWnd;
    if (linkId.empty()) return false;
    const ULONGLONG now = GetTickCount64();
    auto it = g_linkVerifyCache.find(linkId);
    if (it != g_linkVerifyCache.end()) {
        LinkVerifyEntry& e = it->second;
        if (e.state == LinkVerifyState::Known) {
            if (now - e.checkedAt <= kLinkVerifyTtlMs) {
                return e.exists;
            }
            e.state = LinkVerifyState::Unknown;
        }
    }

    bool exists = false;
    try {
        exists = ComputeLinkTargetExistsNow(linkId);
    } catch (const std::exception& ex) {
        AppendCrashLogWide(L"LinkVerify", UTF8ToWide(ex.what()));
    } catch (...) {
        AppendCrashLogWide(L"LinkVerify", L"unknown exception");
    }
    LinkVerifyEntry& entry = g_linkVerifyCache[linkId];
    entry.exists = exists;
    entry.checkedAt = now;
    entry.state = LinkVerifyState::Known;
    return exists;
}

static bool LinkTargetExistsForCurrentNoteSource(HWND hWnd,
                                                 const std::wstring& linkId,
                                                 std::optional<size_t> sourcePos) {
    if (linkId.empty()) return false;
    if (PdfLinkTargetExistsCachedOrQueue(hWnd, linkId)) return true;
    if (CurrentNoteHasLinkTargetExcluding(linkId, sourcePos)) return true;
    return false;
}

static bool IsRichEditControl(HWND hWnd) {
    if (!hWnd) return false;
    wchar_t cls[32]{};
    if (!GetClassNameW(hWnd, cls, static_cast<int>(sizeof(cls) / sizeof(cls[0])))) return false;
    // Accept both "RICHEDIT50W" (MSFTEDIT) and "RichEdit20W" (Riched20) regardless of casing.
    return _wcsnicmp(cls, L"RICHEDIT", 8) == 0;
}

