    bool valid = false;
    std::wstring pathKey;
    std::uint64_t size = 0;
    std::int64_t mtimeMs = 0;
    bool notifiedMissing = false;
    bool notifiedChanged = false;
    std::uint64_t notifiedSize = 0;
    std::int64_t notifiedMtimeMs = 0;
};

