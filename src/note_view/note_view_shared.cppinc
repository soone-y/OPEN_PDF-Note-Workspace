    switch (kind) {
    case note::BlockKind::Paragraph: return englishUi ? L"Paragraph" : L"段落";
    case note::BlockKind::Heading: return englishUi ? L"Heading" : L"見出し";
    case note::BlockKind::List: return englishUi ? L"List" : L"リスト";
    case note::BlockKind::ListItem: return englishUi ? L"List item" : L"リスト項目";
    case note::BlockKind::Quote: return englishUi ? L"Quote" : L"引用";
    case note::BlockKind::CodeBlock: return englishUi ? L"Code block" : L"コードブロック";
    case note::BlockKind::HorizontalRule: return englishUi ? L"Horizontal rule" : L"区切り線";
    case note::BlockKind::Table: return englishUi ? L"Table" : L"表";
    case note::BlockKind::TableHead: return englishUi ? L"Table head" : L"表ヘッダー";
    case note::BlockKind::TableBody: return englishUi ? L"Table body" : L"表本文";
    case note::BlockKind::TableRow: return englishUi ? L"Table row" : L"表行";
    case note::BlockKind::TableHeaderCell: return englishUi ? L"Table header cell" : L"表見出しセル";
    case note::BlockKind::TableCell: return englishUi ? L"Table cell" : L"表セル";
    case note::BlockKind::Blank: return englishUi ? L"Blank" : L"空行";
    }
    return englishUi ? L"Unknown" : L"不明";
}

static std::wstring NoteInlineKindLabel(note::InlineKind kind, bool englishUi) {
    switch (kind) {
    case note::InlineKind::Text: return englishUi ? L"Text" : L"テキスト";
    case note::InlineKind::Code: return englishUi ? L"Code" : L"コード";
    case note::InlineKind::Emphasis: return englishUi ? L"Emphasis" : L"強調";
    case note::InlineKind::Strong: return englishUi ? L"Strong" : L"太字";
    case note::InlineKind::Strike: return englishUi ? L"Strike" : L"取り消し";
    case note::InlineKind::Link: return englishUi ? L"Link" : L"リンク";
    case note::InlineKind::Image: return englishUi ? L"Image" : L"画像";
    }
    return englishUi ? L"Unknown" : L"不明";
}

static const note::BlockNode* FindActiveNoteDocumentBlock(size_t rawPos) {
    if (!CanReadStableParsedNoteDocument()) return nullptr;
    const note::BlockNode* best = nullptr;
    size_t bestSpanLen = static_cast<size_t>(-1);
    for (const auto& block : CurrentNoteDocument().blocks) {
        if (rawPos < block.span.start.value || rawPos > block.span.end.value) continue;
        size_t spanLen = (block.span.end.value >= block.span.start.value) ? (block.span.end.value - block.span.start.value) : 0;
        if (!best || spanLen <= bestSpanLen) {
            best = &block;
            bestSpanLen = spanLen;
        }
    }
    return best;
}

static const note::InlineNode* FindActiveNoteDocumentInline(size_t rawPos) {
    if (!CanReadStableParsedNoteDocument()) return nullptr;
    const note::InlineNode* best = nullptr;
    size_t bestSpanLen = static_cast<size_t>(-1);
    for (const auto& inlineNode : CurrentNoteDocument().inlines) {
        if (rawPos < inlineNode.span.start.value || rawPos > inlineNode.span.end.value) continue;
        size_t spanLen = (inlineNode.span.end.value >= inlineNode.span.start.value) ? (inlineNode.span.end.value - inlineNode.span.start.value) : 0;
        if (!best || spanLen <= bestSpanLen) {
            best = &inlineNode;
            bestSpanLen = spanLen;
        }
    }
    return best;
}

static const note::MathSpan* FindSelectedNoteDocumentMathSpan(size_t rawStart,
                                                              size_t rawEnd,
                                                              bool hasSelection) {
    if (!CanReadStableParsedNoteDocument()) return nullptr;
    const note::MathSpan* best = nullptr;
    size_t bestSpanLen = static_cast<size_t>(-1);
    for (const auto& mathSpan : CurrentNoteDocument().math_spans) {
        const bool contains = hasSelection
            ? (rawStart >= mathSpan.span.start.value && rawEnd <= mathSpan.span.end.value && rawEnd > rawStart)
            : (rawStart >= mathSpan.span.start.value && rawStart < mathSpan.span.end.value);
        if (!contains) continue;
        size_t spanLen = (mathSpan.span.end.value >= mathSpan.span.start.value)
            ? (mathSpan.span.end.value - mathSpan.span.start.value)
            : 0;
        if (!best || spanLen <= bestSpanLen) {
            best = &mathSpan;
            bestSpanLen = spanLen;
        }
    }
    return best;
}

static const note::Diagnostic* FindFirstNoteDocumentDiagnosticForSpan(note::Span span) {
    if (!CanReadStableParsedNoteDocument()) return nullptr;
    for (const auto& diag : CurrentNoteDocument().diagnostics) {
        if (span.start < diag.span.end && span.end > diag.span.start) {
            return &diag;
        }
    }
    return nullptr;
}

static std::wstring BuildAssistSnippet(std::wstring_view text, size_t limit) {
    std::wstring out;
    out.reserve(std::min(limit, text.size()) + 8);
    bool truncated = false;
    for (wchar_t ch : text) {
        if (ch == L'\r' || ch == L'\n' || ch == L'\t') {
            if (out.empty() || out.back() != L' ') {
                out.push_back(L' ');
            }
        } else {
            out.push_back(ch);
        }
        if (out.size() >= limit) {
            truncated = true;
            break;
        }
    }
    while (!out.empty() && out.back() == L' ') {
        out.pop_back();
    }
    if (truncated) {
        out += L"...";
    }
    return out;
}

static size_t RichEditIndexToRawTextIndex(const std::wstring& text, size_t editPos) {
    editPos = std::min(editPos, text.size());
    if (!IsRichEditControl(CurrentNoteViewContextWindow())) {
        return editPos;
    }

    size_t rawPos = 0;
    size_t visiblePos = 0;
    while (rawPos < text.size() && visiblePos < editPos) {
        if (text[rawPos] == L'\r' && rawPos + 1 < text.size() && text[rawPos + 1] == L'\n') {
            rawPos += 2;
        } else {
            ++rawPos;
        }
        ++visiblePos;
    }
    return rawPos;
}

static int GetNoteFontCustomizationMode() {
    return std::clamp(g_config.noteFontCustomization, 0, 2);
}

static bool IsBottomAssistRenderFontVisible() {
    return CurrentNoteSupportsRenderOverlay() && GetNoteFontCustomizationMode() >= 1;
}

static bool IsBottomAssistRenderJpFontVisible() {
    return CurrentNoteSupportsRenderOverlay() && GetNoteFontCustomizationMode() == 2;
}

static bool IsBottomAssistUnifiedFontMode() {
    return CurrentNoteSupportsRenderOverlay() && GetNoteFontCustomizationMode() == 1;
}

static bool IsBottomAssistRawFontVisible() {
    return !IsBottomAssistUnifiedFontMode();
}

static std::wstring BottomAssistRenderFontLabel(bool englishUi) {
    const int mode = GetNoteFontCustomizationMode();
    if (englishUi) {
        return (mode == 1) ? L"Unified font" : L"Render font";
    }
    return (mode == 1) ? L"統一フォント" : L"レンダリングフォント";
}

struct BottomAssistLineLayout {
    int wrapIdx = -1;
    int vimIdx = -1;
    int vimCaretLineRawTextIdx = -1;
    int vimClickInsertIdx = -1;
    int rawFontIdx = -1;
    int renderFontIdx = -1;
    int renderJpFontIdx = -1;
    int fontSizeIdx = -1;
    int bgIdx = -1;
    int separatorIdx = -1;
};

static BottomAssistLineLayout BuildBottomAssistLineLayout() {
    BottomAssistLineLayout layout;
    int nextIdx = 1;
    if (IsNoteWrapToggleAvailable()) {
        layout.wrapIdx = nextIdx++;
    }
    layout.vimIdx = nextIdx++;
    layout.vimCaretLineRawTextIdx = nextIdx++;
    layout.vimClickInsertIdx = nextIdx++;
    if (IsBottomAssistRawFontVisible()) {
        layout.rawFontIdx = nextIdx++;
    }
    if (IsBottomAssistRenderFontVisible()) {
        layout.renderFontIdx = nextIdx++;
    }
    if (IsBottomAssistRenderJpFontVisible()) {
        layout.renderJpFontIdx = nextIdx++;
    }
    layout.fontSizeIdx = nextIdx++;
    layout.bgIdx = nextIdx++;
    layout.separatorIdx = nextIdx++;
    return layout;
}

static std::wstring BuildBottomAssistText() {
    const NoteContentRoute route = CurrentNoteContentRoute();
    const bool enabled = IsNoteRenderActive();
    const bool englishUi = IsEnglishUi();
    const bool vimEnabled = g_noteVimModeEnabled;
    const bool showWrapToggle = IsNoteWrapToggleAvailable();
    const bool showRawFont = IsBottomAssistRawFontVisible();
    const bool showRenderFont = IsBottomAssistRenderFontVisible();
    const bool showRenderJpFont = IsBottomAssistRenderJpFontVisible();
    const bool wrapEnabled = g_noteWrapEnabled;
    const bool renderSupportedRoute = CurrentNoteSupportsRenderOverlay();
    const std::wstring rawFace = g_noteFontName.empty() ? GetDefaultFontFaceName() : g_noteFontName;
    const std::wstring renderFace = g_noteRenderFontName.empty() ? rawFace : g_noteRenderFontName;
    const std::wstring renderJpFace = g_noteRenderJpFontName.empty() ? renderFace : g_noteRenderJpFontName;
    const std::wstring rawName = ResolveFontDisplayName(rawFace);
    const std::wstring renderName = ResolveFontDisplayName(renderFace);
    const std::wstring renderJpName = ResolveFontDisplayName(renderJpFace);
    const std::wstring sizeLabel = std::to_wstring(static_cast<int>(std::lround(g_noteFontPt))) + L"pt";
    const std::wstring wrapLabel = wrapEnabled ? L"ON" : L"OFF";
    const std::wstring vimCaretRawLabel = g_noteVimCaretLineRawTextVisible ? L"ON" : L"OFF";
    const std::wstring vimClickInsertLabel = g_noteVimClickEntersInsertMode ? L"ON" : L"OFF";
    const std::wstring gridLabel = g_noteGridEnabled ? L"ON" : L"OFF";
    const std::wstring gridPitchLabel =
        std::to_wstring(std::clamp(g_noteGridPitch, 4, 256)) + L"px";
    auto ratioLabel = [](int topPercent) -> std::wstring {
        int top = std::clamp(topPercent, 5, 95);
        return std::to_wstring(top) + L":" + std::to_wstring(100 - top);
    };
    const std::wstring mathMarginLabel = ratioLabel(g_config.noteMathMarginTopPercent);
    const std::wstring supSubLabel = (g_config.noteMathSupSubGapSupPercent <= 0)
        ? (englishUi ? L"Auto" : L"自動")
        : ratioLabel(g_config.noteMathSupSubGapSupPercent);
    std::wstring noteBgLabelEn;
    std::wstring noteBgLabelJa;
    std::wstring bgSource = ToLowerAscii(g_config.noteBgSource);
    if (bgSource == L"theme" || bgSource == L"theme_current") {
        std::wstring nameEn = g_theme.name.empty() ? L"(default)" : g_theme.name;
        std::wstring nameJa = g_theme.nameJp.empty() ? nameEn : g_theme.nameJp;
        noteBgLabelEn = L"Theme (current): " + nameEn + L" " + ColorToHexW(g_noteBgColor);
        noteBgLabelJa = L"テーマ準拠: " + nameJa + L" " + ColorToHexW(g_noteBgColor);
    } else if (bgSource == L"theme_named") {
        const ThemeColors* picked = nullptr;
        for (const auto& t : g_themeCatalog) {
            if (t.name == g_config.noteBgThemeName) {
                picked = &t;
                break;
            }
        }
        std::wstring nameEn = picked ? picked->name : g_config.noteBgThemeName;
        if (nameEn.empty()) nameEn = L"(unknown)";
        std::wstring nameJa = (picked && !picked->nameJp.empty()) ? picked->nameJp : nameEn;
        noteBgLabelEn = L"Theme: " + nameEn + L" " + ColorToHexW(g_noteBgColor);
        noteBgLabelJa = L"テーマ: " + nameJa + L" " + ColorToHexW(g_noteBgColor);
    } else {
        noteBgLabelEn = L"Custom " + ColorToHexW(g_noteBgColor);
        noteBgLabelJa = L"カスタム " + ColorToHexW(g_noteBgColor);
        struct BgPreset {
            COLORREF color;
            const wchar_t* labelEn;
            const wchar_t* labelJa;
        };
        const BgPreset bgPresets[] = {
            { RGB(255, 255, 255), L"White", L"白" },
            { RGB(255, 250, 235), L"Cream", L"クリーム" },
            { RGB(245, 245, 245), L"Light gray", L"薄グレー" },
            { RGB(255, 255, 230), L"Soft yellow", L"薄イエロー" },
        };
        for (const auto& p : bgPresets) {
            if (p.color == g_noteBgColor) {
                noteBgLabelEn = p.labelEn;
                noteBgLabelJa = p.labelJa;
                break;
            }
        }
    }
    auto isFocusIn = [](HWND root, HWND focused) -> bool {
        return root && focused && (root == focused || IsChild(root, focused));
    };
    HWND focused = GetFocus();
    bool noteFocused = isFocusIn(g_hNoteEdit, focused);
    bool pdfFocused = isFocusIn(g_hPdfView, focused);
    bool assistFocused = isFocusIn(g_hBottomNote, focused);
    std::wstring focusLabelJa = L"なし";
    std::wstring focusLabelEn = L"None";
    if (noteFocused) {
        focusLabelJa = L"ノート";
        focusLabelEn = L"Note";
    } else if (pdfFocused) {
        focusLabelJa = L"PDF";
        focusLabelEn = L"PDF";
    } else if (assistFocused) {
        focusLabelJa = L"右下欄";
        focusLabelEn = L"Bottom pane";
    } else if (focused) {
        focusLabelJa = L"その他";
        focusLabelEn = L"Other";
    }
    const bool imeComposing = IsNoteImeComposing();
    std::wstring imeLabelJa = imeComposing ? L"変換中" : L"待機";
    std::wstring imeLabelEn = imeComposing ? L"Composing" : L"Idle";
    std::wstring inputLabelJa;
    std::wstring inputLabelEn;
    if (!vimEnabled) {
        inputLabelJa = L"無効";
        inputLabelEn = L"Disabled";
    } else {
        if (g_noteNormalMode && IsNoteNormalVisualActive()) {
            inputLabelJa = L"ビジュアル";
            inputLabelEn = L"Visual";
        } else if (g_noteNormalMode) {
            inputLabelJa = L"通常(i/oで入力)";
            inputLabelEn = L"Normal (press i/o)";
        } else {
            inputLabelJa = noteFocused ? L"入力中" : L"待機";
            inputLabelEn = noteFocused ? L"Typing" : L"Idle";
        }
    }
    DWORD selStartRaw = 0;
    DWORD selEndRaw = 0;
    if (g_hNoteEdit) {
        SendMessageW(g_hNoteEdit, EM_GETSEL,
                     reinterpret_cast<WPARAM>(&selStartRaw),
                     reinterpret_cast<LPARAM>(&selEndRaw));
    }
    unsigned long long selChars = 0;
    if (selEndRaw > selStartRaw) {
        selChars = static_cast<unsigned long long>(selEndRaw - selStartRaw);
    }
    const bool parsedDocumentReady = CanReadStableParsedNoteDocument();
    const bool semanticIndexReady = CanReadStableSemanticIndex();
    const size_t headingCount = semanticIndexReady ? CurrentNoteSemanticIndex().headings.size() : 0;
    size_t warningCount = 0;
    size_t errorCount = 0;
    if (parsedDocumentReady) {
        for (const auto& diag : CurrentNoteDocument().diagnostics) {
            if (diag.severity == note::DiagnosticSeverity::Error) {
                ++errorCount;
            } else {
                ++warningCount;
            }
        }
    }
    const note::Diagnostic* firstDiagnostic =
        parsedDocumentReady && !CurrentNoteDocument().diagnostics.empty() ? &CurrentNoteDocument().diagnostics.front() : nullptr;
    size_t caretRawPos = 0;
    size_t selectionRawStart = 0;
    size_t selectionRawEnd = 0;
    if (parsedDocumentReady) {
        caretRawPos = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, static_cast<size_t>(selStartRaw));
        if (caretRawPos > CurrentNoteSyntaxSource().raw.size()) {
            caretRawPos = CurrentNoteSyntaxSource().raw.size();
        }
        selectionRawStart = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, static_cast<size_t>(selStartRaw));
        selectionRawEnd = RichEditIndexToRawTextIndex(CurrentNoteSyntaxSource().raw, static_cast<size_t>(selEndRaw));
        if (selectionRawStart > selectionRawEnd) {
            std::swap(selectionRawStart, selectionRawEnd);
        }
        if (selectionRawEnd > CurrentNoteSyntaxSource().raw.size()) {
            selectionRawEnd = CurrentNoteSyntaxSource().raw.size();
        }
    }
    const note::BlockNode* activeBlock = FindActiveNoteDocumentBlock(caretRawPos);
    const note::InlineNode* activeInline = FindActiveNoteDocumentInline(caretRawPos);
    const bool hasSelection = selectionRawEnd > selectionRawStart;
    const note::MathSpan* selectedMath =
        FindSelectedNoteDocumentMathSpan(hasSelection ? selectionRawStart : caretRawPos,
                                         hasSelection ? selectionRawEnd : caretRawPos,
                                         hasSelection);
    const note::Diagnostic* selectedMathDiagnostic =
        selectedMath ? FindFirstNoteDocumentDiagnosticForSpan(selectedMath->span) : nullptr;
    if (englishUi) {
        std::wstring renderModeLabel = enabled
            ? (IsNoteMathRenderActive() ? L"ON + Math" : L"ON")
            : L"OFF";
        std::wstring text = std::wstring(L"Note rendering: ") +
            (renderSupportedRoute ? renderModeLabel : L"Unavailable in this route");
        if (showWrapToggle) {
            text += L"\nAuto wrap (raw mode): " + wrapLabel;
        }
        text += L"\nKeyboard software controls: " + std::wstring(vimEnabled ? L"ON" : L"OFF") +
            L"\nKeyboard controls caret line raw text: " + vimCaretRawLabel +
            L"\nEnter insert on note click: " + vimClickInsertLabel;
        if (showRawFont) {
            text += L"\nRaw font: " + rawName;
        }
        if (showRenderFont) {
            text += L"\n" + BottomAssistRenderFontLabel(true) + L": " + renderName;
        }
        if (showRenderJpFont) {
            text += L"\nRender font (JP): " + renderJpName;
        }
        text += L"\nSize: " + sizeLabel +
                L"\nNote background: " + noteBgLabelEn;
        text += renderSupportedRoute
            ? (showWrapToggle
                ? L"\n\nClick the settings above to change render / wrap / keyboard controls / fonts / size / background"
                : L"\n\nClick the settings above to change render / keyboard controls / fonts / size / background")
            : L"\n\nClick the settings above to change wrap / keyboard controls / fonts / size / background";
        text += std::wstring(L"\nDisplay only:") +
                L"\nGrid overlay: " + gridLabel +
                L"\nGrid pitch: " + gridPitchLabel +
                L"\nMath margin (top:bottom): " + mathMarginLabel +
                L"\nSup/sub distribution: " + supSubLabel +
                L"\nStatus - Focus: " + focusLabelEn +
                L"\nStatus - Input: " + inputLabelEn +
                L"\nStatus - IME: " + imeLabelEn +
                L"\nStatus - Note selection: " + std::to_wstring(selChars) + L" chars" +
                L"\nNote route: " + NoteContentRouteLabel(true);
        if (parsedDocumentReady) {
            text += L"\nNote AST: blocks=" + std::to_wstring(CurrentNoteDocument().blocks.size()) +
                    L", inlines=" + std::to_wstring(CurrentNoteDocument().inlines.size()) +
                    L", headings=" + std::to_wstring(headingCount) +
                    L", styles=" + std::to_wstring(CurrentNoteDocument().style_spans.size()) +
                    L", math=" + std::to_wstring(CurrentNoteDocument().math_spans.size()) +
                    L"\nNote diagnostics: errors=" + std::to_wstring(errorCount) +
                    L", warnings=" + std::to_wstring(warningCount);
            if (selectedMath) {
                const note::LineColumn loc = note::ResolveLineColumn(CurrentNoteSyntaxSource(), selectedMath->span.start.value);
                const std::wstring rawMath = BuildAssistSnippet(
                    CurrentNoteSyntaxSource().raw.substr(selectedMath->span.start.value,
                                               selectedMath->span.end.value - selectedMath->span.start.value));
                const std::wstring normalizedMath = BuildAssistSnippet(selectedMath->normalized_tex);
                text += L"\nSelected math: " +
                        std::wstring(selectedMath->kind == note::MathKind::Block ? L"Block" : L"Inline") +
                        L" / " + note::MathDelimiterLabel(selectedMath->delimiter) +
                        L" @" + std::to_wstring(loc.line) + L":" + std::to_wstring(loc.column) +
                        L"\nSelected math raw: " + rawMath;
                if (!normalizedMath.empty()) {
                    text += L"\nSelected math normalized: " + normalizedMath;
                }
                if (selectedMathDiagnostic) {
                    text += L"\nSelected math diagnostic: " + selectedMathDiagnostic->code +
                            L" - " + selectedMathDiagnostic->message;
                }
            }
            if (activeBlock) {
                text += L"\nNote caret block: " + NoteBlockKindLabel(activeBlock->kind, true);
                if (activeBlock->kind == note::BlockKind::Heading && activeBlock->level > 0) {
                    text += L" L" + std::to_wstring(activeBlock->level);
                }
                text += L" @" + std::to_wstring(activeBlock->loc.line) +
                        L":" + std::to_wstring(activeBlock->loc.column);
            }
            if (activeInline) {
                text += L"\nNote caret inline: " + NoteInlineKindLabel(activeInline->kind, true);
            }
            if (firstDiagnostic) {
                text += L"\nNote first diagnostic: " + firstDiagnostic->code +
                        L" - " + firstDiagnostic->message;
            }
        } else if (route == NoteContentRoute::PlainText) {
            text += L"\nNote parser: disabled for plain-text route";
        } else {
            text += L"\nNote parser: (not parsed yet)";
        }
        return text;
    }
    std::wstring renderModeLabelJa = enabled
        ? (IsNoteMathRenderActive() ? L"ON + 数式" : L"ON")
        : L"OFF";
    std::wstring text = std::wstring(L"ノートレンダリング: ") +
        (renderSupportedRoute ? renderModeLabelJa : L"この経路では無効");
    if (showWrapToggle) {
        text += L"\n自動折り返し(生表示時): " + wrapLabel;
    }
    text += L"\nソフトキーボード操作: " + std::wstring(vimEnabled ? L"ON" : L"OFF") +
        L"\nソフトキーボード操作時キャレット行生テキスト: " + vimCaretRawLabel +
        L"\nソフトキーボード操作時クリックでインサート移行: " + vimClickInsertLabel;
    if (showRawFont) {
        text += L"\n生テキスト: " + rawName;
    }
    if (showRenderFont) {
        text += L"\n" + BottomAssistRenderFontLabel(false) + L": " + renderName;
    }
    if (showRenderJpFont) {
        text += L"\nレンダリングフォント(日本語): " + renderJpName;
    }
    text += L"\n文字サイズ: " + sizeLabel +
            L"\nノート背景: " + noteBgLabelJa;
    text += renderSupportedRoute
        ? (showWrapToggle
            ? L"\n\n上の設定行をクリックして、レンダリング・折り返し・ソフトキーボード操作・フォント・サイズ・背景を変更"
            : L"\n\n上の設定行をクリックして、レンダリング・ソフトキーボード操作・フォント・サイズ・背景を変更")
        : L"\n\n上の設定行をクリックして、折り返し・ソフトキーボード操作・フォント・サイズ・背景を変更";
    text += std::wstring(L"\n表示のみ:") +
            L"\nグリッド表示: " + gridLabel +
            L"\nグリッド間隔: " + gridPitchLabel +
            L"\n数式マージン比(上:下): " + mathMarginLabel +
            L"\n上付き/下付き 配分: " + supSubLabel +
            L"\nステータス: フォーカス=" + focusLabelJa +
            L"\nステータス: 入力状態=" + inputLabelJa +
            L"\nステータス: IME=" + imeLabelJa +
            L"\nステータス: ノート選択=" + std::to_wstring(selChars) + L"文字" +
            L"\nノート経路: " + NoteContentRouteLabel(false);
    if (parsedDocumentReady) {
        text += L"\nノート構造: block=" + std::to_wstring(CurrentNoteDocument().blocks.size()) +
                L", inline=" + std::to_wstring(CurrentNoteDocument().inlines.size()) +
                L", 見出し=" + std::to_wstring(headingCount) +
                L", style=" + std::to_wstring(CurrentNoteDocument().style_spans.size()) +
                L", math=" + std::to_wstring(CurrentNoteDocument().math_spans.size()) +
                L"\nノート診断: error=" + std::to_wstring(errorCount) +
                L", warning=" + std::to_wstring(warningCount);
        if (selectedMath) {
            const note::LineColumn loc = note::ResolveLineColumn(CurrentNoteSyntaxSource(), selectedMath->span.start.value);
            const std::wstring rawMath = BuildAssistSnippet(
                CurrentNoteSyntaxSource().raw.substr(selectedMath->span.start.value,
                                           selectedMath->span.end.value - selectedMath->span.start.value));
            const std::wstring normalizedMath = BuildAssistSnippet(selectedMath->normalized_tex);
            text += L"\n選択中数式: " +
                    std::wstring(selectedMath->kind == note::MathKind::Block ? L"ブロック" : L"インライン") +
                    L" / " + note::MathDelimiterLabel(selectedMath->delimiter) +
                    L" @" + std::to_wstring(loc.line) + L":" + std::to_wstring(loc.column);
            text += L"\n選択中生テキスト: " + rawMath;
            if (!normalizedMath.empty()) {
                text += L"\n選択中正規化: " + normalizedMath;
            }
            if (selectedMathDiagnostic) {
                text += L"\n選択中診断: " + selectedMathDiagnostic->code +
                        L" - " + selectedMathDiagnostic->message;
            }
        }
        if (activeBlock) {
            text += L"\nキャレットblock: " + NoteBlockKindLabel(activeBlock->kind, false);
            if (activeBlock->kind == note::BlockKind::Heading && activeBlock->level > 0) {
                text += L" L" + std::to_wstring(activeBlock->level);
            }
            text += L" @" + std::to_wstring(activeBlock->loc.line) +
                    L":" + std::to_wstring(activeBlock->loc.column);
        }
        if (activeInline) {
            text += L"\nキャレットinline: " + NoteInlineKindLabel(activeInline->kind, false);
        }
        if (firstDiagnostic) {
            text += L"\n最初の診断: " + firstDiagnostic->code +
                    L" - " + firstDiagnostic->message;
        }
    } else if (route == NoteContentRoute::PlainText) {
        text += L"\nノート解析器: プレーンテキスト経路では無効";
    } else {
        text += L"\nノート解析器: 未解析";
    }
    return text;
}

static void ToggleNoteRenderSetting() {
    if (!CurrentNoteSupportsRenderOverlay()) {
        HWND owner = g_hMainWnd ? g_hMainWnd : (g_hNoteEdit ? GetParent(g_hNoteEdit) : nullptr);
        ShowSoftNotice(owner,
                       IsEnglishUi()
                           ? L"Render overlay is only available for Markdown and custom note routes."
                           : L"レンダリング表示は Markdown / 独自記法ノートでのみ利用できます。",
                       SoftNoticeKind::Info);
        return;
    }

    struct Guard {
        Guard() { BeginNoteRenderSwitch(); }
        ~Guard() { EndNoteRenderSwitch(); }
    } guard;

    if (IsNoteImeComposing()) {
        CommitNoteImeCompositionNow();
    }
    if (g_hNoteEdit) {
        CaptureNoteViewState(g_hNoteEdit, L"");
    }

    // Cycle modes: OFF -> ON -> ON+MATH -> OFF.
    const bool enabled = g_noteRenderEnabled && !g_noteRawOnly;
    const bool math = enabled && g_noteRenderMath;
    if (!enabled) {
        g_noteRenderEnabled = true;
        g_noteRawOnly = false;
        g_noteRenderMath = false;
    } else if (!math) {
        g_noteRenderEnabled = true;
        g_noteRawOnly = false;
        g_noteRenderMath = true;
    } else {
        g_noteRenderEnabled = false;
        g_noteRawOnly = true;
        g_noteRenderMath = false;
    }
    g_config.noteRenderEnabled = g_noteRenderEnabled;
    g_config.noteRawOnly = g_noteRawOnly;
    g_config.noteRenderMath = g_noteRenderMath;
    PersistConfig();
    HWND owner = g_hMainWnd ? g_hMainWnd : (g_hNoteEdit ? GetParent(g_hNoteEdit) : nullptr);
    SyncNoteWrapMenuState(owner);
    if (g_hNoteEdit) {
        // Prepare markup cache before unfreezing so the first visible frame is consistent.
        if (IsNoteRenderActive()) {
            std::wstring text = GetEditTextForIndexing(g_hNoteEdit);
            if (CurrentNoteContentRoute() == NoteContentRoute::MarkdownMd4c) {
                RefreshMarkdownRenderCache(text);
            } else {
                ClearLegacyRenderCache();
            }
        }
        HFONT active = GetActiveNoteFont();
        SendMessageW(g_hNoteEdit, WM_SETFONT, reinterpret_cast<WPARAM>(active), FALSE);
        UpdateNoteViewMode();
        UpdateNoteLineSpacing();
        RestoreNoteViewState(g_hNoteEdit, L"", true);
        InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    }
    if (g_hBottomNote) {
        InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
}

static void CompletePendingBottomNoteRenderToggleAfterIme() {
    if (!g_bottomNoteRenderTogglePendingAfterIme) return;
    if (IsNoteImeComposing()) return;
    g_bottomNoteRenderTogglePendingAfterIme = false;
    ToggleNoteRenderSetting();
}

static void ToggleNoteVimControlSetting() {
    g_noteVimModeEnabled = !g_noteVimModeEnabled;
    if (!g_noteVimModeEnabled) {
        g_noteNormalMode = false;
        OnExitNoteNormalMode();
    }
    g_config.noteVimModeEnabled = g_noteVimModeEnabled;
    PersistConfig();
    if (g_hBottomNote) {
        InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
    if (g_hNoteEdit) {
        InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    }
}

static void ToggleNoteVimCaretLineRawTextSetting() {
    g_noteVimCaretLineRawTextVisible = !g_noteVimCaretLineRawTextVisible;
    g_config.noteVimCaretLineRawTextVisible = g_noteVimCaretLineRawTextVisible;
    PersistConfig();
    if (g_hBottomNote) {
        InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
    if (g_hNoteEdit) {
        InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    }
}

static void ToggleNoteVimClickInsertSetting() {
    g_noteVimClickEntersInsertMode = !g_noteVimClickEntersInsertMode;
    g_config.noteVimClickEntersInsertMode = g_noteVimClickEntersInsertMode;
    PersistConfig();
    if (g_hBottomNote) {
        InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
}

static void SyncNoteWrapMenuState(HWND owner) {
    if (!owner) return;
    HMENU menu = GetMenu(owner);
    if (!menu) return;
    UINT enableFlags = MF_BYCOMMAND | (IsNoteWrapToggleAvailable() ? MF_ENABLED : MF_GRAYED);
    EnableMenuItem(menu, ID_VIEW_NOTE_WRAP, enableFlags);
    CheckMenuItem(menu, ID_VIEW_NOTE_WRAP,
                  MF_BYCOMMAND | (g_noteWrapEnabled ? MF_CHECKED : MF_UNCHECKED));
    DrawMenuBar(owner);
}

void ToggleNoteWrapSetting() {
    if (!IsNoteWrapToggleAvailable()) {
        HWND owner = g_hMainWnd ? g_hMainWnd : (g_hNoteEdit ? GetParent(g_hNoteEdit) : nullptr);
        SyncNoteWrapMenuState(owner);
        return;
    }
    g_noteWrapEnabled = !g_noteWrapEnabled;
    g_config.noteWrapEnabled = g_noteWrapEnabled;
    PersistConfig();
    HWND owner = g_hMainWnd ? g_hMainWnd : (g_hNoteEdit ? GetParent(g_hNoteEdit) : nullptr);
    SyncNoteWrapMenuState(owner);
    if (g_hNoteEdit) {
        UpdateNoteViewMode();
        UpdateNoteLineSpacing();
        RestoreNoteViewState(g_hNoteEdit, L"", true);
        InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    }
    if (g_hBottomNote) {
        InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
}

static void ShowNoteAssistFontMenu(HWND hWnd, NoteAssistFontTarget target) {
    HMENU menu = CreatePopupMenu();
    if (!menu) return;
    std::wstring currentFace;
    const bool unifiedFontTarget =
        (target == NoteAssistFontTarget::RenderLatin && GetNoteFontCustomizationMode() == 1);
    if (target == NoteAssistFontTarget::Raw) {
        currentFace = g_noteFontName;
    } else if (target == NoteAssistFontTarget::RenderJapanese) {
        currentFace = g_noteRenderJpFontName.empty() ? g_noteRenderFontName : g_noteRenderJpFontName;
    } else if (unifiedFontTarget) {
        currentFace = g_noteRenderFontName.empty() ? g_noteFontName : g_noteRenderFontName;
    } else {
        currentFace = g_noteRenderFontName;
    }
    if (currentFace.empty()) currentFace = GetDefaultFontFaceName();
    const std::wstring currentDisplay = ResolveFontDisplayName(currentFace);
    constexpr UINT kMenuBase = 48000;
    constexpr UINT kMenuCount = static_cast<UINT>(sizeof(kDefaultFontList) / sizeof(kDefaultFontList[0]));
    for (UINT i = 0; i < kMenuCount; ++i) {
        UINT flags = MF_STRING;
        if (currentDisplay == kDefaultFontList[i].displayName) {
            flags |= MF_CHECKED;
        }
        AppendMenuW(menu, flags, kMenuBase + i, kDefaultFontList[i].displayName);
    }
    POINT pt{};
    GetCursorPos(&pt);
    UINT cmd = TrackPopupMenu(menu, TPM_RETURNCMD | TPM_RIGHTBUTTON, pt.x, pt.y, 0, hWnd, nullptr);
    if (cmd >= kMenuBase && cmd < kMenuBase + kMenuCount) {
        const UINT idx = cmd - kMenuBase;
        const std::wstring face = kDefaultFontList[idx].faceName;
        if (unifiedFontTarget) {
            g_noteFontName = face;
            g_noteRenderFontName = face;
            g_noteRenderFontPt = g_noteFontPt;
            g_noteRenderJpFontName = face;
            g_config.noteFontName = g_noteFontName;
            g_config.noteRenderFontName = g_noteRenderFontName;
            g_config.noteRenderFontPt = g_noteRenderFontPt;
            g_config.noteRenderJpFontName = g_noteRenderJpFontName;
        } else if (target == NoteAssistFontTarget::RenderLatin) {
            g_noteRenderFontName = face;
            g_noteRenderFontPt = g_noteFontPt;
            g_config.noteRenderFontName = g_noteRenderFontName;
            g_config.noteRenderFontPt = g_noteRenderFontPt;
        } else if (target == NoteAssistFontTarget::RenderJapanese) {
            g_noteRenderJpFontName = face;
            g_config.noteRenderJpFontName = g_noteRenderJpFontName;
        } else {
            g_noteFontName = face;
            g_config.noteFontName = g_noteFontName;
        }
        if (g_noteRenderJpFontName.empty()) {
            g_noteRenderJpFontName = g_noteRenderFontName.empty() ? g_noteFontName : g_noteRenderFontName;
            g_config.noteRenderJpFontName = g_noteRenderJpFontName;
        }
        ApplyNoteFont();
        PersistConfig();
        if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
    DestroyMenu(menu);
}

static void ShowNoteAssistFontSizeMenu(HWND hWnd) {
    HMENU menu = CreatePopupMenu();
    if (!menu) return;
    constexpr int sizes[] = {8, 9, 10, 11, 12, 14, 16, 18, 20};
    constexpr UINT kMenuBase = 49000;
    for (UINT i = 0; i < static_cast<UINT>(sizeof(sizes) / sizeof(sizes[0])); ++i) {
        const int pt = sizes[i];
        std::wstring label = std::to_wstring(pt) + L"pt";
        UINT flags = MF_STRING;
        if (static_cast<int>(std::lround(g_noteFontPt)) == pt) {
            flags |= MF_CHECKED;
        }
        AppendMenuW(menu, flags, kMenuBase + i, label.c_str());
    }
    POINT pt{};
    GetCursorPos(&pt);
    UINT cmd = TrackPopupMenu(menu, TPM_RETURNCMD | TPM_RIGHTBUTTON, pt.x, pt.y, 0, hWnd, nullptr);
    if (cmd >= kMenuBase && cmd < kMenuBase + (sizeof(sizes) / sizeof(sizes[0]))) {
        const UINT idx = cmd - kMenuBase;
        g_noteFontPt = static_cast<double>(sizes[idx]);
        g_noteRenderFontPt = g_noteFontPt;
        g_config.noteFontPt = g_noteFontPt;
        g_config.noteRenderFontPt = g_noteRenderFontPt;
        ApplyNoteFont();
        PersistConfig();
        if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
    DestroyMenu(menu);
}

static void ShowNoteAssistNoteBackgroundMenu(HWND hWnd) {
    HMENU menu = CreatePopupMenu();
    if (!menu) return;

    const bool isEn = IsEnglishUi();
    std::wstring bgSource = ToLowerAscii(g_config.noteBgSource);
    bool themeCurrent = (bgSource == L"theme" || bgSource == L"theme_current");
    bool themeNamed = (bgSource == L"theme_named");
    bool explicitColor = !themeCurrent && !themeNamed;

    constexpr UINT kMenuThemeCurrent = 51000;
    constexpr UINT kMenuThemeBase = 51100;
    constexpr UINT kMenuPresetBase = 51200;
    constexpr UINT kMenuCustom = 51300;

    UINT flagsThemeCurrent = MF_STRING;
    if (themeCurrent) flagsThemeCurrent |= MF_CHECKED;
    if (g_themeCatalog.empty()) flagsThemeCurrent |= MF_GRAYED;
    AppendMenuW(menu, flagsThemeCurrent, kMenuThemeCurrent, isEn ? L"Theme-follow (current)" : L"テーマ準拠");

    if (!g_themeCatalog.empty()) {
        for (UINT i = 0; i < static_cast<UINT>(g_themeCatalog.size()); ++i) {
            const auto& t = g_themeCatalog[i];
            std::wstring name = (t.nameJp.empty() ? t.name : t.nameJp);
            if (name.empty()) name = L"(unnamed)";
            std::wstring label = name + L" " + ColorToHexW(t.noteBg);
            UINT flags = MF_STRING;
            if (themeNamed && t.name == g_config.noteBgThemeName) flags |= MF_CHECKED;
            AppendMenuW(menu, flags, kMenuThemeBase + i, label.c_str());
        }
    }

    AppendMenuW(menu, MF_SEPARATOR, 0, nullptr);

    struct Preset {
        COLORREF color;
        const wchar_t* en;
        const wchar_t* ja;
    };
    const Preset presets[] = {
        { RGB(255, 255, 255), L"White", L"白" },
        { RGB(255, 250, 235), L"Cream", L"クリーム" },
        { RGB(245, 245, 245), L"Light gray", L"薄グレー" },
        { RGB(255, 255, 230), L"Soft yellow", L"薄イエロー" },
    };
    constexpr UINT kPresetCount = static_cast<UINT>(sizeof(presets) / sizeof(presets[0]));
    for (UINT i = 0; i < kPresetCount; ++i) {
        const auto& p = presets[i];
        UINT flags = MF_STRING;
        if (explicitColor && p.color == g_noteBgColor) flags |= MF_CHECKED;
        AppendMenuW(menu, flags, kMenuPresetBase + i, isEn ? p.en : p.ja);
    }
    AppendMenuW(menu, MF_SEPARATOR, 0, nullptr);
    AppendMenuW(menu, MF_STRING, kMenuCustom, isEn ? L"Custom..." : L"カスタム...");

    POINT pt{};
    GetCursorPos(&pt);
    UINT cmd = TrackPopupMenu(menu, TPM_RETURNCMD | TPM_RIGHTBUTTON, pt.x, pt.y, 0, hWnd, nullptr);

    bool anyPicked = false;
    COLORREF pickedColor = g_noteBgColor;
    std::wstring pickedSource = g_config.noteBgSource;
    std::wstring pickedThemeName = g_config.noteBgThemeName;
    bool explicitPicked = false;

    if (cmd == kMenuThemeCurrent && !g_themeCatalog.empty()) {
        anyPicked = true;
        pickedSource = L"theme_current";
        pickedThemeName.clear();
        pickedColor = g_theme.noteBg;
    } else if (cmd >= kMenuThemeBase && cmd < kMenuThemeBase + static_cast<UINT>(g_themeCatalog.size())) {
        anyPicked = true;
        const UINT idx = cmd - kMenuThemeBase;
        const auto& t = g_themeCatalog[idx];
        pickedSource = L"theme_named";
        pickedThemeName = t.name;
        pickedColor = t.noteBg;
    } else if (cmd >= kMenuPresetBase && cmd < kMenuPresetBase + kPresetCount) {
        anyPicked = true;
        explicitPicked = true;
        const UINT idx = cmd - kMenuPresetBase;
        pickedSource = L"explicit";
        pickedThemeName.clear();
        pickedColor = presets[idx].color;
    } else if (cmd == kMenuCustom) {
        COLORREF c = g_noteBgColor;
        if (PickColorDialog(hWnd, c, &c)) {
            anyPicked = true;
            explicitPicked = true;
            pickedSource = L"explicit";
            pickedThemeName.clear();
            pickedColor = c;
        }
    }

    if (anyPicked) {
        bool changed =
            (ToLowerAscii(g_config.noteBgSource) != ToLowerAscii(pickedSource)) ||
            (g_config.noteBgThemeName != pickedThemeName) ||
            (pickedColor != g_noteBgColor);

        g_config.noteBgSource = pickedSource;
        g_config.noteBgThemeName = pickedThemeName;
        if (explicitPicked) {
            g_config.noteBgColor = pickedColor;
        }
        g_noteBgColor = pickedColor;

        if (changed) {
            PersistConfig();

            if (g_hThemeNoteBrush) {
                DeleteObject(g_hThemeNoteBrush);
                g_hThemeNoteBrush = nullptr;
            }
            g_hThemeNoteBrush = CreateSolidBrush(g_noteBgColor);

            ApplyThemeToUI(g_hMainWnd ? g_hMainWnd : nullptr);
            if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
        } else {
            if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
        }
    }

    DestroyMenu(menu);
}

static int GetNoteRenderRightPadPx(HWND hWnd, int clientW) {
    if (clientW < 0) clientW = 0;
    return std::max(ScaleY(hWnd, 80), clientW / 10);
}

static int NoteRenderLineStartInsetPx(HWND hWnd) {
    return 0;
}

struct NoteVisualAssistMarginState {
    bool captured = false;
    UINT baseMargins = 0;
    int appliedLeft = -1;
    int appliedRight = -1;
};
static std::unordered_map<HWND, NoteVisualAssistMarginState> g_noteVisualAssistMarginByHwnd;

static int GetNoteLineNumberGutterWidth(HWND hWnd) {
    if (!hWnd || !IsWindow(hWnd)) return 0;
    int lineCount = std::max(1, static_cast<int>(SendMessageW(hWnd, EM_GETLINECOUNT, 0, 0)));
    int digits = 1;
    for (int n = lineCount; n >= 10; n /= 10) ++digits;
    digits = std::max(4, digits);

    int textW = ScaleY(hWnd, 32);
    HDC hdc = GetDC(hWnd);
    if (hdc) {
        HFONT font = GetActiveNoteFont();
        HFONT old = font ? static_cast<HFONT>(SelectObject(hdc, font)) : nullptr;
        std::wstring sample(static_cast<size_t>(digits), L'8');
        SIZE sz{};
        if (GetTextExtentPoint32W(hdc, sample.c_str(), static_cast<int>(sample.size()), &sz) && sz.cx > 0) {
            textW = sz.cx;
        }
        if (old) SelectObject(hdc, old);
        ReleaseDC(hWnd, hdc);
    }
    return textW + ScaleY(hWnd, 14);
}

struct NoteMarginFrame {
    int baseLeft = 0;
    int baseRight = 0;
    int desiredLeft = 0;
    int desiredRight = 0;
    int lineNumberGutterPx = 0;
};

static NoteMarginFrame ResolveNoteMarginFrame(HWND hWnd) {
    NoteMarginFrame frame;
    if (!hWnd || !IsWindow(hWnd)) return frame;

    NoteVisualAssistMarginState& state = g_noteVisualAssistMarginByHwnd[hWnd];
    if (!state.captured) {
        state.baseMargins = static_cast<UINT>(SendMessageW(hWnd, EM_GETMARGINS, 0, 0));
        state.captured = true;
    }

    frame.baseLeft = static_cast<int>(LOWORD(state.baseMargins));
    frame.baseRight = static_cast<int>(HIWORD(state.baseMargins));
    frame.lineNumberGutterPx = g_noteShowLineNumbers ? GetNoteLineNumberGutterWidth(hWnd) : 0;
    frame.desiredLeft = frame.baseLeft + NoteRenderLineStartInsetPx(hWnd);
    frame.desiredRight = std::max(frame.baseRight, ScaleY(hWnd, 12));
    if (g_noteShowLineNumbers) {
        frame.desiredLeft = std::max(frame.desiredLeft, frame.lineNumberGutterPx);
    }
    return frame;
}

static bool UpdateNoteVisualAssistMargins(HWND hWnd, bool invalidate) {
    if (!hWnd || !IsWindow(hWnd)) return false;
    NoteVisualAssistMarginState& state = g_noteVisualAssistMarginByHwnd[hWnd];
    const NoteMarginFrame margins = ResolveNoteMarginFrame(hWnd);
    const int desiredLeft = margins.desiredLeft;
    const int desiredRight = margins.desiredRight;
    if (desiredLeft == state.appliedLeft && desiredRight == state.appliedRight) {
        return false;
    }

    SendMessageW(hWnd, EM_SETMARGINS, EC_LEFTMARGIN | EC_RIGHTMARGIN,
                 MAKELPARAM(desiredLeft, desiredRight));
    state.appliedLeft = desiredLeft;
    state.appliedRight = desiredRight;
    if (invalidate) {
        InvalidateRect(hWnd, nullptr, FALSE);
    }
    return true;
}

struct NoteLayoutFrame {
    RECT client{};
    RECT formatRect{};
    int clientWidthPx = 0;
    int clientHeightPx = 0;
    int contentLeftPx = 0;
    int rawLeftPx = 0;
    int overlayLeftPx = 0;
    int lineNumberGutterPx = 0;
    int scrollX = 0;
    int canvasWidthPx = 0;
    int maxScrollX = 0;
    int dpi = 96;
    note::NoteDerivedSnapshotIdentity sourceIdentity{};
    bool renderActive = false;
    bool rawWrapActive = false;
};

static int GetNoteRenderCanvasWidthPx(HWND hWnd, int clientW) {
    clientW = std::max(0, clientW);
    return std::max(clientW, g_noteRenderedContentRightPx + GetNoteRenderRightPadPx(hWnd, clientW));
}

static int GetNoteRenderMaxScrollX(HWND hWnd, int clientW) {
    int canvasWidth = GetNoteRenderCanvasWidthPx(hWnd, clientW);
    return std::max(0, canvasWidth - std::max(0, clientW));
}

static NoteLayoutFrame BuildNoteLayoutFrame(HWND hWnd) {
    NoteLayoutFrame frame;
    if (!hWnd) return frame;

    frame.renderActive = IsNoteRenderActive();
    frame.rawWrapActive = (!frame.renderActive && g_noteWrapEnabled);
    frame.dpi = GetDpiY(hWnd);
    frame.sourceIdentity = note::NoteDerivedSnapshotIdentity{
        CurrentNoteTextCoreOwner(), CurrentNoteTextCoreModel().revision};
    GetClientRect(hWnd, &frame.client);
    frame.clientWidthPx = std::max<int>(0, static_cast<int>(frame.client.right - frame.client.left));
    frame.clientHeightPx = std::max<int>(0, static_cast<int>(frame.client.bottom - frame.client.top));
    frame.canvasWidthPx = frame.clientWidthPx;

    const NoteMarginFrame margins = ResolveNoteMarginFrame(hWnd);
    frame.contentLeftPx = margins.desiredLeft;
    frame.rawLeftPx = margins.desiredLeft;
    frame.overlayLeftPx = margins.desiredLeft;
    frame.lineNumberGutterPx = margins.lineNumberGutterPx;

    frame.formatRect = frame.client;
    const int bottomPadPx = std::max(ScaleY(hWnd, 60), frame.clientHeightPx / 2);

    if (!frame.renderActive) {
        if (HDC hdc = GetDC(hWnd)) {
            HFONT oldFont = static_cast<HFONT>(SelectObject(hdc, GetActiveNoteFont()));
            TEXTMETRICW tm{};
            GetTextMetricsW(hdc, &tm);
            int baseLineHeight = tm.tmHeight;
            if (baseLineHeight <= 0) baseLineHeight = 1;
            int innerPad = std::max(1, baseLineHeight / 12);
            int renderYOffset = 1;
            frame.formatRect.top += innerPad + renderYOffset;
            SelectObject(hdc, oldFont);
            ReleaseDC(hWnd, hdc);
        }
    }

    if (frame.renderActive) {
        constexpr LONG kMaxFmtWidth = 32000;
        frame.canvasWidthPx = std::min<int>(kMaxFmtWidth,
                                            GetNoteRenderCanvasWidthPx(hWnd, frame.clientWidthPx));
        frame.maxScrollX = std::max(0, frame.canvasWidthPx - frame.clientWidthPx);
        frame.scrollX = std::clamp(g_noteRenderScrollX, 0, frame.maxScrollX);
        frame.formatRect.left = -frame.scrollX;
        frame.formatRect.right = frame.formatRect.left + frame.canvasWidthPx;
        frame.rawLeftPx = margins.desiredLeft - frame.scrollX;
        frame.overlayLeftPx = margins.desiredLeft - frame.scrollX;
    } else if (!frame.rawWrapActive) {
        constexpr LONG kMaxFmtWidth = 32000;
        frame.formatRect.right = std::max<LONG>(frame.formatRect.right, kMaxFmtWidth);
        frame.scrollX = 0;
    } else {
        frame.scrollX = 0;
    }
    frame.formatRect.bottom = frame.client.bottom + bottomPadPx;
    if (frame.renderActive && g_noteRenderedContentBottomPx > 0) {
        frame.formatRect.bottom = std::max<LONG>(
            frame.formatRect.bottom,
            static_cast<LONG>(g_noteRenderedContentBottomPx + bottomPadPx));
    }
    return frame;
}

static int NoteLayoutFrameLineBaseXForRenderState(const NoteLayoutFrame& frame, int nativeLineX) {
    if (frame.renderActive) {
        return frame.overlayLeftPx;
    }
    return nativeLineX;
}

static int NoteLayoutFrameClientXFromNativeLineX(const NoteLayoutFrame& frame,
                                                 int nativeLineX,
                                                 int nativeX) {
    return NoteLayoutFrameLineBaseXForRenderState(frame, nativeLineX) + (nativeX - nativeLineX);
}

static int NoteLayoutFrameAnchorScrollX(const NoteLayoutFrame& frame, HWND hWnd) {
    if (frame.renderActive) {
        return frame.scrollX;
    }
    POINT scroll{};
    if (QueryEditScrollPos(hWnd, &scroll)) {
        return scroll.x;
    }
    return 0;
}

static int StableNoteRenderLineBaseX(HWND hWnd) {
    return BuildNoteLayoutFrame(hWnd).overlayLeftPx;
}

static int NoteLineBaseXForRenderState(HWND hWnd, int nativeLineX) {
    if (IsNoteRenderActive()) {
        return StableNoteRenderLineBaseX(hWnd);
    }
    return nativeLineX;
}

static bool SetNoteRenderScrollPosX(HWND hWnd, int pos) {
    if (!hWnd) return false;
    RECT rc{};
    GetClientRect(hWnd, &rc);
    int clientW = std::max<int>(0, static_cast<int>(rc.right - rc.left));
    int next = std::clamp(pos, 0, GetNoteRenderMaxScrollX(hWnd, clientW));
    if (next == g_noteRenderScrollX) return false;
    g_noteRenderScrollX = next;
    UpdateNoteFormatRect(hWnd);
    InvalidateRect(hWnd, nullptr, FALSE);
    return true;
}

static void UpdateNoteFormatRect(HWND hWnd) {
    if (!hWnd) return;

    const bool nextRenderActive = IsNoteRenderActive();
    const bool nextRawWrapActive = (!nextRenderActive && g_noteWrapEnabled);
    if (IsRichEditControl(hWnd)) {
        // RichEdit keeps its own wrap state. Explicitly switch it so existing soft wraps
        // are recomputed immediately when the user toggles raw-mode auto wrap.
        SendMessageW(hWnd, EM_SETTARGETDEVICE, 0, nextRawWrapActive ? 0 : 1);
    }

    // RichEdit may adjust its internal format rectangle when margins change.
    // Commit margins first, then derive and apply one coherent layout frame.
    UpdateNoteVisualAssistMargins(hWnd, false);
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    const bool renderActive = layoutFrame.renderActive;
    const bool rawWrapActive = layoutFrame.rawWrapActive;
    POINT nativeScroll{};
    bool hasNativeScroll = QueryNativeEditScrollPos(hWnd, &nativeScroll);
    if (!hasNativeScroll) {
        nativeScroll.x = GetScrollPos(hWnd, SB_HORZ);
        nativeScroll.y = GetScrollPos(hWnd, SB_VERT);
        hasNativeScroll = true;
    }
    if (renderActive) {
        // RichEdit's native horizontal extent tracks raw text, not the rendered overlay. In render mode,
        // keep a separate x offset and move the formatting rectangle itself.
        g_noteRenderScrollX = layoutFrame.scrollX;
    } else if (!rawWrapActive) {
        g_noteRenderScrollX = 0;
    } else {
        g_noteRenderScrollX = 0;
    }
    if (renderActive || rawWrapActive) {
        nativeScroll.x = 0;
    }
    if (renderActive) {
        SCROLLINFO sx{};
        sx.cbSize = sizeof(sx);
        sx.fMask = SIF_RANGE | SIF_PAGE | SIF_POS;
        sx.nMin = 0;
        sx.nMax = std::max(0, layoutFrame.canvasWidthPx - 1);
        sx.nPage = static_cast<UINT>(std::max(0, layoutFrame.clientWidthPx));
        sx.nPos = g_noteRenderScrollX;
        SetScrollInfo(hWnd, SB_HORZ, &sx, TRUE);
        ShowScrollBar(hWnd, SB_HORZ, (layoutFrame.maxScrollX > 0) ? TRUE : FALSE);
    } else {
        ShowScrollBar(hWnd, SB_HORZ, rawWrapActive ? FALSE : TRUE);
    }
    RECT fmt = layoutFrame.formatRect;
    SendMessageW(hWnd, EM_SETRECTNP, 0, reinterpret_cast<LPARAM>(&fmt));
    if (IsRichEditControl(hWnd)) {
        SendMessageW(hWnd, EM_REQUESTRESIZE, 0, 0);
    }
    if (hasNativeScroll) {
        POINT restore = nativeScroll;
        if (renderActive || rawWrapActive) {
            restore.x = 0;
        }
        if (!SendMessageW(hWnd, EM_SETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&restore))) {
            SetScrollPos(hWnd, SB_VERT, restore.y, TRUE);
            if (renderActive || rawWrapActive) {
                SetScrollPos(hWnd, SB_HORZ, 0, TRUE);
            }
            SendMessageW(hWnd, WM_VSCROLL, MAKEWPARAM(SB_THUMBPOSITION, restore.y), 0);
        }
    }
}

static std::wstring ToLowerAscii(const std::wstring& s) {
    std::wstring out = s;
    for (auto& ch : out) {
        if (ch >= L'A' && ch <= L'Z') ch = static_cast<wchar_t>(ch - L'A' + L'a');
    }
    return out;
}

static wchar_t ToLowerAsciiChar(wchar_t ch) {
    if (ch >= L'A' && ch <= L'Z') return static_cast<wchar_t>(ch - L'A' + L'a');
    return ch;
}

static bool StartsWithAsciiNoCase(const std::wstring& s, const wchar_t* prefix) {
    size_t len = wcslen(prefix);
    if (s.size() < len) return false;
    for (size_t i = 0; i < len; ++i) {
        if (ToLowerAsciiChar(s[i]) != ToLowerAsciiChar(prefix[i])) return false;
    }
    return true;
}

static bool EndsWithAsciiNoCase(const std::wstring& s, const wchar_t* suffix) {
    size_t len = wcslen(suffix);
    if (s.size() < len) return false;
    size_t start = s.size() - len;
    for (size_t i = 0; i < len; ++i) {
        if (ToLowerAsciiChar(s[start + i]) != ToLowerAsciiChar(suffix[i])) return false;
    }
    return true;
}

static bool StartsWithAsciiNoCaseAt(const std::wstring& s, size_t pos, const wchar_t* prefix) {
    size_t len = wcslen(prefix);
    if (pos + len > s.size()) return false;
    for (size_t i = 0; i < len; ++i) {
        if (ToLowerAsciiChar(s[pos + i]) != ToLowerAsciiChar(prefix[i])) return false;
    }
    return true;
}

static bool ParseHexColor(const std::wstring& value, COLORREF& out) {
    std::wstring v = value;
    if (v.rfind(L"0x", 0) == 0 || v.rfind(L"0X", 0) == 0) v = v.substr(2);
    if (!v.empty() && v[0] == L'#') v = v.substr(1);
    if (v.size() != 6) return false;
    auto hex = [](wchar_t ch) -> int {
        if (ch >= L'0' && ch <= L'9') return ch - L'0';
        if (ch >= L'a' && ch <= L'f') return 10 + (ch - L'a');
        if (ch >= L'A' && ch <= L'F') return 10 + (ch - L'A');
        return -1;
    };
    int r1 = hex(v[0]), r2 = hex(v[1]);
    int g1 = hex(v[2]), g2 = hex(v[3]);
    int b1 = hex(v[4]), b2 = hex(v[5]);
    if (r1 < 0 || r2 < 0 || g1 < 0 || g2 < 0 || b1 < 0 || b2 < 0) return false;
    int r = r1 * 16 + r2;
    int g = g1 * 16 + g2;
    int b = b1 * 16 + b2;
    out = RGB(r, g, b);
    return true;
}

enum class ColorMode { None, Explicit, HiContrast };
enum class HorizontalAnchor { None, Left, Center, Right };

struct ColorSpec {
    ColorMode mode = ColorMode::None;
    COLORREF color = RGB(0, 0, 0);
};

struct TagStyle {
    bool bold = false;
    bool italic = false;
    bool underline = false;
    bool strike = false;
    bool hasTextColor = false;
    ColorSpec textColor;
    bool hasBackColor = false;
    ColorSpec backColor;
    bool hasIndent = false;
    int indent = 0;
    HorizontalAnchor anchor = HorizontalAnchor::None;
    int anchorOffsetChars = 0;
    int headingLevel = 0;
    bool hasLink = false;
    std::wstring linkId;
    bool linkAccent = false;
    bool linkUnderline = false;
    bool hasFontSize = false;
    int fontSizePx = 0;
    bool hasFontFace = false;
    std::wstring fontFace;
    bool hasLineHeight = false;
    int lineHeightPermille = 0;
};

struct StyleState {
    bool bold = false;
    bool italic = false;
    bool underline = false;
    bool strike = false;
    ColorSpec text;
    ColorSpec back;
    int indent = 0;
    HorizontalAnchor anchor = HorizontalAnchor::None;
    int anchorOffsetChars = 0;
    int headingLevel = 0;
    std::wstring linkId; // when non-empty, this run is clickable and resolves to a PDF LinkMarker by id
    bool linkAccent = false;
    bool linkUnderline = false;
    bool hasFontSize = false;
    int fontSizePx = 0;
    bool hasFontFace = false;
    std::wstring fontFace;
    bool hasLineHeight = false;
    int lineHeightPermille = 0;
};

struct TagFrame {
    TagStyle style{};
    size_t startLine = 0;
    size_t startSegment = 0;
    bool isMathBlock = false;
    bool isCodeFenceBlock = false;
    wchar_t codeFenceMarker = 0;
    std::wstring codeFenceLanguage;
    std::vector<std::wstring> closeAliases;
};

struct SegmentMeasureCache {
    bool valid = false;
    int baseFontHeight = 0;
    bool renderActive = false;
    int mathSupSubGapSupPercent = 0;
    int spaceWidth = 0;
    int baseAveCharWidth = 0;
    int baseMaxCharWidth = 0;
    int baseOverhang = 0;
    std::wstring baseFace;
    std::wstring jpFace;
    int width = 0;
    bool measureAsMath = false;
    bool prefixValid = false;
    std::vector<int> prefixWidths;
};

struct Segment {
    std::wstring text;
    std::wstring mathText;
    StyleState style;
    size_t rawStart = 0;
    size_t rawLen = 0;
    bool isMath = false;
    bool isMarkupMath = false;
    bool mathDisplay = false;
    bool isMarkdownLink = false;
    bool isInlineCode = false;
    mutable SegmentMeasureCache measureCache;
};

struct LineCache {
    uint64_t source_revision = 0;
    std::wstring rawLine;
    std::vector<Segment> segments;
    int headingLevel = 0;
    int headingPrefixLevel = 0;
    bool hasFontSize = false;
    int fontSizePx = 0;
    bool hasLineHeight = false;
    int lineHeightPermille = 1000;
    bool isCodeBlockLine = false;
    bool isHorizontalRuleLine = false;
    bool isCodeFenceLine = false;
    bool isCodeFenceOpening = false;
    bool isCodeFenceClosing = false;
    wchar_t codeFenceMarker = 0;
    std::wstring codeFenceLanguage;
    bool isCustomContainerLine = false;
    bool isCustomContainerFenceLine = false;
    bool isCustomContainerOpening = false;
    bool isCustomContainerClosing = false;
    int customContainerFenceCount = 0;
    std::wstring customContainerKind;
    std::vector<TagFrame> endStack;
};

struct NoteRenderLineInfo {
    size_t start = 0;
    size_t end = 0;
};

static bool SegmentHasVisibleText(const Segment& seg) {
    for (wchar_t ch : seg.text) {
        if (!iswspace(ch)) return true;
    }
    return false;
}

static bool IsDisplayMathSegment(const Segment& seg) {
    return seg.isMath && seg.mathDisplay;
}

static bool LineHasDisplayMathSegment(const LineCache& cache) {
    for (const auto& seg : cache.segments) {
        if (IsDisplayMathSegment(seg)) return true;
    }
    return false;
}

static bool LineIsStandaloneDisplayMath(const LineCache& cache) {
    bool sawDisplayMath = false;
    for (const auto& seg : cache.segments) {
        if (!SegmentHasVisibleText(seg)) continue;
        if (IsDisplayMathSegment(seg)) {
            sawDisplayMath = true;
            continue;
        }
        return false;
    }
    return sawDisplayMath;
}

static int ResolveAdditionalRenderIndentChars(const LineCache& cache) {
    int indent = (cache.headingLevel > 0) ? 1 : 0;
    if (cache.isCodeBlockLine) indent += 4;
    if (cache.isCustomContainerLine) indent += 3;
    if (LineIsStandaloneDisplayMath(cache)) indent += 1;
    return indent;
}

static int ResolveSpecialLineVisualPadPx(const LineCache& cache, int baseLineHeight) {
    baseLineHeight = std::max(1, baseLineHeight);
    int pad = 0;
    if (cache.isCodeBlockLine) {
        pad = std::max(pad, std::max(2, baseLineHeight / 8));
    }
    if (cache.isCustomContainerLine) {
        pad = std::max(pad, std::max(2, baseLineHeight / 10));
    }
    if (LineHasDisplayMathSegment(cache)) {
        pad = std::max(pad, std::max(2, baseLineHeight / 10));
    }
    return pad;
}

static void ApplyDefaultMathSegmentLayout(Segment* seg) {
    if (!seg || !seg->isMath || !seg->mathDisplay) return;
    seg->style.anchor = HorizontalAnchor::None;
    seg->style.anchorOffsetChars = 0;
}

static size_t SegmentRawLen(const Segment& seg) {
    return (seg.rawLen > 0) ? seg.rawLen : seg.text.size();
}

static bool IsLiteralEscapeLeadAt(const std::wstring& text, size_t pos) {
    return pos + 2 < text.size() && text[pos] == L'!' && text[pos + 1] == L'/';
}

static std::wstring DecodeLiteralEscapes(const std::wstring& raw) {
    if (raw.empty()) return raw;
    std::wstring out;
    out.reserve(raw.size());
    for (size_t i = 0; i < raw.size(); ++i) {
        if (IsLiteralEscapeLeadAt(raw, i)) {
            out.push_back(raw[i + 2]);
            i += 2;
            continue;
        }
        out.push_back(raw[i]);
    }
    return out;
}

static size_t VisibleCharsBeforeRawOffset(const std::wstring& raw,
                                          size_t rawOffset,
                                          bool decodeMarkdownBackslashEscapes = false) {
    rawOffset = std::min(rawOffset, raw.size());
    if (raw.size() >= 4 && raw.front() == L'[') {
        size_t closeBracket = raw.find(L']');
        if (closeBracket != std::wstring::npos &&
            closeBracket + 1 < raw.size() &&
            raw[closeBracket + 1] == L'(' &&
            raw.back() == L')') {
            if (rawOffset <= 1) return 0;
            if (rawOffset <= closeBracket) return rawOffset - 1;
            return closeBracket - 1;
        }
    }
    size_t visible = 0;
    for (size_t i = 0; i < rawOffset;) {
        if (IsLiteralEscapeLeadAt(raw, i)) {
            if (i + 3 <= rawOffset) {
                ++visible;
                i += 3;
            } else {
                break;
            }
            continue;
        }
        if (decodeMarkdownBackslashEscapes && note::IsMarkdownBackslashEscapeAt(raw, i)) {
            if (i + 2 <= rawOffset) {
                ++visible;
                i += 2;
            } else {
                break;
            }
            continue;
        }
        ++visible;
        ++i;
    }
    return visible;
}

static size_t RawOffsetForVisibleCharCount(const std::wstring& raw,
                                           size_t visibleCount,
                                           bool decodeMarkdownBackslashEscapes = false) {
    if (visibleCount == 0) return 0;
    if (raw.size() >= 4 && raw.front() == L'[') {
        size_t closeBracket = raw.find(L']');
        if (closeBracket != std::wstring::npos &&
            closeBracket + 1 < raw.size() &&
            raw[closeBracket + 1] == L'(' &&
            raw.back() == L')') {
            size_t labelLen = closeBracket - 1;
            return 1 + std::min(visibleCount, labelLen);
        }
    }
    size_t visible = 0;
    for (size_t i = 0; i < raw.size();) {
        if (IsLiteralEscapeLeadAt(raw, i)) {
            ++visible;
            i += 3;
            if (visible >= visibleCount) return i;
            continue;
        }
        if (decodeMarkdownBackslashEscapes && note::IsMarkdownBackslashEscapeAt(raw, i)) {
            ++visible;
            i += 2;
            if (visible >= visibleCount) return i;
            continue;
        }
        ++visible;
        ++i;
        if (visible >= visibleCount) return i;
    }
    return raw.size();
}

static bool SegmentDecodesMarkdownBackslashEscapes(const LineCache& cache, const Segment& seg) {
    return !cache.isCodeBlockLine && !seg.isInlineCode && !seg.isMath;
}

static bool VisibleIndexToRawOffsetInLine(const LineCache& cache, size_t visibleIndex, size_t* outRawOffset) {
    if (!outRawOffset) return false;
    size_t visibleCursor = 0;
    for (const auto& seg : cache.segments) {
        if (seg.text.empty()) continue;
        const size_t segVisLen = seg.text.size();
        if (visibleIndex <= visibleCursor + segVisLen) {
            const size_t withinVisible = visibleIndex - visibleCursor;
            const std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
            const size_t withinRaw = RawOffsetForVisibleCharCount(
                rawSeg, withinVisible, SegmentDecodesMarkdownBackslashEscapes(cache, seg));
            *outRawOffset = seg.rawStart + withinRaw;
            return true;
        }
        visibleCursor += segVisLen;
    }
    if (visibleIndex == visibleCursor) {
        *outRawOffset = cache.rawLine.size();
        return true;
    }
    return false;
}

static NoteListMarkerInfo DetectNoteListMarkerInfo(const LineCache& cache) {
    NoteListMarkerInfo info{};
    if (cache.segments.empty()) return info;

    bool haveFirst = false;
    wchar_t first = 0;
    wchar_t second = 0;
    size_t firstIndex = 0;
    size_t visibleIndex = 0;

    for (const auto& seg : cache.segments) {
        for (wchar_t ch : seg.text) {
            if (!haveFirst) {
                if (IsNoteBulletIndentChar(ch)) {
                    ++visibleIndex;
                    continue;
                }
                haveFirst = true;
                first = ch;
                firstIndex = visibleIndex;
                ++visibleIndex;
                continue;
            }
            second = ch;
            goto done_scan;
        }
    }
done_scan:

    if (!haveFirst) return info;
    if (!IsMarkdownBulletMarker(first) || second != L' ') return info;

    size_t rawStart = 0;
    size_t rawEnd = 0;
    if (!VisibleIndexToRawOffsetInLine(cache, firstIndex, &rawStart)) return info;
    if (!VisibleIndexToRawOffsetInLine(cache, firstIndex + 2, &rawEnd)) return info;
    if (rawEnd <= rawStart) return info;

    info.rawStart = rawStart;
    info.rawEnd = rawEnd;
    info.marker = first;
    info.valid = true;
    return info;
}

static bool ShouldRenderMathSegment(const Segment& seg) {
    if (!seg.isMath) return false;
    if (!IsNoteRenderActive()) return false;
    if (IsNoteMathRenderActive()) return true;
    return seg.isMarkupMath;
}

static std::wstring GetSegmentMathBody(const Segment& seg) {
    std::wstring body = !seg.mathText.empty() ? seg.mathText : StripMathDelims(seg.text);
    body = StripLineJoins(body);
    body = NormalizeMarkupMathText(body);
    return body;
}

