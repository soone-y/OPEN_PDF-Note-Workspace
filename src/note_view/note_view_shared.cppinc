static const wchar_t* NoteMenuLabelCopyWithTags() { return IsEnglishUi() ? L"Copy With Tags" : L"タグもコピー"; }
static const wchar_t* NoteMenuLabelPaste() { return IsEnglishUi() ? L"Paste" : L"貼り付け"; }
static const wchar_t* NoteMenuLabelSelectAll() { return IsEnglishUi() ? L"Select All" : L"全選択"; }
static const wchar_t* NoteMenuLabelSelectNone() { return IsEnglishUi() ? L"Deselect" : L"選択解除"; }

static void ShowNoteCopySuccessNotice(HWND owner) {
    ShowSoftNotice(owner ? owner : g_hMainWnd,
                   IsEnglishUi() ? L"Copied text." : L"テキストをコピーしました。",
                   SoftNoticeKind::Info);
}

static bool CopyNoteNormalVisualSelection(HWND owner, bool includeTags) {
    if (!g_hNoteEdit || !IsNoteNormalVisualActive()) return false;
    auto range = NoteNormalSelectionRange();
    if (range.second <= range.first) return false;
    std::wstring text;
    if (includeTags) {
        text = GetEditText(g_hNoteEdit);
        if (range.first >= text.size()) return false;
        range.second = std::min(range.second, text.size());
        text = text.substr(range.first, range.second - range.first);
    } else {
        text = ExtractRenderedTextRange(range.first, range.second);
    }
    if (!SetClipboardUnicodeText(owner ? owner : g_hMainWnd, text)) return false;
    ShowNoteCopySuccessNotice(owner);
    return true;
}

static void ShowNoteContextMenu(HWND hWnd, POINT screenPt) {
    if (!hWnd) return;
    if (screenPt.x == -1 && screenPt.y == -1) {
        GetCursorPos(&screenPt);
    }

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL, reinterpret_cast<WPARAM>(&selStart), reinterpret_cast<LPARAM>(&selEnd));
    const bool hasSelection = (selStart != selEnd);
    const bool canPaste = IsClipboardFormatAvailable(CF_UNICODETEXT) != 0;
    const bool hasText = GetWindowTextLengthW(hWnd) > 0;

    enum : UINT {
        ID_CTX_CUT = 1,
        ID_CTX_COPY,
        ID_CTX_COPY_WITH_TAGS,
        ID_CTX_PASTE,
        ID_CTX_SELECT_ALL,
        ID_CTX_SELECT_NONE
    };

    HMENU menu = CreatePopupMenu();
    if (!menu) return;
    const bool normalVisual = (g_noteVimModeEnabled && g_noteNormalMode && IsNoteNormalVisualActive());
    if (normalVisual) {
        AppendMenuW(menu, MF_STRING | (hasSelection ? 0 : MF_GRAYED), ID_CTX_COPY, NoteMenuLabelCopy());
        AppendMenuW(menu, MF_STRING | (hasSelection ? 0 : MF_GRAYED), ID_CTX_COPY_WITH_TAGS, NoteMenuLabelCopyWithTags());
    } else {
    AppendMenuW(menu, MF_STRING | (hasSelection ? 0 : MF_GRAYED), ID_CTX_CUT, NoteMenuLabelCut());
    AppendMenuW(menu, MF_STRING | (hasSelection ? 0 : MF_GRAYED), ID_CTX_COPY, NoteMenuLabelCopy());
    AppendMenuW(menu, MF_STRING | (canPaste ? 0 : MF_GRAYED), ID_CTX_PASTE, NoteMenuLabelPaste());
    AppendMenuW(menu, MF_SEPARATOR, 0, nullptr);
    AppendMenuW(menu, MF_STRING | (hasText ? 0 : MF_GRAYED), ID_CTX_SELECT_ALL, NoteMenuLabelSelectAll());
    AppendMenuW(menu, MF_STRING | (hasSelection ? 0 : MF_GRAYED), ID_CTX_SELECT_NONE, NoteMenuLabelSelectNone());
    }

    UINT cmd = TrackPopupMenu(menu, TPM_RETURNCMD | TPM_RIGHTBUTTON, screenPt.x, screenPt.y, 0, hWnd, nullptr);
    DestroyMenu(menu);
    if (!cmd) {
        if (normalVisual) {
            ClearNoteNormalVisualMode();
        }
        return;
    }

    switch (cmd) {
    case ID_CTX_CUT:
        SendMessageW(hWnd, WM_CUT, 0, 0);
        break;
    case ID_CTX_COPY:
        if (normalVisual) {
            CopyNoteNormalVisualSelection(hWnd, false);
        } else {
            SendMessageW(hWnd, WM_COPY, 0, 0);
        }
        break;
    case ID_CTX_COPY_WITH_TAGS:
        CopyNoteNormalVisualSelection(hWnd, true);
        break;
    case ID_CTX_PASTE:
        SendMessageW(hWnd, WM_PASTE, 0, 0);
        break;
    case ID_CTX_SELECT_ALL:
        SendMessageW(hWnd, EM_SETSEL, 0, -1);
        break;
    case ID_CTX_SELECT_NONE: {
        DWORD caret = selEnd;
        SendMessageW(hWnd, EM_SETSEL, caret, caret);
        break;
    }
    default:
        break;
    }
}

static bool GetCharPos(HWND hWnd, size_t index, POINT* out) {
    if (!out || !hWnd) return false;
    if (IsRichEditControl(hWnd)) {
        POINTL pt{};
        LRESULT res = SendMessageW(hWnd, EM_POSFROMCHAR,
                                   reinterpret_cast<WPARAM>(&pt),
                                   static_cast<LPARAM>(index));
        if (res == -1) return false;
        out->x = static_cast<int>(pt.x);
        out->y = static_cast<int>(pt.y);
        return true;
    }
    LRESULT pos = SendMessageW(hWnd, EM_POSFROMCHAR, static_cast<WPARAM>(index), 0);
    if (pos == -1) return false;
    out->x = GET_X_LPARAM(pos);
    out->y = GET_Y_LPARAM(pos);
    return true;
}


bool ResolveCtrlInsertNavKey(HWND hWnd, WPARAM wParam,
                             WPARAM* outNavKey, wchar_t* outSuppressedChar) {
    if (!hWnd || !outNavKey) return false;
    if ((GetKeyState(VK_CONTROL) & 0x8000) == 0) return false;
    if ((GetKeyState(VK_MENU) & 0x8000) != 0) return false;

    UINT vk = static_cast<UINT>(wParam);
    if (vk == VK_PROCESSKEY) {
        UINT imeVk = static_cast<UINT>(ImmGetVirtualKey(hWnd));
        if (imeVk != 0) {
            vk = imeVk;
        }
    }

    switch (vk) {
    case 'H':
        *outNavKey = VK_LEFT;
        if (outSuppressedChar) *outSuppressedChar = L'\b';
        return true;
    case 'J':
        *outNavKey = VK_DOWN;
        if (outSuppressedChar) *outSuppressedChar = L'\n';
        return true;
    case 'K':
        *outNavKey = VK_UP;
        if (outSuppressedChar) *outSuppressedChar = 0x0B;
        return true;
    case 'L':
        *outNavKey = VK_RIGHT;
        if (outSuppressedChar) *outSuppressedChar = 0x0C;
        return true;
    default:
        return false;
    }
}

bool ForwardImeNavigationKey(HWND hWnd, WPARAM navKey) {
    if (!hWnd) return false;
    HWND imeWnd = ImmGetDefaultIMEWnd(hWnd);
    if (!imeWnd || !IsWindow(imeWnd)) return false;
    SendMessageW(imeWnd, WM_IME_KEYDOWN, navKey, 0);
    SendMessageW(imeWnd, WM_IME_KEYUP, navKey, 0);
    return true;
}

bool IsImeComposingOnEditWindow(HWND hWnd) {
    if (!hWnd || !IsWindow(hWnd)) return false;
    HIMC himc = ImmGetContext(hWnd);
    if (!himc) return false;
    const LONG compBytes = ImmGetCompositionStringW(himc, GCS_COMPSTR, nullptr, 0);
    ImmReleaseContext(hWnd, himc);
    return compBytes > 0;
}

static void SetEditCaretPosNoSelect(HWND hWnd, size_t caret) {
    if (!hWnd) return;
    int len = GetWindowTextLengthW(hWnd);
    if (len < 0) len = 0;
    const size_t safeCaret = std::min<size_t>(caret, static_cast<size_t>(len));
    SendMessageW(hWnd, EM_SETSEL,
                 static_cast<WPARAM>(safeCaret),
                 static_cast<LPARAM>(safeCaret));
    SendMessageW(hWnd, EM_SCROLLCARET, 0, 0);
}

bool MoveEditCaretForInsertNav(HWND hWnd, WPARAM navKey) {
    if (!hWnd) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));

    if (navKey == VK_LEFT) {
        size_t caret = (selStart == selEnd)
                           ? static_cast<size_t>(selStart)
                           : static_cast<size_t>(std::min(selStart, selEnd));
        if (caret > 0) {
            --caret;
        }
        SetEditCaretPosNoSelect(hWnd, caret);
        return true;
    }

    if (navKey == VK_RIGHT) {
        int len = GetWindowTextLengthW(hWnd);
        if (len < 0) len = 0;
        size_t caret = (selStart == selEnd)
                           ? static_cast<size_t>(selStart)
                           : static_cast<size_t>(std::max(selStart, selEnd));
        if (caret < static_cast<size_t>(len)) {
            ++caret;
        }
        SetEditCaretPosNoSelect(hWnd, caret);
        return true;
    }

    size_t caret = static_cast<size_t>((navKey == VK_DOWN)
                                           ? std::max(selStart, selEnd)
                                           : std::min(selStart, selEnd));
    int lineCount = static_cast<int>(SendMessageW(hWnd, EM_GETLINECOUNT, 0, 0));
    if (lineCount <= 0) lineCount = 1;

    int currentLine = static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR,
                                                    static_cast<WPARAM>(caret), 0));
    if (currentLine < 0) currentLine = 0;
    const int delta = (navKey == VK_DOWN) ? 1 : -1;
    const int targetLine = std::clamp(currentLine + delta, 0, lineCount - 1);
    if (targetLine == currentLine) {
        SetEditCaretPosNoSelect(hWnd, caret);
        return true;
    }

    POINT caretPos{};
    if (!GetCharPos(hWnd, caret, &caretPos)) {
        SetEditCaretPosNoSelect(hWnd, caret);
        return true;
    }

    LRESULT targetLineStartRes = SendMessageW(hWnd, EM_LINEINDEX,
                                              static_cast<WPARAM>(targetLine), 0);
    if (targetLineStartRes < 0) {
        SetEditCaretPosNoSelect(hWnd, caret);
        return true;
    }

    POINT targetLinePos{};
    if (!GetCharPos(hWnd, static_cast<size_t>(targetLineStartRes), &targetLinePos)) {
        SetEditCaretPosNoSelect(hWnd, static_cast<size_t>(targetLineStartRes));
        return true;
    }

    size_t nextCaret = static_cast<size_t>(targetLineStartRes);
    if (IsRichEditControl(hWnd)) {
        POINTL probe{
            static_cast<LONG>(caretPos.x),
            static_cast<LONG>(targetLinePos.y + 1)
        };
        LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, reinterpret_cast<LPARAM>(&probe));
        if (res >= 0) {
            nextCaret = static_cast<size_t>(res);
        }
    } else {
        DWORD res = static_cast<DWORD>(SendMessageW(hWnd, EM_CHARFROMPOS, 0,
                                                    MAKELPARAM(caretPos.x, targetLinePos.y + 1)));
        nextCaret = static_cast<size_t>(LOWORD(res));
    }

    SetEditCaretPosNoSelect(hWnd, nextCaret);
    return true;
}

static int GetCharIndexFromPos(HWND hWnd, LPARAM lParam) {
    if (!hWnd) return -1;
    if (IsRichEditControl(hWnd)) {
        POINTL pt{ GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam) };
        LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, reinterpret_cast<LPARAM>(&pt));
        return static_cast<int>(res);
    }
    DWORD res = static_cast<DWORD>(SendMessageW(hWnd, EM_CHARFROMPOS, 0, lParam));
    return static_cast<int>(LOWORD(res));
}

static bool IsNoteRenderActive() {
    return CurrentNoteSupportsRenderOverlay() && g_noteRenderEnabled && !g_noteRawOnly;
}

static bool IsNoteMathRenderActive() {
    return IsNoteRenderActive() && g_noteRenderMath;
}

static bool IsNoteWrapToggleAvailable() {
    return !IsNoteRenderActive();
}



static void PaintNoteSwitchPlaceholder(HDC hdc, const RECT& rc) {
    if (g_hThemeNoteBrush) {
        FillRect(hdc, &rc, g_hThemeNoteBrush);
        return;
    }
    HBRUSH br = CreateSolidBrush(g_noteBgColor);
    FillRect(hdc, &rc, br);
    DeleteObject(br);
}

bool BeginNoteRenderSwitch() {
    ++g_noteRenderSwitchDepth;
    if (g_noteRenderSwitchDepth != 1) return true;
    g_noteRenderSwitchBlocked = true;
    if (g_hNoteEdit) {
        // Replace the current frame immediately so stale rendered text is not left visible
        // while the switch recomputes markup and line metrics on the UI thread.
        RedrawWindow(g_hNoteEdit, nullptr, nullptr,
                     RDW_INVALIDATE | RDW_ERASE | RDW_UPDATENOW | RDW_NOCHILDREN);
        SendMessageW(g_hNoteEdit, WM_SETREDRAW, FALSE, 0);
    }
    if (g_hBottomNote) {
        SendMessageW(g_hBottomNote, WM_SETREDRAW, FALSE, 0);
    }
    if (g_hBottomMath) {
        SendMessageW(g_hBottomMath, WM_SETREDRAW, FALSE, 0);
    }
    return true;
}

void EndNoteRenderSwitch() {
    if (g_noteRenderSwitchDepth <= 0) return;
    --g_noteRenderSwitchDepth;
    if (g_noteRenderSwitchDepth != 0) return;
    const ULONGLONG startTick = preview_trace::TickNow();
    preview_trace::Append(
        L"EndNoteRenderSwitch",
        L"begin noteEdit=" + preview_trace::Window(g_hNoteEdit) +
        L" bottomNote=" + preview_trace::Window(g_hBottomNote) +
        L" bottomMath=" + preview_trace::Window(g_hBottomMath));
    g_noteRenderSwitchBlocked = false;

    auto enableRedraw = [](HWND hWnd) {
        if (!hWnd) return;
        SendMessageW(hWnd, WM_SETREDRAW, TRUE, 0);
        InvalidateRect(hWnd, nullptr, FALSE);
    };
    enableRedraw(g_hNoteEdit);
    enableRedraw(g_hBottomNote);
    enableRedraw(g_hBottomMath);
    preview_trace::Append(
        L"EndNoteRenderSwitch",
        L"after_enable_redraw elapsed_ms=" + preview_trace::ElapsedMs(startTick));

    // Coalesce repaint into a single synchronous pass to avoid visible intermediate frames.
    HWND root = nullptr;
    if (g_hNoteEdit) root = GetAncestor(g_hNoteEdit, GA_ROOT);
    if (!root && g_hBottomNote) root = GetAncestor(g_hBottomNote, GA_ROOT);
    if (!root && g_hBottomMath) root = GetAncestor(g_hBottomMath, GA_ROOT);
    preview_trace::Append(
        L"EndNoteRenderSwitch",
        L"after_resolve_root root=" + preview_trace::Window(root) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    if (root) {
        RedrawWindow(root, nullptr, nullptr,
                     RDW_INVALIDATE | RDW_ALLCHILDREN | RDW_UPDATENOW);
        preview_trace::Append(
            L"EndNoteRenderSwitch",
            L"after_root_redraw elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    }
    preview_trace::Append(
        L"EndNoteRenderSwitch",
        L"end elapsed_ms=" + preview_trace::ElapsedMs(startTick));
}

bool IsNoteRenderSwitchInProgress() {
    return g_noteRenderSwitchBlocked;
}

bool CommitNoteImeCompositionNow() {
    if (!g_hNoteEdit) return false;
    HIMC imc = ImmGetContext(g_hNoteEdit);
    if (!imc) return false;
    // Complete composition explicitly; click-to-toggle may otherwise commit implicitly mid-transition.
    BOOL ok = ImmNotifyIME(imc, NI_COMPOSITIONSTR, CPS_COMPLETE, 0);
    ImmReleaseContext(g_hNoteEdit, imc);
    if (ok) {
        g_noteImeComposing = false;
        return true;
    }
    return false;
}

static HFONT GetActiveNoteFont() {
    if (IsNoteRenderActive() && g_hNoteRenderFont) {
        return g_hNoteRenderFont;
    }
    return g_hNoteFont ? g_hNoteFont : g_hUIFont;
}

static void ResetBottomAssistFontCache() {
    if (g_hBottomAssistFont) {
        DeleteObject(g_hBottomAssistFont);
        g_hBottomAssistFont = nullptr;
    }
    g_bottomAssistFontFace.clear();
    g_bottomAssistFontPx = 0;
    g_bottomAssistFontDpi = 0;
}

static HFONT GetBottomAssistFont(HWND hWnd) {
    const std::wstring face = g_noteFontName.empty() ? GetDefaultFontFaceName() : g_noteFontName;
    int dpi = hWnd ? GetDpiY(hWnd) : 96;
    if (dpi <= 0) dpi = 96;
    double pt = (g_noteFontPt > 0.0) ? g_noteFontPt : 10.0;
    const int px = std::clamp(static_cast<int>(std::lround(pt * dpi / 72.0)), 8, 14);
    if (!g_hBottomAssistFont ||
        g_bottomAssistFontFace != face ||
        g_bottomAssistFontPx != px ||
        g_bottomAssistFontDpi != dpi) {
        ResetBottomAssistFontCache();
        LOGFONTW lf{};
        lf.lfWeight = FW_NORMAL;
        lf.lfHeight = -px;
        wcscpy_s(lf.lfFaceName, face.c_str());
        g_hBottomAssistFont = CreateFontIndirectW(&lf);
        g_bottomAssistFontFace = face;
        g_bottomAssistFontPx = px;
        g_bottomAssistFontDpi = dpi;
    }
    return g_hBottomAssistFont ? g_hBottomAssistFont : (g_hUIFont ? g_hUIFont : g_hNoteFont);
}

static std::wstring CurrentNoteFileNameForParse() {
    if (g_currentNotePath.empty()) return L"";
    return std::filesystem::path(g_currentNotePath).filename().wstring();
}

static std::wstring NoteExtensionLowerForPath(const std::wstring& notePath) {
    if (notePath.empty()) return L"";
    return ToLowerAscii(std::filesystem::path(notePath).extension().wstring());
}


static NoteContentRoute NoteContentRouteForPath(const std::wstring& notePath) {
    const std::wstring ext = NoteExtensionLowerForPath(notePath);
    if (ext == L".txt" || ext == L".csv") return NoteContentRoute::PlainText;
    return NoteContentRoute::MarkdownMd4c;
}

static std::wstring CurrentNoteExtensionLower() {
    return NoteExtensionLowerForPath(g_currentNotePath);
}

static NoteContentRoute CurrentNoteContentRoute() {
    return NoteContentRouteForPath(g_currentNotePath);
}

static bool NoteContentRouteSupportsLinkTargets(NoteContentRoute route) {
    return route == NoteContentRoute::MarkdownMd4c;
}

static bool CurrentNoteSupportsRenderOverlay() {
    const NoteContentRoute route = CurrentNoteContentRoute();
    return route == NoteContentRoute::MarkdownMd4c;
}

static void ResetParsedNoteDocumentState() {
    note::LocalNoteKernel* kernel = CurrentNoteKernel();
    if (kernel) kernel->ClearDerived();
}

static uint64_t NextNoteTextCoreRevision() {
    if (g_noteDocumentRevisionSeed != std::numeric_limits<uint64_t>::max()) {
        ++g_noteDocumentRevisionSeed;
    }
    return g_noteDocumentRevisionSeed;
}

static note::NoteMetadata CurrentNoteTextMetadata() {
    note::NoteMetadata meta;
    meta.file_name = CurrentNoteFileNameForParse();
    meta.title = note::DeriveTitleFromFileName(meta.file_name);
    return meta;
}

static void ResetCurrentNoteTextCore(note::NoteId noteId,
                                     std::wstring raw,
                                     uint64_t persistenceRevision,
                                     uint64_t knownContentRevision = 0) {
    if (!noteId.valid()) return;
    const uint64_t contentRevision = knownContentRevision != 0
        ? knownContentRevision
        : NextNoteTextCoreRevision();
    g_noteDocumentRevisionSeed = std::max(g_noteDocumentRevisionSeed, contentRevision);
    note::RuntimeNoteWorkspaceService().ResetKernel(
        noteId,
        CurrentNoteTextMetadata(),
        std::move(raw),
        contentRevision,
        persistenceRevision,
        CurrentNoteContentRoute() == NoteContentRoute::PlainText
            ? note::NoteContentKind::PlainText
            : note::NoteContentKind::Markdown);
}

static note::NoteId CurrentNoteTextCoreOwner() {
    const note::ViewIdentity view = CurrentNoteViewIdentity();
    if (view.note_id.valid()) return view.note_id;
    return note::ResolveRuntimeNoteIdentityPath(g_currentNotePath).note_id;
}

static void SynchronizeCurrentNoteTextCore(std::wstring_view editorText) {
    const note::NoteId owner = CurrentNoteTextCoreOwner();
    if (!owner.valid()) return;
    note::NoteTextCore* core = CurrentNoteTextCore();
    if (core && core->note_id() == owner && core->MatchesRaw(editorText)) {
        return;
    }
    const uint64_t persistenceRevision =
        core && core->note_id() == owner
        ? core->persistence_revision()
        : 0;
    ResetCurrentNoteTextCore(owner, std::wstring(editorText), persistenceRevision);
}

static bool CanReadStableParsedNoteDocument() {
    const note::LocalNoteKernel* kernel = CurrentNoteKernel();
    return kernel && kernel->CanReadSyntax();
}

static bool CanReadStableSemanticIndex() {
    const note::LocalNoteKernel* kernel = CurrentNoteKernel();
    return kernel && kernel->CanReadSemantic();
}

static std::optional<note::NoteKernelRefreshResult> RecomputeParsedNoteDocument(const std::wstring& text) {
    SynchronizeCurrentNoteTextCore(text);
    note::LocalNoteKernel* kernel = CurrentNoteKernel();
    if (!kernel) {
        return std::nullopt;
    }

    const note::NoteKernelRefreshResult refresh = kernel->RefreshDerived();
    g_noteDocumentRevisionSeed = std::max(
        g_noteDocumentRevisionSeed, kernel->text_core().content_revision());
    return refresh;
}

static std::wstring NoteContentRouteLabel(bool englishUi) {
    const std::wstring ext = CurrentNoteExtensionLower();
    const std::wstring extSuffix = ext.empty() ? L"" : (L" (" + ext + L")");
    switch (CurrentNoteContentRoute()) {
    case NoteContentRoute::PlainText:
        return englishUi ? (L"Plain text" + extSuffix) : (L"プレーンテキスト" + extSuffix);
    case NoteContentRoute::MarkdownMd4c:
        return englishUi ? (L"Markdown via MD4C" + extSuffix) : (L"MD4C Markdown" + extSuffix);
    }
    return englishUi ? L"Unknown" : L"不明";
}

