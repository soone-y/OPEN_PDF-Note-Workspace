static void ClearCurrentNoteFileSnapshotState() {
    g_currentNoteFileSnapshot = CurrentNoteFileSnapshot{};
}

static std::wstring CurrentLocalTimestampForFileName() {
    SYSTEMTIME st{};
    GetLocalTime(&st);
    wchar_t buf[32]{};
    swprintf_s(buf, L"%04u%02u%02u_%02u%02u%02u",
               st.wYear, st.wMonth, st.wDay, st.wHour, st.wMinute, st.wSecond);
    return buf;
}

static std::wstring DefaultExternalChangeCopyPath() {
    std::filesystem::path notePath(g_currentNotePath);
    std::filesystem::path dir = notePath.parent_path();
    std::wstring stem = notePath.stem().wstring();
    if (stem.empty()) stem = L"note";
    std::wstring ext = notePath.extension().wstring();
    if (ext.empty()) ext = L".txt";
    return (dir / (stem + L"_local_edit_" + CurrentLocalTimestampForFileName() + ext)).wstring();
}

static bool SaveCurrentNoteEditorCopy(HWND owner, std::wstring* outPath) {
    if (outPath) outPath->clear();
    if (!g_hNoteEdit || g_currentNotePath.empty()) return false;

    std::wstring input;
    if (!PromptSimpleText(owner ? owner : g_hMainWnd,
                          IsEnglishUi() ? L"Save current note copy" : L"現在の編集を退避",
                          DefaultExternalChangeCopyPath(),
                          input)) {
        return false;
    }
    while (!input.empty() && iswspace(input.front())) input.erase(input.begin());
    while (!input.empty() && iswspace(input.back())) input.pop_back();
    if (input.size() >= 2 && input.front() == L'"' && input.back() == L'"') {
        input = input.substr(1, input.size() - 2);
    }
    if (input.empty()) return false;

    std::filesystem::path out(input);
    if (out.is_relative()) {
        out = std::filesystem::path(g_currentNotePath).parent_path() / out;
    }
    if (!out.has_extension()) {
        out.replace_extension(std::filesystem::path(g_currentNotePath).extension());
    }

    if (IsUncPath(out) ||
        NormalizePathKey(out.wstring()) == NormalizePathKey(g_currentNotePath)) {
        ShowSoftNotice(owner ? owner : g_hMainWnd,
                       IsEnglishUi()
                           ? L"Choose a local copy path different from the open note."
                           : L"開いているノートとは別のローカル退避先を指定してください。",
                       SoftNoticeKind::Warning);
        return false;
    }

    bool isReparse = false;
    if (TryIsReparsePointNoFollow(out.parent_path(), isReparse) && isReparse) {
        ShowSoftNotice(owner ? owner : g_hMainWnd,
                       IsEnglishUi()
                           ? L"Reparse point output folders are not supported."
                           : L"ジャンクション/シンボリックリンク等の出力先フォルダは使用できません。",
                       SoftNoticeKind::Warning);
        return false;
    }

    std::error_code ec;
    if (std::filesystem::exists(out, ec) && !ec) {
        ShowSoftNotice(owner ? owner : g_hMainWnd,
                       IsEnglishUi()
                           ? L"Existing files are not overwritten. Choose a new copy path."
                           : L"既存ファイルは上書きしません。新しい退避先を指定してください。",
                       SoftNoticeKind::Warning);
        return false;
    }
    if (ec) {
        ShowSoftNotice(owner ? owner : g_hMainWnd,
                       IsEnglishUi() ? L"Could not inspect the copy path."
                                     : L"退避先パスを確認できません。",
                       SoftNoticeKind::Warning);
        return false;
    }

    std::filesystem::create_directories(out.parent_path(), ec);
    if (ec) {
        ShowSoftNotice(owner ? owner : g_hMainWnd,
                       IsEnglishUi() ? L"Could not create the copy folder."
                                     : L"退避先フォルダを作成できません。",
                       SoftNoticeKind::Warning);
        return false;
    }

    const std::wstring text = GetEditText(g_hNoteEdit);
    std::wstring err;
    if (!atomic_write::AtomicWriteUtf8(out, WideToUTF8(text), out.parent_path(), &err)) {
        ShowSoftNotice(owner ? owner : g_hMainWnd,
                       err.empty()
                           ? (IsEnglishUi() ? L"Could not save the current note copy."
                                            : L"現在の編集を退避できませんでした。")
                           : err,
                       SoftNoticeKind::Warning);
        return false;
    }

    if (outPath) *outPath = out.wstring();
    return true;
}

static void OfferCurrentNoteExternalChangeActions(HWND owner, bool missingOnDisk) {
    HWND target = owner ? owner : g_hMainWnd;
    const bool dirty = g_noteDirty || (g_hNoteEdit && SendMessageW(g_hNoteEdit, EM_GETMODIFY, 0, 0) != 0);
    SilentDialogOptions options;
    options.title = IsEnglishUi() ? L"Note file changed" : L"ノート外部変更";
    options.kind = SoftNoticeKind::Warning;
    options.preferredWidthPx = 560;
    options.buttons = dirty ? SilentDialogButtons::OkYesNoCancel
                            : SilentDialogButtons::OkCancel;
    options.okLabel = dirty
        ? (IsEnglishUi() ? L"Save Copy + Reload" : L"退避して再読込")
        : (IsEnglishUi() ? L"Reload" : L"再読み込み");
    options.yesLabel = IsEnglishUi() ? L"Reload Without Copy" : L"退避せず再読込";
    options.noLabel = IsEnglishUi() ? L"Keep Editing" : L"編集を維持";
    options.cancelLabel = IsEnglishUi() ? L"Not Now" : L"今はしない";
    options.defaultResult = SilentDialogResult::Cancel;
    options.escapeResult = SilentDialogResult::Cancel;

    if (missingOnDisk) {
        options.message = IsEnglishUi()
            ? L"The current note file is missing or inaccessible.\n\nSave the current editor text as a separate local copy, or keep editing without changing files."
            : L"現在のノートファイルを確認できません。\n\n現在の編集を別ファイルへ退避するか、ファイルを変更せず編集を維持してください。";
        options.buttons = SilentDialogButtons::OkCancel;
        options.okLabel = IsEnglishUi() ? L"Save Copy" : L"退避する";
    } else if (dirty) {
        options.message = IsEnglishUi()
            ? L"The current note file changed outside the app while this editor also has unsaved edits.\n\nRecommended: save the current editor text as a separate copy, then reload the disk file."
            : L"ノートファイルが外部で変更されています。この編集欄にも未保存の編集があります。\n\n推奨: 現在の編集を別ファイルへ退避してから、ディスク上のノートを再読み込みします。";
    } else {
        options.message = IsEnglishUi()
            ? L"The current note file changed outside the app.\n\nReload the disk file, or keep the current view for now."
            : L"ノートファイルが外部で変更されています。\n\nディスク上のノートを再読み込みするか、今は現在の表示を維持します。";
    }

    const SilentDialogResult result = ShowSilentDialog(target, options);
    if (missingOnDisk) {
        if (result == SilentDialogResult::Ok) {
            std::wstring copyPath;
            if (SaveCurrentNoteEditorCopy(target, &copyPath)) {
                RefreshCurrentNoteFileSnapshot();
                ShowSoftNotice(target,
                               IsEnglishUi() ? L"Saved a copy of the current note edits."
                                             : L"現在の編集を退避しました。",
                               SoftNoticeKind::Info);
            }
        }
        return;
    }

    if (dirty && result == SilentDialogResult::Ok) {
        std::wstring copyPath;
        if (!SaveCurrentNoteEditorCopy(target, &copyPath)) return;
        LoadNoteFile(target, g_currentNotePath);
        return;
    }
    if ((dirty && result == SilentDialogResult::Yes) ||
        (!dirty && result == SilentDialogResult::Ok)) {
        LoadNoteFile(target, g_currentNotePath);
    }
}

void RefreshCurrentNoteFileSnapshot() {
    if (g_currentNotePath.empty()) {
        ClearCurrentNoteFileSnapshotState();
        return;
    }

    std::uint64_t size = 0;
    std::int64_t mtimeMs = 0;
    if (!TryGetFileMetaWin32(std::filesystem::path(g_currentNotePath), &size, &mtimeMs)) {
        ClearCurrentNoteFileSnapshotState();
        return;
    }

    g_currentNoteFileSnapshot.valid = true;
    g_currentNoteFileSnapshot.pathKey = NormalizePathKey(g_currentNotePath);
    g_currentNoteFileSnapshot.size = size;
    g_currentNoteFileSnapshot.mtimeMs = mtimeMs;
    g_currentNoteFileSnapshot.notifiedMissing = false;
    g_currentNoteFileSnapshot.notifiedChanged = false;
    g_currentNoteFileSnapshot.notifiedSize = 0;
    g_currentNoteFileSnapshot.notifiedMtimeMs = 0;
}

bool CheckCurrentNoteFileExternalChange(HWND owner) {
    if (g_currentNotePath.empty()) {
        ClearCurrentNoteFileSnapshotState();
        return false;
    }

    const std::wstring currentKey = NormalizePathKey(g_currentNotePath);
    if (!g_currentNoteFileSnapshot.valid ||
        g_currentNoteFileSnapshot.pathKey != currentKey) {
        RefreshCurrentNoteFileSnapshot();
        return false;
    }

    std::uint64_t size = 0;
    std::int64_t mtimeMs = 0;
    if (!TryGetFileMetaWin32(std::filesystem::path(g_currentNotePath), &size, &mtimeMs)) {
        if (!g_currentNoteFileSnapshot.notifiedMissing) {
            OfferCurrentNoteExternalChangeActions(owner, true);
            g_currentNoteFileSnapshot.notifiedMissing = true;
        }
        return true;
    }

    g_currentNoteFileSnapshot.notifiedMissing = false;
    if (size == g_currentNoteFileSnapshot.size &&
        mtimeMs == g_currentNoteFileSnapshot.mtimeMs) {
        g_currentNoteFileSnapshot.notifiedChanged = false;
        return false;
    }

    if (g_currentNoteFileSnapshot.notifiedChanged &&
        g_currentNoteFileSnapshot.notifiedSize == size &&
        g_currentNoteFileSnapshot.notifiedMtimeMs == mtimeMs) {
        return true;
    }

    OfferCurrentNoteExternalChangeActions(owner, false);
    g_currentNoteFileSnapshot.notifiedChanged = true;
    g_currentNoteFileSnapshot.notifiedSize = size;
    g_currentNoteFileSnapshot.notifiedMtimeMs = mtimeMs;
    return true;
}

enum class NoteContentRoute {
    PlainText,
    MarkdownMd4c,
};

static void DisableImeForNoteEdit(HWND hWnd) {
    if (!hWnd) return;
    HIMC himc = ImmGetContext(hWnd);
    if (himc) {
        ImmNotifyIME(himc, NI_COMPOSITIONSTR, CPS_CANCEL, 0);
        ImmSetOpenStatus(himc, FALSE);
        ImmReleaseContext(hWnd, himc);
    }
    ImmAssociateContextEx(hWnd, nullptr, 0);
}

static void EnableImeForNoteEdit(HWND hWnd) {
    if (!hWnd) return;
    ImmAssociateContextEx(hWnd, nullptr, IACE_DEFAULT);
}

static bool HasOpenNote() {
    return !g_currentNotePath.empty() || !g_currentSessionPath.empty();
}

static void UpdateNoteEditAvailability() {
    if (!g_hNoteEdit) return;
    const bool hasNote = HasOpenNote();
    SendMessageW(g_hNoteEdit, EM_SETREADONLY, hasNote ? FALSE : TRUE, 0);
}

static void MaybeShowNoteOpenNotice(HWND owner) {
    if (HasOpenNote()) return;
    const ULONGLONG now = GetTickCount64();
    if (now - g_noteNoOpenNoticeTick < 1200) return;
    g_noteNoOpenNoticeTick = now;
    const wchar_t* msg = IsEnglishUi()
        ? L"Open a session before editing notes."
        : (g_config.studentMode ? L"ノート入力には回次を開いてください。"
                                : L"ノート入力には下位項目を開いてください。");
    ShowSoftNotice(owner ? owner : g_hMainWnd, msg, SoftNoticeKind::Warning);
}

// 内部ヘルパ
static int GetDpiY(HWND hWnd) {
    HDC dc = GetDC(hWnd);
    if (!dc) return 96;
    int dpi = GetDeviceCaps(dc, LOGPIXELSY);
    ReleaseDC(hWnd, dc);
    return (dpi > 0) ? dpi : 96;
}

int ScaleY(HWND hWnd, int pxAt96Dpi) {
    return MulDiv(pxAt96Dpi, GetDpiY(hWnd), 96);
}

static void SetNoteCmdlineFlash(const std::wstring& msg, int ms = 1500) {
    g_noteCmdlineFlash = msg;
    g_noteCmdlineFlashUntilTick = GetTickCount() + static_cast<DWORD>(std::max(100, ms));
    if (g_noteCmdlineActive && g_hNoteCmdlineEdit && GetWindowTextLengthW(g_hNoteCmdlineEdit) == 0) {
        SendMessageW(g_hNoteCmdlineEdit, EM_SETCUEBANNER, FALSE, reinterpret_cast<LPARAM>(msg.c_str()));
    }
    if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
}

bool IsNoteCmdlineActive() {
    return g_noteCmdlineActive;
}

bool IsNoteCmdlineImeComposing() {
    if (!g_hNoteCmdlineEdit || !IsWindow(g_hNoteCmdlineEdit)) return false;
    HIMC himc = ImmGetContext(g_hNoteCmdlineEdit);
    if (!himc) return false;
    const LONG compBytes = ImmGetCompositionStringW(himc, GCS_COMPSTR, nullptr, 0);
    ImmReleaseContext(g_hNoteCmdlineEdit, himc);
    return compBytes > 0;
}

void CancelNoteCmdline() {
    g_noteCmdlineActive = false;
    g_noteCmdlineBuffer.clear();
    g_noteCmdlineHistoryIndex = -1;
    g_noteCmdlinePrompt = L'/';
    if (g_hNoteCmdlineEdit) {
        ShowWindow(g_hNoteCmdlineEdit, SW_HIDE);
        SetWindowTextW(g_hNoteCmdlineEdit, L"");
        SendMessageW(g_hNoteCmdlineEdit, EM_SETCUEBANNER, FALSE, reinterpret_cast<LPARAM>(L""));
    }
    if (g_noteVimModeEnabled && g_noteNormalMode && g_hNoteEdit && IsWindow(g_hNoteEdit)) {
        SendMessageW(g_hNoteEdit, EM_SCROLLCARET, 0, 0);
        ClearNoteNormalPendingState();
        FocusMainWindowForNoteNormalMode();
    } else if (GetFocus() == g_hNoteCmdlineEdit) {
        FocusMainWindowForNoteNormalMode();
    }
    if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
}

