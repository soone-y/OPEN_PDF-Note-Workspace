struct ActiveNoteRenderSnapshot {
    note::NoteDerivedSnapshotIdentity sourceIdentity{};
    std::vector<LineCache> lines;

    bool Matches(note::NoteId ownerNoteId, uint64_t sourceRevision) const {
        return sourceIdentity == note::NoteDerivedSnapshotIdentity{
            ownerNoteId, sourceRevision};
    }

    void CommitIdentity(note::NoteId ownerNoteId, uint64_t sourceRevision) {
        sourceIdentity = note::NoteDerivedSnapshotIdentity{
            ownerNoteId, sourceRevision};
    }

    void Reset() {
        sourceIdentity = {};
        lines.clear();
    }
};

