    bool valid = false;
    size_t first = 0;
    size_t last = 0;
    bool lineCountChanged = false;
    bool full = false;
};

struct NoteRenderStaleLineRange {
    bool valid = false;
    size_t first = 0;
    size_t last = 0;
};

struct MathDisplayCache {
    bool ready = false;
    std::wstring rawText;
    MathDisplay display;
};

struct LocalNoteViewContext {
    ActiveNoteRenderSnapshot renderSnapshot;
    std::wstring renderTextCache;
    std::vector<std::wstring> renderLines;
    std::vector<NoteRenderLineInfo> renderLineInfos;
    size_t lastParsedMarkupLength = 0;
    int lastParsedMarkupBaseFontHeightPx = 0;
    std::unordered_map<std::wstring, std::shared_ptr<mathrender::Node>> mathNodeCache;
    std::unordered_map<std::wstring, mathrender::Layout> mathLayoutCache;
    note::NoteLayoutMetricsSnapshot measuredLayoutSnapshot;
    note::NoteLayoutMetricsSnapshot appliedLayoutSnapshot;

    int renderedContentRightPx = 0;
    bool renderedHorizontalExtentDirty = false;
    int renderedContentBottomPx = 0;
    int renderScrollX = 0;

    NoteRenderDirtyLineRange renderDirtyLines;
    NoteRenderStaleLineRange renderStaleLines;
    bool derivedFrameCommitRequiredBeforePaint = false;
    bool lineSpacingInvalidatedNote = false;

    bool typing = false;
    wchar_t pendingCtrlInsertNavChar = 0;
    bool imeComposing = false;
    int renderSwitchDepth = 0;
    bool renderSwitchBlocked = false;
    bool bottomNoteRenderTogglePendingAfterIme = false;
    std::vector<MathDisplayCache> mathDisplayCache;

    void Clear() {
        renderSnapshot.Reset();
        renderTextCache.clear();
        renderLines.clear();
        renderLineInfos.clear();
        lastParsedMarkupLength = 0;
        lastParsedMarkupBaseFontHeightPx = 0;
        mathNodeCache.clear();
        mathLayoutCache.clear();
        measuredLayoutSnapshot.Reset();
        appliedLayoutSnapshot.Reset();
        renderedContentRightPx = 0;
        renderedHorizontalExtentDirty = false;
        renderedContentBottomPx = 0;
        renderScrollX = 0;
        renderDirtyLines = {};
        renderStaleLines = {};
        derivedFrameCommitRequiredBeforePaint = false;
        lineSpacingInvalidatedNote = false;
        typing = false;
        pendingCtrlInsertNavChar = 0;
        imeComposing = false;
        renderSwitchDepth = 0;
        renderSwitchBlocked = false;
        bottomNoteRenderTogglePendingAfterIme = false;
        mathDisplayCache.clear();
    }
};



static std::unordered_map<HWND, LocalNoteViewContext> g_viewContexts;
static LocalNoteViewContext g_unboundViewContext;

class ScopedNoteViewContextBinding {
public:
    explicit ScopedNoteViewContextBinding(HWND hwnd)
        : previous_(g_boundNoteViewContextHwnd) {
        if (hwnd) g_boundNoteViewContextHwnd = hwnd;
    }

    ~ScopedNoteViewContextBinding() {
        g_boundNoteViewContextHwnd = previous_;
    }

    ScopedNoteViewContextBinding(const ScopedNoteViewContextBinding&) = delete;
    ScopedNoteViewContextBinding& operator=(const ScopedNoteViewContextBinding&) = delete;

private:
    HWND previous_ = nullptr;
};

static HWND CurrentNoteViewContextWindow() {
    return g_boundNoteViewContextHwnd ? g_boundNoteViewContextHwnd : g_hNoteEdit;
}

static HWND ResolveNoteViewContextHwnd(HWND hwnd = nullptr) {
    if (hwnd) return hwnd;
    return CurrentNoteViewContextWindow();
}

static LocalNoteViewContext& GetViewContext(HWND hwnd) {
    hwnd = ResolveNoteViewContextHwnd(hwnd);
    if (!hwnd) return g_unboundViewContext;
    return g_viewContexts[hwnd];
}

static void ForgetLocalNoteViewContext(HWND hwnd) {
    if (!hwnd) return;
    g_viewContexts.erase(hwnd);
}

