// Note document handling and math extraction.
// Included by note_view.cpp to keep a single translation unit while narrowing edit scope.

// ---------------------------------------------------------------------
// Note handling and math extraction
// ---------------------------------------------------------------------
static std::wstring GetEditText(HWND hEdit) {
    int len = GetWindowTextLengthW(hEdit);
    if (len <= 0) return L"";
    std::wstring text(static_cast<size_t>(len) + 1, L'\0');
    int copied = GetWindowTextW(hEdit, text.data(), len + 1);
    if (copied < 0) copied = 0;
    text.resize(static_cast<size_t>(copied));
    return text;
}

static std::wstring GetEditTextForIndexing(HWND hEdit) {
    // RichEdit's internal indices count line breaks as a single '\r', while GetWindowTextW returns CRLF.
    // Normalize to an index-compatible representation by collapsing CRLF -> CR.
    std::wstring text = GetEditText(hEdit);
    if (text.empty()) return text;
    if (!IsRichEditControl(hEdit)) return text;
    std::wstring normalized;
    normalized.reserve(text.size());
    for (size_t i = 0; i < text.size(); ++i) {
        wchar_t ch = text[i];
        if (ch == L'\r' && i + 1 < text.size() && text[i + 1] == L'\n') {
            normalized.push_back(L'\n');
            ++i; // skip '\n'
        } else if (ch == L'\r') {
            normalized.push_back(L'\n');
        } else {
            normalized.push_back(ch);
        }
    }
    return normalized;
}

// Defined by note_view_input_helpers.cppinc, which is included later in the
// same translation unit. Tab-stop Backspace uses this bounded range reader so
// normal Backspace never needs to copy the entire note just to reject a
// non-indentation caret position.
static std::wstring GetEditTextRangeForIndexing(HWND hWnd, size_t start, size_t end);

static std::wstring NormalizeTextForNoteIndexing(std::wstring text) {
    if (text.empty()) return text;
    std::wstring normalized;
    normalized.reserve(text.size());
    for (size_t i = 0; i < text.size(); ++i) {
        wchar_t ch = text[i];
        normalized.push_back(ch);
        if (ch == L'\r' && i + 1 < text.size() && text[i + 1] == L'\n') {
            ++i;
        }
    }
    return normalized;
}

namespace {

struct NoteUndoEntry {
    note::TextEdit edit;
    std::wstring deletedText;
    DWORD beforeSelStart = 0;
    DWORD beforeSelEnd = 0;
    DWORD afterSelStart = 0;
    DWORD afterSelEnd = 0;
};

struct ExpectedNoteTextEdit {
    HWND hEdit = nullptr;
    NoteUndoEntry entry;
    bool active = false;
};

std::wstring g_noteUndoTextSnapshot;
ExpectedNoteTextEdit g_expectedNoteTextEdit;
bool g_noteUndoSnapshotReady = false;
bool g_noteApplyingUndoRedo = false;

struct NoteUndoHistoryState {
    std::wstring snapshot;
    ExpectedNoteTextEdit expectedEdit;
    bool snapshotReady = false;
};

std::unordered_map<HWND, NoteUndoHistoryState> g_noteUndoHistoryByWindow;

void CaptureNoteUndoHistoryForWindow(HWND hEdit) {
    if (!hEdit || !IsWindow(hEdit) || hEdit != g_hNoteEdit) return;
    NoteUndoHistoryState state;
    state.snapshot = g_noteUndoTextSnapshot;
    state.expectedEdit = (g_expectedNoteTextEdit.hEdit == hEdit) ? g_expectedNoteTextEdit : ExpectedNoteTextEdit{};
    state.snapshotReady = g_noteUndoSnapshotReady;
    g_noteUndoHistoryByWindow[hEdit] = std::move(state);
}

bool RestoreNoteUndoHistoryForWindow(HWND hEdit) {
    if (!hEdit || !IsWindow(hEdit)) return false;
    auto it = g_noteUndoHistoryByWindow.find(hEdit);
    if (it == g_noteUndoHistoryByWindow.end()) return false;
    g_noteUndoTextSnapshot = it->second.snapshot;
    g_expectedNoteTextEdit = it->second.expectedEdit;
    if (g_expectedNoteTextEdit.active) g_expectedNoteTextEdit.hEdit = hEdit;
    g_noteUndoSnapshotReady = it->second.snapshotReady;
    g_noteApplyingUndoRedo = false;
    return true;
}

void ForgetNoteUndoHistoryForWindow(HWND hEdit) {
    if (!hEdit) return;
    g_noteUndoHistoryByWindow.erase(hEdit);
}

void ApplyTextEditToSnapshot(std::wstring* text, const note::TextEdit& edit) {
    if (!text) return;
    const size_t start = std::min(edit.start.value, text->size());
    const size_t deleteLen = std::min(edit.deleted_len, text->size() - start);
    text->replace(start, deleteLen, edit.inserted_text);
}

note::NoteHistoryOperationKind ClassifyNoteHistoryOperation(
    const note::TextEdit& edit,
    note::NoteTextSelection before,
    note::NoteTextSelection after) {
    if (edit.deleted_len != 0 && edit.inserted_text.empty()) {
        return after.caret.value < before.caret.value
            ? note::NoteHistoryOperationKind::DeleteBackward
            : note::NoteHistoryOperationKind::DeleteForward;
    }
    if (edit.deleted_len == 0 && !edit.inserted_text.empty() &&
        before.anchor == before.caret && after.anchor == after.caret &&
        note::BuildTextUnits(edit.inserted_text).size() == 1) {
        return note::NoteHistoryOperationKind::Typing;
    }
    return note::NoteHistoryOperationKind::Replace;
}

bool EntryMatchesSnapshot(const NoteUndoEntry& entry) {
    if (entry.edit.start.value > g_noteUndoTextSnapshot.size()) return false;
    if (entry.edit.deleted_len > g_noteUndoTextSnapshot.size() - entry.edit.start.value) return false;
    return g_noteUndoTextSnapshot.compare(entry.edit.start.value, entry.edit.deleted_len,
                                          entry.deletedText) == 0;
}

} // namespace

void ResetNoteEditHistorySnapshot(HWND hEdit) {
    g_noteUndoTextSnapshot = hEdit ? GetEditTextForIndexing(hEdit) : L"";
    g_expectedNoteTextEdit = {};
    g_noteUndoSnapshotReady = hEdit != nullptr;
    g_noteApplyingUndoRedo = false;
    if (note::LocalNoteKernel* kernel = CurrentNoteKernel()) {
        kernel->DiscardPendingEditAndRequireFullRefresh();
    }
}

static void RegisterExpectedNoteTextEdit(HWND hEdit,
                                         DWORD selStart,
                                         DWORD selEnd,
                                         const std::wstring& insertedText,
                                         DWORD afterSelStart,
                                         DWORD afterSelEnd,
                                         bool allowCoalesce) {
    if (!hEdit || g_noteApplyingUndoRedo) return;
    (void)allowCoalesce;
    if (!g_noteUndoSnapshotReady) {
        ResetNoteEditHistorySnapshot(hEdit);
    }
    if (selStart > selEnd) std::swap(selStart, selEnd);
    const size_t start = std::min<size_t>(selStart, g_noteUndoTextSnapshot.size());
    const size_t end = std::min<size_t>(selEnd, g_noteUndoTextSnapshot.size());

    NoteUndoEntry entry;
    entry.edit.start = {start};
    entry.edit.deleted_len = end - start;
    entry.edit.inserted_text = NormalizeTextForNoteIndexing(insertedText);
    entry.deletedText = g_noteUndoTextSnapshot.substr(start, end - start);
    entry.beforeSelStart = selStart;
    entry.beforeSelEnd = selEnd;
    entry.afterSelStart = afterSelStart;
    entry.afterSelEnd = afterSelEnd;
    g_expectedNoteTextEdit.hEdit = hEdit;
    g_expectedNoteTextEdit.entry = std::move(entry);
    g_expectedNoteTextEdit.active = true;
}

static void RegisterExpectedCurrentNoteSelectionReplacement(HWND hEdit,
                                                            const std::wstring& insertedText,
                                                            DWORD afterSelStart,
                                                            DWORD afterSelEnd,
                                                            bool allowCoalesce) {
    if (!hEdit) return;
    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    RegisterExpectedNoteTextEdit(hEdit, selStart, selEnd, insertedText,
                                 afterSelStart, afterSelEnd, allowCoalesce);
}

bool CommitActiveNoteEditBoundary(HWND owner) {
    if (!g_hNoteEdit || !IsWindow(g_hNoteEdit)) return true;
    if (g_currentNotePath.empty()) return true;
    if (!owner) owner = g_hMainWnd;
    if (!owner) owner = GetParent(g_hNoteEdit);

    if (IsNoteImeComposing()) {
        CommitNoteImeCompositionNow();
    }

    const bool editorModified = (SendMessageW(g_hNoteEdit, EM_GETMODIFY, 0, 0) != 0);
    if (editorModified && !g_noteDirty && !IsNoteChangeSuppressed()) {
        g_noteDirty = true;
        g_noteNeedsIntegrate = true;
        NotifyEditRevisionChanged();
        RecordCurrentNoteTextEditForUndo(g_hNoteEdit);
        file_output::NotifyNoteStageEdit(owner);
    }

    if (g_noteDirty || g_noteNeedsIntegrate || editorModified) {
        return file_output::SaveNoteIfDirty(owner);
    }
    return true;
}

void RecordCurrentNoteTextEditForUndo(HWND hEdit) {
    if (!hEdit || g_noteApplyingUndoRedo) return;
    if (g_expectedNoteTextEdit.active && g_expectedNoteTextEdit.hEdit == hEdit) {
        NoteUndoEntry entry = std::move(g_expectedNoteTextEdit.entry);
        g_expectedNoteTextEdit = {};
        if (!g_noteUndoSnapshotReady) {
            ResetNoteEditHistorySnapshot(hEdit);
            return;
        }
        if (!EntryMatchesSnapshot(entry)) {
            ResetNoteEditHistorySnapshot(hEdit);
            return;
        }
        if (entry.edit.deleted_len == 0 && entry.edit.inserted_text.empty()) {
            return;
        }
        const note::TextEdit edit = entry.edit;
        ApplyTextEditToSnapshot(&g_noteUndoTextSnapshot, edit);
        const note::NoteTextSelection before{{entry.beforeSelStart}, {entry.beforeSelEnd}};
        const note::NoteTextSelection after{{entry.afterSelStart}, {entry.afterSelEnd}};
        ApplyNoteDirtyGraphForUserTextEdit(
            edit, before, after,
            ClassifyNoteHistoryOperation(edit, before, after));
        return;
    }

    const std::wstring currentText = GetEditTextForIndexing(hEdit);
    if (!g_noteUndoSnapshotReady) {
        g_noteUndoTextSnapshot = currentText;
        g_noteUndoSnapshotReady = true;
        return;
    }
    auto editOpt = note::ComputeNoteTextEdit(g_noteUndoTextSnapshot, currentText);
    if (!editOpt) {
        ResetNoteEditHistorySnapshot(hEdit);
        return;
    }
    const note::TextEdit& edit = *editOpt;
    if (edit.deleted_len == 0 && edit.inserted_text.empty()) {
        return;
    }

    NoteUndoEntry entry;
    entry.edit = edit;
    if (entry.edit.start.value <= g_noteUndoTextSnapshot.size()) {
        const size_t deleteLen = std::min(edit.deleted_len, g_noteUndoTextSnapshot.size() - edit.start.value);
        entry.deletedText = g_noteUndoTextSnapshot.substr(edit.start.value, deleteLen);
    }
    entry.beforeSelStart = static_cast<DWORD>(
        std::min<size_t>(edit.start.value, static_cast<size_t>(std::numeric_limits<DWORD>::max())));
    entry.beforeSelEnd = static_cast<DWORD>(
        std::min<size_t>(edit.start.value + entry.deletedText.size(),
                         static_cast<size_t>(std::numeric_limits<DWORD>::max())));
    SendMessageW(hEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&entry.afterSelStart),
                 reinterpret_cast<LPARAM>(&entry.afterSelEnd));

    const note::NoteTextSelection before{{entry.beforeSelStart}, {entry.beforeSelEnd}};
    const note::NoteTextSelection after{{entry.afterSelStart}, {entry.afterSelEnd}};
    g_noteUndoTextSnapshot = currentText;
    ApplyNoteDirtyGraphForUserTextEdit(
        edit, before, after,
        ClassifyNoteHistoryOperation(edit, before, after));
}

static bool IsEditableNoteUndoRedoFocusOwner() {
    HWND focused = GetFocus();
    if (!g_hNoteEdit || !IsWindow(g_hNoteEdit) || !focused ||
        (focused != g_hNoteEdit && !IsChild(g_hNoteEdit, focused))) {
        return false;
    }
    if (!IsWindowEnabled(g_hNoteEdit)) return false;
    const LONG_PTR style = GetWindowLongPtrW(g_hNoteEdit, GWL_STYLE);
    return (style & ES_READONLY) == 0;
}

bool CanExecuteNoteUndoRedoFromFocus(bool undo) {
    if (!IsEditableNoteUndoRedoFocusOwner()) return false;
    const note::LocalNoteKernel* kernel = CurrentNoteKernel();
    return kernel && (undo ? kernel->CanUndo() : kernel->CanRedo());
}

bool ExecuteNoteUndoRedoFromFocus(HWND owner, bool undo) {
    (void)owner;
    if (!CanExecuteNoteUndoRedoFromFocus(undo)) return false;
    note::LocalNoteKernel* kernel = CurrentNoteKernel();
    if (!kernel || !kernel->text_core().MatchesRaw(GetEditTextForIndexing(g_hNoteEdit))) return false;
    const auto replay = undo ? kernel->Undo(IsNoteRenderActive()) : kernel->Redo(IsNoteRenderActive());
    if (!replay.has_value() || !replay->applied()) return false;
    const note::TextEdit& edit = replay->apply_result.dirty_graph.edit;
    g_noteApplyingUndoRedo = true;
    ReleaseNoteChangeSuppressionForUserEdit();
    SendMessageW(g_hNoteEdit, EM_SETSEL,
                 static_cast<WPARAM>(edit.start.value),
                 static_cast<LPARAM>(edit.start.value + edit.deleted_len));
    SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE,
                 reinterpret_cast<LPARAM>(edit.inserted_text.c_str()));
    SendMessageW(g_hNoteEdit, EM_SETSEL,
                 static_cast<WPARAM>(replay->selection.anchor.value),
                 static_cast<LPARAM>(replay->selection.caret.value));
    g_noteApplyingUndoRedo = false;
    g_noteUndoTextSnapshot = GetEditTextForIndexing(g_hNoteEdit);
    g_noteUndoSnapshotReady = true;
    ApplyNoteKernelHistoryResult(kernel, replay->apply_result);
    SendMessageW(g_hNoteEdit, EM_SCROLLCARET, 0, 0);
    return true;
}

struct CachedNoteEditWindow {
    HWND hEdit = nullptr;
    note::NoteId noteId{};
};

static std::unordered_map<std::wstring, CachedNoteEditWindow> g_noteEditWindowCache;

static std::wstring NormalizeNoteEditPathKey(const std::filesystem::path& path) {
    if (path.empty()) return {};
    std::error_code ec;
    std::filesystem::path canon = std::filesystem::weakly_canonical(path, ec);
    std::wstring out = ec ? path.wstring() : canon.wstring();
    std::replace(out.begin(), out.end(), L'/', L'\\');
    std::transform(out.begin(), out.end(), out.begin(), [](wchar_t ch) {
        return static_cast<wchar_t>(std::towlower(ch));
    });
    return out;
}

static std::wstring NoteEditCacheKey(const std::wstring& notePath) {
    if (notePath.empty()) return {};
    return NormalizeNoteEditPathKey(std::filesystem::path(notePath));
}

static HWND FindCachedNoteEditWindow(const std::wstring& notePath) {
    const std::wstring key = NoteEditCacheKey(notePath);
    if (key.empty()) return nullptr;
    auto it = g_noteEditWindowCache.find(key);
    if (it == g_noteEditWindowCache.end()) return nullptr;
    const CachedNoteEditWindow cached = it->second;
    if (!IsWindow(cached.hEdit)) {
        ForgetNoteViewState(cached.hEdit);
        ForgetNoteUndoHistoryForWindow(cached.hEdit);
        g_noteEditWindowCache.erase(it);
        return nullptr;
    }
    const auto noteIdentity = g_noteIdentityRegistry.FindPath(key);
    const note::ViewIdentity viewIdentity = NoteViewIdentityForWindow(cached.hEdit);
    if (!noteIdentity.has_value() || cached.noteId != noteIdentity->note_id ||
        !viewIdentity.valid() || viewIdentity.note_id != cached.noteId) {
        g_noteEditWindowCache.erase(it);
        return nullptr;
    }
    return cached.hEdit;
}

static void CacheNoteEditWindowForPath(const std::wstring& notePath, HWND hEdit) {
    const std::wstring key = NoteEditCacheKey(notePath);
    if (key.empty() || !hEdit || !IsWindow(hEdit)) return;
    const note::ViewIdentity viewIdentity = NoteViewIdentityForWindow(hEdit);
    if (!viewIdentity.valid()) return;
    for (auto it = g_noteEditWindowCache.begin(); it != g_noteEditWindowCache.end(); ) {
        if (it->first != key && it->second.hEdit == hEdit) {
            it = g_noteEditWindowCache.erase(it);
        } else {
            ++it;
        }
    }
    g_noteEditWindowCache[key] = CachedNoteEditWindow{hEdit, viewIdentity.note_id};
}

static void ParkCachedNoteEditWindow(HWND hEdit) {
    if (!hEdit || !IsWindow(hEdit)) return;
    HWND focused = GetFocus();
    if (focused == hEdit || IsChild(hEdit, focused)) {
        HWND owner = GetParent(hEdit);
        if (owner && IsWindow(owner)) SetFocus(owner);
    }
    EnableWindow(hEdit, FALSE);
    ShowWindow(hEdit, SW_HIDE);
    SetWindowPos(hEdit, HWND_BOTTOM, 0, 0, 0, 0,
                 SWP_NOACTIVATE | SWP_NOOWNERZORDER | SWP_HIDEWINDOW);
}

void EnsureInactiveCachedNoteEditWindowsParked() {
    for (auto it = g_noteEditWindowCache.begin(); it != g_noteEditWindowCache.end(); ) {
        HWND hEdit = it->second.hEdit;
        if (!hEdit || !IsWindow(hEdit)) {
            ForgetNoteViewState(hEdit);
            ForgetNoteUndoHistoryForWindow(hEdit);
            it = g_noteEditWindowCache.erase(it);
            continue;
        }
        if (hEdit != g_hNoteEdit) {
            ParkCachedNoteEditWindow(hEdit);
        }
        ++it;
    }
}

static void DestroyInactiveCachedNoteEditWindows() {
    std::vector<HWND> toDestroy;
    toDestroy.reserve(g_noteEditWindowCache.size());
    for (const auto& entry : g_noteEditWindowCache) {
        HWND hEdit = entry.second.hEdit;
        if (!hEdit || !IsWindow(hEdit) || hEdit == g_hNoteEdit) continue;
        if (std::find(toDestroy.begin(), toDestroy.end(), hEdit) == toDestroy.end()) {
            toDestroy.push_back(hEdit);
        }
    }
    g_noteEditWindowCache.clear();
    for (HWND hEdit : toDestroy) {
        ForgetNoteViewState(hEdit);
        ForgetNoteUndoHistoryForWindow(hEdit);
        DestroyWindow(hEdit);
    }
}

static HWND CreateAdditionalNoteEditWindow(HWND owner) {
    if (!g_hNoteEdit || !IsWindow(g_hNoteEdit)) return nullptr;
    if (!owner) owner = GetParent(g_hNoteEdit);
    if (!owner) return nullptr;

    wchar_t className[64] = {};
    if (GetClassNameW(g_hNoteEdit, className, static_cast<int>(std::size(className))) <= 0) {
        return nullptr;
    }

    RECT rc{};
    GetWindowRect(g_hNoteEdit, &rc);
    MapWindowPoints(nullptr, owner, reinterpret_cast<POINT*>(&rc), 2);
    const int width = std::max(1, static_cast<int>(rc.right - rc.left));
    const int height = std::max(1, static_cast<int>(rc.bottom - rc.top));
    const DWORD style = static_cast<DWORD>(GetWindowLongPtrW(g_hNoteEdit, GWL_STYLE));
    const DWORD exStyle = static_cast<DWORD>(GetWindowLongPtrW(g_hNoteEdit, GWL_EXSTYLE));

    HWND hEdit = CreateWindowExW(exStyle, className, L"", style & ~WS_VISIBLE,
                                 rc.left, rc.top, width, height,
                                 owner, nullptr, g_hInst, nullptr);
    if (!hEdit) return nullptr;

    if (IsRichEditControl(g_hNoteEdit)) {
        SendMessageW(hEdit, EM_SETTEXTMODE, TM_RICHTEXT | TM_MULTILEVELUNDO | TM_MULTICODEPAGE, 0);
        SendMessageW(hEdit, EM_EXLIMITTEXT, 0, 0x7FFFFFF0);
        SendMessageW(hEdit, EM_SETBKGNDCOLOR, 0, g_noteBgColor);
        SendMessageW(hEdit, EM_SETTARGETDEVICE, 0, 1);
        SendMessageW(hEdit, EM_SETOPTIONS, ECOOP_OR,
                     ECO_AUTOHSCROLL | ECO_AUTOVSCROLL | ECO_WANTRETURN);
        const LRESULT mask = SendMessageW(hEdit, EM_GETEVENTMASK, 0, 0);
        SendMessageW(hEdit, EM_SETEVENTMASK, 0, mask | ENM_CHANGE);
    } else {
        SendMessageW(hEdit, EM_SETLIMITTEXT, 0x7FFFFFF0, 0);
    }

    const WNDPROC prevProc = reinterpret_cast<WNDPROC>(
        SetWindowLongPtrW(hEdit, GWLP_WNDPROC, reinterpret_cast<LONG_PTR>(NoteEditProc)));
    if (!g_oldNoteProc) g_oldNoteProc = prevProc;
    ScopedNoteViewContextBinding viewContextBinding(hEdit);

    HFONT activeNoteFont = (g_noteRenderEnabled && !g_noteRawOnly && g_hNoteRenderFont)
        ? g_hNoteRenderFont
        : g_hNoteFont;
    if (activeNoteFont) {
        SendMessageW(hEdit, WM_SETFONT, reinterpret_cast<WPARAM>(activeNoteFont), TRUE);
    } else {
        SetUIFont(hEdit);
    }
    SendMessageW(hEdit, EM_SETREADONLY, HasOpenNote() ? FALSE : TRUE, 0);
    UpdateNoteFormatRect(hEdit);
    return hEdit;
}

static void ActivateNoteEditWindow(HWND owner, HWND nextEdit) {
    if (!nextEdit || !IsWindow(nextEdit)) return;
    if (g_hNoteEdit == nextEdit) return;

    if (!owner) {
        owner = g_hNoteEdit ? GetParent(g_hNoteEdit) : GetParent(nextEdit);
    }

    RECT rc{};
    bool haveRect = false;
    if (g_hNoteEdit && IsWindow(g_hNoteEdit) && owner) {
        GetWindowRect(g_hNoteEdit, &rc);
        MapWindowPoints(nullptr, owner, reinterpret_cast<POINT*>(&rc), 2);
        haveRect = true;
        ParkCachedNoteEditWindow(g_hNoteEdit);
    }

    g_hNoteEdit = nextEdit;
    EnableWindow(g_hNoteEdit, TRUE);

    HFONT activeNoteFont = (g_noteRenderEnabled && !g_noteRawOnly && g_hNoteRenderFont)
        ? g_hNoteRenderFont
        : g_hNoteFont;
    if (activeNoteFont) {
        SendMessageW(g_hNoteEdit, WM_SETFONT, reinterpret_cast<WPARAM>(activeNoteFont), TRUE);
    }
    SendMessageW(g_hNoteEdit, EM_SETBKGNDCOLOR, 0, g_noteBgColor);

    if (haveRect) {
        const int width = std::max(1, static_cast<int>(rc.right - rc.left));
        const int height = std::max(1, static_cast<int>(rc.bottom - rc.top));
        SetWindowPos(g_hNoteEdit, HWND_TOP, rc.left, rc.top, width, height,
                     SWP_NOACTIVATE | SWP_SHOWWINDOW);
    } else {
        ShowWindow(g_hNoteEdit, SW_SHOW);
    }

    UpdateNoteEditAvailability();
    UpdateNoteFormatRect(g_hNoteEdit);
    EnsureInactiveCachedNoteEditWindowsParked();
}

static HWND PrepareNoteEditWindowForPath(HWND owner,
                                         const std::wstring& notePath,
                                         bool* outReusedCachedWindow = nullptr) {
    if (outReusedCachedWindow) *outReusedCachedWindow = false;

    const std::wstring currentKey = NoteEditCacheKey(g_currentNotePath);
    const std::wstring targetKey = NoteEditCacheKey(notePath);
    if (g_hNoteEdit && IsWindow(g_hNoteEdit)) {
        CaptureNoteViewState(g_hNoteEdit, currentKey);
        CaptureNoteUndoHistoryForWindow(g_hNoteEdit);
    }
    if (!currentKey.empty() && currentKey != targetKey && g_hNoteEdit && IsWindow(g_hNoteEdit)) {
        CacheNoteEditWindowForPath(g_currentNotePath, g_hNoteEdit);
    }

    HWND targetEdit = FindCachedNoteEditWindow(notePath);
    if (targetEdit) {
        if (outReusedCachedWindow) *outReusedCachedWindow = true;
    } else if (!g_hNoteEdit || !IsWindow(g_hNoteEdit) || (!currentKey.empty() && currentKey != targetKey)) {
        targetEdit = CreateAdditionalNoteEditWindow(owner);
    } else {
        targetEdit = g_hNoteEdit;
    }
    if (!targetEdit) return nullptr;

    ActivateNoteEditWindow(owner, targetEdit);
    BeginNoteViewActivation(g_hNoteEdit, targetKey);
    CacheNoteEditWindowForPath(notePath, g_hNoteEdit);
    EnsureInactiveCachedNoteEditWindowsParked();
    return g_hNoteEdit;
}

static bool IsNoteBulletIndentChar(wchar_t ch) {
    return ch == L' ' || ch == L'\t' || ch == L'\u3000';
}

static bool IsMarkdownBulletMarker(wchar_t ch) {
    return ch == L'-' || ch == L'*' || ch == L'+';
}

struct AutoBulletLineContext {
    size_t lineStart = 0;
    size_t lineEnd = 0;
    size_t markerPos = 0;
    size_t prefixEnd = 0;
    std::wstring prefix;
    std::wstring continuationPrefix;
    bool valid = false;
    bool hasContent = false;
    bool structuralPrefix = false;
};

static bool IsMarkdownOrderedListDigit(wchar_t ch) {
    return ch >= L'0' && ch <= L'9';
}

static size_t FindNoteLineStart(const std::wstring& text, size_t pos) {
    pos = std::min(pos, text.size());
    while (pos > 0) {
        wchar_t prev = text[pos - 1];
        if (prev == L'\r' || prev == L'\n') break;
        --pos;
    }
    return pos;
}

static size_t FindNoteLineEnd(const std::wstring& text, size_t pos) {
    pos = std::min(pos, text.size());
    size_t lineEnd = text.find_first_of(L"\r\n", pos);
    return (lineEnd == std::wstring::npos) ? text.size() : lineEnd;
}

static size_t AdvanceMarkdownQuotePrefix(const std::wstring& text, size_t pos, size_t lineEnd) {
    while (pos < lineEnd && text[pos] == L'>') {
        ++pos;
        while (pos < lineEnd && IsNoteBulletIndentChar(text[pos])) {
            ++pos;
        }
    }
    return pos;
}

static bool TryParseMarkdownOrderedListMarker(const std::wstring& text,
                                              size_t pos,
                                              size_t lineEnd,
                                              unsigned long long* outNumber,
                                              wchar_t* outDelimiter,
                                              size_t* outAfterMarker) {
    if (outNumber) *outNumber = 0;
    if (outDelimiter) *outDelimiter = L'.';
    if (outAfterMarker) *outAfterMarker = pos;
    if (pos >= lineEnd || !IsMarkdownOrderedListDigit(text[pos])) return false;

    size_t scan = pos;
    unsigned long long number = 0;
    while (scan < lineEnd && IsMarkdownOrderedListDigit(text[scan])) {
        unsigned digit = static_cast<unsigned>(text[scan] - L'0');
        if (number < 999999999ULL) {
            number = std::min(999999999ULL, number * 10ULL + digit);
        }
        ++scan;
    }
    if (scan == pos || scan >= lineEnd) return false;
    wchar_t delimiter = text[scan];
    if (delimiter != L'.' && delimiter != L')') return false;
    ++scan;
    if (scan >= lineEnd || !IsNoteBulletIndentChar(text[scan])) return false;
    while (scan < lineEnd && IsNoteBulletIndentChar(text[scan])) {
        ++scan;
    }

    if (outNumber) *outNumber = std::max(1ULL, number);
    if (outDelimiter) *outDelimiter = delimiter;
    if (outAfterMarker) *outAfterMarker = scan;
    return true;
}

static bool TryParseMarkdownChecklistMarker(const std::wstring& text,
                                            size_t pos,
                                            size_t lineEnd,
                                            size_t* outAfterMarker) {
    if (outAfterMarker) *outAfterMarker = pos;
    if (pos + 2 >= lineEnd) return false;
    if (text[pos] != L'[' || text[pos + 2] != L']') return false;
    wchar_t state = text[pos + 1];
    if (!(state == L' ' || state == L'x' || state == L'X')) return false;

    size_t scan = pos + 3;
    if (scan >= lineEnd || !IsNoteBulletIndentChar(text[scan])) return false;
    while (scan < lineEnd && IsNoteBulletIndentChar(text[scan])) {
        ++scan;
    }
    if (outAfterMarker) *outAfterMarker = scan;
    return true;
}

static AutoBulletLineContext AnalyzeAutoBulletLine(const std::wstring& text, size_t caret) {
    AutoBulletLineContext ctx{};
    if (caret > text.size()) caret = text.size();

    size_t lineStart = FindNoteLineStart(text, caret);
    size_t lineEnd = FindNoteLineEnd(text, lineStart);
    if (lineStart >= lineEnd && lineStart >= text.size()) return ctx;

    size_t pos = lineStart;
    while (pos < lineEnd && IsNoteBulletIndentChar(text[pos])) {
        ++pos;
    }
    const size_t afterIndent = pos;
    size_t afterQuotes = AdvanceMarkdownQuotePrefix(text, pos, lineEnd);
    const bool hasQuotePrefix = afterQuotes > afterIndent;
    std::wstring prefixBase = text.substr(lineStart, afterQuotes - lineStart);

    bool valid = (afterQuotes > lineStart);
    size_t markerPos = afterQuotes;
    bool hasListMarker = false;
    bool hasChecklist = false;
    bool ordered = false;
    unsigned long long orderedNumber = 1;
    wchar_t orderedDelimiter = L'.';

    pos = afterQuotes;
    if (pos < lineEnd && IsMarkdownBulletMarker(text[pos])) {
        markerPos = pos;
        ++pos;
        if (pos >= lineEnd || !IsNoteBulletIndentChar(text[pos])) return ctx;
        while (pos < lineEnd && IsNoteBulletIndentChar(text[pos])) {
            ++pos;
        }
        hasListMarker = true;
        valid = true;
        ctx.continuationPrefix = prefixBase + text[markerPos] + L' ';
    } else {
        size_t orderedAfter = pos;
        if (TryParseMarkdownOrderedListMarker(text, pos, lineEnd,
                                              &orderedNumber, &orderedDelimiter, &orderedAfter)) {
            markerPos = pos;
            pos = orderedAfter;
            ordered = true;
            hasListMarker = true;
            valid = true;
            ctx.continuationPrefix = prefixBase +
                                     std::to_wstring(orderedNumber + 1ULL) +
                                     std::wstring(1, orderedDelimiter) + L' ';
        } else {
            ctx.continuationPrefix = prefixBase;
        }
    }

    if (hasListMarker) {
        size_t checklistAfter = pos;
        if (TryParseMarkdownChecklistMarker(text, pos, lineEnd, &checklistAfter)) {
            hasChecklist = true;
            pos = checklistAfter;
            ctx.continuationPrefix += L"[ ] ";
        }
    }
    if (!valid) return ctx;

    bool hasContent = false;
    for (size_t scan = pos; scan < lineEnd; ++scan) {
        if (!IsNoteBulletIndentChar(text[scan])) {
            hasContent = true;
            break;
        }
    }

    ctx.lineStart = lineStart;
    ctx.lineEnd = lineEnd;
    ctx.markerPos = markerPos;
    ctx.prefixEnd = pos;
    ctx.prefix = text.substr(lineStart, pos - lineStart);
    if (!hasListMarker && !hasChecklist && ctx.continuationPrefix.empty()) {
        ctx.continuationPrefix = ctx.prefix;
    }
    if (hasListMarker && !ordered && ctx.continuationPrefix.empty()) {
        ctx.continuationPrefix = prefixBase + text[markerPos] + L' ';
    }
    ctx.valid = valid;
    ctx.hasContent = hasContent;
    ctx.structuralPrefix = hasQuotePrefix || hasListMarker || hasChecklist;
    return ctx;
}

static void FinalizeImmediateNoteEdit(HWND hWnd) {
    if (!hWnd) return;
    SendMessageW(hWnd, EM_SCROLLCARET, 0, 0);
    if (HWND parent = GetParent(hWnd)) {
        if (!IsNoteImeComposing()) {
            PostMessageW(parent, kMsgNoteOverlayUpdate, 0, static_cast<LPARAM>(CurrentEditRevision()));
        }
    }
}

static std::wstring NoteEditHardLineBreakForInsert(HWND hWnd) {
    return IsRichEditControl(hWnd) ? L"\r" : L"\r\n";
}

static bool TryHandleAutoBulletEnter(HWND hWnd) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    const size_t caret = static_cast<size_t>(std::min(selStart, selEnd));

    const std::wstring text = GetEditTextForIndexing(hWnd);
    const AutoBulletLineContext ctx = AnalyzeAutoBulletLine(text, caret);
    if (!ctx.valid) return false;

    if (selStart == selEnd && caret == ctx.lineStart && ctx.hasContent) {
        ReleaseNoteChangeSuppressionForUserEdit();
        const std::wstring insertText = NoteEditHardLineBreakForInsert(hWnd);
        RegisterExpectedCurrentNoteSelectionReplacement(hWnd, insertText,
                                                        static_cast<DWORD>(caret + 1),
                                                        static_cast<DWORD>(caret + 1));
        SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(insertText.c_str()));
        FinalizeImmediateNoteEdit(hWnd);
        return true;
    }

    if (selStart == selEnd && !ctx.hasContent) {
        ReleaseNoteChangeSuppressionForUserEdit();
        SendMessageW(hWnd, EM_SETSEL,
                     static_cast<WPARAM>(ctx.lineStart),
                     static_cast<LPARAM>(ctx.prefixEnd));
        RegisterExpectedCurrentNoteSelectionReplacement(hWnd, L"",
                                                        static_cast<DWORD>(ctx.lineStart),
                                                        static_cast<DWORD>(ctx.lineStart));
        SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(L""));
        FinalizeImmediateNoteEdit(hWnd);
        return true;
    }

    std::wstring insertText = NoteEditHardLineBreakForInsert(hWnd);
    insertText += ctx.continuationPrefix;
    ReleaseNoteChangeSuppressionForUserEdit();
    const DWORD afterCaret = static_cast<DWORD>(
        std::min<size_t>(caret + NormalizeTextForNoteIndexing(insertText).size(),
                         static_cast<size_t>(std::numeric_limits<DWORD>::max())));
    RegisterExpectedCurrentNoteSelectionReplacement(hWnd, insertText, afterCaret, afterCaret);
    SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(insertText.c_str()));
    FinalizeImmediateNoteEdit(hWnd);
    return true;
}

static bool TryHandleAutoBulletPrefixDelete(HWND hWnd, WPARAM vkey) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;
    if (vkey != VK_BACK && vkey != VK_DELETE) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    if (selStart != selEnd) return false;

    const size_t caret = static_cast<size_t>(selStart);
    const LRESULT displayLine = SendMessageW(hWnd, EM_LINEFROMCHAR, static_cast<WPARAM>(caret), 0);
    if (displayLine < 0) return false;
    const LRESULT displayLineStart = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(displayLine), 0);
    if (displayLineStart < 0) return false;
    constexpr size_t kMaxAutoBulletPrefixProbeChars = 16;
    if (caret > static_cast<size_t>(displayLineStart) + kMaxAutoBulletPrefixProbeChars) {
        return false;
    }

    const std::wstring text = GetEditTextForIndexing(hWnd);
    const AutoBulletLineContext ctx = AnalyzeAutoBulletLine(text, caret);
    if (!ctx.valid || ctx.hasContent || !ctx.structuralPrefix) return false;

    const bool shouldDeletePrefix =
        (vkey == VK_BACK && caret > ctx.lineStart && caret <= ctx.prefixEnd) ||
        (vkey == VK_DELETE && caret >= ctx.lineStart && caret < ctx.prefixEnd);
    if (!shouldDeletePrefix) return false;

    ReleaseNoteChangeSuppressionForUserEdit();
    SendMessageW(hWnd, EM_SETSEL,
                 static_cast<WPARAM>(ctx.lineStart),
                 static_cast<LPARAM>(ctx.prefixEnd));
    RegisterExpectedCurrentNoteSelectionReplacement(hWnd, L"",
                                                    static_cast<DWORD>(ctx.lineStart),
                                                    static_cast<DWORD>(ctx.lineStart));
    SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(L""));
    FinalizeImmediateNoteEdit(hWnd);
    return true;
}

static bool TryHandleLeadingTabStopBackspace(HWND hWnd) {
    if (!hWnd) return false;
    if ((GetKeyState(VK_CONTROL) & 0x8000) || (GetKeyState(VK_MENU) & 0x8000) ||
        (GetKeyState(VK_SHIFT) & 0x8000) || g_noteImeComposing) {
        return false;
    }

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    if (selStart != selEnd) return false;

    constexpr size_t kTabStopSpaces = 4;
    constexpr size_t kMaxLeadingIndentProbeChars = 4096;
    const size_t caret = static_cast<size_t>(selStart);
    if (caret < kTabStopSpaces) return false;

    // EM_LINEINDEX follows display lines when wrapping is enabled, so it
    // cannot identify a logical line start here. Read only a bounded suffix
    // and require the portion after the most recent real line break to be
    // spaces. If the logical indent exceeds the bound, keep normal Backspace.
    const size_t probeStart = (caret > kMaxLeadingIndentProbeChars)
        ? caret - kMaxLeadingIndentProbeChars
        : 0;
    const std::wstring probe = GetEditTextRangeForIndexing(hWnd, probeStart, caret);
    if (probe.size() != caret - probeStart) return false;
    const size_t lineBreak = probe.find_last_of(L"\r\n");
    if (lineBreak == std::wstring::npos && probeStart != 0) return false;
    const size_t leadingStart = (lineBreak == std::wstring::npos) ? 0 : lineBreak + 1;
    const size_t column = probe.size() - leadingStart;

    // Only collapse an explicit leading indentation tab stop. Ordinary spaces
    // inside text must continue through the normal single-character Backspace path.
    if (column < kTabStopSpaces || (column % kTabStopSpaces) != 0) return false;
    for (size_t index = leadingStart; index < probe.size(); ++index) {
        const wchar_t ch = probe[index];
        if (ch != L' ') return false;
    }

    const size_t deleteStart = caret - kTabStopSpaces;
    ReleaseNoteChangeSuppressionForUserEdit();
    SendMessageW(hWnd, EM_SETSEL,
                 static_cast<WPARAM>(deleteStart),
                 static_cast<LPARAM>(caret));
    RegisterExpectedCurrentNoteSelectionReplacement(hWnd, L"",
                                                    static_cast<DWORD>(deleteStart),
                                                    static_cast<DWORD>(deleteStart));
    SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(L""));
    FinalizeImmediateNoteEdit(hWnd);
    return true;
}
static bool ReplaceNoteSelectionAndSetSelection(HWND hWnd,
                                                DWORD selStart,
                                                DWORD selEnd,
                                                const std::wstring& replacement,
                                                size_t newSelStart,
                                                size_t newSelEnd) {
    if (!hWnd) return false;
    ReleaseNoteChangeSuppressionForUserEdit();
    SendMessageW(hWnd, EM_SETSEL, selStart, selEnd);
    DWORD base = std::min(selStart, selEnd);
    DWORD nextStart = static_cast<DWORD>(std::min<size_t>(replacement.size(), newSelStart)) + base;
    DWORD nextEnd = static_cast<DWORD>(std::min<size_t>(replacement.size(), newSelEnd)) + base;
    RegisterExpectedCurrentNoteSelectionReplacement(hWnd, replacement, nextStart, nextEnd);
    SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(replacement.c_str()));
    SendMessageW(hWnd, EM_SETSEL, nextStart, nextEnd);
    FinalizeImmediateNoteEdit(hWnd);
    return true;
}

static bool TryResolveNoteAutoPairBracket(wchar_t open, wchar_t* close) {
    if (!close) return false;
    switch (open) {
    case L'[':
        *close = L']';
        return true;
    case L'{':
        *close = L'}';
        return true;
    case L'［':
        *close = L'］';
        return true;
    case L'｛':
        *close = L'｝';
        return true;
    case L'「':
        *close = L'」';
        return true;
    case L'『':
        *close = L'』';
        return true;
    case L'【':
        *close = L'】';
        return true;
    default:
        return false;
    }
}

static bool TryHandleNoteAutoPairBracket(HWND hWnd, wchar_t ch) {
    if (!hWnd || !g_config.autoPairBrackets || g_noteImeComposing) return false;

    wchar_t close = 0;
    if (!TryResolveNoteAutoPairBracket(ch, &close)) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    if (selStart > selEnd) std::swap(selStart, selEnd);

    const std::wstring text = GetEditTextForIndexing(hWnd);
    const size_t safeStart = std::min<size_t>(selStart, text.size());
    const size_t safeEnd = std::min<size_t>(selEnd, text.size());
    const std::wstring selected = text.substr(safeStart, safeEnd - safeStart);

    std::wstring replacement;
    replacement.reserve(selected.size() + 2);
    replacement.push_back(ch);
    replacement += selected;
    replacement.push_back(close);

    const size_t nextSelStart = 1;
    const size_t nextSelEnd = 1 + selected.size();
    return ReplaceNoteSelectionAndSetSelection(hWnd, selStart, selEnd, replacement,
                                                nextSelStart, nextSelEnd);
}
static bool SurroundNoteSelectionWithMarkdown(HWND hWnd,
                                              const std::wstring& prefix,
                                              const std::wstring& suffix) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    if (selStart > selEnd) std::swap(selStart, selEnd);

    const std::wstring text = GetEditTextForIndexing(hWnd);
    size_t safeStart = std::min<size_t>(selStart, text.size());
    size_t safeEnd = std::min<size_t>(selEnd, text.size());

    // Asterisk-based Markdown emphasis is line-local.  A single pair of
    // delimiters around a multi-line selection is not valid emphasis, so wrap
    // each selected line independently instead.
    const std::wstring selectedRange = text.substr(safeStart, safeEnd - safeStart);
    if (selectedRange.find_first_of(L"\r\n") != std::wstring::npos) {
        std::wstring replacement;
        replacement.reserve(selectedRange.size() + prefix.size() * 2 + suffix.size() * 2);
        for (size_t offset = 0; offset < selectedRange.size();) {
            const size_t lineEnd = selectedRange.find_first_of(L"\r\n", offset);
            const size_t contentEnd = (lineEnd == std::wstring::npos) ? selectedRange.size() : lineEnd;
            if (contentEnd > offset) {
                replacement += prefix;
                replacement.append(selectedRange, offset, contentEnd - offset);
                replacement += suffix;
            }
            if (lineEnd == std::wstring::npos) break;
            if (selectedRange[lineEnd] == L'\r' && lineEnd + 1 < selectedRange.size() &&
                selectedRange[lineEnd + 1] == L'\n') {
                replacement += L"\r\n";
                offset = lineEnd + 2;
            } else {
                replacement.push_back(selectedRange[lineEnd]);
                offset = lineEnd + 1;
            }
        }

        // Do not leave the just-formatted text selected: Return and ordinary
        // typing must continue after the emphasis, rather than replace it.
        return ReplaceNoteSelectionAndSetSelection(hWnd, selStart, selEnd, replacement,
                                                   replacement.size(), replacement.size());
    }

    auto getContiguousCount = [&](size_t pos, wchar_t ch, size_t& outStart, size_t& outEnd) {
        size_t start = pos;
        while (start > 0 && text[start - 1] == ch) start--;
        size_t end = pos;
        while (end < text.size() && text[end] == ch) end++;
        outStart = start;
        outEnd = end;
        return end - start;
    };

    bool uniformPrefix = !prefix.empty();
    for (wchar_t c : prefix) if (c != prefix[0]) { uniformPrefix = false; break; }
    
    bool uniformSuffix = !suffix.empty();
    for (wchar_t c : suffix) if (c != suffix[0]) { uniformSuffix = false; break; }

    bool foundL = false;
    size_t bestL = 0;
    size_t minL = (safeStart >= prefix.size()) ? safeStart - prefix.size() : 0;
    for (size_t i = safeStart; i + 1 >= minL + 1; --i) {
        if (i + prefix.size() <= text.size() && text.substr(i, prefix.size()) == prefix) {
            if (uniformPrefix) {
                size_t gStart, gEnd;
                int c = static_cast<int>(getContiguousCount(i, prefix[0], gStart, gEnd));
                int p = static_cast<int>(prefix.size());
                bool contains = (p == 1) ? (c == 1 || c == 3) :
                                (p == 2) ? (c == 2 || c == 3) : (c >= p);
                if (!contains) continue;
            }
            bestL = i;
            foundL = true;
            break;
        }
    }

    bool foundR = false;
    size_t bestR = 0;
    size_t minR = (safeEnd >= suffix.size()) ? safeEnd - suffix.size() : 0;
    for (size_t i = minR; i <= safeEnd; ++i) {
        if (i + suffix.size() <= text.size() && text.substr(i, suffix.size()) == suffix) {
            if (uniformSuffix) {
                size_t gStart, gEnd;
                int c = static_cast<int>(getContiguousCount(i, suffix[0], gStart, gEnd));
                int p = static_cast<int>(suffix.size());
                bool contains = (p == 1) ? (c == 1 || c == 3) :
                                (p == 2) ? (c == 2 || c == 3) : (c >= p);
                if (!contains) continue;
            }
            bestR = i;
            foundR = true;
            break;
        }
    }

    std::wstring replacement;
    size_t nextSelStart = 0;
    size_t nextSelEnd = 0;

    bool isCursorInsideSingleBoundary = false;
    size_t insideBoundaryOffset = 0;
    if (safeStart == safeEnd && prefix == suffix && prefix.size() >= 2) {
        for (size_t i = 1; i < prefix.size(); ++i) {
            if (safeStart >= i && safeStart + (prefix.size() - i) <= text.size()) {
                if (text.substr(safeStart - i, prefix.size()) == prefix) {
                    bool valid = true;
                    if (uniformPrefix) {
                        size_t gStart, gEnd;
                        int c = static_cast<int>(getContiguousCount(safeStart - i, prefix[0], gStart, gEnd));
                        int p = static_cast<int>(prefix.size());
                        valid = (p == 1) ? (c == 1 || c == 3) :
                                (p == 2) ? (c == 2 || c == 3) : (c >= p);
                    }
                    if (valid) {
                        isCursorInsideSingleBoundary = true;
                        insideBoundaryOffset = i;
                        break;
                    }
                }
            }
        }
    }

    if (foundL && foundR && bestL + prefix.size() <= bestR) {
        // Remove formatting
        selStart = static_cast<DWORD>(bestL);
        selEnd = static_cast<DWORD>(bestR + suffix.size());
        replacement = text.substr(bestL + prefix.size(), bestR - (bestL + prefix.size()));
        
        size_t innerOldStart = bestL + prefix.size();
        if (safeStart <= innerOldStart) {
            nextSelStart = 0;
        } else {
            nextSelStart = safeStart - innerOldStart;
        }
        
        if (safeEnd <= innerOldStart) {
            nextSelEnd = 0;
        } else {
            nextSelEnd = safeEnd - innerOldStart;
        }
        
        if (nextSelStart > replacement.size()) nextSelStart = replacement.size();
        if (nextSelEnd > replacement.size()) nextSelEnd = replacement.size();
    } else if (isCursorInsideSingleBoundary) {
        // Remove the single boundary we are inside
        replacement = L"";
        selStart -= static_cast<DWORD>(insideBoundaryOffset);
        selEnd += static_cast<DWORD>(prefix.size() - insideBoundaryOffset);
        nextSelStart = 0;
        nextSelEnd = 0;
    } else {
        // Add
        replacement = prefix + selectedRange + suffix;
        if (selectedRange.empty()) {
            nextSelStart = prefix.size();
            nextSelEnd = prefix.size();
        } else {
            // Match word processors: after applying a style to selected text,
            // collapse the selection after its closing marker.  Further input
            // therefore appends after the emphasis instead of replacing it.
            nextSelStart = replacement.size();
            nextSelEnd = replacement.size();
        }
    }

    return ReplaceNoteSelectionAndSetSelection(hWnd, selStart, selEnd, replacement,
                                               nextSelStart, nextSelEnd);
}



static bool InsertMarkdownLinkAtSelection(HWND hWnd) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    if (selStart > selEnd) std::swap(selStart, selEnd);

    const std::wstring text = GetEditTextForIndexing(hWnd);
    size_t safeStart = std::min<size_t>(selStart, text.size());
    size_t safeEnd = std::min<size_t>(selEnd, text.size());
    std::wstring selected = text.substr(safeStart, safeEnd - safeStart);
    std::wstring replacement = L"[" + selected + L"]()";

    if (selected.empty()) {
        return ReplaceNoteSelectionAndSetSelection(hWnd, selStart, selEnd, replacement, 1, 1);
    }
    size_t caret = replacement.size() - 1;
    return ReplaceNoteSelectionAndSetSelection(hWnd, selStart, selEnd, replacement, caret, caret);
}

static bool TryHandleMarkdownShortcut(HWND hWnd, WPARAM vkey) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;
    switch (vkey) {
    case 'B':
        return SurroundNoteSelectionWithMarkdown(hWnd, L"**", L"**");
    case 'I':
        return SurroundNoteSelectionWithMarkdown(hWnd, L"*", L"*");
    case 'E':
        return SurroundNoteSelectionWithMarkdown(hWnd, L"`", L"`");
    case 'K':
        return InsertMarkdownLinkAtSelection(hWnd);
    default:
        return false;
    }
}

static bool ReplaceNoteLineBlock(HWND hWnd,
                                 size_t replaceStart,
                                 size_t replaceEnd,
                                 const std::wstring& replacement,
                                 size_t newSelStart,
                                 size_t newSelEnd) {
    if (!hWnd) return false;
    ReleaseNoteChangeSuppressionForUserEdit();
    SendMessageW(hWnd, EM_SETSEL,
                 static_cast<WPARAM>(replaceStart),
                 static_cast<LPARAM>(replaceEnd));
    RegisterExpectedCurrentNoteSelectionReplacement(
        hWnd,
        replacement,
        static_cast<DWORD>(replaceStart + newSelStart),
        static_cast<DWORD>(replaceStart + newSelEnd));
    SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(replacement.c_str()));
    SendMessageW(hWnd, EM_SETSEL,
                 static_cast<WPARAM>(replaceStart + newSelStart),
                 static_cast<LPARAM>(replaceStart + newSelEnd));
    FinalizeImmediateNoteEdit(hWnd);
    return true;
}

static bool BuildNoteSelectedLineRange(const std::wstring& text,
                                       DWORD selStart,
                                       DWORD selEnd,
                                       size_t* outBlockStart,
                                       size_t* outBlockEnd) {
    if (!outBlockStart || !outBlockEnd) return false;
    if (selStart > selEnd) std::swap(selStart, selEnd);
    size_t safeStart = std::min<size_t>(selStart, text.size());
    size_t safeEnd = std::min<size_t>(selEnd, text.size());
    if (safeEnd > safeStart && safeEnd <= text.size()) {
        wchar_t prev = text[safeEnd - 1];
        if (prev == L'\r' || prev == L'\n') {
            --safeEnd;
        }
    }
    *outBlockStart = FindNoteLineStart(text, safeStart);
    *outBlockEnd = FindNoteLineEnd(text, safeEnd);
    return *outBlockStart <= *outBlockEnd;
}

static bool TryIndentSelectedMarkdownLines(HWND hWnd) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    if (selStart == selEnd) return false;

    const std::wstring text = GetEditTextForIndexing(hWnd);
    size_t blockStart = 0;
    size_t blockEnd = 0;
    if (!BuildNoteSelectedLineRange(text, selStart, selEnd, &blockStart, &blockEnd)) return false;
    if (blockStart > text.size() || blockEnd > text.size() || blockStart > blockEnd) return false;

    std::wstring replacement;
    replacement.reserve((blockEnd - blockStart) + 8);
    size_t scan = blockStart;
    while (scan <= blockEnd) {
        replacement += L"    ";
        size_t lineEnd = FindNoteLineEnd(text, scan);
        lineEnd = std::min(lineEnd, blockEnd);
        replacement.append(text, scan, lineEnd - scan);
        if (lineEnd >= blockEnd) break;
        replacement.push_back(text[lineEnd]);
        scan = lineEnd + 1;
    }

    return ReplaceNoteLineBlock(hWnd, blockStart, blockEnd, replacement, 0, replacement.size());
}

static size_t CountMarkdownOutdentChars(const std::wstring& text, size_t lineStart, size_t lineEnd) {
    if (lineStart >= lineEnd) return 0;
    if (text[lineStart] == L'\t') return 1;
    size_t removed = 0;
    while (lineStart + removed < lineEnd && removed < 4 && text[lineStart + removed] == L' ') {
        ++removed;
    }
    return removed;
}

static bool TryOutdentSelectedMarkdownLines(HWND hWnd) {
    if (!hWnd) return false;
    if (CurrentNoteContentRoute() != NoteContentRoute::MarkdownMd4c) return false;

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));

    const std::wstring text = GetEditTextForIndexing(hWnd);
    if (selStart == selEnd) {
        size_t caret = std::min<size_t>(selStart, text.size());
        size_t lineStart = FindNoteLineStart(text, caret);
        size_t lineEnd = FindNoteLineEnd(text, caret);
        size_t removeCount = CountMarkdownOutdentChars(text, lineStart, lineEnd);
        if (removeCount == 0) return true;
        size_t nextCaret = (caret > lineStart + removeCount) ? (caret - removeCount) : lineStart;
        SendMessageW(hWnd, EM_SETSEL,
                     static_cast<WPARAM>(lineStart),
                     static_cast<LPARAM>(lineStart + removeCount));
        RegisterExpectedCurrentNoteSelectionReplacement(hWnd, L"",
                                                        static_cast<DWORD>(nextCaret),
                                                        static_cast<DWORD>(nextCaret));
        SendMessageW(hWnd, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(L""));
        SendMessageW(hWnd, EM_SETSEL,
                     static_cast<WPARAM>(nextCaret),
                     static_cast<LPARAM>(nextCaret));
        FinalizeImmediateNoteEdit(hWnd);
        return true;
    }

    size_t blockStart = 0;
    size_t blockEnd = 0;
    if (!BuildNoteSelectedLineRange(text, selStart, selEnd, &blockStart, &blockEnd)) return false;
    if (blockStart > text.size() || blockEnd > text.size() || blockStart > blockEnd) return false;

    std::wstring replacement;
    replacement.reserve(blockEnd - blockStart);
    size_t scan = blockStart;
    while (scan <= blockEnd) {
        size_t lineEnd = FindNoteLineEnd(text, scan);
        lineEnd = std::min(lineEnd, blockEnd);
        size_t removeCount = CountMarkdownOutdentChars(text, scan, lineEnd);
        replacement.append(text, scan + removeCount, lineEnd - scan - removeCount);
        if (lineEnd >= blockEnd) break;
        replacement.push_back(text[lineEnd]);
        scan = lineEnd + 1;
    }

    return ReplaceNoteLineBlock(hWnd, blockStart, blockEnd, replacement, 0, replacement.size());
}

static std::pair<size_t, size_t> GetNoteSelectionBounds() {
    if (!g_hNoteEdit) return {0, 0};
    DWORD selStart = 0, selEnd = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    size_t start = static_cast<size_t>(std::min(selStart, selEnd));
    size_t end = static_cast<size_t>(std::max(selStart, selEnd));
    int textLen = GetWindowTextLengthW(g_hNoteEdit);
    size_t maxLen = (textLen < 0) ? 0 : static_cast<size_t>(textLen);
    if (start > maxLen) start = maxLen;
    if (end > maxLen) end = maxLen;
    return {start, end};
}

static bool ReadCurrentNoteLinePreview(HWND hEdit, std::wstring* out) {
    if (!hEdit || !out) return false;
    out->clear();

    DWORD selStart = 0, selEnd = 0;
    SendMessageW(hEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    int line = static_cast<int>(SendMessageW(hEdit, EM_LINEFROMCHAR, selStart, 0));
    if (line < 0) line = 0;

    LRESULT lineStartRes = SendMessageW(hEdit, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
    if (lineStartRes < 0) lineStartRes = 0;
    LRESULT lineLenRes = SendMessageW(hEdit, EM_LINELENGTH, static_cast<WPARAM>(lineStartRes), 0);
    if (lineLenRes < 0) lineLenRes = 0;

    const int lineLen = static_cast<int>(lineLenRes);
    const int maxCopy = std::min(800, std::max(0, lineLen));
    std::vector<wchar_t> buf(static_cast<size_t>(maxCopy) + 2, L'\0');
    buf[0] = static_cast<wchar_t>(std::min(0xFFFE, maxCopy + 1));
    LRESULT copiedRes = SendMessageW(hEdit, EM_GETLINE, static_cast<WPARAM>(line),
                                     reinterpret_cast<LPARAM>(buf.data()));
    if (copiedRes < 0) copiedRes = 0;
    int copied = static_cast<int>(std::min<LRESULT>(copiedRes, maxCopy));

    out->assign(buf.data(), static_cast<size_t>(copied));
    while (!out->empty() && (out->back() == L'\r' || out->back() == L'\n')) {
        out->pop_back();
    }
    if (lineLen > maxCopy) {
        out->append(L"...");
    }
    if (out->size() > 400) {
        *out = out->substr(0, 400) + L"...";
    }
    return true;
}

static void UpdatePreviewNoteFromCaretLine(HWND hEdit) {
    if (!hEdit) return;
    if (!g_hBottomNote) return;
    if (g_bottomPanePin == BottomPanePin::Math) return;
    if (g_bottomNoteMode == BottomNoteMode::Legacy ||
        g_bottomNoteMode == BottomNoteMode::Assist ||
        g_bottomNoteMode == BottomNoteMode::Headings) {
        return;
    }

    std::wstring next;
    if (!ReadCurrentNoteLinePreview(hEdit, &next)) return;

    if (next != g_previewNote) {
        g_previewNote = std::move(next);
        InvalidateRect(g_hBottomNote, nullptr, FALSE);
    }
}

static void UpdateNotePreviewFromEdit(HWND hEdit) {
    if (!hEdit) return;
    std::wstring next;
    if (!ReadCurrentNoteLinePreview(hEdit, &next)) return;
    g_previewNote = std::move(next);
    RefreshBottomPaneView();
}

static void ResetNoteUndoBuffer(HWND hEdit) {
    if (!hEdit) return;
    SendMessageW(hEdit, EM_EMPTYUNDOBUFFER, 0, 0);
    ResetNoteEditHistorySnapshot(hEdit);
}

void ClearCurrentNoteUndoHistory() {
    ResetNoteUndoBuffer(g_hNoteEdit);
    if (g_hNoteEdit) {
        SendMessageW(g_hNoteEdit, EM_SETMODIFY, FALSE, 0);
    }
}

namespace {
struct MathParseLineInfo {
    size_t start = 0;
    size_t end = 0;
    bool isComment = false;
};

static std::vector<MathParseLineInfo> BuildMathParseLineInfo(const std::wstring& text) {
    std::vector<MathParseLineInfo> lines;
    size_t scan = 0;
    while (scan <= text.size()) {
        size_t lineEnd = text.find(L'\n', scan);
        size_t end = (lineEnd == std::wstring::npos) ? text.size() : lineEnd;
        MathParseLineInfo info;
        info.start = scan;
        info.end = end;
        info.isComment = IsCommentLineAt(text, scan, end);
        lines.push_back(info);
        if (lineEnd == std::wstring::npos) break;
        scan = lineEnd + 1;
    }
    return lines;
}

static std::vector<size_t> BuildNextCommentStart(const std::vector<MathParseLineInfo>& lines,
                                                 size_t textSize) {
    std::vector<size_t> nextCommentStart(lines.size(), textSize);
    size_t nextComment = textSize;
    for (size_t idx = lines.size(); idx-- > 0;) {
        if (lines[idx].isComment) nextComment = lines[idx].start;
        nextCommentStart[idx] = nextComment;
    }
    return nextCommentStart;
}

static size_t FindLineIndexForPos(const std::vector<MathParseLineInfo>& lines, size_t pos) {
    if (lines.empty()) return 0;
    size_t lo = 0;
    size_t hi = lines.size();
    while (lo + 1 < hi) {
        size_t mid = lo + (hi - lo) / 2;
        if (lines[mid].start <= pos) {
            lo = mid;
        } else {
            hi = mid;
        }
    }
    return lo;
}

static size_t RawTextIndexToRichEditIndex(const std::wstring& text, size_t rawPos) {
    rawPos = std::min(rawPos, text.size());
    if (!IsRichEditControl(CurrentNoteViewContextWindow())) {
        return rawPos;
    }
    size_t editPos = 0;
    for (size_t i = 0; i < rawPos; ++i) {
        ++editPos;
        if (text[i] == L'\r' && i + 1 < rawPos && text[i + 1] == L'\n') {
            ++i;
        }
    }
    return editPos;
}

static void AssignMathEqNumbers(std::vector<MathEntry>& entries) {
    int eqNumber = 0;
    for (auto& e : entries) {
        if (e.isBlock) {
            e.eqNumber = ++eqNumber;
        } else {
            e.eqNumber = 0;
        }
    }
}

static void ParseMathBlocksRange(const std::wstring& text,
                                 const std::vector<MathParseLineInfo>& lines,
                                 const std::vector<size_t>& nextCommentStart,
                                 size_t rangeStart,
                                 size_t rangeEnd,
                                 std::vector<MathEntry>* outEntries) {
    if (!outEntries) return;
    if (rangeStart >= rangeEnd) return;
    if (lines.empty()) return;

    auto isEscaped = [&](size_t pos) {
        if (pos == 0) return false;
        size_t count = 0;
        for (size_t j = pos; j > 0 && text[j - 1] == L'\\'; --j) {
            ++count;
        }
        return (count % 2) == 1;
    };
    auto isLineBlock = [&](size_t start, size_t end) {
        size_t lineStart = text.rfind(L'\n', start);
        lineStart = (lineStart == std::wstring::npos) ? 0 : lineStart + 1;
        size_t lineEnd = text.find(L'\n', end);
        lineEnd = (lineEnd == std::wstring::npos) ? text.size() : lineEnd;
        for (size_t k = lineStart; k < start; ++k) {
            if (!iswspace(text[k])) return false;
        }
        for (size_t k = end; k < lineEnd; ++k) {
            if (!iswspace(text[k])) return false;
        }
        return true;
    };
    auto pushEntry = [&](size_t start, size_t end, MathKind kind, bool isBlock) {
        if (end <= start) return;
        MathEntry e;
        e.rawStart = start;
        e.rawEnd = end;
        e.start = RawTextIndexToRichEditIndex(text, start);
        e.end = RawTextIndexToRichEditIndex(text, end);
        e.line = 1 + static_cast<int>(std::count(text.begin(),
                                                 text.begin() + static_cast<long long>(start),
                                                 L'\n'));
        e.text = text.substr(start, end - start);
        e.kind = kind;
        e.isBlock = isBlock;
        outEntries->push_back(std::move(e));
    };
    auto findMathClose = [&](size_t from, size_t limit, size_t* outLen) -> size_t {
        TagFrame mathFrame;
        mathFrame.isMathBlock = true;
        AddUniqueCloseAlias(&mathFrame.closeAliases, L"math");
        size_t close = std::wstring::npos;
        size_t closeLen = 0;
        if (!FindMatchingCloseTagForFrame(text, from, limit, mathFrame, &close, &closeLen)) {
            if (outLen) *outLen = 0;
            return std::wstring::npos;
        }
        if (outLen) *outLen = closeLen;
        return close;
    };

    size_t i = rangeStart;
    size_t lineIdx = FindLineIndexForPos(lines, i);
    auto syncLine = [&]() {
        while (lineIdx + 1 < lines.size() && i >= lines[lineIdx + 1].start) {
            ++lineIdx;
        }
    };

    while (i < rangeEnd) {
        syncLine();
        if (lineIdx >= lines.size()) break;
        if (lines[lineIdx].isComment) {
            size_t next = (lineIdx + 1 < lines.size()) ? lines[lineIdx + 1].start : text.size();
            i = std::min(rangeEnd, next);
            continue;
        }
        size_t limit = (lineIdx < nextCommentStart.size()) ? nextCommentStart[lineIdx] : text.size();
        limit = std::min(limit, rangeEnd);

        if (i + 2 < limit && IsLiteralEscapeLeadAt(text, i)) {
            i += 3;
            continue;
        }

        if (StartsWithAsciiNoCaseAt(text, i, L"<math>")) {
            size_t start = i;
            size_t closeLen = 0;
            size_t close = findMathClose(i + 6, limit, &closeLen);
            if (close == std::wstring::npos) { i = limit; continue; }
            size_t end = close + closeLen;
            bool isBlock = isLineBlock(start, end) || (text.find(L'\n', start) < end);
            pushEntry(start, end, MathKind::Markup, isBlock);
            i = end;
            continue;
        }
        if (text[i] == L'$' && !isEscaped(i)) {
            bool dbl = (i + 1 < text.size() && i + 1 < limit &&
                        text[i + 1] == L'$' && !isEscaped(i + 1));
            size_t start = i;
            size_t search = i + (dbl ? 2 : 1);
            bool found = false;
            while (search < limit) {
                if (IsLiteralEscapeLeadAt(text, search)) {
                    search += 3;
                    continue;
                }
                if (text[search] == L'$' && !isEscaped(search)) {
                    if (dbl) {
                        if (search + 1 < limit &&
                            text[search + 1] == L'$' && !isEscaped(search + 1)) {
                            size_t end = search + 2;
                            pushEntry(start, end, MathKind::Latex, true);
                            i = end;
                            found = true;
                            break;
                        }
                    } else {
                        size_t end = search + 1;
                        pushEntry(start, end, MathKind::Latex, false);
                        i = end;
                        found = true;
                        break;
                    }
                }
                ++search;
            }
            if (!found) i = limit;
            continue;
        }
        if (text[i] == L'\\' && i + 1 < limit && text[i + 1] == L'[' && !isEscaped(i)) {
            size_t start = i;
            size_t search = i + 2;
            bool found = false;
            while (search + 1 < limit) {
                if (IsLiteralEscapeLeadAt(text, search)) {
                    search += 3;
                    continue;
                }
                if (text[search] == L'\\' && text[search + 1] == L']' && !isEscaped(search)) {
                    size_t end = search + 2;
                    pushEntry(start, end, MathKind::Latex, true);
                    i = end;
                    found = true;
                    break;
                }
                ++search;
            }
            if (!found) i = limit;
            continue;
        }
        if (text[i] == L'\\' && i + 1 < limit && text[i + 1] == L'(' && !isEscaped(i)) {
            size_t start = i;
            size_t search = i + 2;
            bool found = false;
            while (search + 1 < limit) {
                if (IsLiteralEscapeLeadAt(text, search)) {
                    search += 3;
                    continue;
                }
                if (text[search] == L'\\' && text[search + 1] == L')' && !isEscaped(search)) {
                    size_t end = search + 2;
                    pushEntry(start, end, MathKind::Latex, false);
                    i = end;
                    found = true;
                    break;
                }
                ++search;
            }
            if (!found) i = limit;
            continue;
        }
        ++i;
    }
}
} // namespace

struct NoteSyntaxRefreshResult {
    note::NoteDerivedSnapshotIdentity sourceIdentity{};
    note::NoteKernelRefreshKind kind = note::NoteKernelRefreshKind::Unavailable;
    std::optional<note::NoteDirtyGraph> consumedDirtyGraph;
    bool current = false;
};

static NoteSyntaxRefreshResult RefreshNoteSyntaxStage(
    const std::wstring& text,
    ULONGLONG startTick) {
    NoteSyntaxRefreshResult result;
    // RecomputeParsedNoteDocument calls kernel->RefreshDerived() exactly once and returns
    // the result so we can propagate kind and consumedDirtyGraph to the Render/Layout stage.
    // Do NOT call RefreshDerived() separately beforehand - that would be a double call and
    // would cause the consumed dirty graph to be lost from the pending graph mechanism.
    const auto kernelRefresh = RecomputeParsedNoteDocument(text);
    if (kernelRefresh.has_value()) {
        result.kind = kernelRefresh->kind;
        // consumedDirtyGraph is already applied to g_notePendingRenderGraph /
        // g_notePendingLineSpacingGraph by ApplyNoteDirtyGraphAfterSyntaxEdit inside
        // RecomputeParsedNoteDocument. We keep a copy here only for the Unchanged fast-path
        // check in RefreshNoteRenderAndLayoutStage.
        result.consumedDirtyGraph = kernelRefresh->consumed_dirty_graph;
    }
    result.current = CanReadStableParsedNoteDocument();
    if (result.current) result.sourceIdentity = CurrentNoteDocument().source_identity;
    preview_trace::Append(
        L"RecomputeMathFromNote",
        L"after_note_document kind=" + std::to_wstring(static_cast<int>(result.kind)) +
        L" blocks=" + std::to_wstring(CurrentNoteDocument().blocks.size()) +
        L" inlines=" + std::to_wstring(CurrentNoteDocument().inlines.size()) +
        L" styles=" + std::to_wstring(CurrentNoteDocument().style_spans.size()) +
        L" math=" + std::to_wstring(CurrentNoteDocument().math_spans.size()) +
        L" diagnostics=" + std::to_wstring(CurrentNoteDocument().diagnostics.size()) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    if (result.current) {
        g_highlightRanges = note::BuildHighlightRanges(CurrentNoteDocument());
    } else {
        g_highlightRanges.clear();
    }
    return result;
}

static void RefreshNoteRenderAndLayoutStage(
    const std::wstring& text,
    const NoteSyntaxRefreshResult& syntax,
    bool needRenderPlan) {
    using Kind = note::NoteKernelRefreshKind;
    //
    // Decide how to update the render (LineCache) based on what the Kernel reported:
    //
    //   Unchanged  - No text or syntax change; if the snapshot identity already
    //                matches the current text revision, skip RefreshMarkdownRenderCache
    //                entirely (fast path). Any pending stale-line marks are still handled
    //                by UpdateNoteLineSpacing.
    //
    //   Incremental - An edit was applied incrementally. syntax.consumedDirtyGraph
    //                 is passed directly to RefreshMarkdownRenderCache which picks it
    //                 up and does a targeted LineCache rebuild.
    //
    //   Full/Deferred - Full (or deferred) syntax reparse. RefreshMarkdownRenderCache
    //                   detects the inconsistency and does a full LineCache rebuild.
    //
    //   Cleared    - Content kind is PlainText; render state is cleared.
    //
    //   Unavailable - No kernel; syntax is unreliable; clear to avoid stale paint.
    //
    if (needRenderPlan &&
        CurrentNoteContentRoute() == NoteContentRoute::MarkdownMd4c) {
        if (syntax.kind == Kind::Unchanged && HasCurrentLineCache()) {
            // Fast path: the LineCache is already consistent with the current text
            // revision - nothing to rebuild. UpdateNoteLineSpacing + InvalidateRect
            // below will handle any pending visual-dirty regions.
        } else if (syntax.kind == Kind::Cleared ||
                   syntax.kind == Kind::Unavailable ||
                   !syntax.current) {
            // Syntax is unavailable or this is a plain-text clear; wipe the render
            // state so we do not paint stale content from a different note or revision.
            ClearLegacyRenderCache();
        } else {
            // Incremental, Full, Deferred, or Unchanged-with-stale-cache:
            // RefreshMarkdownRenderCache selects incremental or full rebuild
            // as appropriate based on syntax.consumedDirtyGraph and cache state.
            RefreshMarkdownRenderCache(text, syntax.consumedDirtyGraph);
        }
    } else if (needRenderPlan) {
        ClearLegacyRenderCache();
    }
    g_mathDisplayCache.clear();
    g_mathEntries.clear();
    UpdateNoteLineSpacing(syntax.consumedDirtyGraph);
    if (!ConsumeNoteLineSpacingInvalidatedNote()) {
        InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    }
}

static void RefreshNoteAssistStage() {
    UpdateNotePreviewFromEdit(g_hNoteEdit);
    if (g_hBottomNote) {
        if (g_bottomPanePin != BottomPanePin::Math &&
            g_bottomNoteMode != BottomNoteMode::Legacy) {
            InvalidateRect(g_hBottomNote, nullptr, FALSE);
        }
    }
    if (g_hBottomMath) {
        InvalidateRect(g_hBottomMath, nullptr, FALSE);
    }
}

static void RefreshNoteLightweightStage() {
    g_mathDisplayCache.clear();
    g_mathEntries.clear();
    UpdateNotePreviewFromEdit(g_hNoteEdit);
    InvalidateRect(g_hNoteEdit, nullptr, FALSE);
    if (g_hBottomNote) InvalidateRect(g_hBottomNote, nullptr, FALSE);
    if (g_hBottomMath) InvalidateRect(g_hBottomMath, nullptr, FALSE);
}

void RecomputeMathFromNote() {
    const ULONGLONG startTick = preview_trace::TickNow();
    const note::NoteDerivedRefreshPlan refreshPlan =
        note::ResolveNoteDerivedRefreshPlan(note::NoteDerivedRefreshRequest{
            IsNoteRenderActive(),
            g_bottomPanePin == BottomPanePin::Math,
            g_bottomNoteMode != BottomNoteMode::Legacy,
        });
    if (refreshPlan.lightweight()) {
        preview_trace::Append(
            L"RecomputeMathFromNote",
            L"begin lightweight=true stable_math_cache=true");
        RefreshNoteLightweightStage();
        preview_trace::Append(
            L"RecomputeMathFromNote",
            L"end lightweight=true elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return;
    }

    const std::wstring text = GetEditTextForIndexing(g_hNoteEdit);
    preview_trace::Append(
        L"RecomputeMathFromNote",
        L"begin chars=" + std::to_wstring(text.size()) +
        L" stable_math_cache=true");

    const NoteSyntaxRefreshResult syntax = RefreshNoteSyntaxStage(text, startTick);
    RefreshNoteRenderAndLayoutStage(
        text, syntax, refreshPlan.refresh_render_plan);
    if (refreshPlan.refresh_assist) RefreshNoteAssistStage();
    preview_trace::Append(
        L"RecomputeMathFromNote",
        L"end elapsed_ms=" + preview_trace::ElapsedMs(startTick));
}

struct NoteTextReadSnapshot {
    std::wstring targetPath;
    std::wstring text;
    note_snapshot::TextSnapshotSource source = note_snapshot::TextSnapshotSource::None;
    note::SnapshotIdentity identity{};
    std::filesystem::path stagePath;
};

static std::optional<NoteTextReadSnapshot> LoadLatestNoteTextSnapshotForRead(const std::wstring& path) {
    note_snapshot::LatestTextSnapshot snapshot = note_snapshot::LoadLatestTextSnapshot(path);
    if (!snapshot.ok) return std::nullopt;
    NoteTextReadSnapshot result;
    result.targetPath = std::move(snapshot.targetPath);
    result.text = UTF8ToWide(snapshot.bytes);
    result.source = snapshot.source;
    result.identity = snapshot.identity;
    result.stagePath = std::move(snapshot.stagePath);
    return result;
}

static void ApplyStagedNoteRestoreViewState(HWND hEdit,
                                            const file_output::StagedNoteRestoreViewState& restore,
                                            uint64_t loadedContentRevision) {
    if (!hEdit || !IsWindow(hEdit)) return;
    if (restore.contentRevision != 0 && loadedContentRevision != 0 &&
        restore.contentRevision != loadedContentRevision) {
        return;
    }
    const int textLen = std::max(0, GetWindowTextLengthW(hEdit));
    const DWORD selStart = static_cast<DWORD>(
        std::min<uint64_t>(restore.selectionStart, static_cast<uint64_t>(textLen)));
    const DWORD selEnd = static_cast<DWORD>(
        std::min<uint64_t>(restore.selectionEnd, static_cast<uint64_t>(textLen)));
    SendMessageW(hEdit, EM_SETSEL, static_cast<WPARAM>(selStart), static_cast<LPARAM>(selEnd));

    POINT scroll{restore.scrollX, restore.scrollY};
    if (!SendMessageW(hEdit, EM_SETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&scroll))) {
        const int currentLine = static_cast<int>(
            SendMessageW(hEdit, EM_GETFIRSTVISIBLELINE, 0, 0));
        if (restore.firstVisibleLine != currentLine) {
            SendMessageW(hEdit, EM_LINESCROLL, 0, restore.firstVisibleLine - currentLine);
        }
        if (restore.scrollY >= 0) {
            SetScrollPos(hEdit, SB_VERT, restore.scrollY, TRUE);
            SendMessageW(hEdit, WM_VSCROLL, MAKEWPARAM(SB_THUMBPOSITION, restore.scrollY), 0);
        }
        if (restore.scrollX >= 0) {
            SetScrollPos(hEdit, SB_HORZ, restore.scrollX, TRUE);
            SendMessageW(hEdit, WM_HSCROLL, MAKEWPARAM(SB_THUMBPOSITION, restore.scrollX), 0);
        }
    }
}

// A stage that predates this process is a recovery candidate. Stages written
// after startup belong to the current editing session and can be resumed
// without asking the user again.
static const std::filesystem::file_time_type g_noteRecoveryProcessStartTime =
    std::filesystem::file_time_type::clock::now();

static bool IsNoteStageCreatedDuringCurrentProcess(const std::filesystem::path& stagePath) {
    if (stagePath.empty()) return false;
    std::error_code ec;
    const auto writeTime = std::filesystem::last_write_time(stagePath, ec);
    return !ec && writeTime >= g_noteRecoveryProcessStartTime;
}

void LoadNoteFile(HWND hWnd, const std::wstring& path) {
    const ULONGLONG startTick = preview_trace::TickNow();
    preview_trace::Append(L"LoadNoteFile", L"begin path=" + path);
    const bool hasCachedEditForTarget = FindCachedNoteEditWindow(path) != nullptr;
    note_snapshot::TextStorageSnapshot storageSnapshot =
        note_snapshot::LoadTextStorageSnapshot(
            path, note_snapshot::TextSnapshotReadPolicy::DiskAndStage);
    std::string buffer = storageSnapshot.diskBytes;
    bool diskOk = storageSnapshot.diskOk;
    bool selectedStageSnapshot = false;
    std::optional<file_output::StagedNoteRestoreViewState> selectedStageRestoreView;
    preview_trace::Append(
        L"LoadNoteFile",
        L"after_disk_read bytes=" + std::to_wstring(buffer.size()) +
        L" diskOk=" + preview_trace::Bool(diskOk) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));

    // If a staged diff exists (e.g. after a crash), let the user recover it.
    g_noteNeedsIntegrate = false;
    if (storageSnapshot.hasStage && storageSnapshot.stageResolved) {
        if (storageSnapshot.diskOk && storageSnapshot.stageBytes == storageSnapshot.diskBytes) {
            file_output::DiscardRedundantStagedNoteFilesMatchingOriginal(path);
        } else {
            std::string& staged = storageSnapshot.stageBytes;
            const bool stageCreatedDuringCurrentProcess =
                IsNoteStageCreatedDuringCurrentProcess(storageSnapshot.stagePath);
            if (hasCachedEditForTarget || stageCreatedDuringCurrentProcess) {
                buffer.swap(staged);
                selectedStageSnapshot = true;
                g_noteNeedsIntegrate = true;
                diskOk = true;
            } else if (!diskOk) {
                // No prompt: the original file couldn't be opened, so the staged diff is the only recoverable state.
                buffer.swap(staged);
                selectedStageSnapshot = true;
                g_noteNeedsIntegrate = true;
                diskOk = true;
            } else {
                std::wstring msg =
                    L"未統合の差分が見つかりました。\n\n"
                    L"差分ファイル:\n" + storageSnapshot.stagePath.wstring() + L"\n\n"
                    L"[はい] 差分を復元 (編集欄に適用)\n"
                    L"[いいえ] いまは復元しない（差分は保持）";
                SilentDialogOptions options;
                options.title = L"Note recovery";
                options.message = msg;
                options.kind = SoftNoticeKind::Warning;
                options.buttons = SilentDialogButtons::YesNo;
                options.defaultResult = SilentDialogResult::No;
                options.escapeResult = SilentDialogResult::No;
                if (ShowSilentDialog(hWnd, options) == SilentDialogResult::Yes) {
                    buffer.swap(staged);
                    selectedStageSnapshot = true;
                    g_noteNeedsIntegrate = true;
                    diskOk = true;
                }
            }
        }
    } else if (storageSnapshot.hasStage && !storageSnapshot.stageResolved) {
        preview_trace::Append(L"LoadNoteFile", L"stage_resolve_failed");
    }
    if (selectedStageSnapshot) {
        selectedStageRestoreView = storageSnapshot.stageRestoreView;
    }
    preview_trace::Append(
        L"LoadNoteFile",
        L"after_stage_check noteNeedsIntegrate=" + preview_trace::Bool(g_noteNeedsIntegrate) +
        L" diskOk=" + preview_trace::Bool(diskOk) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));

    if (!diskOk) {
        preview_trace::Append(
            L"LoadNoteFile",
            L"abort=disk_open_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        ShowSilentMessageDialog(hWnd, L"Note", GetUiText().errNoteOpen, SoftNoticeKind::Error);
        return;
    }

    std::wstring text = UTF8ToWide(buffer);
    const note::SnapshotIdentity loadedSnapshot = note::BuildSnapshotIdentity(
        storageSnapshot.noteIdentity.note_id,
        selectedStageSnapshot ? storageSnapshot.stageContentRevision : 0,
        selectedStageSnapshot ? storageSnapshot.stagePersistenceRevision
                              : storageSnapshot.diskPersistenceRevision,
        buffer);

    if (path == g_currentNotePath && loadedSnapshot.content_revision < CurrentEditRevision()) {
        preview_trace::Append(
            L"LoadNoteFile",
            L"abort=stale_snapshot loaded_rev=" + std::to_wstring(loadedSnapshot.content_revision) +
            L" current_rev=" + std::to_wstring(CurrentEditRevision()));
        return;
    }

    bool reusedCachedWindow = false;
    HWND targetEdit = PrepareNoteEditWindowForPath(hWnd, path, &reusedCachedWindow);
    if (!targetEdit) {
        preview_trace::Append(
            L"LoadNoteFile",
            L"abort=edit_create_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        ShowSilentMessageDialog(hWnd, L"Note", GetUiText().errNoteOpen, SoftNoticeKind::Error);
        return;
    }
    const bool keepCachedUndo = reusedCachedWindow && GetEditText(targetEdit) == text;
    const note::NoteTransactionToken loadTransaction = BeginSuppressedNoteChange(
        note::NoteChangeOrigin::ProgramLoad, true, loadedSnapshot.note_id);
    ResetNoteInteractionState(targetEdit);
    g_currentNotePath = path;
    if (!keepCachedUndo) {
        ResetCurrentNoteTextCore(loadedSnapshot.note_id,
                                 NormalizeTextForNoteIndexing(text),
                                 loadedSnapshot.persistence_revision,
                                 loadedSnapshot.content_revision);
    }
    {
        struct NoteSwitchRedrawGuard {
            NoteSwitchRedrawGuard() { BeginNoteRenderSwitch(); }
            ~NoteSwitchRedrawGuard() { EndNoteRenderSwitch(); }
        } redrawGuard;
        // Switching notes is not an incremental edit; avoid leaking markup stack/metrics from the previous note.
        ClearLineCache();
        if (!keepCachedUndo) {
            SetWindowTextW(g_hNoteEdit, text.c_str());
            preview_trace::Append(
                L"LoadNoteFile",
                L"after_set_text chars=" + std::to_wstring(text.size()) +
                L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
            ResetNoteUndoBuffer(g_hNoteEdit);
            ForgetNoteUndoHistoryForWindow(g_hNoteEdit);
        } else {
            if (!RestoreNoteUndoHistoryForWindow(g_hNoteEdit)) {
                ResetNoteEditHistorySnapshot(g_hNoteEdit);
            }
            preview_trace::Append(
                L"LoadNoteFile",
                L"after_reuse_cached_edit chars=" + std::to_wstring(text.size()) +
                L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        }
        SendMessageW(g_hNoteEdit, EM_SETMODIFY, FALSE, 0);
        g_noteDirty = false;
        // Richedit can emit EN_CHANGE asynchronously after SetWindowText/EM_SETMODIFY.
        // Keep suppression until the user actually inputs something.
        SetNoteTyping(false);
        file_output::ResetNoteStageSaveTracking(hWnd);
        RecomputeMathFromNote();
        preview_trace::Append(
            L"LoadNoteFile",
            L"after_recompute_math elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        RefreshMainWindowUiState(hWnd);
        preview_trace::Append(
            L"LoadNoteFile",
            L"after_refresh_main_ui elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        UpdateNoteViewMode();
        RestoreNoteViewState(
            g_hNoteEdit, NoteEditCacheKey(path), keepCachedUndo, loadedSnapshot);
        if (selectedStageRestoreView.has_value()) {
            ApplyStagedNoteRestoreViewState(
                g_hNoteEdit, *selectedStageRestoreView, loadedSnapshot.content_revision);
        }
        preview_trace::Append(
            L"LoadNoteFile",
            L"after_update_view_mode elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        SyncLeftPaneSelection();
        preview_trace::Append(
            L"LoadNoteFile",
            L"after_sync_left_pane elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        UpdateSessionLastOpenTargetsAfterOpen();
        preview_trace::Append(
            L"LoadNoteFile",
            L"after_update_session_last_open elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        RefreshCurrentNoteFileSnapshot();
    }
    g_noteTransactions.Commit(loadTransaction);
    preview_trace::Append(
        L"LoadNoteFile",
        L"after_note_switch_guard elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    if (g_bottomPanePin == BottomPanePin::Math && g_hBottomMath) {
        ShowWindow(g_hBottomMath, SW_SHOW);
        RedrawWindow(g_hBottomMath, nullptr, nullptr,
                     RDW_INVALIDATE | RDW_ERASE | RDW_FRAME | RDW_UPDATENOW);
        preview_trace::Append(
            L"LoadNoteFile",
            L"after_bottom_math_redraw elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    }
    if (g_hMainWnd) {
        PostMessageW(g_hMainWnd, kMsgLectureContentOpened, 0, 0);
    }
    preview_trace::Append(
        L"LoadNoteFile",
        L"after_post_opened_message elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    preview_trace::Append(
        L"LoadNoteFile",
        L"end noteNeedsIntegrate=" + preview_trace::Bool(g_noteNeedsIntegrate) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
}

void ClearNoteEditorSilently(HWND hWnd, const std::wstring& nextNotePath) {
    if (g_hNoteEdit && IsWindow(g_hNoteEdit)) {
        CaptureNoteViewState(g_hNoteEdit, NoteEditCacheKey(g_currentNotePath));
        CaptureNoteUndoHistoryForWindow(g_hNoteEdit);
    }
    DestroyInactiveCachedNoteEditWindows();
    const note::NoteTransactionToken clearTransaction = BeginSuppressedNoteChange(
        note::NoteChangeOrigin::ProgramClear,
        true,
        note::ResolveRuntimeNoteIdentityPath(nextNotePath).note_id);
    ResetNoteInteractionState(g_hNoteEdit);
    g_currentNotePath = nextNotePath;
    BeginNoteViewActivation(g_hNoteEdit, NoteEditCacheKey(nextNotePath));
    ResetCurrentNoteTextCore(CurrentActiveNoteViewIdentity().note_id, L"", 0);

    struct NoteSwitchRedrawGuard {
        NoteSwitchRedrawGuard() { BeginNoteRenderSwitch(); }
        ~NoteSwitchRedrawGuard() { EndNoteRenderSwitch(); }
    } redrawGuard;

    ClearLineCache();
    if (g_hNoteEdit) {
        SetWindowTextW(g_hNoteEdit, L"");
        ResetNoteUndoBuffer(g_hNoteEdit);
        SendMessageW(g_hNoteEdit, EM_SETMODIFY, FALSE, 0);
    }
    g_noteDirty = false;
    g_noteNeedsIntegrate = false;
    RefreshCurrentNoteFileSnapshot();
    SetNoteTyping(false);
    file_output::ResetNoteStageSaveTracking(hWnd);
    RecomputeMathFromNote();
    RefreshMainWindowUiState(hWnd);
    UpdateNoteViewMode();
    RestoreNoteViewState(g_hNoteEdit, NoteEditCacheKey(nextNotePath), false);
    SyncLeftPaneSelection();

    if (g_bottomPanePin == BottomPanePin::Math && g_hBottomMath) {
        ShowWindow(g_hBottomMath, SW_SHOW);
        RedrawWindow(g_hBottomMath, nullptr, nullptr,
                     RDW_INVALIDATE | RDW_ERASE | RDW_FRAME | RDW_UPDATENOW);
    }
    g_noteTransactions.Commit(clearTransaction);
}

bool SaveNoteFile(HWND hWnd) {
    return file_output::SaveNoteFile(hWnd);
}

void CommitPendingNoteClickCaret() {
    if (!g_hNoteEdit) return;
    g_notePendingCaretIdx = static_cast<size_t>(-1);
    ClearNoteLinkRenderGrace(g_hNoteEdit);
    InvalidateRect(g_hNoteEdit, nullptr, FALSE);
}

void InsertSnippetIntoNote(const std::wstring& snippet) {
    if (!HasOpenNote()) {
        MaybeShowNoteOpenNotice(g_hNoteEdit ? GetParent(g_hNoteEdit) : g_hMainWnd);
        return;
    }
    ReleaseNoteChangeSuppressionForUserEdit();
    CommitPendingNoteClickCaret();
    DWORD start = 0, end = 0;
    SendMessageW(g_hNoteEdit, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&start),
                 reinterpret_cast<LPARAM>(&end));
    SendMessageW(g_hNoteEdit, EM_SETSEL, start, end);
    {
        DWORD base = std::min(start, end);
        DWORD insertedLen = static_cast<DWORD>(
            std::min<size_t>(NormalizeTextForNoteIndexing(snippet).size(),
                             static_cast<size_t>(std::numeric_limits<DWORD>::max() - base)));
        RegisterExpectedCurrentNoteSelectionReplacement(g_hNoteEdit, snippet,
                                                        base + insertedLen,
                                                        base + insertedLen);
    }
    SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE,
                 reinterpret_cast<LPARAM>(snippet.c_str()));
    if (HWND parent = GetParent(g_hNoteEdit)) {
        PostMessageW(parent, kMsgNoteOverlayUpdate, 0, static_cast<LPARAM>(CurrentEditRevision()));
    }
}

bool InsertSnippetIntoCurrentNoteAt(size_t pos, const std::wstring& snippet) {
    if (!g_hNoteEdit || snippet.empty() || !HasOpenNote()) return false;

    ScopedNoteViewContextBinding viewContextBinding(g_hNoteEdit);
    MaybeReleaseNoteChangeSuppression(g_hNoteEdit);
    const std::wstring textBefore = GetEditTextForIndexing(g_hNoteEdit);
    if (note::LocalNoteKernel* kernel = CurrentNoteKernel();
        kernel && !kernel->text_core().MatchesRaw(textBefore)) {
        // This path is used by automation to make a direct RichEdit mutation.
        // Reconcile a stale kernel before adding a new history entry; otherwise
        // CanUndo may expose an old entry that cannot safely be replayed.
        SynchronizeCurrentNoteTextCore(textBefore);
    }
    ResetNoteEditHistorySnapshot(g_hNoteEdit);
    const size_t maxPos = textBefore.size();
    const DWORD insertPos = static_cast<DWORD>(
        std::min<size_t>(std::min(pos, maxPos), static_cast<size_t>(std::numeric_limits<DWORD>::max())));
    const DWORD insertedLength = static_cast<DWORD>(
        std::min<size_t>(NormalizeTextForNoteIndexing(snippet).size(),
                         static_cast<size_t>(std::numeric_limits<DWORD>::max() - insertPos)));
    RegisterExpectedNoteTextEdit(g_hNoteEdit, insertPos, insertPos, snippet,
                                 insertPos + insertedLength, insertPos + insertedLength);
    SendMessageW(g_hNoteEdit, EM_SETSEL, insertPos, insertPos);
    SendMessageW(g_hNoteEdit, EM_REPLACESEL, TRUE, reinterpret_cast<LPARAM>(snippet.c_str()));
    // When a programmatic edit's EN_CHANGE is suppression-gated, consume the
    // registered edit here. If EN_CHANGE already consumed it, this is a no-op.
    RecordCurrentNoteTextEditForUndo(g_hNoteEdit);
    if (HWND parent = GetParent(g_hNoteEdit)) {
        PostMessageW(parent, kMsgNoteOverlayUpdate, 0, static_cast<LPARAM>(CurrentEditRevision()));
    }
    return true;
}

static std::shared_ptr<const note::WorkspaceNoteIndexSnapshot>
ResolveCurrentNoteWorkspaceIndex() {
    note::LocalNoteKernel* kernel = CurrentNoteKernel();
    if (!kernel || !kernel->valid()) return nullptr;

    note::SnapshotIdentity identity = CaptureCurrentNoteSnapshotIdentity();
    if (kernel->CanReadSemantic()) {
        return note::RuntimeNoteWorkspaceService().ResolveIndexFromKernel(
            identity, g_currentNotePath, *kernel);
    }
    return note::RuntimeNoteWorkspaceService().ResolveIndex(
        identity,
        g_currentNotePath,
        CurrentNoteTextMetadata(),
        kernel->text_core().model().raw,
        CurrentNoteContentRoute() == NoteContentRoute::PlainText
            ? note::NoteContentKind::PlainText
            : note::NoteContentKind::Markdown);
}

static bool CurrentNoteHasLinkTargetExcluding(const std::wstring& linkId,
                                              std::optional<size_t> sourcePos) {
    if (!NoteContentRouteSupportsLinkTargets(CurrentNoteContentRoute())) return false;
    const auto index = ResolveCurrentNoteWorkspaceIndex();
    if (!index) return false;
    return note::FindWorkspaceLinkIdAnchor(
        *index, linkId, sourcePos).has_value();
}

static std::optional<note::SemanticLinkTargetResolution> FindNoteTargetForLinkId(
    const std::wstring& linkId,
    const std::wstring& skipPath,
    const std::wstring& sourcePath,
    std::optional<size_t> sourcePos) {
    if (linkId.empty()) return std::nullopt;
    const std::wstring skipKey = NoteEditCacheKey(skipPath);
    const std::wstring sourceKey = NoteEditCacheKey(sourcePath);
    for (const auto& f : g_noteFiles) {
        if (f.path.empty()) continue;
        const std::wstring candidateKey = NoteEditCacheKey(f.path);
        if (!skipKey.empty() && candidateKey == skipKey) continue;
        if (!NoteContentRouteSupportsLinkTargets(NoteContentRouteForPath(f.path))) continue;
        auto snapshot = LoadLatestNoteTextSnapshotForRead(f.path);
        if (!snapshot) continue;
        std::optional<size_t> localExclude = std::nullopt;
        if (!sourceKey.empty() && candidateKey == sourceKey) {
            localExclude = sourcePos;
        }
        note::NoteMetadata metadata;
        metadata.file_name = std::filesystem::path(snapshot->targetPath).filename().wstring();
        metadata.title = note::DeriveTitleFromFileName(metadata.file_name);
        const auto candidateIndex =
            note::RuntimeNoteWorkspaceService().ResolveIndex(
                snapshot->identity,
                snapshot->targetPath,
                std::move(metadata),
                snapshot->text,
                note::NoteContentKind::Markdown);
        if (!candidateIndex) continue;
        const auto anchorPos = note::FindWorkspaceLinkIdAnchor(
            *candidateIndex, linkId, localExclude);
        if (anchorPos) {
            if (note_snapshot::IsStageSource(snapshot->source)) {
                preview_trace::Append(L"FindNoteTargetForLinkId",
                                      L"found_in_stage path=" + snapshot->targetPath);
            }
            note::SemanticLinkTargetResolution target;
            target.target_path = snapshot->targetPath.empty() ? f.path : snapshot->targetPath;
            target.snapshot_identity = snapshot->identity;
            target.anchor_position = *anchorPos;
            return target;
        }
    }
    return std::nullopt;
}

static bool CurrentNoteContentMatchesLinkTarget(
    const note::SemanticLinkTargetResolution& target) {
    if (!target.valid() || !g_hNoteEdit) return false;
    note::SnapshotIdentity currentIdentity = CaptureCurrentNoteSnapshotIdentity();
    if (!currentIdentity.note_id.valid()) return false;
    const std::string bytes = WideToUTF8(GetEditText(g_hNoteEdit));
    currentIdentity = note::BuildSnapshotIdentity(
        currentIdentity.note_id,
        currentIdentity.content_revision,
        currentIdentity.persistence_revision,
        bytes);
    return note::SemanticLinkTargetMatchesSnapshot(target, currentIdentity);
}

static bool FindLinkAnnotation(const std::vector<Annotation>& annots,
                               const std::wstring& linkId,
                               Annotation* out) {
    if (linkId.empty()) return false;
    for (const auto& ann : annots) {
        if (ann.type != Annotation::Type::LinkMarker) continue;
        if (ann.linkId != linkId) continue;
        if (out) *out = ann;
        return true;
    }
    return false;
}

static bool FindPdfLinkHit(const std::wstring& linkId, std::wstring& outPdfPath, Annotation& outAnn) {
    if (linkId.empty()) return false;
    for (const auto& f : g_pdfFiles) {
        if (f.path.empty() || !f.isPdf) continue;
        if (!CurrentLogicalPdfPath().empty() && f.path == CurrentLogicalPdfPath()) continue;
        std::wstring err;
        std::vector<Annotation> annots;
        const auto staged = file_output::FindLatestStagedClropPathForPdf(f.path);
        bool loaded = false;
        if (!staged.empty()) {
            loaded = file_output::LoadResolvedStagedAnnotations(f.path, staged, &annots, &err);
            if (!loaded) {
                annots.clear();
            }
        }
        if (!loaded) {
            std::wstring clropPath = clrop_bridge::ClropPathForPdf(f.path);
            if (clropPath.empty()) continue;
            if (!PathExistsWin32(std::filesystem::path(clropPath))) continue;
            bool mismatch = false;
            loaded = clrop_bridge::LoadAnnotations(clropPath, f.path, annots, mismatch, nullptr, err,
                                                   clrop_bridge::LoadAnnotationsValidation::None);
            if (!loaded) {
                continue;
            }
        }
        if (FindLinkAnnotation(annots, linkId, &outAnn)) {
            outPdfPath = f.path;
            return true;
        }
    }
    return false;
}

bool JumpToNoteLinkId(const std::wstring& linkId,
                      const std::wstring& notePath,
                      bool showNotFoundNotice,
                      const std::wstring& sourceNotePath,
                      std::optional<size_t> sourcePos) {
    HWND owner = g_hNoteEdit ? GetParent(g_hNoteEdit) : nullptr;
    if (!owner && g_hPdfView) owner = GetParent(g_hPdfView);
    if (!owner) owner = g_hMainWnd;
    auto tryJumpCurrent = [&](std::optional<size_t> excludePos,
                              std::optional<size_t> resolvedAnchorPos) -> bool {
        if (!NoteContentRouteSupportsLinkTargets(CurrentNoteContentRoute())) return false;
        if (!g_hNoteEdit) return false;
        const auto index = ResolveCurrentNoteWorkspaceIndex();
        if (!index) return false;
        auto pos = note::FindWorkspaceLinkIdAnchor(
            *index, linkId, excludePos);
        if (!pos) return false;
        if (resolvedAnchorPos.has_value() && *resolvedAnchorPos != *pos) {
            preview_trace::Append(
                L"JumpToNoteLinkId",
                L"anchor_remapped from=" + std::to_wstring(*resolvedAnchorPos) +
                    L" to=" + std::to_wstring(*pos));
        }
        size_t idx = *pos;

        // Calculate target line and current scroll position
        LRESULT targetLine = SendMessageW(g_hNoteEdit, EM_LINEFROMCHAR, static_cast<WPARAM>(idx), 0);
        LRESULT firstVisible = SendMessageW(g_hNoteEdit, EM_GETFIRSTVISIBLELINE, 0, 0);

        // Estimate visible line count to place target slightly above middle (e.g. 30% from top)
        RECT rc;
        GetClientRect(g_hNoteEdit, &rc);
        HDC hdc = GetDC(g_hNoteEdit);
        HFONT hFont = (HFONT)SendMessageW(g_hNoteEdit, WM_GETFONT, 0, 0);
        if (!hFont) hFont = (HFONT)GetStockObject(DEFAULT_GUI_FONT);
        HGDIOBJ hOld = SelectObject(hdc, hFont);
        TEXTMETRIC tm;
        GetTextMetrics(hdc, &tm);
        SelectObject(hdc, hOld);
        ReleaseDC(g_hNoteEdit, hdc);
        
        int lineHeight = tm.tmHeight + tm.tmExternalLeading;
        if (lineHeight <= 0) lineHeight = 16;
        int visibleCount = (rc.bottom - rc.top) / lineHeight;
        if (visibleCount <= 0) visibleCount = 1;

        int offsetByLines = visibleCount * 30 / 100;
        LRESULT scrollNeeded = (targetLine - offsetByLines) - firstVisible;

        // Scroll to target without moving caret or focus
        SendMessageW(g_hNoteEdit, EM_LINESCROLL, 0, scrollNeeded);
        return true;
    };

    auto excludeForCurrent = [&]() -> std::optional<size_t> {
        if (sourceNotePath.empty() || g_currentNotePath.empty()) return std::nullopt;
        if (NoteEditCacheKey(sourceNotePath) != NoteEditCacheKey(g_currentNotePath)) {
            return std::nullopt;
        }
        return sourcePos;
    };

    if (!notePath.empty() &&
        NoteEditCacheKey(notePath) != NoteEditCacheKey(g_currentNotePath)) {
        if (owner) {
            if (!file_output::SaveNoteIfDirty(owner)) return false;
            LoadNoteFile(owner, notePath);
        }
        std::optional<size_t> exclude =
            (NoteEditCacheKey(notePath) == NoteEditCacheKey(sourceNotePath))
            ? sourcePos
            : std::nullopt;
        if (tryJumpCurrent(exclude, std::nullopt)) return true;
    }

    if (tryJumpCurrent(excludeForCurrent(), std::nullopt)) return true;

    if (owner) {
        auto found = FindNoteTargetForLinkId(
            linkId, g_currentNotePath, sourceNotePath, sourcePos);
        if (found) {
            if (!file_output::SaveNoteIfDirty(owner)) return false;
            if (NoteEditCacheKey(found->target_path) != NoteEditCacheKey(g_currentNotePath)) {
                LoadNoteFile(owner, found->target_path);
            }
            if (!CurrentNoteContentMatchesLinkTarget(*found)) {
                preview_trace::Append(
                    L"JumpToNoteLinkId",
                    L"target_snapshot_changed path=" + found->target_path);
                return false;
            }
            std::optional<size_t> exclude =
                (NoteEditCacheKey(found->target_path) == NoteEditCacheKey(sourceNotePath))
                ? sourcePos
                : std::nullopt;
            if (tryJumpCurrent(exclude, found->anchor_position)) return true;
        }
    }

    if (showNotFoundNotice && owner) {
        ShowSoftNotice(owner, IsEnglishUi() ? L"Link target not found." : L"リンク先が見つかりませんでした。");
    }
    return false;
}

bool CommitNoteRenderStateBeforePaintIfNeeded(HWND hWnd) {
    if (!hWnd || !g_noteRenderEnabled || g_noteRawOnly) return false;
    if (IsNoteImeComposing() || IsImeComposingOnEditWindow(hWnd)) return false;
    
    int currentLen = GetWindowTextLengthW(hWnd);
    bool isStale = IsNoteTyping();
    if (!isStale && currentLen >= 0) {
        isStale = (static_cast<size_t>(currentLen) != g_lastParsedMarkupLength);
    }
    
    bool staleLineCountChanged = false;
    if (isStale) {
        std::wstring currentTextForStale = GetEditTextForIndexing(hWnd);
        staleLineCountChanged = (SplitLines(currentTextForStale).size() != g_lineCache.size());
    }
    const bool derivedFrameCommitRequired = RequiresImmediateNoteDerivedFrameCommit();
    
    const bool lineCacheCurrent = HasCurrentLineCache();
    const note::NotePresentationFrameAction frameAction =
        note::ResolveNotePresentationFrameAction(note::NotePresentationFrameState{
            IsNoteRenderActive(),
            !g_lineCache.empty(),
            lineCacheCurrent,
            isStale,
            staleLineCountChanged || derivedFrameCommitRequired,
            IsNoteImeComposing() || IsImeComposingOnEditWindow(hWnd),
        });
        
    if (frameAction == note::NotePresentationFrameAction::CommitBeforePaint) {
        // Synchronous commit to prevent raw text flicker.
        RecomputeMathFromNote();
        return true;
    }
    return false;
}

static void DrawHighlightOverlay(HWND hWnd, HDC hdc) {
    if (!hdc || !hWnd) return;
    if (!g_noteRenderEnabled || g_noteRawOnly) return;
    
    // While delayed reparse is pending, avoid drawing stale rendered markup over the raw edit text.
    // Length mismatches catch inserts/deletes, while the typing flag also covers same-length edits
    // (e.g. replacing one character with another) that would otherwise keep the old overlay visible.
    int currentLen = GetWindowTextLengthW(hWnd);
    bool isStale = IsNoteTyping();
    if (!isStale && currentLen >= 0) {
        isStale = (static_cast<size_t>(currentLen) != g_lastParsedMarkupLength);
    }

    // Compare against logical lines in the current text, not EM_GETLINECOUNT.
    // RichEdit's line count includes soft wraps, while g_lineCache tracks hard lines only.
    // Using display-line count here can incorrectly drop overlay rendering on unrelated lines.
    std::wstring currentTextForStale;
    bool haveCurrentTextForStale = false;
    bool staleLineCountChanged = false;
    if (isStale) {
        currentTextForStale = GetEditTextForIndexing(hWnd);
        haveCurrentTextForStale = true;
        staleLineCountChanged = (SplitLines(currentTextForStale).size() != g_lineCache.size());
    }
    const bool derivedFrameCommitRequired = RequiresImmediateNoteDerivedFrameCommit();
    const bool lineCacheCurrent = HasCurrentLineCache();
    const note::NotePresentationFrameAction frameAction =
        note::ResolveNotePresentationFrameAction(note::NotePresentationFrameState{
            IsNoteRenderActive(),
            !g_lineCache.empty(),
            lineCacheCurrent,
            isStale,
            staleLineCountChanged || derivedFrameCommitRequired,
            IsNoteImeComposing() || IsImeComposingOnEditWindow(hWnd),
        });
    if (frameAction == note::NotePresentationFrameAction::RawFallback ||
        frameAction == note::NotePresentationFrameAction::CommitBeforePaint) {
        return;
    }

    RECT rc{};
    GetClientRect(hWnd, &rc);
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    bool requireExactRevision = (frameAction != note::NotePresentationFrameAction::ReuseCommittedLayout);
    if (!NoteLayoutFrameMatchesRenderSnapshot(layoutFrame, requireExactRevision)) return;
    rc = layoutFrame.client;
    int clientH = layoutFrame.clientHeightPx;
    int clientW = layoutFrame.clientWidthPx;
    if (clientW <= 0 || clientH <= 0) return;

    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return;

    int baseLineHeight = fonts.baseMetrics.tmHeight;
    if (baseLineHeight <= 0) baseLineHeight = 1;
    int baseAscent = fonts.baseAscent;
    COLORREF baseText = g_noteFgColor;
    COLORREF baseBack = g_noteBgColor;
    int spaceW = fonts.spaceWidth;
    if (spaceW <= 0) spaceW = fonts.baseMetrics.tmAveCharWidth;
    if (spaceW <= 0) spaceW = 1;

    int oldBkMode = SetBkMode(hdc, TRANSPARENT);

    DWORD selStart = 0, selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL, reinterpret_cast<WPARAM>(&selStart), reinterpret_cast<LPARAM>(&selEnd));
    bool hasSelection = (selStart != selEnd);

    size_t normalSelStart = 0;
    size_t normalSelEnd = 0;
    bool showNormalVisualSelection = false;

    if (g_noteVimModeEnabled && g_noteNormalMode && g_noteNormalVisualMode) {
        showNormalVisualSelection = true;
        auto range = NoteNormalSelectionRange();
        normalSelStart = range.first;
        normalSelEnd = range.second;
    } else if (hasSelection) {
        showNormalVisualSelection = true;
        normalSelStart = std::min(static_cast<size_t>(selStart), static_cast<size_t>(selEnd));
        normalSelEnd = std::max(static_cast<size_t>(selStart), static_cast<size_t>(selEnd));
    }

    if (showNormalVisualSelection && normalSelEnd <= normalSelStart) {
        showNormalVisualSelection = false;
    }
    bool showSearchHit = g_noteSearchHitActive;
    size_t searchHitStart = g_noteSearchHitStart;
    size_t searchHitEnd = g_noteSearchHitEnd;
    if (showSearchHit && searchHitEnd <= searchHitStart) {
        showSearchHit = false;
    }
    const bool noteNormalModeActive = (g_noteVimModeEnabled && g_noteNormalMode);
    const MathEntry* caretMath = nullptr;
    if (g_noteHasFocus && !hasSelection && !noteNormalModeActive) {
        size_t caretPos = static_cast<size_t>(selStart);
        for (const auto& entry : g_mathEntries) {
            if (caretPos >= entry.start && caretPos < entry.end) {
                caretMath = &entry;
                break;
            }
        }
    }
    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    const bool renderActive = layoutFrame.renderActive;
    if (renderActive) {
        logicalStarts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    }
    int lineCount = renderActive
        ? std::max<int>(1, static_cast<int>(logicalStarts.size()))
        : NoteLineCount();
    if (lineCount <= 0) {
        return;
    }
    const bool showVimCaretLineRawInNote =
        renderActive && noteNormalModeActive && !g_noteNormalVisualMode && g_noteVimCaretLineRawTextVisible;
    const size_t caretLineRawIndex = showVimCaretLineRawInNote
        ? ClampNoteRawIndex(static_cast<size_t>(g_noteNormalCaret))
        : static_cast<size_t>(selStart);

    int caretLine = renderActive
                        ? FindLogicalLineForRaw(logicalStarts, caretLineRawIndex)
                        : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, selStart, 0));
    int selStartLine = caretLine;
    int selEndLine = caretLine;
    if (hasSelection) {
        DWORD endPos = (selEnd > selStart) ? (selEnd - 1) : selEnd;
        selStartLine = renderActive
                           ? FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(selStart))
                           : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, selStart, 0));
        selEndLine = renderActive
                         ? FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(endPos))
                         : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, endPos, 0));
        if (selEndLine < selStartLine) std::swap(selStartLine, selEndLine);
    }

    int firstVisible = 0;
    int lastVisible = std::max(0, lineCount - 1);
    if (renderActive) {
        auto queryBand = [&](int line, int* top, int* bottom) -> bool {
            return QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line,
                                                  baseLineHeight, top, bottom,
                                                  nullptr, nullptr, nullptr, nullptr);
        };
        const int overscan = std::max(baseLineHeight * 6, ScaleY(hWnd, 96));
        const int visibleTop = rc.top - overscan;
        const int visibleBottom = rc.bottom + overscan;
        bool haveBandRange = false;
        bool bandSearchOk = true;
        int lo = 0;
        int hi = lineCount;
        while (lo < hi) {
            int mid = lo + (hi - lo) / 2;
            int bottom = 0;
            if (!queryBand(mid, nullptr, &bottom)) {
                bandSearchOk = false;
                break;
            }
            if (bottom <= visibleTop) {
                lo = mid + 1;
            } else {
                hi = mid;
            }
        }
        if (bandSearchOk) {
            firstVisible = std::clamp(lo, 0, std::max(0, lineCount - 1));
            lo = firstVisible;
            hi = lineCount;
            while (lo < hi) {
                int mid = lo + (hi - lo) / 2;
                int top = 0;
                if (!queryBand(mid, &top, nullptr)) {
                    bandSearchOk = false;
                    break;
                }
                if (top < visibleBottom) {
                    lo = mid + 1;
                } else {
                    hi = mid;
                }
            }
            if (bandSearchOk) {
                lastVisible = std::clamp(std::max(firstVisible, lo - 1),
                                         0, std::max(0, lineCount - 1));
                haveBandRange = true;
            }
        }
        if (!haveBandRange) {
            auto lineFromPoint = [&](int y) -> int {
                if (IsRichEditControl(hWnd)) {
                    POINTL pt{ 0, y };
                    LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, reinterpret_cast<LPARAM>(&pt));
                    if (res >= 0) {
                        return std::clamp(FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(res)),
                                          0, std::max(0, lineCount - 1));
                    }
                } else {
                    LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, MAKELPARAM(0, y));
                    if (res != -1) {
                        return std::clamp(FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(LOWORD(res))),
                                          0, std::max(0, lineCount - 1));
                    }
                }
                return 0;
            };
            auto correctLineByBand = [&](int candidate, int y) -> int {
                candidate = std::clamp(candidate, 0, std::max(0, lineCount - 1));
                for (int guard = 0; guard < lineCount; ++guard) {
                    int top = 0;
                    int bottom = 0;
                    if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, candidate,
                                                        baseLineHeight, &top, &bottom,
                                                        nullptr, nullptr, nullptr, nullptr)) {
                        break;
                    }
                    if (y < top && candidate > 0) {
                        --candidate;
                        continue;
                    }
                    if (y >= bottom && candidate + 1 < lineCount) {
                        ++candidate;
                        continue;
                    }
                    break;
                }
                return candidate;
            };
            firstVisible = correctLineByBand(lineFromPoint(0), 0);
            const int bottomY = std::max(0, clientH - 1);
            lastVisible = std::max(firstVisible, correctLineByBand(lineFromPoint(bottomY), bottomY));
            firstVisible = std::max(0, firstVisible - 6);
            lastVisible = std::min(lineCount - 1, lastVisible + 6);
        }
    } else {
        firstVisible = static_cast<int>(SendMessageW(hWnd, EM_GETFIRSTVISIBLELINE, 0, 0));
        if (renderActive) {
            size_t firstVisibleChar = static_cast<size_t>(SendMessageW(hWnd, EM_LINEINDEX, firstVisible, 0));
            if (!logicalStarts.empty()) {
                auto it = std::upper_bound(logicalStarts.begin(), logicalStarts.end(), firstVisibleChar);
                firstVisible = static_cast<int>(std::distance(logicalStarts.begin(), it)) - 1;
                if (firstVisible < 0) firstVisible = 0;
            }
            
            int visualLastVisible = firstVisible + clientH / baseLineHeight + 4; // Add buffer
            size_t lastVisibleChar = static_cast<size_t>(SendMessageW(hWnd, EM_LINEINDEX, visualLastVisible, 0));
            if (lastVisibleChar > 0 && !logicalStarts.empty()) {
                auto it = std::upper_bound(logicalStarts.begin(), logicalStarts.end(), lastVisibleChar);
                lastVisible = static_cast<int>(std::distance(logicalStarts.begin(), it));
            } else {
                lastVisible = lineCount - 1;
            }
            lastVisible = std::min(lineCount - 1, lastVisible);
        } else {
            if (lineCount <= 0) lineCount = 1;
            int visibleLines = clientH / baseLineHeight + 2;
            lastVisible = std::min(lineCount - 1, firstVisible + visibleLines);
        }
    }
    int maxLine = std::min<int>(static_cast<int>(g_lineCache.size()) - 1, lineCount - 1);

    auto isRawLine = [&](int line) -> bool {
        return IsNoteLineRawHelper(hWnd, line);
    };
    auto fillSolidRect = [&](const RECT& r, COLORREF col) {
        HBRUSH br = CreateSolidBrush(col);
        FillRect(hdc, &r, br);
        DeleteObject(br);
    };
    auto frameRect = [&](const RECT& r, COLORREF col) {
        HBRUSH br = CreateSolidBrush(col);
        FrameRect(hdc, &r, br);
        DeleteObject(br);
    };
    auto drawLine = [&](int x1, int y, int x2, COLORREF col) {
        if (x2 < x1) std::swap(x1, x2);
        HPEN pen = CreatePen(PS_SOLID, 1, col);
        HGDIOBJ oldPen = SelectObject(hdc, pen);
        MoveToEx(hdc, x1, y, nullptr);
        LineTo(hdc, x2, y);
        SelectObject(hdc, oldPen);
        DeleteObject(pen);
    };
    auto fillRoundedRect = [&](RECT r, COLORREF col, int radiusPx) {
        if (r.right <= r.left || r.bottom <= r.top) return;
        radiusPx = std::max(2, radiusPx);
        HBRUSH brush = CreateSolidBrush(col);
        HPEN pen = CreatePen(PS_NULL, 0, col);
        if (!brush || !pen) {
            if (brush) DeleteObject(brush);
            if (pen) DeleteObject(pen);
            fillSolidRect(r, col);
            return;
        }
        HGDIOBJ oldBrush = SelectObject(hdc, brush);
        HGDIOBJ oldPen = SelectObject(hdc, pen);
        RoundRect(hdc, r.left, r.top, r.right, r.bottom, radiusPx, radiusPx);
        SelectObject(hdc, oldPen);
        SelectObject(hdc, oldBrush);
        DeleteObject(pen);
        DeleteObject(brush);
    };
    auto strokeRoundedRect = [&](RECT r, COLORREF col, int radiusPx) {
        if (r.right <= r.left || r.bottom <= r.top) return;
        radiusPx = std::max(2, radiusPx);
        HPEN pen = CreatePen(PS_SOLID, 1, col);
        if (!pen) {
            if (pen) DeleteObject(pen);
            frameRect(r, col);
            return;
        }
        HGDIOBJ oldBrush = SelectObject(hdc, GetStockObject(HOLLOW_BRUSH));
        HGDIOBJ oldPen = SelectObject(hdc, pen);
        RoundRect(hdc, r.left, r.top, r.right, r.bottom, radiusPx, radiusPx);
        SelectObject(hdc, oldPen);
        SelectObject(hdc, oldBrush);
        DeleteObject(pen);
    };
    auto isStaleEditingLine = [&](int line) -> bool {
        if (noteNormalModeActive) return false;
        if (!isStale) return false;
        if (staleLineCountChanged) return true;
        if (renderActive) {
            if (IsNoteRenderStaleLine(line)) return true;
            size_t lineStart = 0;
            if (line < static_cast<int>(logicalStarts.size())) {
                lineStart = logicalStarts[line];
            }
            size_t lineEnd = lineStart + ((line >= 0 && line < static_cast<int>(g_lineCache.size())) ? g_lineCache[line].rawLine.size() : 0);
            return hasSelection ? (static_cast<size_t>(selEnd) > lineStart && static_cast<size_t>(selStart) < lineEnd)
                                : (static_cast<size_t>(selStart) >= lineStart && static_cast<size_t>(selStart) <= lineEnd);
        } else {
            return hasSelection ? (line >= selStartLine && line <= selEndLine)
                                : (line == caretLine);
        }
    };
    auto currentRawLineText = [&](int line, size_t lineStart, size_t lineEnd) -> std::wstring {
        if (haveCurrentTextForStale) {
            if (lineStart <= currentTextForStale.size() && lineEnd >= lineStart) {
                lineEnd = std::min(lineEnd, currentTextForStale.size());
                return currentTextForStale.substr(lineStart, lineEnd - lineStart);
            }
        }
        if (line >= 0 && line < static_cast<int>(g_lineCache.size())) {
            return g_lineCache[static_cast<size_t>(line)].rawLine;
        }
        return L"";
    };
    auto drawStaleRawLine = [&](int line, int x, int y, size_t lineStart, size_t lineEnd) {
        std::wstring raw = currentRawLineText(line, lineStart, lineEnd);
        if (raw.empty()) return;
        
        size_t sStart = std::min(static_cast<size_t>(selStart), static_cast<size_t>(selEnd));
        size_t sEnd = std::max(static_cast<size_t>(selStart), static_cast<size_t>(selEnd));
        
        if (hasSelection && sEnd > lineStart && sStart < lineEnd) {
            size_t rawLen = raw.size();
            size_t hlStart = std::max(sStart, lineStart);
            size_t hlEnd = std::min(sEnd, lineEnd);
            
            size_t beforeLen = std::min(hlStart - lineStart, rawLen);
            size_t selLen = std::min(hlEnd - hlStart, rawLen - beforeLen);
            size_t afterLen = rawLen - beforeLen - selLen;
            
            int currX = x;
            int oldMode = SetBkMode(hdc, TRANSPARENT);
            COLORREF oldText = GetTextColor(hdc);
            
            if (beforeLen > 0) {
                SetTextColor(hdc, baseText);
                std::wstring sub = raw.substr(0, beforeLen);
                DrawStyledSegmentText(hdc, fonts, currX, y, sub, false, false, 0, nullptr);
                currX += MeasureStyledSegmentTextWidth(hdc, fonts, sub, false, false, 0, nullptr, nullptr);
            }
            
            if (selLen > 0) {
                std::wstring sub = raw.substr(beforeLen, selLen);
                int w = MeasureStyledSegmentTextWidth(hdc, fonts, sub, false, false, 0, nullptr, nullptr);
                RECT selRc{ currX, y, currX + w, y + baseLineHeight };
                fillSolidRect(selRc, g_theme.selectionBg);
                
                SetTextColor(hdc, g_theme.selectionText);
                DrawStyledSegmentText(hdc, fonts, currX, y, sub, false, false, 0, nullptr);
                currX += w;
            }
            
            if (afterLen > 0) {
                SetTextColor(hdc, baseText);
                DrawStyledSegmentText(hdc, fonts, currX, y, raw.substr(beforeLen + selLen, afterLen), false, false, 0, nullptr);
            }
            SetBkMode(hdc, oldMode);
            SetTextColor(hdc, oldText);
        } else {
            COLORREF oldText = SetTextColor(hdc, baseText);
            int oldMode = SetBkMode(hdc, TRANSPARENT);
            DrawStyledSegmentText(hdc, fonts, x, y, raw, false, false, 0, nullptr);
            SetBkMode(hdc, oldMode);
            SetTextColor(hdc, oldText);
        }
    };
    bool suppressRawLineOverlay = false;
    if (!g_noteLastClickLinkId.empty()) {
        auto hitId = LinkIdAtCharIndex(hWnd, static_cast<size_t>(selStart));
        if (hitId && *hitId == g_noteLastClickLinkId) {
            suppressRawLineOverlay = NoteLinkRenderGraceRemainingMs() > 0;
        }
    }
    if (renderActive) {
        // [REASON FOR CHANGE]
        // 以前は、IME入力中のみクリッピングを除外していました：
        // if (IsNoteImeComposing() && caretLine >= 0 && caretLine < lineCount) {
        //
        // しかし、PDF-Note独自の生テキスト描画処理 (drawStaleRawLine) には自動折り返し(Word Wrap)
        // の機能が実装されていないため、長い行が生テキスト表示されると画面外に突き抜けてしまいます。
        // IME入力中は、このクリッピング除外と drawStaleRawLine のスキップによって、
        // 「自動折り返しが効くWindows標準のRichEditの描画」がそのまま画面に見えていました。
        //
        // キャレットがある行（生テキスト表示すべき行）が常に正しく折り返されるようにするため、
        // IME入力中に限らず「生テキストであるべき時」は常にこのネイティブテキストへの
        // フォールバック（透過）処理を適用するように変更しています。
        for (int rawL = std::max(0, firstVisible - 2); rawL <= std::min(lineCount - 1, lastVisible + 2); ++rawL) {
            if (IsNoteLineRawHelper(hWnd, rawL) && !suppressRawLineOverlay) {
            int imeY = 0;
            int imeBottom = 0;
            if (QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, rawL, baseLineHeight,
                                               &imeY, &imeBottom, nullptr, nullptr, nullptr, nullptr)) {
                if (!logicalStarts.empty() && rawL == static_cast<int>(logicalStarts.size() - 1)) {
                    imeBottom = std::max<int>(imeBottom, static_cast<int>(rc.bottom));
                }
                ExcludeClipRect(hdc, rc.left, imeY, rc.right, imeBottom);
            }
        }
        }
        fillSolidRect(rc, baseBack);
    }

    for (int line = firstVisible; line <= lastVisible && line < lineCount; ++line) {
        if (line < 0) continue;
        bool staleEditing = isStaleEditingLine(line);
        const bool rawLine = isRawLine(line) && !suppressRawLineOverlay;
        if (!staleEditing && !rawLine) {
            if (line > maxLine) break;
            if (line >= static_cast<int>(g_lineCache.size())) break;
        }

        size_t lineStart = 0;
        size_t lineEnd = 0;
        POINT linePos{};
        int lineY = 0;
        int lineHeight = baseLineHeight;
        if (renderActive) {
            int lineBottom = 0;
            if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line, baseLineHeight,
                                                &lineY, &lineBottom, &lineStart, &lineEnd, nullptr, &linePos)) {
                continue;
            }
            lineHeight = std::max(1, lineBottom - lineY);
        } else {
            LRESULT lineIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineIdxRes < 0) continue;
            lineStart = static_cast<size_t>(lineIdxRes);
            LRESULT lineLenRes = SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineIdxRes), 0);
            lineEnd = lineStart + static_cast<size_t>(std::max<LRESULT>(0, lineLenRes));
            if (!GetCharPos(hWnd, lineStart, &linePos)) continue;
            lineY = linePos.y;
            if (line + 1 < lineCount) {
                LRESULT nextIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
                if (nextIdxRes >= 0) {
                    POINT nextPos{};
                    if (GetCharPos(hWnd, static_cast<size_t>(nextIdxRes), &nextPos) && nextPos.y > lineY) {
                        lineHeight = nextPos.y - lineY;
                    }
                }
            }
        }
        int lineBottom = lineY + lineHeight;
        if (lineBottom <= lineY) lineBottom = lineY + baseLineHeight;
        if (line == lastVisible || line == maxLine) {
            lineBottom = std::max<int>(lineBottom, static_cast<int>(rc.bottom));
        }
        RECT lineRc{ rc.left, lineY, rc.right, lineBottom };
        fillSolidRect(lineRc, baseBack);
        if (staleEditing || rawLine) {
            // [REASON FOR CHANGE]
            // 以前は、IME入力中のみ独自描画をスキップしていました：
            // if (renderActive && IsNoteImeComposing() && line == caretLine) { continue; }
            //
            // 折り返されない drawStaleRawLine による描画を防ぎ、背面のRichEditの
            // 折り返しテキストを表示させるため、キャレット行の生テキスト表示時は常にスキップします。
            if (renderActive && rawLine) {
                continue;
            }
            int lineX = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x);
            drawStaleRawLine(line, lineX, lineY, lineStart, lineEnd);
            continue;
        }
    }

    for (int line = firstVisible; line <= lastVisible && line <= maxLine; ++line) {
        if (line < 0) continue;
        if (line >= static_cast<int>(g_lineCache.size())) break;
        
        // If cache is stale (typing), skip rendering the overlay for the line(s) being edited.
        // This prevents drawing old/wrong text over the new raw text.
        // Other lines remain highlighted.
        if (isStaleEditingLine(line)) continue;
        size_t lineStart = 0;
        size_t lineEnd = 0;
        POINT linePos{};
        int lineY = 0;
        int lineHeight = baseLineHeight;
        if (renderActive) {
            int lineBottom = 0;
            if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line, baseLineHeight,
                                                &lineY, &lineBottom, &lineStart, &lineEnd, nullptr, &linePos)) {
                continue;
            }
            lineHeight = std::max(1, lineBottom - lineY);
        } else {
            LRESULT lineIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineIdxRes < 0) continue;
            lineStart = static_cast<size_t>(lineIdxRes);
            LRESULT lineLenRes = SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineIdxRes), 0);
            size_t lineLen = (lineLenRes > 0) ? static_cast<size_t>(lineLenRes) : 0;
            lineEnd = lineStart + lineLen;
            if (!GetCharPos(hWnd, lineStart, &linePos)) continue;
            lineY = linePos.y;
            if (line + 1 < lineCount) {
                LRESULT nextIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
                if (nextIdxRes >= 0) {
                    POINT nextPos{};
                    if (GetCharPos(hWnd, static_cast<size_t>(nextIdxRes), &nextPos)) {
                        if (nextPos.y > lineY) {
                            lineHeight = nextPos.y - lineY;
                        }
                    }
                }
            }
        }
        POINT nativeLinePos = linePos;
        if (renderActive) {
            POINT queriedNativeLinePos{};
            if (GetCharPos(hWnd, lineStart, &queriedNativeLinePos)) {
                nativeLinePos = queriedNativeLinePos;
            }
        }
        int lineX = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x);
        int lineBottom = lineY + lineHeight;
        if (lineBottom <= lineY) lineBottom = lineY + baseLineHeight;
        const int linePaintHeight = std::max<int>(1, lineBottom - lineY);
        int fillBottom = lineBottom;
        if (line == lastVisible || line == maxLine) {
            fillBottom = std::max<int>(fillBottom, static_cast<int>(rc.bottom));
        }
        const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
        const NoteListMarkerInfo listMarker = cache.isCodeBlockLine ? NoteListMarkerInfo{} : DetectNoteListMarkerInfo(cache);
        int linePermille = ResolveLineHeightPermille(cache);
        int topPercent = std::clamp(g_config.noteMathMarginTopPercent, 5, 95);
        if (const note::NoteLayoutLineMetrics* metrics =
                FindAppliedNoteLayoutLineMetrics(line)) {
            linePermille = metrics->line_height_permille;
            if (metrics->top_margin_percent_override > 0) {
                topPercent = std::clamp(metrics->top_margin_percent_override, 5, 95);
            }
        }
        int renderLineY = lineY;
        int renderHeight = std::max(1, linePaintHeight);
        int baselineY = lineY + baseAscent;
        GetLineRenderMetrics(line, lineY, linePaintHeight, baseLineHeight, baseAscent, linePermille,
                             topPercent, &renderLineY, &renderHeight, &baselineY);
        lineBottom = fillBottom;
        if (isRawLine(line)) {
            if (!suppressRawLineOverlay) {
                if (caretMath && caretMath->end > lineStart && caretMath->start < lineEnd) {
                    size_t hlStart = std::max(caretMath->start, lineStart);
                    size_t hlEnd = std::min(caretMath->end, lineEnd);
                    if (hlEnd > hlStart) {
                        POINT p1{};
                        POINT p2{};
                        if (GetCharPos(hWnd, hlStart, &p1) && GetCharPos(hWnd, hlEnd, &p2)) {
                            RECT hlRc{
                                NoteLayoutFrameClientXFromNativeLineX(layoutFrame, nativeLinePos.x, p1.x),
                                renderLineY,
                                NoteLayoutFrameClientXFromNativeLineX(layoutFrame, nativeLinePos.x, p2.x),
                                renderLineY + renderHeight
                            };
                            frameRect(hlRc, kMathCaretHighlight);
                        }
                    }
                }
                continue;
            }
        }

        int indentPx = spaceW * ResolveLineIndent(cache);
        int runX = 0;
        bool h1RangeInit = false;
        int h1StartX = 0;
        int h1EndX = 0;
        if (cache.isHorizontalRuleLine) {
            const int ruleInset = std::max(spaceW * 2, ScaleY(hWnd, 18));
            const int x1 = std::max<int>(rc.left + ruleInset, lineX + indentPx);
            const int x2 = std::max<int>(x1 + 1, rc.right - ruleInset);
            const int y = renderLineY + std::max(1, renderHeight / 2);
            COLORREF ruleColor = BlendColor(baseText, baseBack, (Luma(baseBack) >= 128) ? 0.62 : 0.48);
            drawLine(x1, y, x2, ruleColor);
            continue;
        }
        if (cache.isCustomContainerLine) {
            const bool prevContainer =
                (line > 0 && g_lineCache[static_cast<size_t>(line - 1)].isCustomContainerLine);
            const bool nextContainer =
                (line + 1 < static_cast<int>(g_lineCache.size()) &&
                 g_lineCache[static_cast<size_t>(line + 1)].isCustomContainerLine);
            const int containerInsetX = std::max(spaceW * 2, ScaleY(hWnd, 14));
            const int containerInsetY = std::max(1, baseLineHeight / 12);
            const int containerTop = prevContainer ? lineY : (renderLineY + containerInsetY);
            const int containerBottom = nextContainer ? (lineY + linePaintHeight)
                                                      : (renderLineY + renderHeight - containerInsetY);
            const int containerLeft =
                std::max<LONG>(rc.left, rc.left + containerInsetX / 2 - std::max(spaceW, ScaleY(hWnd, 8)));
            RECT containerRc{
                containerLeft,
                containerTop,
                rc.right - containerInsetX / 2,
                std::max(containerTop + 1, containerBottom)
            };
            COLORREF containerBack = BlendColor(baseBack, g_theme.accent, (Luma(baseBack) >= 128) ? 0.045 : 0.10);
            COLORREF containerBorder = BlendColor(g_theme.accent, baseText, 0.52);
            COLORREF containerBar = BlendColor(g_theme.accent, baseBack, 0.28);
            fillSolidRect(containerRc, containerBack);
            if (!prevContainer) {
                drawLine(containerRc.left, containerRc.top, containerRc.right, containerBorder);
            }
            if (!nextContainer) {
                drawLine(containerRc.left, containerRc.bottom - 1, containerRc.right, containerBorder);
            }
            RECT containerBarRc{
                containerRc.left,
                containerRc.top,
                std::min<LONG>(containerRc.right, containerRc.left + std::max(3, containerInsetX / 5)),
                containerRc.bottom
            };
            fillSolidRect(containerBarRc,
                          cache.isCustomContainerFenceLine
                              ? BlendColor(containerBar, baseBack, 0.35)
                              : containerBar);
        }
        if (cache.isCodeBlockLine) {
            const bool prevCodeBlock = (line > 0 && g_lineCache[static_cast<size_t>(line - 1)].isCodeBlockLine);
            const bool nextCodeBlock =
                (line + 1 < static_cast<int>(g_lineCache.size()) &&
                 g_lineCache[static_cast<size_t>(line + 1)].isCodeBlockLine);
            const int codeInsetX = std::max(spaceW * 2, ScaleY(hWnd, 16));
            const int codeInsetY = std::max(1, baseLineHeight / 10);
            const int codeTop = prevCodeBlock ? lineY : (renderLineY + codeInsetY);
            const int codeBottom = nextCodeBlock ? (lineY + linePaintHeight)
                                                 : (renderLineY + renderHeight - codeInsetY);
            const int codeLeft = std::max<LONG>(rc.left, rc.left + codeInsetX / 2 - std::max(spaceW, ScaleY(hWnd, 8)));
            RECT codeRc{
                codeLeft,
                codeTop,
                rc.right - codeInsetX / 2,
                std::max(codeTop + 1, codeBottom)
            };
            COLORREF codeBack = BlendColor(baseBack, g_theme.accent, (Luma(baseBack) >= 128) ? 0.075 : 0.14);
            COLORREF codeBorder = BlendColor(g_theme.accent, baseText, 0.50);
            COLORREF codeBar = BlendColor(g_theme.accent, baseText, 0.42);
            fillSolidRect(codeRc, codeBack);
            if (!prevCodeBlock) {
                drawLine(codeRc.left, codeRc.top, codeRc.right, codeBorder);
            }
            if (!nextCodeBlock) {
                drawLine(codeRc.left, codeRc.bottom - 1, codeRc.right, codeBorder);
            }
            RECT codeBarRc{
                codeRc.left,
                codeRc.top,
                std::min<LONG>(codeRc.right, codeRc.left + std::max(3, codeInsetX / 5)),
                codeRc.bottom
            };
            fillSolidRect(codeBarRc, cache.isCodeFenceLine ? BlendColor(codeBar, baseBack, 0.18) : codeBar);
        }

        for (size_t segIndex = 0; segIndex < cache.segments.size(); ++segIndex) {
            const auto& seg = cache.segments[segIndex];
            if (seg.text.empty()) continue;
            TEXTMETRICW tmSeg{};
            int segHeading = EffectiveSegmentHeadingLevel(cache, seg);
            int extraPx = ComputeSegmentFontExtraPx(segHeading, seg.style, baseLineHeight);
            bool effectiveBold = seg.style.bold || (segHeading > 0 && g_config.headingBold);
            const std::wstring* fontFaceOverride = EffectiveSegmentFontFaceOverride(cache, seg);
            HFONT segFont = fonts.Acquire(hdc, effectiveBold, seg.style.italic, extraPx, &tmSeg,
                                          /*japanese=*/false, fontFaceOverride);
            HFONT oldSeg = nullptr;
            if (segFont) oldSeg = static_cast<HFONT>(SelectObject(hdc, segFont));

            std::vector<int> segPrefixWidths;
            bool segPrefixWidthsReady = false;
            int segWidth = MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseLineHeight, nullptr, nullptr);
            SIZE segSize{};
            segSize.cx = segWidth;
            segSize.cy = tmSeg.tmHeight;

            bool drawAsMath = ShouldRenderMathSegment(seg);
            mathrender::Layout mathLayout{};
            mathrender::RenderStyle mathStyle = seg.mathDisplay ? mathrender::RenderStyle::Display
                                                                : mathrender::RenderStyle::Inline;
            std::wstring mathBody;
            const mathrender::Node* mathNode = nullptr;
            if (drawAsMath) {
                mathBody = GetSegmentMathBody(seg);
                mathNode = GetCachedMathNode(mathBody);
                if (mathNode) {
                    mathLayout = MeasureCachedMathLayout(*mathNode, hdc, mathBody, tmSeg.tmHeight, mathStyle);
                    segSize.cx = mathLayout.width;
                    segSize.cy = mathLayout.height;
                    segWidth = segSize.cx;
                } else {
                    drawAsMath = false;
                }
            }

            int drawX = lineX + indentPx + runX;
            if (SegmentUsesAnchoredLayout(seg)) {
                int anchoredRunWidth = MeasureAnchoredRunWidth(hdc, fonts, cache, segIndex, baseLineHeight);
                drawX = ComputeAnchoredRunStartX(hWnd, clientW, layoutFrame.scrollX, seg.style.anchor,
                                                 seg.style.anchorOffsetChars * spaceW, anchoredRunWidth);
                for (size_t prev = segIndex; prev > 0; --prev) {
                    const auto& prevSeg = cache.segments[prev - 1];
                    if (!SameAnchoredLayout(prevSeg, seg)) break;
                    if (prevSeg.text.empty()) continue;
                    drawX += MeasureRenderedSegmentWidth(hdc, fonts, cache, prevSeg, baseLineHeight, nullptr, nullptr);
                }
            }
            int drawY = lineY;
            if (drawAsMath) {
                drawY = baselineY - mathLayout.baseline;
            } else {
                if (tmSeg.tmAscent > 0) {
                    drawY = baselineY - tmSeg.tmAscent;
                }
            }

            ResolvedColors colors = ApplyInlineCodeColors(seg, ResolveColors(seg.style, baseText, baseBack),
                                                          baseText, baseBack);
            if (segHeading > 0 && seg.style.text.mode == ColorMode::None && g_config.headingColor >= 0) {
                colors.text = NoteConfigColorToRef(g_config.headingColor);
            }
            if (cache.isCodeBlockLine) {
                colors.hasBack = false;
                colors.text = cache.isCodeFenceLine ? MutedTextColor(baseText) : BlendColor(baseText, g_theme.accent, 0.06);
            } else if (cache.isCustomContainerFenceLine) {
                colors.hasBack = false;
                colors.text = MutedTextColor(baseText);
            }
            bool isLink = !seg.style.linkId.empty();
            bool displayAsLink = isLink || seg.isMarkdownLink;
            bool isLastClicked = false;
            if (isLink) {
                const std::wstring& currentId = seg.style.linkId;
                isLastClicked = (!g_noteLastClickLinkId.empty() && currentId == g_noteLastClickLinkId);
            }

            if (displayAsLink) {
                if (seg.isMarkdownLink || seg.style.linkAccent) {
                    colors.text = g_theme.accent;
                }
                if (isLastClicked) {
                    colors.hasBack = true;
                    colors.back = g_theme.selectionBg;
                }
            }
            int visualW = segSize.cx;
            auto ensureSegPrefixWidths = [&]() -> const std::vector<int>& {
                if (!segPrefixWidthsReady) {
                    bool ignoredMeasureAsMath = false;
                    MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseLineHeight,
                                                &segPrefixWidths, &ignoredMeasureAsMath);
                    segPrefixWidthsReady = true;
                }
                return segPrefixWidths;
            };
            auto prefixWidthAt = [&](size_t vis) -> int {
                if (vis == 0) return 0;
                const auto& prefix = ensureSegPrefixWidths();
                const size_t idx = vis - 1;
                if (idx < prefix.size()) return prefix[idx];
                return segSize.cx;
            };
            size_t segStart = lineStart + seg.rawStart;
            size_t segEnd = segStart + SegmentRawLen(seg);
            int normalSelWStart = 0;
            int normalSelWEnd = 0;
            bool hasNormalSegSelection = false;
            bool fullSegSelected = false;
            int searchSelWStart = 0;
            int searchSelWEnd = 0;
            bool hasSearchSegSelection = false;
            if (showNormalVisualSelection && normalSelEnd > segStart && normalSelStart < segEnd) {
                size_t partStart = std::max(normalSelStart, segStart);
                size_t partEnd = std::min(normalSelEnd, segEnd);
                if (partEnd > partStart) {
                    std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
                    const bool decodeEscapes = SegmentDecodesMarkdownBackslashEscapes(cache, seg);
                    size_t relStart = VisibleCharsBeforeRawOffset(rawSeg, partStart - segStart, decodeEscapes);
                    size_t relEnd = VisibleCharsBeforeRawOffset(rawSeg, partEnd - segStart, decodeEscapes);
                    if (drawAsMath && !seg.text.empty()) {
                        normalSelWStart = static_cast<int>(std::lround(static_cast<double>(visualW) * relStart /
                                                                      static_cast<double>(seg.text.size())));
                        normalSelWEnd = static_cast<int>(std::lround(static_cast<double>(visualW) * relEnd /
                                                                    static_cast<double>(seg.text.size())));
                    } else {
                        normalSelWStart = prefixWidthAt(relStart);
                        normalSelWEnd = prefixWidthAt(relEnd);
                    }
                    hasNormalSegSelection = (normalSelWEnd > normalSelWStart);
                    fullSegSelected = (normalSelWStart <= 0 && normalSelWEnd >= segSize.cx);
                }
            }
            if (showSearchHit && searchHitEnd > segStart && searchHitStart < segEnd) {
                size_t partStart = std::max(searchHitStart, segStart);
                size_t partEnd = std::min(searchHitEnd, segEnd);
                if (partEnd > partStart) {
                    std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
                    const bool decodeEscapes = SegmentDecodesMarkdownBackslashEscapes(cache, seg);
                    size_t relStart = VisibleCharsBeforeRawOffset(rawSeg, partStart - segStart, decodeEscapes);
                    size_t relEnd = VisibleCharsBeforeRawOffset(rawSeg, partEnd - segStart, decodeEscapes);
                    if (drawAsMath && !seg.text.empty()) {
                        searchSelWStart = static_cast<int>(std::lround(static_cast<double>(visualW) * relStart /
                                                                       static_cast<double>(seg.text.size())));
                        searchSelWEnd = static_cast<int>(std::lround(static_cast<double>(visualW) * relEnd /
                                                                     static_cast<double>(seg.text.size())));
                    } else {
                        searchSelWStart = prefixWidthAt(relStart);
                        searchSelWEnd = prefixWidthAt(relEnd);
                    }
                    hasSearchSegSelection = (searchSelWEnd > searchSelWStart);
                }
            }
            const bool useInlineCodeChip = seg.isInlineCode && !cache.isCodeBlockLine && visualW > 0;
            const bool useDisplayMathCard = drawAsMath && seg.mathDisplay && visualW > 0;
            const int inlineChipPadX = std::max(3, baseLineHeight / 4);
            const int inlineChipPadY = std::max(1, baseLineHeight / 9);
            const int blockCardPadX = std::max(spaceW, baseLineHeight / 2);
            const int blockCardPadY = std::max(4, baseLineHeight / 4);
            const int inlineChipTop = std::max(renderLineY, drawY - inlineChipPadY);
            const int inlineChipBottom = std::min(renderLineY + renderHeight,
                                                  drawY + std::max(1, static_cast<int>(tmSeg.tmHeight)) +
                                                      inlineChipPadY);
            const int displayMathTop = useDisplayMathCard
                ? (drawY - blockCardPadY)
                : (renderLineY + blockCardPadY);
            const int displayMathBottom = useDisplayMathCard
                ? (drawY + mathLayout.height + blockCardPadY)
                : (renderLineY + renderHeight - blockCardPadY);
            RECT inlineChipRc{
                std::max<int>(rc.left, drawX - inlineChipPadX),
                inlineChipTop,
                std::min<int>(rc.right, drawX + visualW + inlineChipPadX),
                std::max(inlineChipTop + 1, inlineChipBottom)
            };
            RECT displayMathRc{
                std::max<int>(rc.left, drawX - blockCardPadX),
                displayMathTop,
                std::min<int>(rc.right, drawX + visualW + blockCardPadX),
                std::max(displayMathTop + 1, displayMathBottom)
            };
            const bool fullSelectionUsesCustomBackground =
                fullSegSelected && (useInlineCodeChip || useDisplayMathCard);
            if (useDisplayMathCard && displayMathRc.right > displayMathRc.left && displayMathRc.bottom > displayMathRc.top) {
                const bool brightBack = (Luma(baseBack) >= 128);
                COLORREF mathBack = fullSegSelected
                    ? g_theme.selectionBg
                    : BlendColor(baseBack, g_theme.accent, brightBack ? 0.07 : 0.16);
                COLORREF mathBorder = BlendColor(g_theme.accent, baseText, brightBack ? 0.50 : 0.38);
                fillRoundedRect(displayMathRc, mathBack, std::max(8, baseLineHeight / 2));
                strokeRoundedRect(displayMathRc, mathBorder, std::max(8, baseLineHeight / 2));
                colors.hasBack = false;
            }
            if (useInlineCodeChip && inlineChipRc.right > inlineChipRc.left && inlineChipRc.bottom > inlineChipRc.top) {
                COLORREF chipBack = fullSegSelected ? g_theme.selectionBg : colors.back;
                COLORREF chipBorder = BlendColor(colors.text, baseBack, (Luma(baseBack) >= 128) ? 0.58 : 0.38);
                const int inlineCodeRadius = std::max(2, baseLineHeight / 6);
                fillRoundedRect(inlineChipRc, chipBack, inlineCodeRadius);
                strokeRoundedRect(inlineChipRc, chipBorder, inlineCodeRadius);
                colors.hasBack = false;
            }
            if (colors.hasBack) {
                RECT backRc{ drawX, renderLineY, drawX + visualW, renderLineY + renderHeight };
                fillSolidRect(backRc, colors.back);
            }
            if (hasSearchSegSelection) {
                int y = renderLineY + renderHeight - 1;
                drawLine(drawX + searchSelWStart, y, drawX + searchSelWEnd, kSearchHitHighlight);
            }
            if (hasNormalSegSelection) {
                RECT selRc{
                    drawX + normalSelWStart,
                    renderLineY,
                    drawX + normalSelWEnd,
                    renderLineY + renderHeight
                };
                if (!(fullSelectionUsesCustomBackground && fullSegSelected)) {
                    fillSolidRect(selRc, g_theme.selectionBg);
                }
                if (fullSegSelected) {
                    colors.text = g_theme.selectionText;
                }
            }
            if (caretMath && caretMath->end > lineStart && caretMath->start < lineEnd) {
                size_t hlStart = std::max(caretMath->start, segStart);
                size_t hlEnd = std::min(caretMath->end, segEnd);
                if (hlEnd > hlStart) {
                    size_t relStart = hlStart - segStart;
                    size_t relEnd = hlEnd - segStart;
                    int wStart = 0;
                    int wEnd = segSize.cx;
                    if (drawAsMath && !seg.text.empty()) {
                        wStart = static_cast<int>(std::lround(static_cast<double>(visualW) * relStart /
                                                              static_cast<double>(seg.text.size())));
                        wEnd = static_cast<int>(std::lround(static_cast<double>(visualW) * relEnd /
                                                            static_cast<double>(seg.text.size())));
                    } else {
                        wStart = prefixWidthAt(relStart);
                        wEnd = prefixWidthAt(relEnd);
                    }
                    if (wEnd > wStart) {
                        RECT hlRc{ drawX + wStart, renderLineY, drawX + wEnd, renderLineY + renderHeight };
                        fillSolidRect(hlRc, kMathCaretHighlight);
                    }
                }
            }

            SetTextColor(hdc, colors.text);
            SetBkMode(hdc, TRANSPARENT);
            if (drawAsMath && mathNode) {
                mathrender::Draw(*mathNode, mathLayout, hdc, drawX, drawY, tmSeg.tmHeight, colors.text, mathStyle);
            } else {
                bool handledListMarker = false;
                if (listMarker.valid) {
                    const size_t segRawStartInLine = seg.rawStart;
                    const size_t segRawEndInLine = segRawStartInLine + SegmentRawLen(seg);
                    if (listMarker.rawStart < segRawEndInLine && listMarker.rawEnd > segRawStartInLine) {
                        const std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
                        const size_t ovStartRaw = std::max(listMarker.rawStart, segRawStartInLine) - segRawStartInLine;
                        const size_t ovEndRaw = std::min(listMarker.rawEnd, segRawEndInLine) - segRawStartInLine;
                        const bool decodeEscapes = SegmentDecodesMarkdownBackslashEscapes(cache, seg);
                        const size_t visStart = VisibleCharsBeforeRawOffset(rawSeg, ovStartRaw, decodeEscapes);
                        const size_t visEnd = VisibleCharsBeforeRawOffset(rawSeg, ovEndRaw, decodeEscapes);
                        const auto prefixW = [&](size_t vis) -> int {
                            return prefixWidthAt(vis);
                        };
                        const int x1 = drawX + prefixW(visStart);
                        const int x2 = drawX + prefixW(visEnd);
                        if (x2 > x1) {
                            COLORREF coverCol = baseBack;
                            if (colors.hasBack) coverCol = colors.back;
                            if (hasNormalSegSelection) {
                                int selX1 = drawX + normalSelWStart;
                                int selX2 = drawX + normalSelWEnd;
                                if (selX2 > selX1 && x2 > selX1 && x1 < selX2) {
                                    coverCol = g_theme.selectionBg;
                                }
                            }
                            RECT coverRc{ x1, renderLineY, x2, renderLineY + renderHeight };
                            fillSolidRect(coverRc, coverCol);
                        }

                        if (visStart > 0) {
                            DrawStyledSegmentText(hdc, fonts, drawX, drawY, seg.text.substr(0, visStart),
                                                  effectiveBold, seg.style.italic, extraPx,
                                                  fontFaceOverride);
                        }
                        if (visEnd < seg.text.size()) {
                            DrawStyledSegmentText(hdc, fonts, drawX + prefixW(visEnd), drawY, seg.text.substr(visEnd),
                                                  effectiveBold, seg.style.italic, extraPx,
                                                  fontFaceOverride);
                        }
                        if (listMarker.rawStart >= segRawStartInLine && listMarker.rawStart < segRawEndInLine) {
                            const size_t dashRaw = listMarker.rawStart - segRawStartInLine;
                            const size_t dashVis = VisibleCharsBeforeRawOffset(
                                rawSeg, dashRaw, SegmentDecodesMarkdownBackslashEscapes(cache, seg));
                            const int dashX = drawX + prefixW(dashVis);
                            const std::wstring bullet(1, L'\u2022'); // "•"
                            DrawStyledSegmentText(hdc, fonts, dashX, drawY, bullet,
                                                  effectiveBold, seg.style.italic, extraPx,
                                                  fontFaceOverride);
                        }
                        handledListMarker = true;
                    }
                }
                if (!handledListMarker) {
                    DrawStyledSegmentText(hdc, fonts, drawX, drawY, seg.text,
                                          effectiveBold, seg.style.italic, extraPx,
                                          fontFaceOverride);
                }
            }

            if (segHeading == 1 && visualW > 0) {
                int segStartX = drawX;
                int segEndX = drawX + visualW;
                if (!h1RangeInit) {
                    h1RangeInit = true;
                    h1StartX = segStartX;
                    h1EndX = segEndX;
                } else {
                    h1StartX = std::min(h1StartX, segStartX);
                    h1EndX = std::max(h1EndX, segEndX);
                }
            }

            bool wantUnderline = seg.style.underline || seg.isMarkdownLink;
            if (!seg.style.linkId.empty() && seg.style.linkUnderline) {
                if (LinkTargetExistsForCurrentNoteSource(hWnd, seg.style.linkId, segStart)) {
                    wantUnderline = true;
                }
            }
            if ((wantUnderline || seg.style.strike) && visualW > 0) {
                int x1 = drawX;
                int x2 = drawX + visualW;
                if (wantUnderline) {
                    int y = drawY + tmSeg.tmAscent + 1;
                    int limit = renderLineY + renderHeight - 1;
                    if (y > limit) y = limit;
                    drawLine(x1, y, x2, colors.text);
                }
                if (seg.style.strike) {
                    int y = drawY + tmSeg.tmAscent / 2;
                    drawLine(x1, y, x2, colors.text);
                }
            }

            if (oldSeg) SelectObject(hdc, oldSeg);
            if (!SegmentUsesAnchoredLayout(seg)) {
                runX += visualW;
            }
        }

        if (cache.headingLevel > 0) {
            COLORREF headingDecorColor = (g_config.headingColor >= 0)
                ? NoteConfigColorToRef(g_config.headingColor)
                : BlendColor(g_theme.accent, baseText, (Luma(baseBack) >= 128) ? 0.34 : 0.18);
            if (g_config.headingLeftBar) {
                int barWidth = std::max(1, ScaleY(hWnd, 3));
                int barGap = std::max(1, ScaleY(hWnd, 1));
                int barRight = std::max<int>(rc.left + barWidth, lineX - barGap);
                int barLeft = barRight - barWidth;
                RECT barRc{ barLeft, renderLineY, barRight, renderLineY + renderHeight };
                COLORREF headingBarColor = ComputeHeadingLeftBarColor(headingDecorColor,
                                                                      baseBack,
                                                                      cache.headingLevel);
                fillSolidRect(barRc, headingBarColor);
            }

            if (g_config.headingUnderline && cache.headingLevel == 1 && h1RangeInit) {
                int underlineStart = h1StartX;
                int underlineEnd = h1EndX;
                int y = baselineY + 1;
                int limit = renderLineY + renderHeight - 1;
                if (y > limit) y = limit;
                drawLine(underlineStart, y, underlineEnd, headingDecorColor);
            }
        }
    }

    if (g_noteVimModeEnabled && g_noteNormalMode) {
        RECT caretRc{};
        const bool caretOk = showVimCaretLineRawInNote
            ? TryGetRawCaretRect(hWnd, hdc, static_cast<size_t>(g_noteNormalCaret), &caretRc)
            : TryGetRenderedCaretRect(hWnd, hdc, static_cast<size_t>(g_noteNormalCaret), &caretRc);
        if (caretOk) {
            HBRUSH caretBrush = CreateSolidBrush(g_theme.accent);
            FillRect(hdc, &caretRc, caretBrush);
            DeleteObject(caretBrush);
        }
    }

    if (oldBkMode != 0) SetBkMode(hdc, oldBkMode);
}

void MarkupFontProvider::Initialize(HDC hdc, HFONT preferred) {
    if (!hdc) return;
    baseFont = preferred ? preferred : g_hUIFont;
    if (!baseFont) return;
    HFONT old = static_cast<HFONT>(SelectObject(hdc, baseFont));
    TEXTMETRICW tm{};
    if (GetTextMetricsW(hdc, &tm)) {
        baseMetrics = tm;
    }
    baseAscent = baseMetrics.tmAscent;
    SIZE spaceSz{};
    if (GetTextExtentPoint32W(hdc, L" ", 1, &spaceSz)) {
        spaceWidth = spaceSz.cx;
    } else {
        spaceWidth = baseMetrics.tmAveCharWidth;
    }
    if (spaceWidth < 0) spaceWidth = 0;
    if (GetObjectW(baseFont, sizeof(baseLf), &baseLf)) {
        hasBaseLf = true;
        jpLf = baseLf;

        std::wstring baseFace = ResolveNoteRenderBaseFace();
        std::wstring jpFace = ResolveNoteRenderJpFace();

        wcsncpy_s(baseLf.lfFaceName, baseFace.c_str(), _TRUNCATE);
        wcsncpy_s(jpLf.lfFaceName, jpFace.c_str(), _TRUNCATE);
        hasJpLf = true;
    }
    SelectObject(hdc, old);
}

HFONT MarkupFontProvider::Acquire(HDC hdc,
                                  bool bold,
                                  bool italic,
                                  int extraPx,
                                  TEXTMETRICW* out,
                                  bool japanese,
                                  const std::wstring* fontFaceOverride) {
    if (!baseFont) {
        if (out) *out = TEXTMETRICW{};
        return nullptr;
    }
    FontKey key{};
    key.bold = bold;
    key.italic = italic;
    key.japanese = japanese;
    key.extraPx = extraPx;
    if (fontFaceOverride && !fontFaceOverride->empty()) {
        key.fontFace = *fontFaceOverride;
    }
    for (auto& entry : cache) {
        if (entry.key.bold == key.bold &&
            entry.key.italic == key.italic &&
            entry.key.japanese == key.japanese &&
            entry.key.extraPx == key.extraPx &&
            entry.key.fontFace == key.fontFace) {
            if (out) *out = entry.metrics;
            return entry.font;
        }
    }
    if (!hasBaseLf || (japanese && !hasJpLf)) {
        if (out) *out = baseMetrics;
        return baseFont;
    }
    LOGFONTW lf = japanese ? jpLf : baseLf;
    if (!key.fontFace.empty()) {
        wcsncpy_s(lf.lfFaceName, key.fontFace.c_str(), _TRUNCATE);
    }
    if (bold) lf.lfWeight = FW_BOLD;
    if (italic) lf.lfItalic = TRUE;
    if (extraPx != 0) {
        if (lf.lfHeight < 0) {
            int h = lf.lfHeight - extraPx;
            if (h >= -1) h = -1;
            lf.lfHeight = h;
        } else if (lf.lfHeight > 0) {
            int h = lf.lfHeight + extraPx;
            if (h <= 1) h = 1;
            lf.lfHeight = h;
        }
    }
    HFONT font = CreateFontIndirectW(&lf);
    if (!font) {
        if (out) *out = baseMetrics;
        return baseFont;
    }
    HFONT old = static_cast<HFONT>(SelectObject(hdc, font));
    TEXTMETRICW metrics{};
    if (!GetTextMetricsW(hdc, &metrics)) metrics = baseMetrics;
    SelectObject(hdc, old);
    cache.push_back(FontEntry{ key, font, metrics });
    if (out) *out = metrics;
    return font;
}

MarkupFontProvider::~MarkupFontProvider() {
    for (auto& entry : cache) {
        if (entry.font && entry.font != baseFont) {
            DeleteObject(entry.font);
        }
    }
}

static bool IsJapaneseRenderChar(wchar_t ch) {
    return IsJapaneseRenderCharForNoteFont(ch);
}

static std::wstring MarkupFontProviderBaseFace(const MarkupFontProvider& fonts) {
    if (fonts.hasBaseLf && fonts.baseLf.lfFaceName[0] != L'\0') {
        return fonts.baseLf.lfFaceName;
    }
    return ResolveNoteRenderBaseFace();
}

static std::wstring MarkupFontProviderJpFace(const MarkupFontProvider& fonts) {
    if (fonts.hasJpLf && fonts.jpLf.lfFaceName[0] != L'\0') {
        return fonts.jpLf.lfFaceName;
    }
    return ResolveNoteRenderJpFace();
}

static bool SegmentMeasureCacheMatches(const SegmentMeasureCache& c,
                                       const MarkupFontProvider& fonts,
                                       int baseFontHeight) {
    return c.valid &&
           c.baseFontHeight == baseFontHeight &&
           c.renderActive == IsNoteRenderActive() &&
           c.mathSupSubGapSupPercent == g_config.noteMathSupSubGapSupPercent &&
           c.spaceWidth == fonts.spaceWidth &&
           c.baseAveCharWidth == fonts.baseMetrics.tmAveCharWidth &&
           c.baseMaxCharWidth == fonts.baseMetrics.tmMaxCharWidth &&
           c.baseOverhang == fonts.baseMetrics.tmOverhang &&
           c.baseFace == MarkupFontProviderBaseFace(fonts) &&
           c.jpFace == MarkupFontProviderJpFace(fonts);
}

static void StoreSegmentMeasureCacheKey(SegmentMeasureCache* c,
                                        const MarkupFontProvider& fonts,
                                        int baseFontHeight) {
    if (!c) return;
    c->valid = true;
    c->baseFontHeight = baseFontHeight;
    c->renderActive = IsNoteRenderActive();
    c->mathSupSubGapSupPercent = g_config.noteMathSupSubGapSupPercent;
    c->spaceWidth = fonts.spaceWidth;
    c->baseAveCharWidth = fonts.baseMetrics.tmAveCharWidth;
    c->baseMaxCharWidth = fonts.baseMetrics.tmMaxCharWidth;
    c->baseOverhang = fonts.baseMetrics.tmOverhang;
    c->baseFace = MarkupFontProviderBaseFace(fonts);
    c->jpFace = MarkupFontProviderJpFace(fonts);
}

static int MeasureStyledSegmentTextWidth(HDC hdc,
                                         MarkupFontProvider& fonts,
                                         const std::wstring& text,
                                         bool bold,
                                         bool italic,
                                         int extraPx,
                                         const std::wstring* fontFaceOverride,
                                         std::vector<int>* prefix) {
    if (prefix) {
        prefix->assign(text.size(), 0);
    }
    if (!hdc || text.empty()) return 0;

    int total = 0;
    size_t runStart = 0;
    while (runStart < text.size()) {
        bool jp = IsJapaneseRenderChar(text[runStart]);
        size_t runEnd = runStart + 1;
        while (runEnd < text.size() && IsJapaneseRenderChar(text[runEnd]) == jp) {
            ++runEnd;
        }

        HFONT runFont = fonts.Acquire(hdc, bold, italic, extraPx, nullptr, jp, fontFaceOverride);
        HFONT oldFont = runFont ? static_cast<HFONT>(SelectObject(hdc, runFont)) : nullptr;
        const int runLen = static_cast<int>(runEnd - runStart);
        int runWidth = 0;
        if (prefix) {
            SIZE runSize{};
            std::vector<int> dx(static_cast<size_t>(runLen), 0);
            int fit = 0;
            bool ok = GetTextExtentExPointW(hdc, text.c_str() + runStart, runLen, 0x7FFFFFFF,
                                            &fit, dx.data(), &runSize) != 0;
            if (!ok || fit <= 0) {
                for (int i = 0; i < runLen; ++i) {
                    SIZE sz{};
                    if (GetTextExtentPoint32W(hdc, text.c_str() + runStart, i + 1, &sz)) {
                        dx[static_cast<size_t>(i)] = sz.cx;
                    } else if (i > 0) {
                        dx[static_cast<size_t>(i)] = dx[static_cast<size_t>(i - 1)];
                    }
                }
            } else if (fit < runLen) {
                for (int i = fit; i < runLen; ++i) {
                    dx[static_cast<size_t>(i)] = runSize.cx;
                }
            }
            runWidth = dx.empty() ? 0 : dx.back();
            for (int i = 0; i < runLen; ++i) {
                (*prefix)[runStart + static_cast<size_t>(i)] = total + dx[static_cast<size_t>(i)];
            }
        } else {
            SIZE runSize{};
            if (GetTextExtentPoint32W(hdc, text.c_str() + runStart, runLen, &runSize)) {
                runWidth = runSize.cx;
            }
        }
        total += runWidth;
        if (oldFont) SelectObject(hdc, oldFont);
        runStart = runEnd;
    }
    return total;
}

static void DrawStyledSegmentText(HDC hdc,
                                  MarkupFontProvider& fonts,
                                  int x,
                                  int y,
                                  const std::wstring& text,
                                  bool bold,
                                  bool italic,
                                  int extraPx,
                                  const std::wstring* fontFaceOverride) {
    if (!hdc || text.empty()) return;
    int runX = 0;
    size_t runStart = 0;
    while (runStart < text.size()) {
        bool jp = IsJapaneseRenderChar(text[runStart]);
        size_t runEnd = runStart + 1;
        while (runEnd < text.size() && IsJapaneseRenderChar(text[runEnd]) == jp) {
            ++runEnd;
        }
        const int runLen = static_cast<int>(runEnd - runStart);
        HFONT runFont = fonts.Acquire(hdc, bold, italic, extraPx, nullptr, jp, fontFaceOverride);
        HFONT oldFont = runFont ? static_cast<HFONT>(SelectObject(hdc, runFont)) : nullptr;
        TextOutW(hdc, x + runX, y, text.c_str() + runStart, runLen);
        SIZE runSize{};
        if (GetTextExtentPoint32W(hdc, text.c_str() + runStart, runLen, &runSize)) {
            runX += runSize.cx;
        }
        if (oldFont) SelectObject(hdc, oldFont);
        runStart = runEnd;
    }
}

static bool QueryNativeEditScrollPos(HWND hWnd, POINT* out) {
    if (!hWnd || !out) return false;
    POINT pt{};
    LRESULT res = SendMessageW(hWnd, EM_GETSCROLLPOS, 0, reinterpret_cast<LPARAM>(&pt));
    if (res) {
        *out = pt;
        return true;
    }
    out->x = GetScrollPos(hWnd, SB_HORZ);
    out->y = GetScrollPos(hWnd, SB_VERT);
    return true;
}

static bool QueryEditScrollPos(HWND hWnd, POINT* out) {
    if (!QueryNativeEditScrollPos(hWnd, out)) return false;
    if (out && IsNoteRenderActive()) {
        out->x = g_noteRenderScrollX;
    }
    return true;
}

static int MeasureRenderedLineVisualWidth(HDC hdc, MarkupFontProvider& fonts, const LineCache& cache) {
    if (!hdc || !fonts.baseFont) return 0;

    int spaceW = fonts.spaceWidth;
    if (spaceW <= 0) spaceW = fonts.baseMetrics.tmAveCharWidth;
    if (spaceW <= 0) spaceW = 1;

    int baseFontHeight = std::max<int>(1, static_cast<int>(fonts.baseMetrics.tmHeight));
    int width = spaceW * ResolveLineIndent(cache);
    for (const auto& seg : cache.segments) {
        if (seg.text.empty()) continue;
        if (SegmentUsesAnchoredLayout(seg)) continue;
        width += MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseFontHeight, nullptr, nullptr);
    }
    return width;
}

static bool SegmentUsesAnchoredLayout(const Segment& seg) {
    return seg.style.anchor != HorizontalAnchor::None;
}

static bool SameAnchoredLayout(const Segment& a, const Segment& b) {
    return a.style.anchor == b.style.anchor &&
           a.style.anchorOffsetChars == b.style.anchorOffsetChars;
}

static int GetNoteRenderRightEdgeInkPadPx(HWND hWnd) {
    const int scaled = hWnd ? ScaleY(hWnd, 6) : 6;
    return std::max(4, scaled);
}

static int ComputeAnchoredRunStartX(HWND hWnd,
                                    int clientW,
                                    int scrollX,
                                    HorizontalAnchor anchor,
                                    int offsetPx,
                                    int runWidth) {
    (void)hWnd;
    int baseX = -scrollX;
    switch (anchor) {
    case HorizontalAnchor::Left:
        return baseX + offsetPx;
    case HorizontalAnchor::Center:
        return baseX + (std::max(0, clientW) - runWidth) / 2 + offsetPx;
    case HorizontalAnchor::Right:
        // GDI advance width can be slightly smaller than the inked glyph bounds.
        // Keep right-anchored render runs inside the viewport so the final glyph is not clipped.
        return baseX + std::max(0, clientW) - runWidth + offsetPx - GetNoteRenderRightEdgeInkPadPx(hWnd);
    case HorizontalAnchor::None:
    default:
        return baseX + offsetPx;
    }
}

static int MeasureRenderedSegmentWidth(HDC hdc,
                                       MarkupFontProvider& fonts,
                                       const LineCache& cache,
                                       const Segment& seg,
                                       int baseFontHeight,
                                       std::vector<int>* outPrefixWidths,
                                       bool* outMeasureAsMath) {
    if (outPrefixWidths) outPrefixWidths->clear();
    if (outMeasureAsMath) *outMeasureAsMath = false;
    if (seg.text.empty()) return 0;

    SegmentMeasureCache& measureCache = seg.measureCache;
    if (SegmentMeasureCacheMatches(measureCache, fonts, baseFontHeight)) {
        if (outMeasureAsMath) *outMeasureAsMath = measureCache.measureAsMath;
        if (outPrefixWidths && !measureCache.measureAsMath) {
            if (measureCache.prefixValid) {
                *outPrefixWidths = measureCache.prefixWidths;
            }
        }
        if (!outPrefixWidths || measureCache.measureAsMath || measureCache.prefixValid) {
            return measureCache.width;
        }
    } else {
        measureCache = SegmentMeasureCache{};
        StoreSegmentMeasureCacheKey(&measureCache, fonts, baseFontHeight);
    }

    TEXTMETRICW tmSeg{};
    int segHeading = EffectiveSegmentHeadingLevel(cache, seg);
    int extraPx = ComputeSegmentFontExtraPx(segHeading, seg.style, baseFontHeight);
    bool effectiveBold = seg.style.bold || (segHeading > 0 && g_config.headingBold);
    const std::wstring* fontFaceOverride = EffectiveSegmentFontFaceOverride(cache, seg);
    HFONT segFont = fonts.Acquire(hdc, effectiveBold, seg.style.italic, extraPx, &tmSeg,
                                  /*japanese=*/false, fontFaceOverride);
    HFONT oldSeg = nullptr;
    if (segFont) oldSeg = static_cast<HFONT>(SelectObject(hdc, segFont));

    int segWidth = MeasureStyledSegmentTextWidth(hdc, fonts, seg.text,
                                                 effectiveBold, seg.style.italic, extraPx,
                                                 fontFaceOverride,
                                                 outPrefixWidths);
    if (outPrefixWidths) {
        measureCache.prefixWidths = *outPrefixWidths;
        measureCache.prefixValid = true;
    }
    bool measureAsMath = ShouldRenderMathSegment(seg);
    if (measureAsMath) {
        std::wstring mathBody = GetSegmentMathBody(seg);
        if (const mathrender::Node* node = GetCachedMathNode(mathBody)) {
            auto layout = MeasureCachedMathLayout(*node,
                                                  hdc,
                                                  mathBody,
                                                  std::max(1, static_cast<int>(tmSeg.tmHeight)),
                                                  seg.mathDisplay ? mathrender::RenderStyle::Display
                                                                  : mathrender::RenderStyle::Inline);
            segWidth = layout.width;
        } else {
            measureAsMath = false;
        }
    }

    if (oldSeg) SelectObject(hdc, oldSeg);
    if (outMeasureAsMath) *outMeasureAsMath = measureAsMath;
    measureCache.width = segWidth;
    measureCache.measureAsMath = measureAsMath;
    if (measureAsMath) {
        measureCache.prefixWidths.clear();
        measureCache.prefixValid = false;
    }
    return segWidth;
}

static int MeasureAnchoredRunWidth(HDC hdc,
                                   MarkupFontProvider& fonts,
                                   const LineCache& cache,
                                   size_t startIndex,
                                   int baseFontHeight) {
    if (startIndex >= cache.segments.size()) return 0;
    const Segment& first = cache.segments[startIndex];
    if (!SegmentUsesAnchoredLayout(first)) return 0;
    int width = 0;
    for (size_t i = startIndex; i < cache.segments.size(); ++i) {
        const Segment& seg = cache.segments[i];
        if (!SameAnchoredLayout(first, seg)) break;
        width += MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseFontHeight, nullptr, nullptr);
    }
    return width;
}

static int MeasureRenderedContentRightPx(HWND hWnd, HDC hdc) {
    if (!hWnd || !hdc || !CanReadStableRenderDerivedState()) return 0;

    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    if (!NoteLayoutFrameMatchesRenderSnapshot(layoutFrame)) return 0;
    const int anchorScrollX = NoteLayoutFrameAnchorScrollX(layoutFrame, hWnd);

    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return 0;

    int maxRight = 0;
    const int clientW = layoutFrame.clientWidthPx;
    const bool renderActive = layoutFrame.renderActive;
    int lineCount = renderActive ? static_cast<int>(g_lineCache.size()) : NoteLineCount();
    int usable = renderActive
        ? static_cast<int>(g_lineCache.size())
        : std::min<int>(lineCount, static_cast<int>(g_lineCache.size()));
    for (int line = 0; line < usable; ++line) {
        int lineBaseX = 0;
        if (!renderActive) {
            LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineStartRes < 0) continue;
            POINT linePos{};
            if (!GetCharPos(hWnd, static_cast<size_t>(lineStartRes), &linePos)) continue;
            lineBaseX = anchorScrollX + linePos.x;
        }
        const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
        // In render mode the cache is the source of truth for hard lines. Depending on when
        // RichEdit has recomputed its format rectangle, EM_LINEINDEX/GetCharPos can still reflect
        // a stale soft-wrapped layout; measuring from g_lineCache avoids a too-small first width.
        int flowRight = lineBaseX + MeasureRenderedLineVisualWidth(hdc, fonts, cache);
        maxRight = std::max(maxRight, flowRight);

        const int baseFontHeight = std::max<int>(1, static_cast<int>(fonts.baseMetrics.tmHeight));
        for (size_t segIndex = 0; segIndex < cache.segments.size(); ++segIndex) {
            const auto& seg = cache.segments[segIndex];
            if (!SegmentUsesAnchoredLayout(seg) || seg.text.empty()) continue;
            int anchoredRunWidth = MeasureAnchoredRunWidth(hdc, fonts, cache, segIndex, baseFontHeight);
            int segBaseX = ComputeAnchoredRunStartX(hWnd, clientW, anchorScrollX, seg.style.anchor,
                                                    seg.style.anchorOffsetChars * fonts.spaceWidth, anchoredRunWidth);
            int prefix = 0;
            for (size_t prev = segIndex; prev > 0; --prev) {
                const auto& prevSeg = cache.segments[prev - 1];
                if (!SameAnchoredLayout(prevSeg, seg)) break;
                if (prevSeg.text.empty()) continue;
                prefix += MeasureRenderedSegmentWidth(hdc, fonts, cache, prevSeg, baseFontHeight, nullptr, nullptr);
            }
            int segWidth = MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseFontHeight, nullptr, nullptr);
            int anchoredRight = anchorScrollX + segBaseX + prefix + segWidth;
            maxRight = std::max(maxRight, anchoredRight);
        }
    }
    if (maxRight > 0) {
        const int baseFontHeight = std::max<int>(1, static_cast<int>(fonts.baseMetrics.tmHeight));
        const int visualSafetyPad = std::max(4, baseFontHeight / 4);
        maxRight += visualSafetyPad;
    }
    return maxRight;
}

void ExpandNoteRenderCanvasForPendingEdit(HWND hWnd) {
    if (!hWnd || !IsNoteRenderActive()) return;
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);

    DWORD selStart = 0;
    DWORD selEnd = 0;
    SendMessageW(hWnd, EM_GETSEL,
                 reinterpret_cast<WPARAM>(&selStart),
                 reinterpret_cast<LPARAM>(&selEnd));
    DWORD caret = std::max(selStart, selEnd);

    std::wstring indexingText = GetEditTextForIndexing(hWnd);
    if (indexingText.empty()) return;
    caret = static_cast<DWORD>(std::min<size_t>(caret, indexingText.size()));

    std::vector<size_t> logicalStarts = BuildLogicalLineStartsFromIndexingText(indexingText);
    if (logicalStarts.empty()) return;
    int line = FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(caret));

    size_t lineStart = 0;
    size_t lineEnd = 0;
    if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, line, &lineStart, &lineEnd, nullptr)) {
        return;
    }

    POINT linePos{};
    if (!GetCharPos(hWnd, lineStart, &linePos)) return;

    HDC hdc = GetDC(hWnd);
    if (!hdc) return;
    HFONT font = GetActiveNoteFont();
    HFONT oldFont = font ? static_cast<HFONT>(SelectObject(hdc, font)) : nullptr;
    SIZE rawSize{};
    const size_t len = (lineEnd > lineStart) ? (lineEnd - lineStart) : 0;
    if (len > 0) {
        GetTextExtentPoint32W(hdc,
                              indexingText.c_str() + lineStart,
                              static_cast<int>(std::min<size_t>(len, static_cast<size_t>(std::numeric_limits<int>::max()))),
                              &rawSize);
    }
    TEXTMETRICW tm{};
    int safetyPad = 8;
    if (GetTextMetricsW(hdc, &tm)) {
        safetyPad = std::max(safetyPad, static_cast<int>(tm.tmHeight) / 2);
    }
    if (oldFont) SelectObject(hdc, oldFont);
    ReleaseDC(hWnd, hdc);

    const int lineBaseX = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x);
    int provisionalRight = layoutFrame.scrollX + lineBaseX +
                           std::max<int>(0, static_cast<int>(rawSize.cx)) + safetyPad;
    const bool expanded = (provisionalRight > g_noteRenderedContentRightPx);
    if (expanded) {
        g_noteRenderedContentRightPx = provisionalRight;
    }

    int clientW = layoutFrame.clientWidthPx;
    int visibleRight = layoutFrame.scrollX + clientW;
    int scrollMargin = std::max(ScaleY(hWnd, 24), safetyPad * 2);
    bool scrolled = false;
    if (clientW > 0 && provisionalRight + scrollMargin > visibleRight) {
        scrolled = SetNoteRenderScrollPosX(hWnd, provisionalRight + scrollMargin - clientW);
    }
    if (expanded && !scrolled) {
        UpdateNoteFormatRect(hWnd);
    }
    if (expanded || scrolled) {
        InvalidateRect(hWnd, nullptr, FALSE);
    }
}

static int MeasureRenderedContentBottomPx(HWND hWnd, HDC hdc) {
    if (!hWnd || !hdc || !CanReadStableRenderDerivedState()) return 0;
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    if (!NoteLayoutFrameMatchesRenderSnapshot(layoutFrame)) return 0;

    POINT scroll{};
    QueryEditScrollPos(hWnd, &scroll);

    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return 0;

    int baseLineHeight = std::max<int>(1, static_cast<int>(fonts.baseMetrics.tmHeight));
    int baseAscent = std::max(0, fonts.baseAscent);
    int maxBottom = 0;
    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    const bool renderActive = layoutFrame.renderActive;
    if (renderActive) {
        logicalStarts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    }
    int lineCount = renderActive
        ? std::max<int>(1, static_cast<int>(logicalStarts.size()))
        : NoteLineCount();
    int usable = std::min<int>(lineCount, static_cast<int>(g_lineCache.size()));

    for (int line = 0; line < usable; ++line) {
        POINT linePos{};
        int lineY = 0;
        int lineHeight = baseLineHeight;
        if (renderActive) {
            int lineBottom = 0;
            if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line, baseLineHeight,
                                                &lineY, &lineBottom, nullptr, nullptr, nullptr, &linePos)) {
                continue;
            }
            lineHeight = std::max(1, lineBottom - lineY);
        } else {
            LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineStartRes < 0) continue;
            if (!GetCharPos(hWnd, static_cast<size_t>(lineStartRes), &linePos)) continue;

            lineY = linePos.y;
            if (line + 1 < lineCount) {
                LRESULT nextIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
                if (nextIdxRes >= 0) {
                    POINT nextPos{};
                    if (GetCharPos(hWnd, static_cast<size_t>(nextIdxRes), &nextPos) && nextPos.y > lineY) {
                        lineHeight = nextPos.y - lineY;
                    }
                }
            }
        }

        int linePermille = ResolveLineHeightPermille(g_lineCache[static_cast<size_t>(line)]);
        int topPercent = std::clamp(g_config.noteMathMarginTopPercent, 5, 95);
        if (const note::NoteLayoutLineMetrics* metrics =
                FindAppliedNoteLayoutLineMetrics(line)) {
            linePermille = metrics->line_height_permille;
            if (metrics->top_margin_percent_override > 0) {
                topPercent = std::clamp(metrics->top_margin_percent_override, 5, 95);
            }
        }

        int renderTop = lineY;
        int renderHeight = std::max(1, lineHeight);
        GetLineRenderMetrics(line, lineY, lineHeight, baseLineHeight, baseAscent, linePermille,
                             topPercent, &renderTop, &renderHeight, nullptr);
        int renderBottomAbs = static_cast<int>(scroll.y) + renderTop + renderHeight;
        maxBottom = std::max(maxBottom, renderBottomAbs);
    }

    return maxBottom;
}

static int ResolveHeadingLevel(const LineCache& cache, const Segment& seg) {
    int prefix = cache.headingPrefixLevel;
    int segLevel = seg.style.headingLevel;
    if (prefix > 0 && segLevel > 0) return std::min(prefix, segLevel);
    if (prefix > 0) return prefix;
    return segLevel;
}

static int ResolveLineIndent(const LineCache& cache) {
    // Indent is line-level; use the first segment that carries visible text.
    int baseIndent = 0;
    for (const auto& seg : cache.segments) {
        if (seg.text.empty()) continue;
        for (wchar_t ch : seg.text) {
            if (!iswspace(ch)) {
                baseIndent = seg.style.indent;
                return baseIndent + ResolveAdditionalRenderIndentChars(cache);
            }
        }
    }
    for (const auto& seg : cache.segments) {
        if (!seg.text.empty()) {
            baseIndent = seg.style.indent;
            return baseIndent + ResolveAdditionalRenderIndentChars(cache);
        }
    }
    return ResolveAdditionalRenderIndentChars(cache);
}

static int ResolveLineHeightPermille(const LineCache& cache) {
    int permille = cache.hasLineHeight ? std::max(1000, cache.lineHeightPermille) : 0;
    for (const auto& seg : cache.segments) {
        if (!seg.style.hasLineHeight) continue;
        permille = std::max(permille, seg.style.lineHeightPermille);
    }
    return (permille > 0) ? permille : 1000;
}

static int ResolveLineMaxFontSizePx(const LineCache& cache) {
    int px = cache.hasFontSize ? std::max(0, cache.fontSizePx) : 0;
    for (const auto& seg : cache.segments) {
        if (!seg.style.hasFontSize) continue;
        px = std::max(px, seg.style.fontSizePx);
    }
    return px;
}

static int ComputeRenderMarginTopWithPercent(int linePaintHeight, int baseLineHeight, int linePermille, int topPercent) {
    int extra = std::max(0, linePaintHeight - baseLineHeight);
    if (extra <= 0) return 0;
    if (linePermille > 1000) {
        topPercent = std::clamp(topPercent, 5, 95);
        return (extra * topPercent) / 100;
    }
    return 0;
}

static void GetLineRenderMetrics(int line,
                                 int lineTop,
                                 int linePaintHeight,
                                 int baseLineHeight,
                                 int baseAscent,
                                 int linePermille,
                                 int topPercent,
                                 int* outRenderTop,
                                 int* outRenderHeight,
                                 int* outBaselineY) {
    if (!outRenderTop || !outRenderHeight) return;

    linePaintHeight = std::max(1, linePaintHeight);
    baseLineHeight = std::max(1, baseLineHeight);
    baseAscent = std::max(0, baseAscent);

    int baseDescent = std::max(1, baseLineHeight - baseAscent);
    int visualAscent = baseAscent;
    int visualDescent = baseDescent;
    if (const note::NoteLayoutLineMetrics* metrics =
            FindAppliedNoteLayoutLineMetrics(line)) {
        if (metrics->visual_ascent_px > 0) {
            visualAscent = metrics->visual_ascent_px;
        }
        if (metrics->visual_descent_px > 0) {
            visualDescent = metrics->visual_descent_px;
        }
    }

    int innerPad = std::max(1, baseLineHeight / 12);
    constexpr int kRenderYOffset = 1;
    int marginTop = ComputeRenderMarginTopWithPercent(linePaintHeight, baseLineHeight, linePermille, topPercent);
    int lineBottom = lineTop + linePaintHeight;
    int baselineY = lineTop + marginTop + innerPad + kRenderYOffset + baseAscent;
    int minBaseline = lineTop + visualAscent;
    int maxBaseline = lineBottom - visualDescent;
    if (minBaseline <= maxBaseline) {
        baselineY = std::clamp(baselineY, minBaseline, maxBaseline);
    } else {
        baselineY = minBaseline;
    }
    int renderTop = baselineY - visualAscent;
    int renderBottom = baselineY + visualDescent;
    renderTop = std::clamp(renderTop, lineTop, lineBottom - 1);
    renderBottom = std::clamp(renderBottom, renderTop + 1, lineBottom);

    *outRenderTop = renderTop;
    *outRenderHeight = std::max(1, renderBottom - renderTop);
    if (outBaselineY) {
        *outBaselineY = baselineY;
    }
}

static bool TryGetRenderedCaretRect(HWND hWnd, HDC hdc, size_t caretIndex, RECT* outRect) {
    if (!hWnd || !hdc || !outRect) return false;
    if (!CanReadStableRenderDerivedState(/*requireExactRevision=*/false)) return false;
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    if (!NoteLayoutFrameMatchesRenderSnapshot(layoutFrame, /*requireExactRevision=*/false)) return false;
    RECT rc = layoutFrame.client;
    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return false;

    int baseLineHeight = fonts.baseMetrics.tmHeight;
    if (baseLineHeight <= 0) baseLineHeight = 1;
    int textLen = GetWindowTextLengthW(hWnd);
    if (textLen < 0) textLen = 0;
    size_t clampedCaret = std::min<size_t>(caretIndex, static_cast<size_t>(textLen));
    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    const bool renderActive = layoutFrame.renderActive;
    if (renderActive) {
        logicalStarts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    }
    int lineCount = renderActive
        ? std::max<int>(1, static_cast<int>(logicalStarts.size()))
        : NoteLineCount();
    if (lineCount <= 0) lineCount = 1;
    int line = renderActive
                   ? FindLogicalLineForRaw(logicalStarts, clampedCaret)
                   : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, static_cast<WPARAM>(clampedCaret), 0));
    line = std::clamp(line, 0, lineCount - 1);
    line = std::clamp(line, 0, static_cast<int>(g_lineCache.size()) - 1);
    if (renderActive && IsNoteLineRawHelper(hWnd, line)) {
        return TryGetRawCaretRect(hWnd, hdc, caretIndex, outRect);
    }

    size_t lineStart = 0;
    if (renderActive) {
        if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, line, &lineStart, nullptr, nullptr)) {
            return false;
        }
    } else {
        LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
        if (lineStartRes < 0) return false;
        lineStart = static_cast<size_t>(lineStartRes);
    }
    size_t rel = (clampedCaret > lineStart) ? (clampedCaret - lineStart) : 0;
    const LineCache* cachePtr = &g_lineCache[static_cast<size_t>(line)];

    std::wstring newRawLine;
    if (renderActive && !indexingText.empty() && lineStart <= indexingText.size()) {
        size_t nextStart = (line + 1 < static_cast<int>(logicalStarts.size())) ? logicalStarts[line + 1] : indexingText.size();
        if (nextStart > lineStart) {
            newRawLine = indexingText.substr(lineStart, nextStart - lineStart);
            while (!newRawLine.empty() && (newRawLine.back() == L'\n' || newRawLine.back() == L'\r')) {
                newRawLine.pop_back();
            }
        }
    } else {
        // Raw fallback or no indexing text
        int lineLen = static_cast<int>(SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineStart), 0));
        if (lineLen > 0) {
            newRawLine.resize(static_cast<size_t>(lineLen));
            *reinterpret_cast<WORD*>(&newRawLine[0]) = static_cast<WORD>(lineLen);
            SendMessageW(hWnd, EM_GETLINE, static_cast<WPARAM>(line), reinterpret_cast<LPARAM>(&newRawLine[0]));
        }
    }

    if (renderActive && !newRawLine.empty() && newRawLine != cachePtr->rawLine &&
        CurrentNoteContentRoute() == NoteContentRoute::MarkdownMd4c) {
        RefreshMarkdownRenderCache(indexingText);
        if (static_cast<size_t>(line) < g_lineCache.size()) {
            cachePtr = &g_lineCache[static_cast<size_t>(line)];
        }
    }
    const LineCache& cache = *cachePtr;

    size_t newCaretRel = rel;
    size_t diffStart = rel;
    const bool cacheMatchesCurrentLine = !newRawLine.empty() && cache.rawLine == newRawLine;
    if (!cacheMatchesCurrentLine) {
        if (!newRawLine.empty()) {
            diffStart = 0;
            while (diffStart < rel && diffStart < cache.rawLine.size() && diffStart < newRawLine.size() &&
                   newRawLine[diffStart] == cache.rawLine[diffStart]) {
                diffStart++;
            }
        } else {
            diffStart = std::min(rel, cache.rawLine.size());
        }
        rel = diffStart; // Use diffStart to calculate the base X from the stale layout
    }

    POINT linePos{};
    if (!GetCharPos(hWnd, lineStart, &linePos)) return false;
    int lineHeight = baseLineHeight;
    if (renderActive) {
        int lineBottom = 0;
        if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line, baseLineHeight,
                                            nullptr, &lineBottom, nullptr, nullptr, nullptr, nullptr)) {
            return false;
        }
        if (lineBottom > linePos.y) {
            lineHeight = lineBottom - linePos.y;
        }
    } else if (line + 1 < lineCount) {
        LRESULT nextIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
        if (nextIdxRes >= 0) {
            POINT nextPos{};
            if (GetCharPos(hWnd, static_cast<size_t>(nextIdxRes), &nextPos)) {
                if (nextPos.y > linePos.y) {
                    lineHeight = nextPos.y - linePos.y;
                }
            }
        }
    }
    if (lineHeight <= 0) lineHeight = baseLineHeight;
    int linePaintHeight = std::max(1, lineHeight);
    int linePermille = ResolveLineHeightPermille(cache);
    int topPercent = std::clamp(g_config.noteMathMarginTopPercent, 5, 95);
    if (const note::NoteLayoutLineMetrics* metrics =
            FindAppliedNoteLayoutLineMetrics(line)) {
        linePermille = metrics->line_height_permille;
        if (metrics->top_margin_percent_override > 0) {
            topPercent = std::clamp(metrics->top_margin_percent_override, 5, 95);
        }
    }
    int renderLineY = linePos.y;
    int renderHeight = std::max(1, linePaintHeight);
    GetLineRenderMetrics(line, linePos.y, linePaintHeight, baseLineHeight, fonts.baseAscent, linePermille,
                         topPercent, &renderLineY, &renderHeight, nullptr);

    int spaceW = fonts.spaceWidth;
    if (spaceW <= 0) spaceW = fonts.baseMetrics.tmAveCharWidth;
    if (spaceW <= 0) spaceW = 1;
    int indentPx = spaceW * ResolveLineIndent(cache);
    int w = indentPx;
    int baseLineX = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x);
    int caretX = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x) + w;
    std::vector<RenderBoundary> boundaries;
    bool caretXResolvedFromBoundaries = false;
    if (BuildRenderedBoundariesForLine(hWnd, hdc, line, &boundaries) && !boundaries.empty()) {
        size_t boundaryIndex = 0;
        while (boundaryIndex + 1 < boundaries.size() &&
               boundaries[boundaryIndex + 1].raw <= clampedCaret) {
            ++boundaryIndex;
        }
        caretX = boundaries[boundaryIndex].x;
        caretXResolvedFromBoundaries = true;
    }

    if (!caretXResolvedFromBoundaries) {
        int runX = 0;
        int clientW = layoutFrame.clientWidthPx;
        const int anchorScrollX = NoteLayoutFrameAnchorScrollX(layoutFrame, hWnd);
        bool extraBold = false;
        bool extraItalic = false;
        int extraExtraPx = 0;

        for (size_t segIndex = 0; segIndex < cache.segments.size(); ++segIndex) {
            const auto& seg = cache.segments[segIndex];
            if (seg.text.empty()) continue;
            TEXTMETRICW tmSeg{};
            int segHeading = EffectiveSegmentHeadingLevel(cache, seg);
            int extraPx = ComputeSegmentFontExtraPx(segHeading, seg.style, baseLineHeight);
            bool effectiveBold = seg.style.bold || (segHeading > 0 && g_config.headingBold);

            size_t segStart = seg.rawStart;
            size_t segEnd = segStart + SegmentRawLen(seg);

            if (rel >= segStart && rel <= segEnd) {
                extraBold = effectiveBold;
                extraItalic = seg.style.italic;
                extraExtraPx = extraPx;
            }

            const std::wstring* fontFaceOverride = EffectiveSegmentFontFaceOverride(cache, seg);
            HFONT segFont = fonts.Acquire(hdc, effectiveBold, seg.style.italic, extraPx, &tmSeg,
                                          /*japanese=*/false, fontFaceOverride);
            HFONT oldSeg = nullptr;
            if (segFont) oldSeg = static_cast<HFONT>(SelectObject(hdc, segFont));

            std::vector<int> segPrefixWidths;
            bool measureAsMath = false;
            int segWidth = MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, baseLineHeight,
                                                       &segPrefixWidths, &measureAsMath);
            int segBaseX = baseLineX + indentPx + runX;
            if (SegmentUsesAnchoredLayout(seg)) {
                int anchoredRunWidth = MeasureAnchoredRunWidth(hdc, fonts, cache, segIndex, baseLineHeight);
                segBaseX = ComputeAnchoredRunStartX(hWnd, clientW, anchorScrollX, seg.style.anchor,
                                                    seg.style.anchorOffsetChars * spaceW, anchoredRunWidth);
                for (size_t prev = segIndex; prev > 0; --prev) {
                    const auto& prevSeg = cache.segments[prev - 1];
                    if (!SameAnchoredLayout(prevSeg, seg)) break;
                    if (prevSeg.text.empty()) continue;
                    segBaseX += MeasureRenderedSegmentWidth(hdc, fonts, cache, prevSeg, baseLineHeight, nullptr, nullptr);
                }
            }

            if (rel <= segStart) {
                if (oldSeg) SelectObject(hdc, oldSeg);
                break;
            }
            if (rel >= segEnd) {
                if (!SegmentUsesAnchoredLayout(seg)) {
                    runX += segWidth;
                    caretX = baseLineX + indentPx + runX;
                }
                if (oldSeg) SelectObject(hdc, oldSeg);
                continue;
            }

            size_t prefixChars = rel - segStart;
            int prefixWidth = 0;
            std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
            size_t visiblePrefixChars = VisibleCharsBeforeRawOffset(
                rawSeg, prefixChars, SegmentDecodesMarkdownBackslashEscapes(cache, seg));
            if (prefixChars > 0) {
                if (measureAsMath && !seg.text.empty()) {
                    prefixWidth = static_cast<int>(std::lround(static_cast<double>(segWidth) * visiblePrefixChars /
                                                               static_cast<double>(seg.text.size())));
                } else {
                    size_t prefixIdx = visiblePrefixChars - 1;
                    prefixWidth = (visiblePrefixChars == 0)
                                      ? 0
                                      : ((prefixIdx < segPrefixWidths.size()) ? segPrefixWidths[prefixIdx] : segWidth);
                }
            }
            caretX = segBaseX + prefixWidth;
            if (oldSeg) SelectObject(hdc, oldSeg);
            break;
        }

        size_t extraChars = (!cacheMatchesCurrentLine && newCaretRel > diffStart) ? (newCaretRel - diffStart) : 0;
        if (extraChars > 0 && !newRawLine.empty() && diffStart + extraChars <= newRawLine.size()) {
            std::wstring extraText = newRawLine.substr(diffStart, extraChars);
            caretX += MeasureStyledSegmentTextWidth(hdc, fonts, extraText,
                                                    extraBold, extraItalic, extraExtraPx);
        }
    }

    int caretTop = renderLineY + 1;
    int caretBottom = caretTop + std::max(2, renderHeight - 3);
    const int topBound = static_cast<int>(rc.top);
    const int bottomBound = static_cast<int>(rc.bottom);
    caretTop = std::clamp(caretTop, topBound, bottomBound);
    caretBottom = std::clamp(caretBottom, topBound, bottomBound);
    if (caretBottom <= caretTop) {
        caretBottom = std::min(bottomBound, caretTop + 2);
    }
    int caretWidth = std::max(1, ScaleY(hWnd, 1));
    outRect->left = caretX;
    outRect->top = caretTop;
    outRect->right = caretX + caretWidth;
    outRect->bottom = caretBottom;
    return true;
}

static bool TryGetRawCaretRect(HWND hWnd, HDC hdc, size_t caretIndex, RECT* outRect) {
    if (!hWnd || !hdc || !outRect) return false;
    if (!CanReadStableRenderDerivedState(/*requireExactRevision=*/false)) return false;

    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    if (!NoteLayoutFrameMatchesRenderSnapshot(layoutFrame, /*requireExactRevision=*/false)) return false;
    RECT rc = layoutFrame.client;
    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return false;

    int baseLineHeight = fonts.baseMetrics.tmHeight;
    if (baseLineHeight <= 0) baseLineHeight = 1;
    int textLen = GetWindowTextLengthW(hWnd);
    if (textLen < 0) textLen = 0;
    size_t clampedCaret = std::min<size_t>(caretIndex, static_cast<size_t>(textLen));

    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    const bool renderActive = layoutFrame.renderActive;
    if (renderActive) {
        logicalStarts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    }
    int lineCount = renderActive
        ? std::max<int>(1, static_cast<int>(logicalStarts.size()))
        : NoteLineCount();
    if (lineCount <= 0) lineCount = 1;
    int line = renderActive
        ? FindLogicalLineForRaw(logicalStarts, clampedCaret)
        : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, static_cast<WPARAM>(clampedCaret), 0));
    line = std::clamp(line, 0, lineCount - 1);
    if (line < 0 || line >= static_cast<int>(g_lineCache.size())) return false;

    POINT caretPos{};
    if (!GetCharPos(hWnd, clampedCaret, &caretPos)) return false;

    int lineY = caretPos.y;
    int lineHeight = baseLineHeight;
    if (renderActive) {
        int lineBottom = 0;
        if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line, baseLineHeight,
                                            &lineY, &lineBottom, nullptr, nullptr, nullptr, nullptr)) {
            return false;
        }
        if (lineBottom > lineY) {
            lineHeight = lineBottom - lineY;
        }
    } else if (line + 1 < lineCount) {
        LRESULT nextIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
        if (nextIdxRes >= 0) {
            POINT nextPos{};
            if (GetCharPos(hWnd, static_cast<size_t>(nextIdxRes), &nextPos) && nextPos.y > lineY) {
                lineHeight = nextPos.y - lineY;
            }
        }
    }
    if (lineHeight <= 0) lineHeight = baseLineHeight;

    const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
    int linePaintHeight = std::max(1, lineHeight);
    int linePermille = ResolveLineHeightPermille(cache);
    int topPercent = std::clamp(g_config.noteMathMarginTopPercent, 5, 95);
    if (const note::NoteLayoutLineMetrics* metrics =
            FindAppliedNoteLayoutLineMetrics(line)) {
        linePermille = metrics->line_height_permille;
        if (metrics->top_margin_percent_override > 0) {
            topPercent = std::clamp(metrics->top_margin_percent_override, 5, 95);
        }
    }
    int renderLineY = lineY;
    int renderHeight = std::max(1, linePaintHeight);
    GetLineRenderMetrics(line, lineY, linePaintHeight, baseLineHeight, fonts.baseAscent, linePermille,
                         topPercent, &renderLineY, &renderHeight, nullptr);

    size_t lineStart = 0;
    if (renderActive) {
        if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, line, &lineStart, nullptr, nullptr)) {
            return false;
        }
    } else {
        LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
        if (lineStartRes < 0) return false;
        lineStart = static_cast<size_t>(lineStartRes);
    }
    POINT linePos{};
    if (!GetCharPos(hWnd, lineStart, &linePos)) return false;
    
    int caretX = NoteLayoutFrameClientXFromNativeLineX(layoutFrame, linePos.x, caretPos.x);
    if (renderActive && !IsNoteImeComposing()) {
        caretX = NoteLayoutFrameClientXFromNativeLineX(layoutFrame, linePos.x, caretPos.x);
    }
    int caretTop = renderLineY + 1;
    int caretBottom = caretTop + std::max(2, renderHeight - 3);
    const int topBound = static_cast<int>(rc.top);
    const int bottomBound = static_cast<int>(rc.bottom);
    caretTop = std::clamp(caretTop, topBound, bottomBound);
    caretBottom = std::clamp(caretBottom, topBound, bottomBound);
    if (caretBottom <= caretTop) {
        caretBottom = std::min(bottomBound, caretTop + 2);
    }
    int caretWidth = std::max(1, ScaleY(hWnd, 1));
    outRect->left = caretX;
    outRect->top = caretTop;
    outRect->right = caretX + caretWidth;
    outRect->bottom = caretBottom;
    return true;
}

static std::optional<std::wstring> LinkIdAtCharIndex(HWND hWnd, size_t idx) {
    if (!NoteContentRouteSupportsLinkTargets(CurrentNoteContentRoute())) return std::nullopt;
    if (!hWnd) return std::nullopt;
    if (!CanReadStableRenderDerivedState()) return std::nullopt;
    int line = FindLineForRaw(idx);
    if (line < 0 || line >= static_cast<int>(g_lineCache.size())) return std::nullopt;
    size_t lineStart = 0;
    if (IsNoteRenderActive()) {
        if (!GetLogicalLineRangeFromStarts(GetEditTextForIndexing(hWnd), GetNoteLogicalLineStarts(hWnd), line,
                                           &lineStart, nullptr, nullptr)) {
            return std::nullopt;
        }
    } else {
        LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
        if (lineStartRes < 0) return std::nullopt;
        lineStart = static_cast<size_t>(lineStartRes);
    }
    if (idx < lineStart) return std::nullopt;
    size_t rel = idx - lineStart;

    const LineCache& cache = g_lineCache[static_cast<size_t>(line)];
    for (const auto& seg : cache.segments) {
        if (seg.text.empty()) continue;
        size_t segStart = seg.rawStart;
        size_t segEnd = segStart + SegmentRawLen(seg);
        if (rel < segStart || rel >= segEnd) continue;
        if (!seg.style.linkId.empty()) return seg.style.linkId;
        break;
    }
    return std::nullopt;
}

static std::optional<size_t> HitTestMarkupPosition(HWND hWnd, int clientX, int clientY) {
    if (!hWnd || !CanReadStableRenderDerivedState(/*requireExactRevision=*/false)) return std::nullopt;
    const NoteLayoutFrame layoutFrame = BuildNoteLayoutFrame(hWnd);
    if (!NoteLayoutFrameMatchesRenderSnapshot(layoutFrame, /*requireExactRevision=*/false)) return std::nullopt;
    RECT rc = layoutFrame.client;
    HDC hdc = GetDC(hWnd);
    if (!hdc) return std::nullopt;
    auto finish = [&](std::optional<size_t> result) {
        ReleaseDC(hWnd, hdc);
        return result;
    };
    auto queryNativeHitRaw = [&]() -> std::optional<size_t> {
        if (IsRichEditControl(hWnd)) {
            POINTL pt{ clientX, clientY };
            LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, reinterpret_cast<LPARAM>(&pt));
            if (res >= 0) {
                return ClampNoteRawIndex(static_cast<size_t>(res));
            }
            return std::nullopt;
        }
        LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, MAKELPARAM(clientX, clientY));
        if (res == -1) return std::nullopt;
        return ClampNoteRawIndex(static_cast<size_t>(LOWORD(res)));
    };
    MarkupFontProvider fonts;
    fonts.Initialize(hdc, GetActiveNoteFont());
    if (!fonts.baseFont) return finish(std::nullopt);
    int lineHeight = fonts.baseMetrics.tmHeight;
    if (lineHeight <= 0) lineHeight = 1;
    int spaceW = fonts.spaceWidth;
    if (spaceW <= 0) spaceW = fonts.baseMetrics.tmAveCharWidth;
    if (spaceW <= 0) spaceW = 1;
    std::wstring indexingText;
    std::vector<size_t> logicalStarts;
    const bool renderActive = layoutFrame.renderActive;
    if (renderActive) {
        logicalStarts = GetNoteLogicalLineStarts(hWnd, &indexingText);
    }
    int lineCount = renderActive
        ? std::max<int>(1, static_cast<int>(logicalStarts.size()))
        : NoteLineCount();
    if (lineCount <= 0) lineCount = 1;
    int maxLine = std::min<int>(lineCount - 1, static_cast<int>(g_lineCache.size()) - 1);
    if (maxLine < 0) return finish(std::nullopt);
    if (renderActive && logicalStarts.size() != g_lineCache.size()) {
        return finish(std::nullopt);
    }
    const std::optional<size_t> nativeHitRaw = queryNativeHitRaw();

    auto tryResolveNativeRawHit = [&](int rawLine, size_t* outRaw) -> bool {
        if (!outRaw || !nativeHitRaw) return false;
        if (rawLine < 0 || rawLine > maxLine) return false;
        if (!IsNoteLineRawHelper(hWnd, rawLine)) return false;
        size_t rawLineStart = 0;
        size_t rawLineEnd = 0;
        if (renderActive) {
            if (!GetLogicalLineRangeFromStarts(indexingText, logicalStarts, rawLine,
                                               &rawLineStart, &rawLineEnd, nullptr)) {
                return false;
            }
            while (rawLineEnd > rawLineStart &&
                   (indexingText[rawLineEnd - 1] == L'\n' || indexingText[rawLineEnd - 1] == L'\r')) {
                --rawLineEnd;
            }
        } else {
            LRESULT lineStartRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(rawLine), 0);
            if (lineStartRes < 0) return false;
            LRESULT lineLenRes = SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineStartRes), 0);
            if (lineLenRes < 0) lineLenRes = 0;
            rawLineStart = static_cast<size_t>(lineStartRes);
            rawLineEnd = rawLineStart + static_cast<size_t>(lineLenRes);
        }
        *outRaw = std::clamp(*nativeHitRaw, rawLineStart, rawLineEnd);
        return true;
    };
    if (nativeHitRaw) {
        int nativeHitLine = renderActive
            ? FindLineForRaw(*nativeHitRaw)
            : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, static_cast<WPARAM>(*nativeHitRaw), 0));
        size_t rawHit = 0;
        if (tryResolveNativeRawHit(nativeHitLine, &rawHit)) {
            return finish(rawHit);
        }
    }

    auto queryLineBand = [&](int line, int* outTop, int* outBottom, size_t* outStart, POINT* outPos) -> bool {
        line = std::clamp(line, 0, maxLine);
        size_t lineStart = 0;
        POINT linePos{};
        int top = 0;
        int bottom = 0;
        if (renderActive) {
            if (!QueryLogicalLineBandFromStarts(hWnd, indexingText, logicalStarts, line, lineHeight,
                                                &top, &bottom, &lineStart, nullptr, nullptr, &linePos)) {
                return false;
            }
        } else {
            LRESULT lineIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line), 0);
            if (lineIdxRes < 0) return false;
            lineStart = static_cast<size_t>(lineIdxRes);
            if (!GetCharPos(hWnd, lineStart, &linePos)) return false;
            top = linePos.y;
            bottom = top + std::max(1, lineHeight);
            if (line < maxLine) {
                LRESULT nextIdxRes = SendMessageW(hWnd, EM_LINEINDEX, static_cast<WPARAM>(line + 1), 0);
                if (nextIdxRes >= 0) {
                    POINT nextPos{};
                    if (GetCharPos(hWnd, static_cast<size_t>(nextIdxRes), &nextPos) && nextPos.y > top) {
                        bottom = nextPos.y;
                    }
                }
            } else {
                bottom = std::max(bottom, static_cast<int>(rc.bottom));
            }
        }
        if (renderActive && line == maxLine) {
            bottom = std::max(bottom, static_cast<int>(rc.bottom));
        }
        if (outTop) *outTop = top;
        if (outBottom) *outBottom = bottom;
        if (outStart) *outStart = lineStart;
        linePos.x = NoteLayoutFrameLineBaseXForRenderState(layoutFrame, linePos.x);
        if (outPos) *outPos = linePos;
        return true;
    };

    int candidate = -1;
    if (nativeHitRaw) {
        candidate = renderActive ? FindLogicalLineForRaw(logicalStarts, *nativeHitRaw)
                                 : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR,
                                                                 static_cast<WPARAM>(*nativeHitRaw), 0));
    } else if (IsRichEditControl(hWnd)) {
        POINTL pt{ clientX, clientY };
        LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, reinterpret_cast<LPARAM>(&pt));
        if (res >= 0) {
            candidate = renderActive ? FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(res))
                                     : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, res, 0));
        }
    } else {
        LRESULT res = SendMessageW(hWnd, EM_CHARFROMPOS, 0, MAKELPARAM(clientX, clientY));
        if (res != -1) {
            candidate = renderActive ? FindLogicalLineForRaw(logicalStarts, static_cast<size_t>(LOWORD(res)))
                                     : static_cast<int>(SendMessageW(hWnd, EM_LINEFROMCHAR, LOWORD(res), 0));
        }
    }
    if (candidate < 0) {
        candidate = std::max(0, clientY / std::max(1, lineHeight));
    }
    candidate = std::clamp(candidate, 0, maxLine);

    // Correct candidate by rendered Y-bands to avoid EM_CHARFROMPOS drift on sparse/blank lines.
    for (int guard = 0; guard <= maxLine + 1; ++guard) {
        int top = 0, bottom = 0;
        if (!queryLineBand(candidate, &top, &bottom, nullptr, nullptr)) break;
        if (clientY < top && candidate > 0) {
            --candidate;
            continue;
        }
        if (clientY >= bottom && candidate < maxLine) {
            ++candidate;
            continue;
        }
        break;
    }

    size_t lineStart = 0;
    POINT linePos{};
    if (!queryLineBand(candidate, nullptr, nullptr, &lineStart, &linePos)) return finish(std::nullopt);
    const LineCache& cache = g_lineCache[static_cast<size_t>(candidate)];
    int hitX = clientX - linePos.x;
    if (hitX <= 0) {
        // Clicking in the left margin should always map to the very beginning of the raw line (index 0).
        return finish(lineStart);
    }

    bool isRaw = !renderActive || IsNoteLineRawHelper(hWnd, candidate);
    if (isRaw) {
        size_t rawHit = 0;
        if (tryResolveNativeRawHit(candidate, &rawHit)) {
            return finish(rawHit);
        }
        std::wstring raw;
        if (renderActive) {
            size_t lineEnd = indexingText.size();
            if (candidate + 1 < static_cast<int>(logicalStarts.size())) {
                lineEnd = logicalStarts[static_cast<size_t>(candidate + 1)];
            }
            while (lineEnd > lineStart &&
                   (indexingText[lineEnd - 1] == L'\n' || indexingText[lineEnd - 1] == L'\r')) {
                --lineEnd;
            }
            raw.assign(indexingText, lineStart, lineEnd - lineStart);
        } else {
            LRESULT lenRes = SendMessageW(hWnd, EM_LINELENGTH, static_cast<WPARAM>(lineStart), 0);
            if (lenRes > 0) {
                raw.resize(static_cast<size_t>(lenRes));
                WORD* ptr = reinterpret_cast<WORD*>(&raw[0]);
                *ptr = static_cast<WORD>(lenRes);
                LRESULT copied = SendMessageW(
                    hWnd, EM_GETLINE, static_cast<WPARAM>(candidate),
                    reinterpret_cast<LPARAM>(&raw[0]));
                if (copied >= 0 && copied <= lenRes) {
                    raw.resize(static_cast<size_t>(copied));
                }
            }
        }
        if (raw.empty()) return finish(lineStart);

        std::vector<int> dx;
        MeasureStyledSegmentTextWidth(hdc, fonts, raw, false, false, 0, nullptr, &dx);
        if (dx.empty()) return finish(lineStart);

        size_t idx = 0;
        while (idx < dx.size() && dx[idx] < hitX) ++idx;
        if (idx >= dx.size()) idx = dx.size() - 1;

        int left = (idx == 0) ? 0 : dx[idx - 1];
        int right = dx[idx];
        size_t insertPos = (hitX >= (left + right + 1) / 2) ? (idx + 1) : idx;
        return finish(lineStart + insertPos);
    }

    int indentPx = spaceW * ResolveLineIndent(cache);
    int runX = 0;
    size_t lastRawEnd = 0;
    int clientW = layoutFrame.clientWidthPx;
    const int anchorScrollX = NoteLayoutFrameAnchorScrollX(layoutFrame, hWnd);
    for (size_t segIndex = 0; segIndex < cache.segments.size(); ++segIndex) {
        const auto& seg = cache.segments[segIndex];
        if (seg.text.empty()) continue;
        TEXTMETRICW tmSeg{};
        int segHeading = EffectiveSegmentHeadingLevel(cache, seg);
        int extraPx = ComputeSegmentFontExtraPx(segHeading, seg.style, lineHeight);
        bool effectiveBold = seg.style.bold || (segHeading > 0 && g_config.headingBold);
        const std::wstring* fontFaceOverride = EffectiveSegmentFontFaceOverride(cache, seg);
        HFONT segFont = fonts.Acquire(hdc, effectiveBold, seg.style.italic, extraPx, &tmSeg,
                                      /*japanese=*/false, fontFaceOverride);
        HFONT oldSeg = nullptr;
        if (segFont) oldSeg = static_cast<HFONT>(SelectObject(hdc, segFont));

        int segBaseX = indentPx + runX;
        if (SegmentUsesAnchoredLayout(seg)) {
            int anchoredRunWidth = MeasureAnchoredRunWidth(hdc, fonts, cache, segIndex, lineHeight);
            segBaseX = ComputeAnchoredRunStartX(hWnd, clientW, anchorScrollX, seg.style.anchor,
                                                seg.style.anchorOffsetChars * spaceW, anchoredRunWidth);
            for (size_t prev = segIndex; prev > 0; --prev) {
                const auto& prevSeg = cache.segments[prev - 1];
                if (!SameAnchoredLayout(prevSeg, seg)) break;
                if (prevSeg.text.empty()) continue;
                segBaseX += MeasureRenderedSegmentWidth(hdc, fonts, cache, prevSeg, lineHeight, nullptr, nullptr);
            }
            segBaseX -= linePos.x;
        }

        if (ShouldRenderMathSegment(seg)) {
            std::wstring mathBody = GetSegmentMathBody(seg);
            if (const mathrender::Node* node = GetCachedMathNode(mathBody)) {
                auto layout = MeasureCachedMathLayout(*node,
                                                      hdc,
                                                      mathBody,
                                                      tmSeg.tmHeight,
                                                      seg.mathDisplay ? mathrender::RenderStyle::Display
                                                                      : mathrender::RenderStyle::Inline);
                int segWidth = layout.width;
                int relX = hitX - segBaseX;
                if (relX <= 0) {
                    if (oldSeg) SelectObject(hdc, oldSeg);
                    // If this is the first segment and we are to its left, include preceding tags.
                    if (runX == 0) return finish(lineStart);
                    return finish(lineStart + seg.rawStart);
                }
                if (relX < segWidth && !seg.text.empty()) {
                    size_t len = seg.text.size();
                    size_t idx = static_cast<size_t>(std::clamp<int>(
                        static_cast<int>(std::floor(static_cast<double>(relX) * len / std::max(1, segWidth))), 0,
                        static_cast<int>(len - 1)));
                    int left = static_cast<int>(std::lround(static_cast<double>(segWidth) * idx /
                                                            static_cast<double>(len)));
                    int right = static_cast<int>(std::lround(static_cast<double>(segWidth) * (idx + 1) /
                                                             static_cast<double>(len)));
                    size_t insertPos = (relX >= (left + right + 1) / 2) ? (idx + 1) : idx;
                    if (oldSeg) SelectObject(hdc, oldSeg);

                    // If clicking the very beginning of the first character, jump outside leading tags.
                    if (runX == 0 && idx == 0 && insertPos == 0) return finish(lineStart);

                    return finish(lineStart + seg.rawStart + insertPos);
                }
                if (!SegmentUsesAnchoredLayout(seg)) runX += segWidth;
                if (oldSeg) SelectObject(hdc, oldSeg);
                lastRawEnd = seg.rawStart + SegmentRawLen(seg);
                continue;
            }
        }

        std::vector<int> dx;
        int segWidth = 0;
        int relX = hitX - segBaseX;
        if (!seg.text.empty()) {
            bool ignoredMeasureAsMath = false;
            segWidth = MeasureRenderedSegmentWidth(hdc, fonts, cache, seg, lineHeight,
                                                   &dx, &ignoredMeasureAsMath);
        }
        if (!dx.empty()) {
            if (relX <= 0) {
                if (oldSeg) SelectObject(hdc, oldSeg);
                // If this is the first segment and we are to its left, include preceding tags.
                if (runX == 0) return finish(lineStart);
                return finish(lineStart + seg.rawStart);
            }
            if (relX < segWidth) {
                size_t idx = 0;
                while (idx < dx.size() && dx[idx] < relX) ++idx;
                if (idx >= dx.size()) idx = dx.size() - 1;
                int left = (idx == 0) ? 0 : dx[idx - 1];
                int right = dx[idx];
                size_t insertPos = (relX >= (left + right + 1) / 2) ? (idx + 1) : idx;
                std::wstring rawSeg = cache.rawLine.substr(seg.rawStart, SegmentRawLen(seg));
                size_t rawInsertPos = RawOffsetForVisibleCharCount(
                    rawSeg, insertPos, SegmentDecodesMarkdownBackslashEscapes(cache, seg));
                if (oldSeg) SelectObject(hdc, oldSeg);

                // If clicking the very beginning of the first character, jump outside leading tags.
                if (runX == 0 && idx == 0 && insertPos == 0) return finish(lineStart);

                return finish(lineStart + seg.rawStart + rawInsertPos);
            }
            if (!SegmentUsesAnchoredLayout(seg)) runX += segWidth;
        } else {
            if (!SegmentUsesAnchoredLayout(seg)) runX += segWidth;
        }
        if (oldSeg) SelectObject(hdc, oldSeg);
        lastRawEnd = seg.rawStart + SegmentRawLen(seg);
    }
    size_t outRaw = lastRawEnd;
    if (outRaw > cache.rawLine.size()) outRaw = cache.rawLine.size();

    // Render-mode heuristic:
    // - Click just after the line end => stay at the end of the last segment (before trailing tags like "</h1>").
    // - Click significantly past the line end => go to the absolute end of the raw line.
    if (outRaw < cache.rawLine.size()) {
        int contentEndX = indentPx + runX;
        int extraX = hitX - contentEndX;
        if (extraX < 0) extraX = 0;
        int thresholdPx = std::max(1, spaceW * 2); 
        if (extraX > thresholdPx) {
            outRaw = cache.rawLine.size();
        }
    }
    return finish(lineStart + outRaw);
}

// very small renderer: handle single \frac{a}{b} by stacking numerator/bar/denominator
MAYBE_UNUSED static std::wstring RenderPlainMath(const std::wstring& tex) {
    auto findBrace = [&](size_t pos) -> std::optional<std::pair<size_t, size_t>> {
        if (pos >= tex.size() || tex[pos] != L'{') return std::nullopt;
        int depth = 0;
        for (size_t i = pos; i < tex.size(); ++i) {
            if (tex[i] == L'{') depth++;
            else if (tex[i] == L'}') {
                depth--;
                if (depth == 0) return std::make_pair(pos + 1, i);
            }
        }
        return std::nullopt;
    };

    size_t fracPos = tex.find(L"\\frac");
    if (fracPos != std::wstring::npos) {
        size_t numStartPos = fracPos + 5;
        auto numSpan = findBrace(numStartPos);
        if (!numSpan) return tex;
        auto denSpan = findBrace(numSpan->second + 1);
        if (!denSpan) return tex;
        std::wstring num = tex.substr(numSpan->first, numSpan->second - numSpan->first);
        std::wstring den = tex.substr(denSpan->first, denSpan->second - denSpan->first);
        size_t width = std::max(num.size(), den.size());
        if (width == 0) width = 1;
        std::wstring bar(width, L'-'); // simple ASCII bar for plain rendering
        return num + L"\n" + bar + L"\n" + den;
    }
    return tex;
}

static mathrender::Layout MeasureMathLineLayout(const std::wstring& line, HDC hdc, int fontPx,
                                                mathrender::RenderStyle style) {
    mathrender::Layout layout{};
    if (!hdc) return layout;
    if (line.empty()) {
        TEXTMETRICW tm{}; GetTextMetricsW(hdc, &tm);
        layout.width = 0;
        layout.height = tm.tmHeight;
        layout.baseline = tm.tmAscent;
        return layout;
    }
    auto node = mathrender::Parse(line);
    if (!node) return layout;
    layout = mathrender::Measure(*node, hdc, fontPx, style);
    if (layout.height <= 0) {
        TEXTMETRICW tm{}; GetTextMetricsW(hdc, &tm);
        layout.height = tm.tmHeight;
        layout.baseline = tm.tmAscent;
    }
    return layout;
}

static int MeasureMathLinePrefixWidth(const std::wstring& line, size_t endPos, HDC hdc, int fontPx,
                                      mathrender::RenderStyle style) {
    if (!hdc || endPos == 0 || endPos == std::wstring::npos) return 0;
    if (endPos > line.size()) endPos = line.size();
    std::wstring prefix = line.substr(0, endPos);
    if (prefix.empty()) return 0;
    auto node = mathrender::Parse(prefix);
    if (!node) return 0;
    auto layout = mathrender::Measure(*node, hdc, fontPx, style);
    return layout.width;
}

static std::wstring BuildSemanticHeadingListText(
    std::vector<size_t>* headingStarts = nullptr,
    std::vector<std::pair<size_t, size_t>>* headingRanges = nullptr,
    std::vector<int>* headingLevels = nullptr) {
    if (!CanReadStableSemanticIndex()) return L"";
    std::wstring out;
    for (const note::SemanticHeadingEntry& heading : CurrentNoteSemanticIndex().headings) {
        if (heading.text.empty()) continue;
        if (headingStarts) {
            const size_t pos =
                RawTextIndexToRichEditIndex(CurrentNoteSyntaxSource().raw, heading.content_span.start.value);
            headingStarts->push_back(pos);
        }
        if (headingRanges) {
            const size_t rangeStart =
                RawTextIndexToRichEditIndex(CurrentNoteSyntaxSource().raw, heading.line_span.start.value);
            const size_t rangeEnd =
                RawTextIndexToRichEditIndex(CurrentNoteSyntaxSource().raw, heading.line_span.end.value);
            headingRanges->emplace_back(rangeStart, std::max(rangeStart, rangeEnd));
        }
        if (headingLevels) {
            headingLevels->push_back(heading.level);
        }
        const int indent = (heading.level > 1) ? (heading.level - 1) : 0;
        if (!out.empty()) out.append(L"\r\n");
        if (indent > 0) out.append(static_cast<size_t>(indent * 2), L' ');
        out.append(L"- ");
        out.append(heading.text);
    }
    return out;
}

struct HeadingsPaneProjection {
    bool valid = false;
    bool empty = false;
    note::NoteDerivedSnapshotIdentity sourceIdentity{};
    std::wstring text;
    std::vector<int> headingLevels;
    std::vector<size_t> positions;
    std::vector<std::pair<size_t, size_t>> ranges;
    bool highlightBackground = false;
    int activeHeadingIdx = -1;
};

static HeadingsPaneProjection BuildHeadingsPaneProjection(
    std::pair<size_t, size_t> selectionRange) {
    HeadingsPaneProjection projection;
    projection.sourceIdentity = note::NoteDerivedSnapshotIdentity{
        CurrentNoteTextCoreOwner(), CurrentNoteTextCoreModel().revision};
    if (!CanReadStableSemanticIndex()) {
        projection.text = IsEnglishUi() ? L"(updating headings)" : L"(見出しを更新中)";
        return projection;
    }

    projection.sourceIdentity = CurrentNoteSemanticIndex().source_identity;
    projection.valid = true;
    projection.text =
        BuildSemanticHeadingListText(&projection.positions, &projection.ranges, &projection.headingLevels);
    if (projection.text.empty()) {
        projection.empty = true;
        projection.text = L"(見出しがありません)";
        return projection;
    }

    if (selectionRange.second < selectionRange.first) {
        std::swap(selectionRange.first, selectionRange.second);
    }

    const size_t caretPos = selectionRange.first;
    for (size_t i = 0; i < projection.ranges.size(); ++i) {
        size_t rangeStart = projection.ranges[i].first;
        size_t rangeEnd = projection.ranges[i].second;
        if (rangeEnd < rangeStart) rangeEnd = rangeStart;
        if (caretPos >= rangeStart && caretPos <= rangeEnd) {
            projection.activeHeadingIdx = static_cast<int>(i);
            break;
        }
    }

    return projection;
}

struct BottomPaneProjection {
    BottomNoteMode mode = BottomNoteMode::Legacy;
    note::ViewIdentity viewIdentity{};
    note::NoteDerivedSnapshotIdentity sourceIdentity{};
    bool valid = false;
    bool empty = false;
    bool muted = false;
    bool highlightBackground = false;
    bool useAssistFont = false;
    bool drawAssistSeparator = false;
    int activeLineIdx = -1;
    std::wstring text;
    BottomAssistLineLayout assistLayout;
    std::vector<size_t> headingEditPositions;
    std::vector<std::pair<size_t, size_t>> headingRanges;
    std::vector<int> headingLevels;
};

static BottomPaneProjection BuildCurrentBottomPaneProjection(BottomNoteMode mode) {
    BottomPaneProjection projection;
    projection.mode = mode;
    projection.viewIdentity = CurrentActiveNoteViewIdentity();
    projection.sourceIdentity = note::NoteDerivedSnapshotIdentity{
        projection.viewIdentity.note_id, CurrentNoteTextCoreModel().revision};

    if (mode == BottomNoteMode::Headings) {
        HeadingsPaneProjection headings =
            BuildHeadingsPaneProjection(GetNoteSelectionBounds());
        projection.sourceIdentity = headings.sourceIdentity;
        projection.valid = headings.valid;
        projection.empty = headings.empty;
        projection.muted = !headings.valid || headings.empty;
        projection.highlightBackground = headings.highlightBackground;
        projection.activeLineIdx = headings.activeHeadingIdx;
        projection.text = std::move(headings.text);
        projection.headingEditPositions = std::move(headings.positions);
        projection.headingRanges = std::move(headings.ranges);
        projection.headingLevels = std::move(headings.headingLevels);
        return projection;
    }

    projection.valid = true;
    if (mode == BottomNoteMode::Assist) {
        projection.useAssistFont = true;
        projection.drawAssistSeparator = true;
        projection.assistLayout = BuildBottomAssistLineLayout();
        projection.text = BuildBottomAssistText();
        return projection;
    }

    projection.text = g_previewNote;
    if (projection.text.empty()) {
        projection.empty = true;
        projection.muted = true;
        projection.text = L"(ノートをクリック/キー入力するとここに表示します)";
    }
    return projection;
}

bool ShouldShowBottomNotePane() {
    if (g_bottomPanePin == BottomPanePin::Math) return false;
    if (g_bottomNoteMode == BottomNoteMode::Legacy) return false;

    const BottomPaneProjection projection = BuildCurrentBottomPaneProjection(g_bottomNoteMode);
    if (projection.mode == BottomNoteMode::Headings) {
        return !projection.text.empty();
    }
    if (!projection.valid || projection.empty) return false;
    return !projection.text.empty();
}
enum class BottomPaneCommandKind {
    None,
    ToggleRender,
    ToggleWrap,
    ToggleVimControls,
    ToggleCaretLineRawText,
    ToggleClickInsert,
    ShowRawFontMenu,
    ShowRenderFontMenu,
    ShowRenderJapaneseFontMenu,
    ShowFontSizeMenu,
    ShowBackgroundMenu,
    JumpToHeading,
};

struct BottomPaneCommand {
    BottomPaneCommandKind kind = BottomPaneCommandKind::None;
    note::ViewIdentity viewIdentity{};
    note::NoteDerivedSnapshotIdentity sourceIdentity{};
    size_t editPosition = 0;
};

static BottomPaneCommand BuildBottomPaneCommandForLine(const BottomPaneProjection& projection,
                                                       int lineIdx) {
    BottomPaneCommand command;
    command.viewIdentity = projection.viewIdentity;
    command.sourceIdentity = projection.sourceIdentity;
    if (!projection.valid || lineIdx < 0) return command;

    if (projection.mode == BottomNoteMode::Headings) {
        if (lineIdx >= static_cast<int>(projection.headingEditPositions.size())) return command;
        command.kind = BottomPaneCommandKind::JumpToHeading;
        command.editPosition = projection.headingEditPositions[static_cast<size_t>(lineIdx)];
        return command;
    }

    if (projection.mode != BottomNoteMode::Assist) return command;
    const BottomAssistLineLayout& layout = projection.assistLayout;
    if (lineIdx == 0) {
        command.kind = BottomPaneCommandKind::ToggleRender;
    } else if (layout.wrapIdx >= 0 && lineIdx == layout.wrapIdx) {
        command.kind = BottomPaneCommandKind::ToggleWrap;
    } else if (lineIdx == layout.vimIdx) {
        command.kind = BottomPaneCommandKind::ToggleVimControls;
    } else if (lineIdx == layout.vimCaretLineRawTextIdx) {
        command.kind = BottomPaneCommandKind::ToggleCaretLineRawText;
    } else if (lineIdx == layout.vimClickInsertIdx) {
        command.kind = BottomPaneCommandKind::ToggleClickInsert;
    } else if (layout.rawFontIdx >= 0 && lineIdx == layout.rawFontIdx) {
        command.kind = BottomPaneCommandKind::ShowRawFontMenu;
    } else if (layout.renderFontIdx >= 0 && lineIdx == layout.renderFontIdx) {
        command.kind = BottomPaneCommandKind::ShowRenderFontMenu;
    } else if (layout.renderJpFontIdx >= 0 && lineIdx == layout.renderJpFontIdx) {
        command.kind = BottomPaneCommandKind::ShowRenderJapaneseFontMenu;
    } else if (lineIdx == layout.fontSizeIdx) {
        command.kind = BottomPaneCommandKind::ShowFontSizeMenu;
    } else if (lineIdx == layout.bgIdx) {
        command.kind = BottomPaneCommandKind::ShowBackgroundMenu;
    }
    return command;
}

static std::wstring NormalizeMarkupMathText(const std::wstring& s) {
    std::wstring out;
    out.reserve(s.size());
    for (size_t i = 0; i < s.size(); ++i) {
        wchar_t ch = s[i];
        if (ch >= 0xFF01 && ch <= 0xFF5E) {
            ch = static_cast<wchar_t>(ch - 0xFEE0);
        }
        out.push_back(ch);
    }
    std::wstring res;
    res.reserve(out.size());
    constexpr wchar_t kArrow = L'\u2192';
    constexpr wchar_t kKara0 = L'\u304b';
    constexpr wchar_t kKara1 = L'\u3089';
    for (size_t i = 0; i < out.size(); ++i) {
        if (i + 1 < out.size() && out[i] == L'-' && out[i + 1] == L'>') {
            res.push_back(kArrow);
            ++i;
            continue;
        }
        if (i + 1 < out.size() && out[i] == kKara0 && out[i + 1] == kKara1) {
            res.push_back(kArrow);
            ++i;
            continue;
        }
        res.push_back(out[i]);
    }
    return res;
}

static std::wstring StripLineJoins(const std::wstring& s) {
    std::wstring out;
    out.reserve(s.size());
    size_t i = 0;
    while (i < s.size()) {
        if (s[i] == L'\\' && i + 1 < s.size() && (s[i + 1] == L'\n' || s[i + 1] == L'\r')) {
            if (s[i + 1] == L'\r' && i + 2 < s.size() && s[i + 2] == L'\n') {
                i += 3;
            } else {
                i += 2;
            }
            continue;
        }
        out.push_back(s[i]);
        ++i;
    }
    return out;
}

static std::vector<std::wstring> SplitLines(const std::wstring& s) {
    std::vector<std::wstring> out;
    if (s.empty()) {
        out.push_back(L"");
        return out;
    }

    size_t pos = 0;
    bool endedWithBreak = false;
    while (pos < s.size()) {
        size_t end = pos;
        while (end < s.size() && s[end] != L'\r' && s[end] != L'\n') {
            ++end;
        }
        out.push_back(s.substr(pos, end - pos));

        if (end >= s.size()) {
            endedWithBreak = false;
            break;
        }

        endedWithBreak = true;
        if (s[end] == L'\r' && end + 1 < s.size() && s[end + 1] == L'\n') {
            pos = end + 2;
        } else {
            pos = end + 1;
        }
    }
    if (endedWithBreak) {
        out.push_back(L"");
    }

    return out;
}


static bool ContainsMathDepthOperator(const std::wstring& text) {
    std::wstring lower = ToLowerAscii(text);
    if (lower.find(L"lim") != std::wstring::npos) return true;
    if (lower.find(L"limsup") != std::wstring::npos) return true;
    if (lower.find(L"liminf") != std::wstring::npos) return true;
    for (wchar_t op : { L'\u222b', L'\u2211', L'\u03a3', L'\u220f' }) {
        if (text.find(op) != std::wstring::npos) return true;
    }
    return false;
}

static bool NodeHasFraction(const mathrender::Node& node) {
    if (node.type == mathrender::Node::Type::Fraction) return true;
    if (node.a && NodeHasFraction(*node.a)) return true;
    if (node.b && NodeHasFraction(*node.b)) return true;
    if (node.super && NodeHasFraction(*node.super)) return true;
    if (node.sub && NodeHasFraction(*node.sub)) return true;
    return false;
}

static std::wstring TrimMathCell(std::wstring s) {
    return TrimWhitespace(s);
}

static std::vector<std::wstring> SplitLatexRows(const std::wstring& text) {
    std::vector<std::wstring> rows;
    std::wstring cur;
    cur.reserve(text.size());
    for (size_t i = 0; i < text.size(); ++i) {
        if (text[i] == L'\\' && i + 1 < text.size() && text[i + 1] == L'\\') {
            rows.push_back(TrimMathCell(cur));
            cur.clear();
            ++i;
            continue;
        }
        if (text[i] == L'\r' || text[i] == L'\n') {
            continue;
        }
        cur.push_back(text[i]);
    }
    rows.push_back(TrimMathCell(cur));
    return rows;
}

static std::vector<std::wstring> SplitLatexColumns(const std::wstring& row) {
    std::vector<std::wstring> cols;
    std::wstring cur;
    cur.reserve(row.size());
    int braceDepth = 0;
    for (size_t i = 0; i < row.size(); ++i) {
        wchar_t ch = row[i];
        if (ch == L'{') {
            ++braceDepth;
        } else if (ch == L'}' && braceDepth > 0) {
            --braceDepth;
        }
        if (ch == L'&' && braceDepth == 0) {
            cols.push_back(TrimMathCell(cur));
            cur.clear();
            continue;
        }
        cur.push_back(ch);
    }
    cols.push_back(TrimMathCell(cur));
    return cols;
}

static bool ExtractLatexEnvironmentBody(const std::wstring& text,
                                        const wchar_t* envName,
                                        std::wstring* outBody) {
    if (!envName || !outBody) return false;
    std::wstring beginTag = L"\\begin{" + std::wstring(envName) + L"}";
    std::wstring endTag = L"\\end{" + std::wstring(envName) + L"}";
    std::wstring lower = ToLowerAscii(text);
    std::wstring lowerBegin = ToLowerAscii(beginTag);
    std::wstring lowerEnd = ToLowerAscii(endTag);
    size_t beginPos = lower.find(lowerBegin);
    if (beginPos == std::wstring::npos) return false;
    beginPos += beginTag.size();
    size_t endPos = lower.rfind(lowerEnd);
    if (endPos == std::wstring::npos || endPos < beginPos) return false;
    *outBody = text.substr(beginPos, endPos - beginPos);
    return true;
}

MAYBE_UNUSED static bool TryBuildLatexBlockDisplay(const std::wstring& rawBody, MathDisplay& d) {
    struct Candidate {
        const wchar_t* name;
        MathDisplay::LatexBlockLayout layout;
    };
    const Candidate candidates[] = {
        { L"aligned", MathDisplay::LatexBlockLayout::Aligned },
        { L"align", MathDisplay::LatexBlockLayout::Aligned },
        { L"cases", MathDisplay::LatexBlockLayout::Cases },
        { L"matrix", MathDisplay::LatexBlockLayout::Matrix },
        { L"pmatrix", MathDisplay::LatexBlockLayout::Matrix },
        { L"bmatrix", MathDisplay::LatexBlockLayout::Matrix },
        { L"vmatrix", MathDisplay::LatexBlockLayout::Matrix },
        { L"Vmatrix", MathDisplay::LatexBlockLayout::Matrix }
    };
    std::wstring body;
    for (const auto& c : candidates) {
        body.clear();
        if (!ExtractLatexEnvironmentBody(rawBody, c.name, &body)) continue;
        auto rows = SplitLatexRows(body);
        d.table.clear();
        d.table.reserve(rows.size());
        for (const auto& row : rows) {
            if (row.empty() && rows.size() > 1) continue;
            d.table.push_back(SplitLatexColumns(row));
        }
        if (d.table.empty()) {
            d.table.push_back({ L"" });
        }
        d.latexBlock = c.layout;
        d.body = body;
        d.node.reset();
        return true;
    }
    return false;
}

MAYBE_UNUSED static MathDisplay BuildMathDisplay(const MathEntry& entry) {
    MathDisplay d;
    d.kind = entry.kind;
    d.body = StripMathDelims(entry.text);
    if (entry.kind == MathKind::Latex) {
        if (TryBuildLatexBlockDisplay(d.body, d)) {
            return d;
        }
        d.node = mathrender::Parse(d.body);
        if (!d.node) {
            d.body = RenderPlainMath(d.body); // simple LaTeX-ish fallback for list/preview
        }
        return d;
    }
    std::wstring body = d.body;
    body = StripLineJoins(body);
    body = NormalizeMarkupMathText(body);
    bool hasLineBreak = (body.find(L'\n') != std::wstring::npos) || (body.find(L'\r') != std::wstring::npos);
    if (!hasLineBreak) {
        if (auto node = mathrender::Parse(body); node) {
            d.kind = MathKind::Latex;
            d.body = body;
            d.node = std::move(node);
            return d;
        }
    }
    d.body = body;
    d.lines = SplitLines(body);
    return d;
}

MAYBE_UNUSED static MathDisplay& GetCachedMathDisplay(int idx) {
    static MathDisplay empty;
    if (idx < 0 || idx >= static_cast<int>(g_mathEntries.size())) return empty;
    if (g_mathDisplayCache.size() != g_mathEntries.size()) {
        std::vector<MathDisplayCache> newCache(g_mathEntries.size());
        for (size_t i = 0; i < g_mathEntries.size(); ++i) {
            const std::wstring& targetText = g_mathEntries[i].text;
            for (size_t j = 0; j < g_mathDisplayCache.size(); ++j) {
                if (g_mathDisplayCache[j].ready && g_mathDisplayCache[j].rawText == targetText) {
                    newCache[i] = std::move(g_mathDisplayCache[j]);
                    newCache[i].ready = true;
                    g_mathDisplayCache[j].ready = false;
                    break;
                }
            }
        }
        g_mathDisplayCache = std::move(newCache);
    }
    MathDisplayCache& cache = g_mathDisplayCache[static_cast<size_t>(idx)];
    if (cache.ready && cache.rawText != g_mathEntries[static_cast<size_t>(idx)].text) {
        cache.ready = false;
    }
    if (!cache.ready) {
        cache.display = BuildMathDisplay(g_mathEntries[static_cast<size_t>(idx)]);
        cache.rawText = g_mathEntries[static_cast<size_t>(idx)].text;
        cache.ready = true;
    }
    return cache.display;
}

bool BuildBottomMathPreviewDisplay(const std::wstring& rawText, MathDisplay* outDisplay, MathKind* outKind) {
    note::MathInputAnalysis analysis = note::AnalyzeMathBoxInput(rawText);
    std::wstring text = analysis.trimmed_text;
    if (!analysis.has_input) return false;

    MathKind kind = (analysis.flavor == note::MathInputFlavor::Latex)
        ? MathKind::Latex
        : MathKind::Markup;
    if (!analysis.has_wrapping) {
        std::wstring latexBody = StripLineJoins(StripMathDelims(text));
        if (auto node = mathrender::Parse(latexBody); node) {
            kind = MathKind::Latex;
        }
    }

    MathEntry entry;
    entry.kind = kind;
    entry.text = text;
    if (outDisplay) *outDisplay = BuildMathDisplay(entry);
    if (outKind) *outKind = kind;
    return true;
}

MAYBE_UNUSED static void DrawMathDisplay(const MathDisplay& m, HDC hdc, int x, int y, int fontPx, int availW,
                                         int bottomY, mathrender::RenderStyle style, bool enhanceDepth) {
    if (m.kind == MathKind::Latex && m.latexBlock != MathDisplay::LatexBlockLayout::None) {
        TEXTMETRICW tm{}; GetTextMetricsW(hdc, &tm);
        int rowGap = std::max(4, fontPx / 4);
        int colGap = std::max(12, fontPx / 2);
        size_t maxCols = 0;
        for (const auto& row : m.table) {
            maxCols = std::max(maxCols, row.size());
        }
        std::vector<int> colWidths(maxCols, 0);
        std::vector<int> rowHeights;
        rowHeights.reserve(m.table.size());
        for (const auto& row : m.table) {
            int rowH = std::max<int>(tm.tmHeight, 1);
            for (size_t c = 0; c < row.size(); ++c) {
                auto layout = MeasureMathLineLayout(row[c], hdc, fontPx, style);
                colWidths[c] = std::max(colWidths[c], layout.width);
                rowH = std::max(rowH, layout.height);
            }
            rowHeights.push_back(rowH);
        }

        int leftBraceW = 0;
        int rightBraceW = 0;
        if (m.latexBlock == MathDisplay::LatexBlockLayout::Cases) {
            leftBraceW = std::max(8, fontPx / 2);
        } else if (m.latexBlock == MathDisplay::LatexBlockLayout::Matrix) {
            leftBraceW = std::max(6, fontPx / 3);
            rightBraceW = leftBraceW;
        }

        int totalH = 0;
        for (int h : rowHeights) totalH += h;
        if (!rowHeights.empty()) totalH += rowGap * static_cast<int>(rowHeights.size() - 1);
        int colStartX = x + leftBraceW + (leftBraceW ? 6 : 0);
        int drawY = y;

        if (leftBraceW > 0 && totalH > 0) {
            HPEN pen = CreatePen(PS_SOLID, 1, GetTextColor(hdc));
            HGDIOBJ oldPen = pen ? SelectObject(hdc, pen) : nullptr;
            int braceTop = y;
            int braceBottom = y + totalH;
            if (m.latexBlock == MathDisplay::LatexBlockLayout::Cases) {
                MoveToEx(hdc, x + leftBraceW, braceTop, nullptr);
                LineTo(hdc, x + 2, braceTop);
                LineTo(hdc, x + 2, braceTop + totalH / 2);
                LineTo(hdc, x + leftBraceW, braceTop + totalH / 2);
                MoveToEx(hdc, x + 2, braceTop + totalH / 2, nullptr);
                LineTo(hdc, x + 2, braceBottom);
                LineTo(hdc, x + leftBraceW, braceBottom);
            } else {
                MoveToEx(hdc, x + leftBraceW, braceTop, nullptr);
                LineTo(hdc, x + 2, braceTop);
                LineTo(hdc, x + 2, braceBottom);
                LineTo(hdc, x + leftBraceW, braceBottom);
                int rx = colStartX;
                int rightX = rx;
                for (size_t c = 0; c < colWidths.size(); ++c) {
                    rightX += colWidths[c];
                    if (c + 1 < colWidths.size()) rightX += colGap;
                }
                rightX += 4;
                MoveToEx(hdc, rightX, braceTop, nullptr);
                LineTo(hdc, rightX + rightBraceW - 2, braceTop);
                LineTo(hdc, rightX + rightBraceW - 2, braceBottom);
                LineTo(hdc, rightX, braceBottom);
            }
            if (oldPen) SelectObject(hdc, oldPen);
            if (pen) DeleteObject(pen);
        }

        for (size_t r = 0; r < m.table.size(); ++r) {
            int rowX = colStartX;
            const auto& row = m.table[r];
            for (size_t c = 0; c < row.size(); ++c) {
                auto node = mathrender::Parse(row[c]);
                auto layout = MeasureMathLineLayout(row[c], hdc, fontPx, style);
                int cellX = rowX;
                if (m.latexBlock == MathDisplay::LatexBlockLayout::Matrix) {
                    cellX += (colWidths[c] - layout.width) / 2;
                }
                if (node) {
                    mathrender::Draw(*node, layout, hdc, cellX, drawY, fontPx, GetTextColor(hdc), style);
                } else if (!row[c].empty()) {
                    RECT cellRc{ cellX, drawY, cellX + colWidths[c], drawY + rowHeights[r] };
                    DrawTextW(hdc, row[c].c_str(), -1, &cellRc, DT_LEFT | DT_TOP | DT_NOPREFIX | DT_END_ELLIPSIS);
                }
                rowX += colWidths[c] + colGap;
            }
            drawY += rowHeights[r] + rowGap;
            if (drawY >= bottomY) break;
        }
        return;
    }
    if (m.kind == MathKind::Latex && m.node) {
        COLORREF textColor = GetTextColor(hdc);
        bool useDepth = enhanceDepth &&
                        (style == mathrender::RenderStyle::Display) &&
                        (ContainsMathDepthOperator(m.body) || NodeHasFraction(*m.node));
        auto layout = mathrender::Measure(*m.node, hdc, fontPx, style);
        if (useDepth) {
            COLORREF shadowColor = AdjustColorBrightness(textColor, -90);
            mathrender::Draw(*m.node, layout, hdc, x + 2, y + 1, fontPx, shadowColor, style);
        }
        if (useDepth && NodeHasFraction(*m.node)) {
            COLORREF glowColor = AdjustColorBrightness(textColor, 40);
            mathrender::Draw(*m.node, layout, hdc, x - 1, y, fontPx, glowColor, style);
        }
        mathrender::Draw(*m.node, layout, hdc, x, y, fontPx, textColor, style);
        return;
    }
    if (m.kind == MathKind::Markup) {
        TEXTMETRICW tm{};
        GetTextMetricsW(hdc, &tm);
        int maxLeft = 0;
        bool hasEq = false;
        std::vector<size_t> opIdx;
        std::vector<int> leftWidths;
        opIdx.reserve(m.lines.size());
        leftWidths.reserve(m.lines.size());
        for (const auto& line : m.lines) {
            size_t eqPos = line.find(L'=');
            size_t pos = eqPos;
            if (eqPos != std::wstring::npos) {
                hasEq = true;
            } else {
                size_t plus = line.find(L'+');
                size_t minus = line.find(L'-');
                size_t mul = line.find(L'*');
                size_t div = line.find(L'/');
                pos = std::min({ plus, minus, mul, div });
            }
            opIdx.push_back(pos);
            leftWidths.push_back(0);
        }
        for (size_t i = 0; i < m.lines.size(); ++i) {
            if (opIdx[i] == std::wstring::npos) continue;
            if (hasEq && m.lines[i].find(L'=') == std::wstring::npos) continue;
            int w = MeasureMathLinePrefixWidth(m.lines[i], opIdx[i], hdc, fontPx, style);
            leftWidths[i] = w;
            maxLeft = std::max(maxLeft, w);
        }
        int drawY = y;
        for (size_t i = 0; i < m.lines.size(); ++i) {
            int offset = 0;
            if (opIdx[i] != std::wstring::npos) {
                if (!hasEq || m.lines[i].find(L'=') != std::wstring::npos) {
                    offset = maxLeft - leftWidths[i];
                }
            }
            if (!m.lines[i].empty()) {
                auto node = mathrender::Parse(m.lines[i]);
                if (node) {
                    auto layout = mathrender::Measure(*node, hdc, fontPx, style);
                    mathrender::Draw(*node, layout, hdc, x + offset, drawY, fontPx, GetTextColor(hdc), style);
                    drawY += std::max(layout.height, static_cast<int>(tm.tmHeight));
                    continue;
                }
            }
            drawY += tm.tmHeight;
        }
        return;
    }
    RECT textRc{ x, y, x + availW, bottomY };
    DrawTextW(hdc, m.body.c_str(), -1, &textRc, DT_LEFT | DT_TOP | DT_WORDBREAK);
}

MAYBE_UNUSED static SIZE MeasureMathDisplayExtentNoWrap(const MathDisplay& m, HDC hdc, int fontPx,
                                                        mathrender::RenderStyle style) {
    SIZE out{};
    if (m.kind == MathKind::Latex && m.latexBlock != MathDisplay::LatexBlockLayout::None) {
        TEXTMETRICW tm{}; GetTextMetricsW(hdc, &tm);
        int rowGap = std::max(4, fontPx / 4);
        int colGap = std::max(12, fontPx / 2);
        size_t maxCols = 0;
        for (const auto& row : m.table) {
            maxCols = std::max(maxCols, row.size());
        }
        std::vector<int> colWidths(maxCols, 0);
        int totalH = 0;
        for (size_t r = 0; r < m.table.size(); ++r) {
            int rowH = std::max<int>(tm.tmHeight, 1);
            int rowW = 0;
            for (size_t c = 0; c < m.table[r].size(); ++c) {
                auto layout = MeasureMathLineLayout(m.table[r][c], hdc, fontPx, style);
                colWidths[c] = std::max(colWidths[c], layout.width);
                rowH = std::max(rowH, layout.height);
            }
            for (size_t c = 0; c < m.table[r].size(); ++c) {
                rowW += colWidths[c];
                if (c + 1 < m.table[r].size()) rowW += colGap;
            }
            out.cx = std::max<int>(static_cast<int>(out.cx), rowW);
            totalH += rowH;
            if (r + 1 < m.table.size()) totalH += rowGap;
        }
        int braceW = 0;
        if (m.latexBlock == MathDisplay::LatexBlockLayout::Cases) {
            braceW = std::max(8, fontPx / 2) + 6;
        } else if (m.latexBlock == MathDisplay::LatexBlockLayout::Matrix) {
            braceW = (std::max(6, fontPx / 3) + 4) * 2;
        }
        out.cx += braceW;
        out.cy = totalH;
        return out;
    }
    if (m.kind == MathKind::Latex && m.node) {
        auto layout = mathrender::Measure(*m.node, hdc, fontPx, style);
        out.cx = layout.width;
        out.cy = layout.height;
        return out;
    }
    if (m.kind == MathKind::Markup) {
        TEXTMETRICW tm{}; GetTextMetricsW(hdc, &tm);
        int totalH = 0;
        int maxW = 0;
        int maxLeft = 0;
        bool hasEq = false;
        std::vector<size_t> opIdx;
        std::vector<int> leftWidths;
        opIdx.reserve(m.lines.size());
        leftWidths.reserve(m.lines.size());
        for (const auto& line : m.lines) {
            size_t eqPos = line.find(L'=');
            size_t pos = eqPos;
            if (eqPos != std::wstring::npos) {
                hasEq = true;
            } else {
                size_t plus = line.find(L'+');
                size_t minus = line.find(L'-');
                size_t mul = line.find(L'*');
                size_t div = line.find(L'/');
                pos = std::min({ plus, minus, mul, div });
            }
            opIdx.push_back(pos);
            leftWidths.push_back(0);
        }
        for (size_t i = 0; i < m.lines.size(); ++i) {
            if (opIdx[i] == std::wstring::npos) continue;
            if (hasEq && m.lines[i].find(L'=') == std::wstring::npos) continue;
            int w = MeasureMathLinePrefixWidth(m.lines[i], opIdx[i], hdc, fontPx, style);
            leftWidths[i] = w;
            maxLeft = std::max(maxLeft, w);
        }
        for (size_t i = 0; i < m.lines.size(); ++i) {
            auto layout = MeasureMathLineLayout(m.lines[i], hdc, fontPx, style);
            int offset = 0;
            if (opIdx[i] != std::wstring::npos &&
                (!hasEq || m.lines[i].find(L'=') != std::wstring::npos)) {
                offset = maxLeft - leftWidths[i];
            }
            maxW = std::max(maxW, offset + layout.width);
            totalH += std::max(layout.height, static_cast<int>(tm.tmHeight));
        }
        out.cx = maxW;
        out.cy = totalH;
        return out;
    }
    TEXTMETRICW tm{}; GetTextMetricsW(hdc, &tm);
    SIZE sz{};
    if (!m.body.empty()) {
        GetTextExtentPoint32W(hdc, m.body.c_str(), static_cast<int>(m.body.size()), &sz);
    }
    out.cx = sz.cx;
    out.cy = std::max<int>(tm.tmHeight, sz.cy);
    return out;
}

MAYBE_UNUSED void DrawMathDisplayNoWrap(const MathDisplay& m, HDC hdc, const RECT& rc, int fontPx,
                                        mathrender::RenderStyle style, int scrollX,
                                        bool enhanceDepth = true) {
    if (rc.right <= rc.left || rc.bottom <= rc.top) return;
    const bool structured = (m.kind == MathKind::Markup) ||
                            (m.kind == MathKind::Latex &&
                             (m.node || m.latexBlock != MathDisplay::LatexBlockLayout::None));
    if (!structured) {
        SIZE sz{};
        if (!m.body.empty()) {
            GetTextExtentPoint32W(hdc, m.body.c_str(), static_cast<int>(m.body.size()), &sz);
        }
        int viewW = std::max<int>(1, static_cast<int>(rc.right - rc.left));
        int drawX = rc.left;
        if (sz.cx > viewW) {
            drawX = rc.left - std::max(0, scrollX);
        }
        RECT textRc{ drawX, rc.top, drawX + std::max(viewW, static_cast<int>(sz.cx)), rc.bottom };
        int saved = SaveDC(hdc);
        IntersectClipRect(hdc, rc.left, rc.top, rc.right, rc.bottom);
        DrawTextW(hdc, m.body.c_str(), -1, &textRc,
                  DT_LEFT | DT_VCENTER | DT_SINGLELINE | DT_NOPREFIX);
        RestoreDC(hdc, saved);
        return;
    }
    SIZE extent = MeasureMathDisplayExtentNoWrap(m, hdc, fontPx, style);
    int drawX = rc.left;
    int viewW = std::max<int>(1, static_cast<int>(rc.right - rc.left));
    if (extent.cx > viewW) {
        drawX = rc.left - std::max(0, scrollX);
    } else if (extent.cx > 0 && extent.cx < viewW) {
        drawX = rc.left + (viewW - extent.cx) / 2;
    }
    int drawY = rc.top;
    if (extent.cy > 0 && extent.cy < (rc.bottom - rc.top)) {
        drawY = rc.top + ((rc.bottom - rc.top) - extent.cy) / 2;
    }
    int saved = SaveDC(hdc);
    IntersectClipRect(hdc, rc.left, rc.top, rc.right, rc.bottom);
    DrawMathDisplay(m, hdc, drawX, drawY, fontPx,
                    std::max<int>(1, static_cast<int>(rc.right - rc.left)),
                    static_cast<int>(rc.bottom), style, enhanceDepth);
    RestoreDC(hdc, saved);
}
