// file: main/main_view_layout.cpp
// NOTE: This file is intentionally included by `src/main.cpp` to keep the build as a
// single translation unit while physically splitting responsibilities.

// ---------------------------------------------------------------------
// Layout and UI creation
// ---------------------------------------------------------------------
static bool IsAnnotOptionCycleComboId(int id) {
    switch (id) {
    case ID_TOOL_FONT:
    case ID_TOOL_FONT_SIZE:
    case ID_TOOL_FONT_SIZE_ALT:
    case ID_TOOL_WIDTH:
    case ID_TOOL_MARKER_ALPHA:
    case ID_TOOL_ANNOT_METHOD:
    case ID_TOOL_FREEHAND_CORRECTION:
    case ID_TOOL_MARKER_TEXT_STYLE:
    case ID_TOOL_LINE_DASH_STYLE:
    case ID_TOOL_SHAPE_KIND:
    case ID_TOOL_SHAPE_GEOMETRY:
    case ID_TOOL_SHAPE_DRAW_MODE:
    case ID_TOOL_MAGNIFIER_SHAPE:
        return true;
    default:
        return false;
    }
}

static LRESULT CALLBACK AnnotOptionCycleComboProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam,
                                                  UINT_PTR, DWORD_PTR) {
    switch (msg) {
    case WM_LBUTTONDOWN:
        {
            if (IsAnnotOptionCycleComboId(static_cast<int>(GetWindowLongPtrW(hWnd, GWLP_ID)))) {
                SetFocus(hWnd);
                SendMessageW(hWnd, CB_SHOWDROPDOWN, TRUE, 0);
                return 0;
            }
            break;
        }
    case WM_LBUTTONDBLCLK:
        if (IsAnnotOptionCycleComboId(static_cast<int>(GetWindowLongPtrW(hWnd, GWLP_ID)))) {
            SendMessageW(hWnd, CB_SHOWDROPDOWN, TRUE, 0);
        }
        return 0;
    default:
        break;
    }
    return DefSubclassProc(hWnd, msg, wParam, lParam);
}

static void InstallAnnotOptionCycleCombo(HWND combo) {
    if (!combo) return;
    const int id = static_cast<int>(GetWindowLongPtrW(combo, GWLP_ID));
    if (!IsAnnotOptionCycleComboId(id)) return;
    SetWindowSubclass(combo, AnnotOptionCycleComboProc, 2, 0);
}

