int CurrentLectureIndex() {
    for (size_t i = 0; i < g_lectures.size(); ++i) {
        if (g_lectures[i] == g_currentLecturePath) return static_cast<int>(i);
    }
    return -1;
}
int CurrentSessionIndex() {
    auto curCanon = g_currentSessionPath.empty() ? std::filesystem::path{} : CanonicalOrSelf(std::filesystem::path(g_currentSessionPath));
    for (size_t i = 0; i < g_sessions.size(); ++i) {
        const auto& s = g_sessions[i];
        auto pathCanon = CanonicalOrSelf(std::filesystem::path(s.path));
        if (!curCanon.empty() && pathCanon == curCanon) {
            return static_cast<int>(i);
        }
    }
    return -1;
}

int CurrentPdfIndex() {
    if (CurrentLogicalPdfPath().empty()) return -1;
    for (size_t i = 0; i < g_pdfFiles.size(); ++i) {
        if (g_pdfFiles[i].path == CurrentLogicalPdfPath()) return static_cast<int>(i);
    }
    return -1;
}

int CurrentNoteIndex() {
    if (g_currentNotePath.empty()) return -1;
    for (size_t i = 0; i < g_noteFiles.size(); ++i) {
        if (g_noteFiles[i].path == g_currentNotePath) return static_cast<int>(i);
    }
    return -1;
}

struct SessionOrganizeStats {
    int candidates = 0;
    int moved = 0;
    int renamedOnConflict = 0;
    int failed = 0;
    std::vector<std::wstring> failures;
};

static std::filesystem::path BuildConflictFreePath(const std::filesystem::path& destDir,
                                                   const std::filesystem::path& fileName) {
    std::error_code ec;
    std::filesystem::path base = fileName.stem();
    std::filesystem::path ext = fileName.extension();
    std::filesystem::path candidate = destDir / fileName;
    int suffix = 1;
    while (std::filesystem::exists(candidate, ec) && !ec) {
        candidate = destDir / (base.wstring() + L" (" + std::to_wstring(suffix) + L")" + ext.wstring());
        ++suffix;
    }
    return candidate;
}

static SessionOrganizeStats NormalizeCacheSession(const std::filesystem::path& sessionRoot) {
    SessionOrganizeStats stats;
    std::error_code ec;
    auto pdfDir  = sessionRoot / L"pdf";
    auto noteDir = sessionRoot / L"note";
    std::filesystem::create_directories(pdfDir, ec);
    if (ec) {
        stats.failed++;
        stats.failures.push_back(L"failed to create directory: " + pdfDir.wstring());
        return stats;
    }
    ec.clear();
    std::filesystem::create_directories(noteDir, ec);
    if (ec) {
        stats.failed++;
        stats.failures.push_back(L"failed to create directory: " + noteDir.wstring());
        return stats;
    }
    ec.clear();

    for (const auto& entry : std::filesystem::directory_iterator(sessionRoot, ec)) {
        bool isReparse = false;
        if (TryIsReparsePointNoFollow(entry.path(), isReparse) && isReparse) continue;
        std::error_code stEc;
        if (!entry.is_regular_file(stEc) || stEc) continue;
        auto src = entry.path();
        auto ext = src.extension().wstring();
        std::transform(ext.begin(), ext.end(), ext.begin(), ::towlower);
        bool isPdf = IsPdfFile(src);
        bool isClrop = (ext == L".clrop");

        std::filesystem::path destDir;
        if (isPdf || IsImageFile(src) || isClrop) {
            destDir = pdfDir;
        } else if (IsNoteFile(src)) {
            destDir = noteDir;
        } else {
            continue;
        }
        stats.candidates++;

        std::filesystem::path dest = destDir / src.filename();
        if (CanonicalOrSelf(src) == CanonicalOrSelf(dest)) continue;
        if (std::filesystem::exists(dest, ec) && !ec) {
            dest = BuildConflictFreePath(destDir, src.filename());
            if (dest.filename() != src.filename()) {
                stats.renamedOnConflict++;
            }
        }
        ec.clear();

        std::filesystem::rename(src, dest, ec);
        if (!ec) {
            if (isPdf) {
                MovePdfViewInfoPath(src.wstring(), dest.wstring());
            }
            stats.moved++;
            continue;
        }

        ec.clear();
        std::filesystem::copy_file(src, dest, std::filesystem::copy_options::none, ec);
        if (ec) {
            stats.failed++;
            stats.failures.push_back(src.wstring() + L" -> " + dest.wstring());
            continue;
        }

        ec.clear();
        std::filesystem::remove(src, ec);
        if (ec) {
            stats.failed++;
            stats.failures.push_back(L"copied but source remove failed: " + src.wstring());
            continue;
        }
        if (isPdf) {
            MovePdfViewInfoPath(src.wstring(), dest.wstring());
        }
        stats.moved++;
    }
    return stats;
}

static void OrganizeCurrentSessionFiles(HWND hWnd) {
    const auto& ui = GetUiText();
    if (g_currentSessionPath.empty()) {
        ShowSoftNotice(hWnd, ui.errNewClroNoSession, SoftNoticeKind::Warning);
        return;
    }

    std::filesystem::path sessionRoot(g_currentSessionPath);
    std::error_code ec;
    if (!std::filesystem::exists(sessionRoot, ec) || !std::filesystem::is_directory(sessionRoot, ec)) {
        std::wstring msg = ui.errImportFile + L"\n" + sessionRoot.wstring();
        ShowSilentMessageDialog(hWnd, ui.menuOrganizeSessionFiles, msg, SoftNoticeKind::Error);
        return;
    }

    int candidates = 0;
    for (const auto& entry : std::filesystem::directory_iterator(sessionRoot, ec)) {
        bool isReparse = false;
        if (TryIsReparsePointNoFollow(entry.path(), isReparse) && isReparse) continue;
        std::error_code stEc;
        if (!entry.is_regular_file(stEc) || stEc) continue;
        auto path = entry.path();
        auto ext = path.extension().wstring();
        std::transform(ext.begin(), ext.end(), ext.begin(), ::towlower);
        bool isClrop = (ext == L".clrop");
        if (IsPdfFile(path) || IsImageFile(path) || isClrop || IsNoteFile(path)) {
            ++candidates;
        }
    }
    if (candidates <= 0) {
        std::wstring msg = IsEnglishUi() ? L"No files to organize." : L"整理するファイルはありません。";
        ShowSoftNotice(hWnd, msg);
        return;
    }

    if (!SaveNoteIfDirty(hWnd)) return;

    std::filesystem::path pdfDir  = sessionRoot / L"pdf";
    std::filesystem::path noteDir = sessionRoot / L"note";
    std::filesystem::path reopenPdfPath;
    std::filesystem::path reloadNotePath;

    if (g_pdf.kind != DocKind::None && !CurrentLogicalPdfPath().empty()) {
        std::filesystem::path currentPdf(CurrentLogicalPdfPath());
        bool isAtRoot = (CanonicalOrSelf(currentPdf.parent_path()) == CanonicalOrSelf(sessionRoot));
        if (isAtRoot && (IsPdfFile(currentPdf) || IsImageFile(currentPdf))) {
            reopenPdfPath = pdfDir / currentPdf.filename();
            if (IsPdfFile(currentPdf)) {
                SaveLastPdfViewInfo();
            }
            ClearPdfState();
            if (g_hPdfView) InvalidateRect(g_hPdfView, nullptr, FALSE);
        }
    }
    if (!g_currentNotePath.empty()) {
        std::filesystem::path currentNote(g_currentNotePath);
        if (CanonicalOrSelf(currentNote.parent_path()) == CanonicalOrSelf(sessionRoot) && IsNoteFile(currentNote)) {
            reloadNotePath = noteDir / currentNote.filename();
        }
    }

    SessionOrganizeStats organizeStats = NormalizeCacheSession(sessionRoot);
    RefreshCurrentSessionFiles();

    if (!reloadNotePath.empty() && std::filesystem::exists(reloadNotePath, ec)) {
        LoadNoteFile(hWnd, reloadNotePath.wstring());
    }
    if (!reopenPdfPath.empty() && std::filesystem::exists(reopenPdfPath, ec)) {
        EndIntegratedPdfPreviewMode(hWnd, true);
        OpenPdfWithAnnotations(hWnd, reopenPdfPath.wstring());
    }

    std::wstring msg;
    if (organizeStats.failed > 0) {
        msg = IsEnglishUi() ? L"Organize finished with warnings." : L"整理処理を完了しました（一部警告あり）。";
        msg += (IsEnglishUi() ? L"\nMoved: " : L"\n移動: ") + std::to_wstring(organizeStats.moved);
        msg += (IsEnglishUi() ? L"\nFailed: " : L"\n失敗: ") + std::to_wstring(organizeStats.failed);
        if (!organizeStats.failures.empty()) {
            msg += IsEnglishUi() ? L"\n\nDetails:\n" : L"\n\n詳細:\n";
            const size_t limit = std::min<size_t>(organizeStats.failures.size(), 6);
            for (size_t i = 0; i < limit; ++i) {
                msg += L" - " + organizeStats.failures[i] + L"\n";
            }
            if (organizeStats.failures.size() > limit) {
                msg += L" - ...\n";
            }
        }
    } else if (organizeStats.candidates <= 0) {
        msg = IsEnglishUi() ? L"No files to organize." : L"整理するファイルはありません。";
    } else {
        msg = IsEnglishUi() ? L"Organized files into \"pdf\" / \"note\" folders." : L"\"pdf\" / \"note\" フォルダに整理しました。";
        if (organizeStats.renamedOnConflict > 0) {
            msg += IsEnglishUi()
                ? L"\nName conflicts were kept safely by renaming destination files."
                : L"\n同名衝突は上書きせず、別名で安全に保存しました。";
        }
    }

    if (g_hBtnModeMarker) ShowWindow(g_hBtnModeMarker, SW_HIDE);
    if (g_hBtnModeMarkerFree) ShowWindow(g_hBtnModeMarkerFree, SW_HIDE);
    if (g_hBtnModeMarkerLine) ShowWindow(g_hBtnModeMarkerLine, SW_HIDE);
    if (g_hBtnModeMarkerArrow) ShowWindow(g_hBtnModeMarkerArrow, SW_HIDE);
    if (g_hBtnModeMarkerWave) ShowWindow(g_hBtnModeMarkerWave, SW_HIDE);
    if (g_hBtnModeLine) ShowWindow(g_hBtnModeLine, SW_HIDE);
    if (g_hBtnModeArrow) ShowWindow(g_hBtnModeArrow, SW_HIDE);
    if (g_hBtnModeWave) ShowWindow(g_hBtnModeWave, SW_HIDE);
    if (g_hBtnModeFreehand) ShowWindow(g_hBtnModeFreehand, SW_HIDE);
    if (organizeStats.failed > 0) {
        ShowSilentMessageDialog(hWnd, ui.menuOrganizeSessionFiles, msg, SoftNoticeKind::Warning);
    } else {
        ShowSoftNotice(hWnd, msg);
    }
}

static int PromptCompleteOffStageActionOnExit(HWND hWnd) {
    std::wstring msg = IsEnglishUi()
        ? L"There are unintegrated staged changes. Choose how to exit.\n\n"
          L"Yes:\n"
          L"Save to the original now, then exit.\n\n"
          L"No:\n"
          L"Exit without saving to the original and keep staged changes.\n\n"
          L"Cancel:\n"
          L"Return to the app without exiting."
        : L"未統合の stage 差分があります。終了方法を選んでください。\n\n"
          L"はい:\n"
          L"いま原本へ保存してから終了します。\n\n"
          L"いいえ:\n"
          L"原本へ保存せず、stage 差分を残したまま終了します。\n\n"
          L"キャンセル:\n"
          L"終了せずアプリに戻ります。";
    const std::wstring stagedLocations = file_output::FormatStagedDiffLocationSummary();
    if (!stagedLocations.empty()) {
        msg += IsEnglishUi() ? L"\n\nStaged diff details:\n\n" : L"\n\n未統合差分の詳細:\n\n";
        msg += stagedLocations;
    }
    SilentDialogOptions dialog;
    dialog.title = IsEnglishUi() ? L"Exit confirmation" : L"終了確認";
    dialog.message = msg;
    dialog.kind = SoftNoticeKind::Warning;
    dialog.buttons = SilentDialogButtons::YesNoCancel;
    dialog.defaultResult = SilentDialogResult::Yes;
    dialog.escapeResult = SilentDialogResult::Cancel;
    dialog.preferredWidthPx = 680;
    SilentDialogResult res = ShowSilentDialog(hWnd, dialog);
    if (res == SilentDialogResult::Yes) return IDYES;
    if (res == SilentDialogResult::No) return IDNO;
    return IDCANCEL;
}

static bool CommitActiveEditsForAppExit(HWND hWnd) {
    if (!CommitActiveNoteEditBoundary(hWnd)) return false;
    EndInlineTextEditing(g_hPdfView, true);
    return true;
}

static void FinalizeAppExitState(HWND hWnd, const std::wstring& previewTempPath) {
    UpdateWindowTitle(hWnd);
    RefreshStatusDisplay(hWnd);
    if (g_pdfPreviewActive) {
        EndIntegratedPdfPreviewMode(hWnd, /*restoreOriginalPdf=*/false);
    }
    if (!previewTempPath.empty()) {
        std::filesystem::path previewTemp(previewTempPath);
        std::error_code ec;
        std::filesystem::remove(previewTemp, ec);
        const std::filesystem::path siblingA = previewTemp.parent_path() / L"note_preview.pdf";
        const std::filesystem::path siblingB = previewTemp.parent_path() / L"note_preview_alt.pdf";
        if (previewTemp.filename() == L"note_preview.pdf") {
            std::filesystem::remove(siblingB, ec);
        } else if (previewTemp.filename() == L"note_preview_alt.pdf") {
            std::filesystem::remove(siblingA, ec);
        }
    }
    SaveLastPdfViewInfo();
    PersistTempExternalLecturesToSetup(); // best-effort: keep external lecture paths across restarts
    ClearPdfState();
    g_tempExternalLectures.clear();
}

static bool HandleManagedAbnormalExit(HWND hWnd) {
    const ULONGLONG startTick = preview_trace::TickNow();
    preview_trace::Append(
        L"ManagedAbnormalExit",
        L"begin noteDirty=" + preview_trace::Bool(g_noteDirty) +
        L" noteNeedsIntegrate=" + preview_trace::Bool(g_noteNeedsIntegrate) +
        L" annotsDirty=" + preview_trace::Bool(g_annotsDirty) +
        L" annotsNeedsIntegrate=" + preview_trace::Bool(g_annotsNeedsIntegrate));
    CancelPendingLinkMode(hWnd);
    if (!CommitActiveEditsForAppExit(hWnd)) {
        ClearManagedAbnormalExitRequest();
        preview_trace::Append(
            L"ManagedAbnormalExit",
            L"abort=commit_active_edits_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return false;
    }

    const bool noteHadDirty = g_noteDirty;
    const bool annotHadDirty = g_annotsDirty;
    const std::wstring previewTempPath = g_pdfPreviewTempPath;
    const bool noteStageOk = SaveNoteIfDirty(hWnd);
    const bool annotStageOk = SaveAnnotationsIfDirty(hWnd);
    if (!noteStageOk || !annotStageOk) {
        ClearManagedAbnormalExitRequest();
        ShowMainMessageDialog(
            hWnd,
            IsEnglishUi() ? L"Abnormal exit canceled" : L"異常終了を中止しました",
            IsEnglishUi()
                ? L"Unsaved edits could not be preserved to stage, so the abnormal exit was canceled."
                : L"未保存の編集を stage に保護できなかったため、異常終了を中止しました。",
            SoftNoticeKind::Error);
        preview_trace::Append(
            L"ManagedAbnormalExit",
            L"abort=stage_preserve_failed noteOk=" + preview_trace::Bool(noteStageOk) +
            L" annotOk=" + preview_trace::Bool(annotStageOk) +
            L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return false;
    }

    RememberCurrentSessionFiles();
    s_managedAbnormalExit.reportText =
        BuildManagedAbnormalExitReportText(noteHadDirty, noteStageOk, annotHadDirty, annotStageOk);
    s_managedAbnormalExit.reportPending = true;
    s_managedAbnormalExit.completed = true;
    s_managedAbnormalExit.requested = false;
    AppendCrashLogWide(L"ManagedAbnormalExitReport", s_managedAbnormalExit.reportText);
    FinalizeAppExitState(hWnd, previewTempPath);
    preview_trace::Append(
        L"ManagedAbnormalExit",
        L"end elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    return true;
}

static bool HandleAppExit(HWND hWnd) {
    const ULONGLONG startTick = preview_trace::TickNow();
    preview_trace::Append(
        L"HandleAppExit",
        L"begin notePath=" + g_currentNotePath +
        L" pdfPath=" + g_pdf.path +
        L" previewActive=" + preview_trace::Bool(g_pdfPreviewActive) +
        L" noteDirty=" + preview_trace::Bool(g_noteDirty) +
        L" noteNeedsIntegrate=" + preview_trace::Bool(g_noteNeedsIntegrate) +
        L" annotsDirty=" + preview_trace::Bool(g_annotsDirty) +
        L" annotsNeedsIntegrate=" + preview_trace::Bool(g_annotsNeedsIntegrate));
    if (s_managedAbnormalExit.requested) {
        return HandleManagedAbnormalExit(hWnd);
    }
    CancelPendingLinkMode(hWnd);
    if (!CommitActiveEditsForAppExit(hWnd)) {
        preview_trace::Append(
            L"HandleAppExit",
            L"abort=commit_active_edits_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return false;
    }
    RememberCurrentSessionFiles();
    const std::wstring previewTempPath = g_pdfPreviewTempPath;
    if (!SaveNoteIfDirty(hWnd)) {
        preview_trace::Append(
            L"HandleAppExit",
            L"abort=save_note_if_dirty_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return PromptStayOrOpenDiffManager(
            hWnd,
            IsEnglishUi() ? L"Exiting the app" : L"アプリ終了",
            IsEnglishUi() ? L"Please resolve the pending diff from Diff Manager, then try exiting again."
                          : L"「差分管理」で未統合差分を整理してから、もう一度終了してください。");
    }
    if (!SaveAnnotationsIfDirty(hWnd)) {
        preview_trace::Append(
            L"HandleAppExit",
            L"abort=save_annotations_if_dirty_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return PromptStayOrOpenDiffManager(
            hWnd,
            IsEnglishUi() ? L"Exiting the app" : L"アプリ終了",
            IsEnglishUi() ? L"Please resolve the pending diff from Diff Manager, then try exiting again."
                          : L"「差分管理」で未統合差分を整理してから、もう一度終了してください。");
    }
    const bool hasStagedDiffs = file_output::HasAnyStagedDiffs();
    preview_trace::Append(
        L"HandleAppExit",
        L"post_stage_save hasStagedDiffs=" + preview_trace::Bool(hasStagedDiffs) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
    if (hasStagedDiffs) {
        int action = PromptCompleteOffStageActionOnExit(hWnd);
        preview_trace::Append(
            L"HandleAppExit",
            L"staged_action=" + std::to_wstring(action) +
            L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        if (action == IDCANCEL) {
            preview_trace::Append(
                L"HandleAppExit",
                L"abort=user_canceled elapsed_ms=" + preview_trace::ElapsedMs(startTick));
            return false;
        }
        if (action == IDYES) {
            if (!file_output::IntegrateStagedNoteAndAnnotations(hWnd)) {
                preview_trace::Append(
                    L"HandleAppExit",
                    L"abort=integrate_failed elapsed_ms=" + preview_trace::ElapsedMs(startTick));
                return false;
            }
        } else {
            preview_trace::Append(
                L"HandleAppExit",
                L"exit_with_staged_diffs elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        }
    }
    FinalizeAppExitState(hWnd, previewTempPath);
    preview_trace::Append(
        L"HandleAppExit",
        L"end elapsed_ms=" + preview_trace::ElapsedMs(startTick) +
        L" previewTempPath=" + previewTempPath);
    return true;
}

static bool PrepareWorkspaceRestart(HWND hWnd) {
    RememberCurrentSessionFiles();
    if (!SaveNoteIfDirty(hWnd)) {
        return PromptStayOrOpenDiffManager(
            hWnd,
            IsEnglishUi() ? L"Switching workspaces" : L"ワークスペース切替",
            IsEnglishUi() ? L"Please resolve the pending diff from Diff Manager, then try again."
                          : L"「差分管理」で未統合差分を整理してから、もう一度切り替えてください。");
    }
    if (!SaveAnnotationsIfDirty(hWnd)) {
        return PromptStayOrOpenDiffManager(
            hWnd,
            IsEnglishUi() ? L"Switching workspaces" : L"ワークスペース切替",
            IsEnglishUi() ? L"Please resolve the pending diff from Diff Manager, then try again."
                          : L"「差分管理」で未統合差分を整理してから、もう一度切り替えてください。");
    }
    SaveLastPdfViewInfo();
    ClearPdfAndNoteSelection();
    return true;
}

static void ReloadWorkspaceFromRoot(HWND hWnd, const std::wstring& root, bool promptClassdir, bool persistConfig) {
    const ULONGLONG startTick = preview_trace::TickNow();
    preview_trace::Append(
        L"ReloadWorkspaceFromRoot",
        L"begin root=" + root +
        L" promptClassdir=" + preview_trace::Bool(promptClassdir) +
        L" persistConfig=" + preview_trace::Bool(persistConfig));
    if (root.empty()) return;
    // No-network requirement: block UNC/device-prefix workspace roots (\\server\share, \\?\UNC\..., etc).
    if (root.rfind(L"\\\\", 0) == 0) {
        const wchar_t* msg = IsEnglishUi()
            ? L"UNC/device paths are not supported as a workspace root."
            : L"UNC/デバイスパスはワークスペースのルートとして使用できません。";
        ShowSoftNotice(hWnd, msg, SoftNoticeKind::Warning);
        preview_trace::Append(
            L"ReloadWorkspaceFromRoot",
            L"abort=unsupported_unc elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return;
    }
    bool isReparse = false;
    if (TryIsReparsePointNoFollow(std::filesystem::path(root), isReparse) && isReparse) {
        const wchar_t* msg = IsEnglishUi()
            ? L"Reparse point folders (junction/symlink) are not supported as a workspace root."
            : L"ジャンクション/シンボリックリンク等（reparse point）のフォルダはワークスペースとして使用できません。";
        ShowSoftNotice(hWnd, msg, SoftNoticeKind::Warning);
        preview_trace::Append(
            L"ReloadWorkspaceFromRoot",
            L"abort=reparse_root elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return;
    }
    std::error_code ec;
    if (!std::filesystem::exists(std::filesystem::path(root), ec) || ec ||
        !std::filesystem::is_directory(std::filesystem::path(root), ec) || ec) {
        std::wstring msg = IsEnglishUi()
            ? L"Workspace folder not found:\n" + root
            : L"ワークスペースフォルダが見つかりません:\n" + root;
        ShowSilentMessageDialog(hWnd, GetUiText().menuFile, msg, SoftNoticeKind::Warning);
        preview_trace::Append(
            L"ReloadWorkspaceFromRoot",
            L"abort=missing_root elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return;
    }

    // Preflight: ensure we can create/write __resource__ before switching (avoid starting edits that can't be saved).
    {
        std::wstring err;
        if (!EnsureWorkspaceResourceDirsWithErr(root, nullptr, &err)) {
            std::wstring msg = IsEnglishUi()
                ? L"Workspace switch was canceled because the target workspace is not writable.\n\nroot:\n" + root
                : L"切り替え先ワークスペースに書き込みできないため、ワークスペース切り替えを中断しました。\n\nroot:\n" + root;
            msg += IsEnglishUi()
                ? L"\n\nCheck access control / security policy for this folder."
                : L"\n\nこのフォルダのアクセス権・セキュリティ制御を確認してください。";
            if (!err.empty()) msg += L"\n\n" + err;
            ShowSoftNotice(hWnd, msg);
            preview_trace::Append(
                L"ReloadWorkspaceFromRoot",
                L"abort=resource_dir_unwritable elapsed_ms=" + preview_trace::ElapsedMs(startTick));
            return;
        }
    }
    std::wstring workspaceLockError;
    if (!AcquireWorkspaceWriteLock(std::filesystem::path(root), &workspaceLockError)) {
        std::wstring msg = IsEnglishUi()
            ? L"Workspace switch was canceled because the target workspace is open in another PDF Note Workspace process."
            : L"切り替え先ワークスペースが別の PDF Note Workspace プロセスで開かれているため、切り替えを中断しました。";
        if (!workspaceLockError.empty()) msg += L"\n\n" + workspaceLockError;
        ShowSilentMessageDialog(hWnd, GetUiText().menuFile, msg, SoftNoticeKind::Warning);
        preview_trace::Append(
            L"ReloadWorkspaceFromRoot",
            L"abort=workspace_write_lock elapsed_ms=" + preview_trace::ElapsedMs(startTick));
        return;
    }
    g_workspaceRoot = root;
    SetAppLogWorkspaceRoot(g_workspaceRoot);
    g_config = LoadWorkspaceConfig(g_workspaceRoot);
    ApplyRuntimeLogConfigFromWorkspace(g_workspaceRoot, g_config);
    InitScheduleSortBaseTime();
    EnsureWorkspaceResourceDirs(nullptr);
    {
        std::wstring identityErr;
        if (!note::ConfigureRuntimeNoteIdentityStore(
                std::filesystem::path(g_workspaceRoot), &identityErr)) {
            std::wstring message = IsEnglishUi()
                ? L"Persistent note identities could not be loaded. Notes remain available, but identity persistence is disabled for this workspace."
                : L"ノートの永続identityを読み込めませんでした。ノートは利用できますが、このワークスペースではidentityの永続化を無効にします。";
            if (!identityErr.empty()) message += L"\n\n" + identityErr;
            ShowSoftNotice(hWnd, message, SoftNoticeKind::Warning);
        }
    }
    LoadThemeConfig(g_workspaceRoot);
    if (promptClassdir) {
        CheckAndPromptClassdirMismatch(hWnd, g_workspaceRoot);
    }
    ApplyConfigToUI(hWnd);
    OnWorkspaceLoaded(hWnd);
    UpdateAutoSaveTimer(hWnd);
    UpdateAutoIntegrateTimer(hWnd);
    if (persistConfig) {
        PersistConfig();
    }
    RefreshStatusDisplay(hWnd);
    preview_trace::Append(
        L"ReloadWorkspaceFromRoot",
        L"end root=" + root +
        L" lectureCount=" + std::to_wstring(g_lectures.size()) +
        L" sessionCount=" + std::to_wstring(g_sessions.size()) +
        L" elapsed_ms=" + preview_trace::ElapsedMs(startTick));
}

void LayoutChildren(HWND hWnd) {
    LayoutChildrenImpl(hWnd, ui::LayoutPass::Commit);
}

static void LayoutChildrenLive(HWND hWnd) {
    LayoutChildrenImpl(hWnd, ui::LayoutPass::Live);
}

static void LayoutChildrenImpl(HWND hWnd, ui::LayoutPass pass) {
    RECT rc{};
    GetClientRect(hWnd, &rc);
    int cw = rc.right - rc.left;
    int ch = rc.bottom - rc.top;
    DebugAppendLayoutLog(pass == ui::LayoutPass::Live ? L"Layout(live)" : L"Layout", hWnd, cw, ch);
    if (cw <= 0 || ch <= 0) return;

    ui::ApplyLayout(hWnd, pass);
}

static bool IsLeftPaneFocusWindow(HWND hwnd) {
    if (!hwnd) return false;
    const HWND hiddenWhenCollapsed[] = {
        g_hLectureList,
        g_hSessionList,
        g_hPdfList,
        g_hNoteList,
        g_hBtnNewSession,
        g_hBtnNewNote,
        g_hChkShortcutHeading1,
        g_hChkShortcutHeading2,
        g_hShortcutHeadingLevelLabel,
        g_hBtnShortcutHeadingLevelUp,
        g_hChkShortcutBack,
        g_hChkShortcutChar,
        g_hChkShortcutBold,
        g_hChkShortcutItalic,
        g_hChkShortcutStrike,
        g_hChkShortcutUnderline,
        g_hChkShortcutLinkDecor,
        g_hBtnShortcutBackPreview,
        g_hBtnShortcutCharPreview,
        g_hBtnShortcutBackPalette,
        g_hBtnShortcutCharPalette,
        g_hShortcutIndentLabel,
        g_hShortcutIndentEdit,
        g_hShortcutMarginLabel,
        g_hShortcutMarginEdit,
        g_hShortcutFontSizeLabel,
        g_hShortcutFontSizeEdit,
        g_hShortcutTagEdit,
        g_hBtnShortcutInput,
        g_hBtnShortcutPdfLink,
        g_hBtnNoteAssistBullet,
        g_hBtnNoteAssistQuote,
        g_hBtnNoteAssistPageRef,
    };
    for (HWND h : hiddenWhenCollapsed) {
        if (hwnd == h) return true;
    }
    return false;
}

static void SetLeftPaneCollapsed(HWND hWnd, bool collapsed) {
    if (g_leftPaneCollapsed == collapsed) return;
    if (collapsed && IsLeftPaneFocusWindow(GetFocus())) {
        SetFocus(g_hPdfView ? g_hPdfView : hWnd);
    }
    g_leftPaneCollapsed = collapsed;
    g_config.leftPaneCollapsed = collapsed;
    LayoutChildren(hWnd);
    RedrawWorkspaceLayout(hWnd);
    PersistConfig();
    RefreshMainMenuBar(hWnd);
}


